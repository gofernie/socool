---
import { createClient } from "@supabase/supabase-js";
import ShortlistReviewModal from "../components/ShortlistReviewModal.astro";
import IntentModalController from "../components/IntentModalController.astro";
export const prerender = false;

const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.SUPABASE_SERVICE_ROLE_KEY
);

const url = Astro.url;

const city = url.searchParams.get("city") || "nanaimo";
const area = url.searchParams.get("area") || "";
const type = url.searchParams.get("type") || "";
const minPrice = Number(url.searchParams.get("minPrice") || 0);
const maxPrice = Number(url.searchParams.get("maxPrice") || 0);
const sort = url.searchParams.get("sort") || "newest";

const clean = (value: any) =>
  String(value || "")
    .toLowerCase()
    .trim();

const getListingMls = (listing: any) =>
  String(
    listing.mls_number ||
      listing.mlsNumber ||
      listing.id ||
      listing.repliers_listing_id ||
      listing.raw?.mlsNumber ||
      listing.raw?.id ||
      ""
  ).replace(/[^0-9]/g, "");

const getListingPrice = (listing: any) => {
  const num = Number(listing.price ?? listing.listPrice ?? listing.priceNumber ?? 0);
  if (Number.isFinite(num) && num > 1000) return `$${Math.round(num).toLocaleString()}`;
  return listing.price_text || listing.priceText || "Price on request";
};

const getListingAddress = (listing: any) =>
  listing.address ||
  listing.full_address ||
  listing.addressText ||
  listing.addressObj?.streetAddress ||
  [listing.addressObj?.streetNumber, listing.addressObj?.streetName, listing.addressObj?.streetSuffix]
    .filter(Boolean)
    .join(" ") ||
  "Address available";

const normalizeListingImageUrl = (value: any) => {
  if (!value) return "";
  const raw = typeof value === "string" ? value : value.highRes || value.mediumRes || value.lowRes || value.url || value.src || value.href || value.path || "";
  if (!raw) return "";
  if (raw.startsWith("http://") || raw.startsWith("https://")) return raw;
  const cleaned = raw.startsWith("/") ? raw : `/${raw}`;
  if (cleaned.startsWith("/vreb/")) return `https://cdn.repliers.io${cleaned}`;
  return cleaned;
};

const getListingImage = (listing: any) => {
  const image = listing.image_url || listing.image || listing.photo || listing.images?.[0] || listing.images?.[1] || listing.raw?.images?.[0] || listing.raw?.images?.[1] || listing.raw?.images?.[0]?.url || listing.raw?.images?.[1]?.url;
  return normalizeListingImageUrl(image);
};

const getListingImages = (listing: any) => {
  const rawImages = listing.images || listing.photo_urls || listing.photos || listing.raw?.images || [];
  const images = Array.isArray(rawImages)
    ? rawImages.map((img: any) => typeof img === "string" ? normalizeListingImageUrl(img) : normalizeListingImageUrl(img.highRes || img.mediumRes || img.lowRes || img.url || img.src || img.href || img.path || "")).filter(Boolean)
    : [];
  const firstImage = getListingImage(listing);
  return Array.from(new Set([firstImage, ...images].filter(Boolean)));
};

const getListingBeds = (listing: any) => listing.beds || listing.bedrooms || listing.details?.numBedrooms || listing.raw?.details?.numBedrooms || 0;
const getListingBaths = (listing: any) => listing.baths || listing.bathrooms || listing.details?.numBathrooms || listing.raw?.details?.numBathrooms || 0;
const getListingSqft = (listing: any) => listing.sqft || listing.square_feet || listing.squareFeet || listing.details?.sqft || listing.details?.squareFeet || listing.raw?.details?.sqft || listing.raw?.details?.squareFeet || "";
const getListingDescription = (listing: any) => listing.description || listing.publicRemarks || listing.remarks || listing.details?.description || listing.details?.publicRemarks || listing.details?.remarks || listing.raw?.description || listing.raw?.publicRemarks || listing.raw?.remarks || listing.raw?.details?.description || listing.raw?.details?.publicRemarks || listing.raw?.details?.remarks || "A quiet preview of this property.";
const getListingYearBuilt = (listing: any) => listing.year_built || listing.yearBuilt || listing.details?.yearBuilt || listing.raw?.details?.yearBuilt || "";
const getListingLotSize = (listing: any) => listing.lot_size || listing.lotSize || listing.details?.lotSize || listing.raw?.details?.lotSize || "";
const getListingArea = (listing: any) => listing.normalized_area || listing.area || listing.neighborhood || listing.addressObj?.neighborhood || listing.address?.neighborhood || listing.details?.area || listing.details?.subArea || listing.raw?.address?.neighborhood || listing.raw?.details?.area || listing.raw?.details?.subArea || "";
const getListingPropertyType = (listing: any) => String(listing.normalized_type || listing.property_type || listing.propertyType || listing.type || listing.details?.propertyType || listing.raw?.details?.propertyType || "Home").replace(/[_-]+/g, " ").replace(/\b\w/g, (char: string) => char.toUpperCase());

const groupLabel = [
  area || "",
  type ? type.replace(/-/g, " ") : "",
  maxPrice ? `under $${maxPrice}k` : "",
  minPrice ? `over $${minPrice}k` : ""
].filter(Boolean).join(" · ");

let listings: any[] = [];
let errorMessage = "";

try {
let query = supabase.from("listing_rows").select("*").eq("status", "A").limit(16);

  if (city) query = query.eq("normalized_city", clean(city));

  if (type) {
    if (["condo", "house", "townhouse", "land", "mobile"].includes(type)) {
      query = query.eq("normalized_type", type);
    } else {
      query = query.eq("normalized_type", clean(type));
    }
  }

  if (area) query = query.eq("normalized_area", clean(area));
  if (minPrice) query = query.gte("price", minPrice * 1000);
  if (maxPrice) query = query.lte("price", maxPrice * 1000);

  if (sort === "price-low" || sort === "price-asc") query = query.order("price", { ascending: true });
  else if (sort === "price-high" || sort === "price-desc") query = query.order("price", { ascending: false });
  else if (sort === "beds-high") query = query.order("beds", { ascending: false });
  else query = query.order("listed_at", { ascending: false });

  const { data, error } = await query;
  if (error) throw error;
  listings = data || [];

  if (type === "condo") {
    listings = listings.filter((listing: any) => {
      const text = [listing.normalized_type, listing.property_type, listing.propertyType, listing.type, listing.details?.propertyType, listing.raw?.details?.propertyType, listing.description, listing.publicRemarks, listing.remarks].filter(Boolean).join(" ").toLowerCase();
      return !text.includes("manufactured") && !text.includes("mobile") && !text.includes("modular") && !text.includes("park model") && !text.includes("mfd");
    });
  }
} catch (error: any) {
  errorMessage = error?.message || "Could not load listings.";
}
---

<html lang="en">
  <head>
    <title>{city ? `${city} ${type ? type.replace(/-/g, " ") + "s" : "homes"} for sale${maxPrice ? ` under $${maxPrice}k` : ""}` : "Explore homes for sale"} | {city || "Listings"}</title>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={city ? `Browse ${listings.length} ${type ? type.replace(/-/g, " ") + "s" : "homes"} for sale in ${city}${maxPrice ? ` under $${maxPrice}k` : ""}${minPrice ? ` over $${minPrice}k` : ""}. View photos, prices, and listing details.` : "Browse current homes for sale. View photos, prices, and listing details."} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={Astro.url.href} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={city ? `${city} ${type ? type.replace(/-/g, " ") + "s" : "homes"} for sale` : "Explore homes for sale"} />
    <meta property="og:url" content={Astro.url.href} />

    
    
    <link href="https://?family=Lora:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Nunito+Sans:opsz,wght@6..12,300;6..12,400;6..12,500;6..12,600&display=swap" rel="stylesheet" />

    <style>
      :root {
        --bg: #f5f2ed;
        --surface: #fdfcfa;
        --surface-warm: #f9f6f1;
        --ink: #1c1917;
        --ink-soft: #3d3935;
        --muted: #6b6560;
        --soft: #9c9590;
        --line: #e8e3dc;
        --line-warm: #ddd8d0;
        --accent: #8b6f47;
        --accent-light: #c4a882;
        --accent-bg: #f7f0e6;

        --f-display: "Lora", Georgia, serif;
        --f-body: "Nunito Sans", -apple-system, BlinkMacSystemFont, sans-serif;
        --ease: cubic-bezier(0.25, 0.46, 0.45, 0.94);
        --radius: 12px;
        --radius-lg: 20px;
      }

      * { box-sizing: border-box; margin: 0; padding: 0; }
      html, body { width: 100%; overflow-x: hidden; }
      body { font-family: var(--f-body); background: var(--bg); color: var(--ink); font-size: 16px; line-height: 1.6; -webkit-font-smoothing: antialiased; }
      body.modal-open { overflow: hidden; }
      a { color: inherit; text-decoration: none; }
      button { font: inherit; }

      .shell { width: min(1400px, calc(100% - 80px)); margin: 0 auto; }

      /* ========== HERO ========== */

      .hero {
        position: relative;
        min-height: 360px;
        padding: 56px 0 46px;
        background:
          linear-gradient(90deg, rgba(253,252,250,0.98) 0%, rgba(253,252,250,0.92) 42%, rgba(253,252,250,0.42) 62%, rgba(253,252,250,0.02) 100%),
url("https://images.unsplash.com/photo-1505693416388-ac5ce068fe85?auto=format&fit=crop&w=1200&q=70");        background-size: cover;
        background-position: center right;
        border-bottom: 1px solid var(--line);
      }

      .hero__inner {
        display: block;
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        margin: 0 0 18px;
        color: var(--accent);
        font-size: 0.72rem;
        font-weight: 850;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      .eyebrow::before {
        content: "";
        width: 28px;
        height: 1px;
        background: var(--accent);
      }

      h1 {
        max-width: 560px;
        font-family: var(--f-display);
        font-size: clamp(3.4rem, 6.6vw, 6rem);
        font-weight: 500;
        line-height: 0.92;
        letter-spacing: -0.06em;
        color: var(--ink);
        margin: 0 0 22px;
      }

      h1 em {
        font-style: normal;
        color: inherit;
      }

      .hero-desc {
        color: var(--muted);
        font-size: 1.1rem;
        line-height: 1.55;
        max-width: 520px;
        font-weight: 500;
      }

      .hero__meta {
        display: none;
      }

      /* ========== MAIN SECTION ========== */

           .section {
        padding: 28px 0 100px;
        background: #fffdf9;
      }

      /* ========== BACK LINK ========== */

      .back {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 36px;
        color: var(--muted);
        font-size: 0.82rem;
        font-weight: 600;
        padding: 8px 20px;
        border-radius: 999px;
        border: 1.5px solid var(--line-warm);
        transition: all 0.2s var(--ease);
      }

      .back:hover {
        border-color: var(--accent-light);
        color: var(--accent);
        transform: translateY(-1px);
      }

      /* ========== TOOLBAR / RESULTS HEADER ========== */

      .explore-toolbar {
        display: flex;
        align-items: center;
        gap: 14px;
        flex-wrap: wrap;
        margin-bottom: 26px;
      }

      .view-pill {
        display: inline-flex;
        padding: 4px;
        border-radius: 999px;
        background: #fff;
        border: 1px solid var(--line-warm);
        box-shadow: 0 8px 24px rgba(28, 25, 23, 0.08);
      }

      .view-pill__btn {
        appearance: none;
        border: 0;
        border-radius: 999px;
        background: transparent;
        color: var(--ink);
        min-height: 40px;
        padding: 0 18px;
        font: inherit;
        font-size: 0.88rem;
        font-weight: 850;
        cursor: pointer;
      }

      .view-pill__btn.active {
        background: #eadcc9;
      }

      .filter-pill {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 44px;
        padding: 0 22px;
        border-radius: 999px;
        background: #fff;
        border: 1px solid var(--line-warm);
        box-shadow: 0 8px 24px rgba(28, 25, 23, 0.07);
        color: var(--ink);
        font-size: 0.88rem;
        font-weight: 850;
      }

      .sort-pill {
        margin-left: auto;
      }

      .results-heading {
        margin: 0 0 18px;
      }

      .results-heading h2 {
        margin: 0 0 4px;
        font-family: var(--f-display);
        font-size: 1.7rem;
        font-weight: 600;
        letter-spacing: -0.035em;
      }

      .results-heading p {
        margin: 0;
        color: var(--muted);
        font-size: 0.92rem;
        font-weight: 700;
      }
      /* ========== GRID / INTENT CARDS ========== */

   .grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 18px;
  list-style: none;
  padding: 0;
  margin: 0;
}

      .card {
        background: var(--surface);
        border-radius: var(--radius-lg);
        overflow: hidden;
        border: 1px solid var(--line-warm);
        color: inherit;
        display: block;
        cursor: pointer;
        transition: all 0.28s var(--ease);
        box-shadow: 0 2px 16px rgba(28, 25, 23, 0.04);
      }

      .card:hover {
        transform: translateY(-4px);
        box-shadow: 0 16px 48px rgba(28, 25, 23, 0.1);
        border-color: var(--accent-light);
      }

      .card {
  position: relative;
}

.card::before {
  content: "♡";
  position: absolute;
  top: 14px;
  right: 14px;
  z-index: 3;
  width: 42px;
  height: 42px;
  border-radius: 999px;
  display: grid;
  place-items: center;
  background: rgba(255, 255, 255, 0.94);
  color: #8a5529;
  font-size: 1.45rem;
  font-weight: 800;
  box-shadow: 0 8px 22px rgba(28, 25, 23, 0.14);
}

.card img {
  width: 100%;
  aspect-ratio: 16 / 9;
  object-fit: cover;
  display: block;
}

.card-image-wrap {
  position: relative;
}

.new-badge {
  position: absolute;
  left: 14px;
  bottom: 12px;
  z-index: 2;
  padding: 5px 10px;
  border-radius: 9px;
  background: #b87934;
  color: #fff;
  font-size: 0.72rem;
  font-weight: 900;
  letter-spacing: 0.04em;
  text-transform: uppercase;
}

.card-body {
  padding: 16px 16px 18px;
  background: #fff;
}

.price {
  font-size: 1.34rem;
  line-height: 1.1;
  font-weight: 950;
  margin-bottom: 8px;
  letter-spacing: -0.035em;
}

.address {
  margin-bottom: 2px;
  color: var(--ink);
  line-height: 1.35;
  font-size: 0.9rem;
  font-weight: 850;
}

.card-city {
  margin-bottom: 14px;
  color: var(--muted);
  font-size: 0.86rem;
  font-weight: 700;
}

.meta {
  display: flex;
  align-items: center;
  gap: 18px;
  font-size: 0.86rem;
  color: var(--ink-soft);
  font-weight: 750;
}

.meta span {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  white-space: nowrap;
}

.meta svg {
  width: 15px;
  height: 15px;
  color: #9a5b25;
}

      .card-decision-badge {
        display: inline-flex;
        width: fit-content;
        margin-top: 14px;
        padding: 7px 11px;
        border-radius: 999px;
        font-size: 0.72rem;
        font-weight: 900;
        letter-spacing: 0.05em;
        text-transform: uppercase;
      }

      .card-decision-badge[hidden] {
        display: none;
      }
      /* ========== EMPTY STATE ========== */

      .empty {
        padding: 80px 28px;
        background: var(--surface);
        border: 1px solid var(--line-warm);
        border-radius: var(--radius-lg);
        color: var(--muted);
        text-align: center;
        font-size: 0.95rem;
        font-weight: 300;
      }


      /* ========== RESPONSIVE ========== */

  @media (max-width: 1100px) {
  .shell { width: calc(100% - 60px); }
  .hero__inner { grid-template-columns: 1fr; gap: 48px; }
  .grid { grid-template-columns: repeat(2, 1fr); }
}

      @media (max-width: 768px) {
        .hero { padding: 60px 0 48px; }
        .section { padding: 48px 0 80px; }
        .section-head { flex-direction: column; align-items: flex-start; gap: 12px; }
      }

      @media (max-width: 640px) {
        .shell { width: calc(100% - 32px); }
        .grid { grid-template-columns: 1fr; }
        .hero-stats { grid-template-columns: 1fr 1fr; }
           /* Modal styles come from ShortlistReviewModal.astro */
      }
    </style>

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ItemList",
      "name": city ? `${city} ${type ? type.replace(/-/g, " ") + "s" : "homes"} for sale` : "Homes for sale",
      "description": city ? `${listings.length} active listings in ${city}` : "Active real estate listings",
      "numberOfItems": listings.length,
      "url": Astro.url.href
    })}></script>
  </head>

<body
  data-intent-page-id="homepage"
  data-city={city || "nanaimo"}
  data-slug="homepage"
>  <header class="hero">
      <div class="shell hero__inner">
        <div>
         <p class="eyebrow">Homes worth watching</p>

<h1>
  Discover homes in
  <br />
  {city || "Nanaimo"}.
</h1>

<p class="hero-desc">
  Hand-picked properties that match your goals,
  your lifestyle, and the way you want to live.
</p>
        </div>

       
      </div>
    </header>

    <main class="section">
      <div class="shell">
             <div class="explore-toolbar">
          <div class="view-pill">
            <button type="button" class="view-pill__btn active">☷ List</button>
            <button type="button" class="view-pill__btn">⌖ Map</button>
          </div>

          <div class="filter-pill">⌖ {city || "Nanaimo"}⌄</div>
          <div class="filter-pill">{type ? getListingPropertyType({ normalized_type: type }) : "All Types"}⌄</div>
          <div class="filter-pill">{maxPrice ? `Under $${maxPrice}k` : "Any Price"}⌄</div>
          <div class="filter-pill">Any Beds⌄</div>
          <div class="filter-pill">More Filters⌄</div>

          <div class="filter-pill sort-pill">Newest first ⇅</div>
        </div>

        <div class="results-heading">
          <h2>{listings.length} homes found</h2>
          <p>Updated just now</p>
        </div>

        {errorMessage && <div class="empty">{errorMessage}</div>}

        {!errorMessage && listings.length === 0 && (
          <div class="empty">No matching homes found yet.</div>
        )}

        {!errorMessage && listings.length > 0 && (
          <ol class="grid" aria-label={`${listings.length} listings${city ? ` in ${city}` : ""}`}>
            {listings.map((listing: any) => {
              const image = getListingImage(listing);
              const address = getListingAddress(listing);
              const price = getListingPrice(listing);
              const beds = getListingBeds(listing);
              const baths = getListingBaths(listing);
              const sqft = getListingSqft(listing);
              const mls = getListingMls(listing);
              const propertyType = getListingPropertyType(listing);
              const description = getListingDescription(listing);
              const images = getListingImages(listing);

              return (
                <li style="display:contents;">
<article
  class="card original-card"
  data-item-id={String(listing?.id || listing?.mls_number || "")}
  data-card-id={String(listing?.id || listing?.mls_number || "")}
  data-listing-id={String(listing?.id || listing?.mls_number || "")}
 data-price={price}
data-raw-price={String(listing?.price || 0)}
data-listed-at={String(listing?.listed_at || listing?.created_at || "")}
                data-address={address}
data-meta={`${beds || "-"} bed · ${baths || "-"} bath`}
data-image={image}
                    data-images={JSON.stringify(images)}
                    data-beds={String(beds)}
                    data-baths={String(baths)}
                    data-sqft={String(sqft)}
                    data-description={description}
                    data-property-type={propertyType}
                    data-type={String(listing?.normalized_type || listing?.property_type || type || "Home")}
                    data-year={String(getListingYearBuilt(listing))}
                    data-lot-size={String(getListingLotSize(listing))}
                    data-area={String(getListingArea(listing))}
                    data-liked-tags="[]"
data-is-favourite="false"
data-decision=""
data-lat={listing?.lat || ""}
data-lng={listing?.lng || ""}
data-city={String(listing?.normalized_city || listing?.city || city || "")}
                    data-highlights={JSON.stringify([
                      propertyType.toLowerCase().includes("condo") ? "Open outlook" : "",
                      description.toLowerCase().includes("parking") ? "Parking included" : "",
                      (description.toLowerCase().includes("patio") || description.toLowerCase().includes("balcony")) ? "Outdoor space" : ""
                    ].filter(Boolean))}
                    data-mls={mls}
                    aria-label={`${price} — ${address}`}
                  >
                  <div class="card-image-wrap">
  <img src={image || "https://placehold.co/800x600?text=Listing"} alt={address || "Listing"} />
  <span class="new-badge">New</span>
</div>

<div class="card-body">
  <div class="price">{price}</div>
  <div class="address">{address}</div>
  <div class="card-city">{city || "Nanaimo"}, BC</div>

  <div class="meta">
    <span>🛏 {beds || "-"} bd</span>
    <span>🛁 {baths || "-"} ba</span>
    {sqft && <span>↗ {Number(sqft).toLocaleString()} sq ft</span>}
  </div>

  <div class="card-decision-badge" hidden></div>
</div>
                 </article>
</li>
              );
            })}
          </ol>
        )}
      </div>
    </main>

<ShortlistReviewModal />
<IntentModalController />

<style is:global>
  #preview-sheet .decision-btn.is-selected {
    background: #1f1b18 !important;
    border-color: #f0c6b3 !important;
    color: #fff !important;
    box-shadow: 0 0 0 4px rgba(240, 198, 179, 0.75), 0 14px 34px rgba(17, 14, 9, 0.14) !important;
    animation: intentDecisionPulse 0.7s ease-out !important;
  }

  #preview-sheet .decision-btn.is-selected::after {
    content: "✓";
    margin-left: 8px;
    font-weight: 900;
  }

  #preview-sheet .chip::before,
  #preview-sheet .feedback-pill::before,
  #preview-sheet .intent-like-tag::before {
    content: "✦";
    color: #8d8a84;
    font-size: 0.72rem;
  }

  #preview-sheet .chip.active,
  #preview-sheet .feedback-pill.active,
  #preview-sheet .intent-like-tag.active {
    background: #1f1b18 !important;
    border-color: #1f1b18 !important;
    color: #fff !important;
  }

  @keyframes intentDecisionPulse {
    0% { transform: scale(0.98); }
    55% { transform: scale(1.025); }
