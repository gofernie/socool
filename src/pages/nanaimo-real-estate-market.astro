    --surface: #fdfcfa;
    --surface-warm: #f9f6f1;
    --ink: #1c1917;
    --ink-soft: #3d3935;
    --muted: #6b6560;
    --soft: #9c9590;
    --line: #e8e3dc;
    --line-warm: #ddd8d0;
    --accent: #8b6f47;
    --accent-light: #c4a882;
    --accent-bg: #f7f0e6;

