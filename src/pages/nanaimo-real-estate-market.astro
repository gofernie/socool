---

import { createClient } from "@supabase/supabase-js";
import ListingCard from "../components/ListingCard.astro";
import ShortlistReviewModal from "../components/ShortlistReviewModal.astro";
import IntentModalController from "../components/IntentModalController.astro";

const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.SUPABASE_SERVICE_ROLE_KEY
);

const { data: allListings = [], error } = await supabase
  .from("listing_rows")
  .select("*")
  .eq("normalized_city", "nanaimo");

const { data: featuredIntentPages = [], error: featuredIntentError } =
  await supabase
    .from("intent_pages")
    .select("slug, hero_heading, intro_copy")
    .limit(6);

console.log("FEATURED INTENT PAGES", {
  count: featuredIntentPages.length,
  rows: featuredIntentPages,
  error: featuredIntentError,
});

if (error) {
  console.error("Nanaimo market page error:", error);
}

const normalizeListingImageUrl = (value: any) => {
  if (!value) return "";

  const raw =
    typeof value === "string"
      ? value
      : value.highRes ||
        value.mediumRes ||
        value.lowRes ||
        value.url ||
        value.src ||
        value.href ||
        value.path ||
        "";

  if (!raw) return "";

  if (raw.startsWith("http://") || raw.startsWith("https://")) return raw;

  const cleaned = raw.startsWith("/") ? raw : `/${raw}`;

  if (cleaned.startsWith("/vreb/")) {
    return `https://cdn.repliers.io${cleaned}`;
  }

  return cleaned;
};

const getListingImage = (listing: any) => {
  return normalizeListingImageUrl(
    listing.image_url ||
      listing.image ||
      listing.photo ||
      listing.images?.[0] ||
      listing.images?.[1] ||
      listing.raw?.images?.[0] ||
      listing.raw?.images?.[1] ||
      listing.raw?.images?.[0]?.url ||
      listing.raw?.images?.[1]?.url ||
      listing.raw?.images?.[0]?.mediumRes ||
      listing.raw?.images?.[1]?.mediumRes ||
      listing.raw?.images?.[0]?.highRes ||
      listing.raw?.images?.[1]?.highRes
  );
};
const listings = [...allListings]
  .sort((a, b) => {
    const da = new Date(a.listed_at || a.updated_at || 0).getTime();
    const db = new Date(b.listed_at || b.updated_at || 0).getTime();
    return db - da;
  })
  .slice(0, 12);

const activeListings = allListings.length;

const prices = allListings
  .map((l) => Number(l.price || 0))
  .filter((p) => p > 0)
  .sort((a, b) => a - b);

const avgPrice =
  prices.length > 0
    ? Math.round(prices.reduce((sum, p) => sum + p, 0) / prices.length)
    : 0;

const medianPrice =
  prices.length > 0
    ? prices[Math.floor(prices.length / 2)]
    : 0;

const condoCount = allListings.filter(
  (l) => l.normalized_type === "condo"
).length;

const houseCount = allListings.filter(
  (l) => l.normalized_type === "house"
).length;

const townhomeCount = allListings.filter(
  (l) => l.normalized_type === "townhouse"
).length;

const areaCounts = allListings.reduce((acc, listing) => {
  const area = listing.normalized_area || "other";
  acc[area] = (acc[area] || 0) + 1;
  return acc;
}, {});

const topAreas = Object.entries(areaCounts)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 10);

const labelize = (value) =>
  String(value || "")
    .split("-")
    .join(" ")
    .replace(/\b\w/g, (c) => c.toUpperCase());

const priceBuckets = [
  { label: "Under $500k", min: 0, max: 500000 },
  { label: "$500k-$750k", min: 500000, max: 750000 },
  { label: "$750k-$1M", min: 750000, max: 1000000 },
  { label: "$1M-$1.5M", min: 1000000, max: 1500000 },
  { label: "$1.5M+", min: 1500000, max: Infinity },
];

const priceBucketCounts = priceBuckets.map((bucket) =>
  allListings.filter((listing) => {
    const price = Number(listing.price || 0);
    return price >= bucket.min && price < bucket.max;
  }).length
);

const chartData = {
  priceLabels: priceBuckets.map((bucket) => bucket.label),
  priceCounts: priceBucketCounts,
areaLabels: topAreas.map(([area]) =>
  labelize(area)
    .replace("North Nanaimo", "North")
    .replace("South Nanaimo", "South")
    .replace("Central Nanaimo", "Central")
    .replace("University District", "University")
    .replace("Departure Bay", "Departure")
    .replace("Pleasant Valley", "Pleasant")
),  areaCounts: topAreas.map(([, count]) => count),
};
---

<html lang="en">
  <head>
    <title>Nanaimo Real Estate Market Report</title>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Latest Nanaimo real estate market trends, listings, neighbourhood activity and market insights."
    />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Nunito+Sans:opsz,wght@6..12,300;6..12,400;6..12,500;6..12,600&display=swap"
      rel="stylesheet"
    />
<script defer src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>

  <body>
 <header class="hero">
<div class="shell hero__inner">
    <span class="eyebrow">NANAIMO MARKET REPORT</span>

    <h1>Nanaimo Real Estate Market</h1>

    <p>
      Explore active listings, inventory levels, pricing trends and
      neighbourhood activity across Nanaimo.
    </p>
   </div>
</header>

  <section class="shell stats-grid">
    <div class="stat-card">
      <div class="value">{activeListings}</div>
      <div class="label">Active Listings</div>
    </div>

    <div class="stat-card">
      <div class="value">
        ${avgPrice.toLocaleString()}
      </div>
      <div class="label">Average Price</div>
    </div>

    <div class="stat-card">
      <div class="value">
        ${medianPrice.toLocaleString()}
      </div>
      <div class="label">Median Price</div>
    </div>

    <div class="stat-card">
      <div class="value">{houseCount}</div>
      <div class="label">Houses</div>
    </div>

    <div class="stat-card">
      <div class="value">{condoCount}</div>
      <div class="label">Condos</div>
    </div>

    <div class="stat-card">
      <div class="value">{townhomeCount}</div>
      <div class="label">Townhomes</div>
    </div>
</section>

<section class="shell chart-section">
  <div class="chart-card">
    <div>
      <span class="eyebrow dark">Price Distribution</span>
<h2>Where Nanaimo Inventory Sits by Price</h2>
    </div>
    <div class="chart-wrap">
      <canvas id="priceChart"></canvas>
    </div>
  </div>

  <div class="chart-card">
    <div>
      <span class="eyebrow dark">Area Activity</span>
      <h2>Top Areas by Listing Count</h2>
    </div>
    <div class="chart-wrap">
      <canvas id="areaChart"></canvas>
    </div>
  </div>
</section>

   <section class="shell listings-section">
    <div class="section-heading">
      <span class="eyebrow dark">LATEST LISTINGS</span>
      <h2>Newest Nanaimo Listings</h2>
      <p>
        A quick look at some of the newest active listings currently available
        across Nanaimo.
      </p>
    </div>

   <div class="listing-grid">
  {listings.map((listing) => (
  <ListingCard listing={listing} image={getListingImage(listing)} />
))}
</div>
  </section>

<section class="shell intent-interrupter">
  <div class="intent-interrupter__inner">
    <span class="eyebrow">EXPLORE NANAIMO HOMES</span>

    <h2>Browse Curated Collections</h2>

    <p>
      Looking for something specific? Explore some of Nanaimo's most popular
      home searches.
    </p>

    <div class="intent-grid">
  {featuredIntentPages.map((intentPage) => (
    <a href={`/nanaimo/${intentPage.slug}`} class="intent-tile">
      <strong>{intentPage.hero_heading}</strong>
      <span>
        {intentPage.intro_copy ||
          "Explore this curated Nanaimo real estate search."}
      </span>
    </a>
  ))}
</div>
  </div>
</section>

<section class="shell content-card">
    <h2>Market Activity By Area</h2>

    <div class="area-table">
      {topAreas.map(([area, count]) => (
<a class="area-row" href={`/nanaimo/areas/${String(area).replace(/\s+/g, "-")}`}>       <span>{labelize(area)}</span>
          <strong>{count} listings</strong>
        </a>
      ))}
    </div>
  </section>

  <section class="shell content-card">
    <h2>Popular Nanaimo Searches</h2>

    <ul>
      <li><a href="/nanaimo-homes-under-700k">Homes Under $700k</a></li>
      <li><a href="/nanaimo-condos">Condos</a></li>
      <li><a href="/nanaimo-townhomes">Townhomes</a></li>
      <li><a href="/nanaimo-ocean-view-homes">Ocean View Homes</a></li>
      <li><a href="/nanaimo-retirement-properties">Retirement Properties</a></li>
    </ul>
  </section>
    <ShortlistReviewModal />
    <IntentModalController />

  <script is:inline define:vars={{ chartData }}>
  window.addEventListener("load", () => {
    if (!window.Chart) {
      console.error("Chart.js did not load");
      return;
    }

    const priceCanvas = document.getElementById("priceChart");
    const areaCanvas = document.getElementById("areaChart");

    if (!priceCanvas || !areaCanvas) return;

   const sharedOptions = {
  responsive: true,
  maintainAspectRatio: false,
  plugins: {
    legend: {
      display: false,
    },
    tooltip: {
      displayColors: false,
    },
  },
  scales: {
    x: {
      grid: {
        display: false,
      },
      ticks: {
        maxRotation: 0,
        minRotation: 0,
        font: {
          size: 10,
        },
      },
    },
    y: {
      beginAtZero: true,
      border: {
        display: false,
      },
      grid: {
        color: "rgba(28,25,23,0.08)",
      },
      ticks: {
        precision: 0,
        font: {
          size: 10,
        },
      },
    },
  },
};

    new Chart(priceCanvas, {
      type: "bar",
      data: {
        labels: chartData.priceLabels,
        datasets: [
          {
            label: "Listings",
            data: chartData.priceCounts,
          },
        ],
      },
      options: sharedOptions,
    });

    new Chart(areaCanvas, {
      type: "bar",
      data: {
        labels: chartData.areaLabels,
        datasets: [
          {
            label: "Listings",
            data: chartData.areaCounts,
          },
        ],
      },
      options: sharedOptions,
    });
  });
</script>
  </body>
</html>

<style is:global>
