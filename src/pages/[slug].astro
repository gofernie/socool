---
import { createClient } from "@supabase/supabase-js";
import { getSeoListingPage } from "../lib/seoListingPages";

export const prerender = false;

const { slug } = Astro.params;
const page = getSeoListingPage(String(slug || ""));

if (!page) {
  return Astro.redirect("/404");
}

const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.SUPABASE_SERVICE_ROLE_KEY
);

let query = supabase
  .from("listing_rows")
  .select("*")
  .eq("normalized_city", page.city.toLowerCase())
  .limit(48);

if (page.area) query = query.eq("normalized_area", page.area.toLowerCase());
if (page.type) query = query.eq("normalized_type", page.type);
if (page.minPrice) query = query.gte("price", page.minPrice * 1000);
if (page.maxPrice) query = query.lte("price", page.maxPrice * 1000);

if (page.sort === "price-low") {
  query = query.order("price", { ascending: true });
} else if (page.sort === "price-high") {
  query = query.order("price", { ascending: false });
} else if (page.sort === "beds-high") {
  query = query.order("beds", { ascending: false });
} else {
  query = query.order("listed_at", { ascending: false });
}

const { data, error } = await query;
const listings = Array.isArray(data) ? data : [];

const clean = (value: any) => String(value || "").toLowerCase().trim();

const priceText = (price: any) =>
  Number(price) ? `$${Number(price).toLocaleString()}` : "Price on request";

const normalizeImageUrl = (value: any) => {
  if (!value) return "";

  const raw =
    typeof value === "string"
      ? value
      : value.highRes ||
        value.mediumRes ||
        value.lowRes ||
        value.url ||
        value.src ||
        value.href ||
        value.path ||
        "";

  if (!raw) return "";
  if (raw.startsWith("http://") || raw.startsWith("https://")) return raw;

  const cleaned = raw.startsWith("/") ? raw : `/${raw}`;

  if (cleaned.startsWith("/vreb/")) {
    return `https://cdn.repliers.io${cleaned}`;
  }

  return cleaned;
};

const getListingImage = (listing: any) =>
  normalizeImageUrl(
    listing.image_url ||
      listing.image ||
      listing.photo ||
      listing.images?.[0] ||
      listing.images?.[1] ||
      listing.photos?.[0] ||
      listing.photo_urls?.[0] ||
      listing.raw?.images?.[0] ||
      listing.raw?.images?.[1] ||
      listing.raw?.images?.[0]?.url ||
      listing.raw?.images?.[1]?.url
  ) || "https://placehold.co/800x600?text=Listing";

const getListingImages = (listing: any) => {
  const rawImages =
    listing.images ||
    listing.photo_urls ||
    listing.photos ||
    listing.raw?.images ||
    [];

  const images = Array.isArray(rawImages)
    ? rawImages
        .map((img) => {
          if (typeof img === "string") return normalizeImageUrl(img);

          return normalizeImageUrl(
            img.highRes ||
              img.mediumRes ||
              img.lowRes ||
              img.url ||
              img.src ||
              img.href ||
              img.path ||
              ""
          );
        })
        .filter(Boolean)
    : [];

  const firstImage = getListingImage(listing);

  return Array.from(new Set([firstImage, ...images].filter(Boolean)));
};

const getListingMls = (listing: any) =>
  String(
    listing.mls_number ||
      listing.mlsNumber ||
      listing.id ||
      listing.repliers_listing_id ||
      listing.raw?.mlsNumber ||
      listing.raw?.id ||
      ""
  ).replace(/[^0-9]/g, "");

const getListingAddress = (listing: any) =>
  listing.address ||
  listing.full_address ||
  listing.addressText ||
  listing.addressObj?.streetAddress ||
  [
    listing.addressObj?.streetNumber,
    listing.addressObj?.streetName,
    listing.addressObj?.streetSuffix
  ]
    .filter(Boolean)
    .join(" ") ||
  "Address available";

const getListingBeds = (listing: any) =>
  listing.beds ||
  listing.bedrooms ||
  listing.details?.numBedrooms ||
  listing.raw?.details?.numBedrooms ||
  0;

const getListingBaths = (listing: any) =>
  listing.baths ||
  listing.bathrooms ||
  listing.details?.numBathrooms ||
  listing.raw?.details?.numBathrooms ||
  0;

const getListingSqft = (listing: any) =>
  listing.sqft ||
  listing.square_feet ||
  listing.squareFeet ||
  listing.details?.sqft ||
  listing.details?.squareFeet ||
  listing.raw?.details?.sqft ||
  listing.raw?.details?.squareFeet ||
  "";

const getListingDescription = (listing: any) =>
  listing.description ||
  listing.publicRemarks ||
  listing.remarks ||
  listing.details?.description ||
  listing.details?.publicRemarks ||
  listing.details?.remarks ||
  listing.raw?.description ||
  listing.raw?.publicRemarks ||
  listing.raw?.remarks ||
  listing.raw?.details?.description ||
  listing.raw?.details?.publicRemarks ||
  listing.raw?.details?.remarks ||
  "A quick preview of this property.";

const getListingYearBuilt = (listing: any) =>
  listing.year_built ||
  listing.yearBuilt ||
  listing.details?.yearBuilt ||
  listing.raw?.details?.yearBuilt ||
  "";

const getListingLotSize = (listing: any) =>
  listing.lot_size ||
  listing.lotSize ||
  listing.details?.lotSize ||
  listing.raw?.details?.lotSize ||
  "";

const getListingArea = (listing: any) =>
  listing.area ||
  listing.neighborhood ||
  listing.normalized_area ||
  listing.addressObj?.neighborhood ||
  listing.address?.neighborhood ||
  listing.details?.area ||
  listing.details?.subArea ||
  listing.raw?.address?.neighborhood ||
  listing.raw?.details?.area ||
  listing.raw?.details?.subArea ||
  "";

const getListingPropertyType = (listing: any) =>
  String(
    listing.normalized_type ||
      listing.property_type ||
      listing.propertyType ||
      listing.type ||
      listing.details?.propertyType ||
      listing.raw?.details?.propertyType ||
      "Home"
  )
    .replace(/[_-]+/g, " ")
    .replace(/\b\w/g, (char) => char.toUpperCase());

const getListingDom = (listing: any) => {
  const direct =
    listing.days_on_market ||
    listing.daysOnMarket ||
    listing.dom ||
    listing.details?.daysOnMarket ||
    listing.details?.dom ||
    listing.raw?.daysOnMarket ||
    listing.raw?.dom ||
    listing.raw?.details?.daysOnMarket ||
    listing.raw?.details?.dom;

  if (direct) return direct;

  const listedRaw =
    listing.listed_at ||
    listing.list_date ||
    listing.listDate ||
    listing.created_at ||
    listing.raw?.listDate ||
    listing.raw?.timestamps?.listingUpdated;

  const listedTime = new Date(listedRaw).getTime();
  if (!listedTime) return "";

  return Math.max(0, Math.floor((Date.now() - listedTime) / 86400000));
};

const buildListingHighlights = (listing: any) => {
  const desc = clean(getListingDescription(listing));
  const propertyType = clean(getListingPropertyType(listing));
  const highlights: string[] = [];

  const sqft = Number(String(getListingSqft(listing) || "").replace(/[^0-9.]/g, ""));
  const beds = Number(getListingBeds(listing));

  const isCondo = propertyType.includes("condo") || propertyType.includes("apartment");
  const isTownhouse =
    propertyType.includes("townhouse") ||
    propertyType.includes("townhome") ||
    propertyType.includes("row");
  const isHouse =
    propertyType.includes("house") ||
    propertyType.includes("detached") ||
    propertyType.includes("single family");

  const hasView =
    /ocean view|water view|harbour view|harbor view|sea view|lake view|mountain view|city view|panoramic view/.test(desc) &&
    !/viewing|preview|virtual tour|view today|viewing appointment/.test(desc);

  const hasSuite = /suite|mortgage helper|income|secondary suite|legal suite/.test(desc);
  const isUpdated = /renovated|updated|modernized|new kitchen|new roof|contemporary/.test(desc);
  const hasParking = /garage|rv parking|double garage|underground parking|secure parking/.test(desc);
  const quiet = /cul-de-sac|quiet street|private|privacy/.test(desc);
  const amenities = /pool|gym|fitness|clubhouse|elevator|storage locker|amenities/.test(desc);
  const outdoor = /patio|balcony|deck|yard|garden|outdoor space/.test(desc);

  if (isCondo) {
    if (hasView) highlights.push("Open outlook");
    if (amenities) highlights.push("Building amenities");
    if (hasParking) highlights.push("Parking included");
    if (outdoor) highlights.push("Outdoor space");
    if (isUpdated) highlights.push("Updated interior");
    if (sqft && sqft >= 900) highlights.push("Larger layout");
    if (highlights.length === 0) highlights.push("Low-maintenance living");
  } else if (isTownhouse) {
    if (beds && beds >= 3) highlights.push("Family-friendly layout");
    if (hasParking) highlights.push("Good parking");
    if (outdoor) highlights.push("Private outdoor space");
    if (isUpdated) highlights.push("Updated features");
    if (quiet) highlights.push("Quieter setting");
    highlights.push("Lock-and-leave option");
  } else if (isHouse) {
    if (sqft && sqft >= 2500) highlights.push("Generous floor plan");
    if (beds && beds >= 4) highlights.push("Family-sized");
    if (hasView) highlights.push("View potential");
    if (hasSuite) highlights.push("Suite potential");
    if (isUpdated) highlights.push("Updated features");
    if (quiet) highlights.push("Quiet setting");
    if (hasParking) highlights.push("Good parking");
  } else {
    if (hasView) highlights.push("View setting");
    if (isUpdated) highlights.push("Updated features");
    if (hasParking) highlights.push("Good parking");
    if (outdoor) highlights.push("Outdoor space");
  }

  return Array.from(new Set(highlights)).slice(0, 3);
};

const updatedLabel = new Date().toLocaleDateString("en-CA", {
  year: "numeric",
  month: "long",
  day: "numeric"
});
---

<html lang="en">
  <head>
    <title>{page.metaTitle}</title>
    <meta name="description" content={page.metaDescription} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700&display=swap"
      rel="stylesheet"
    />

    <style>
      :root {
        --bg: #f7f6f3;
        --card: #ffffff;
        --warm: #f0ede8;
        --dark: #181614;
        --ink: #18160f;
        --muted: #6b6760;
        --soft: #a09c96;
        --gold: #c09b64;
        --gold-soft: #f6ebcf;
        --line: #e4e0d9;
        --line-strong: #ccc8c0;
        --green: #2d5016;
        --green-mid: #3d6b20;
        --f-display: "DM Serif Display", Georgia, serif;
        --f-body: "DM Sans", system-ui, sans-serif;
        --r-xl: 16px;
        --r-2xl: 22px;
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        margin: 0;
        width: 100%;
        overflow-x: hidden;
      }

      body {
        background: var(--bg);
        color: var(--ink);
        font-family: var(--f-body);
      }

      body.modal-open {
        overflow: hidden;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      button {
        font: inherit;
      }

      .shell {
        width: min(1280px, calc(100% - 64px));
        margin: 0 auto;
      }

      .hero {
        background: var(--dark);
        color: #f0ede8;
        padding: 72px 0 64px;
      }

      .eyebrow {
        margin: 0 0 18px;
        color: var(--gold);
        font-size: 0.66rem;
        font-weight: 800;
        letter-spacing: 0.2em;
        text-transform: uppercase;
      }

      h1 {
        max-width: 900px;
        margin: 0;
        font-family: var(--f-display);
        font-size: clamp(3.1rem, 7vw, 6.4rem);
        font-weight: 400;
        line-height: 0.95;
        letter-spacing: -0.04em;
      }

      .lead {
        max-width: 720px;
        margin: 22px 0 0;
        color: rgba(240, 237, 232, 0.58);
        line-height: 1.75;
        font-size: 1rem;
      }

      .section {
        padding: 48px 0;
      }

      .insight-grid {
        display: grid;
        grid-template-columns: 1.15fr 0.85fr;
        gap: 28px;
        align-items: start;
      }

      .insight-card,
      .quick-card {
        background: #fff;
        border: 1px solid var(--line);
        border-radius: 24px;
        padding: 28px;
        box-shadow: 0 8px 24px rgba(17, 14, 9, 0.04);
      }

      .insight-card h2,
      .quick-card h2,
      .section-head h2 {
        margin: 0 0 16px;
        font-family: var(--f-display);
        font-size: clamp(2rem, 4vw, 3.4rem);
        font-style: italic;
        font-weight: 400;
        line-height: 1;
      }

      .insight-card p {
        margin: 0 0 16px;
        color: var(--muted);
        line-height: 1.8;
      }

      .quick-card ul {
        margin: 0;
        padding-left: 20px;
        color: var(--muted);
        line-height: 1.8;
      }

      .meta-line {
        margin-top: 18px;
        color: var(--soft);
        font-size: 0.74rem;
        font-weight: 800;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      .section-head {
        display: flex;
        align-items: end;
        justify-content: space-between;
        gap: 24px;
        padding-bottom: 18px;
        margin-bottom: 22px;
        border-bottom: 1px solid var(--line);
      }

      .count {
        color: var(--soft);
        font-size: 0.74rem;
        font-weight: 800;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      .grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 16px;
      }

      .card {
        appearance: none;
        display: block;
        width: 100%;
        padding: 0;
        text-align: left;
        cursor: pointer;
        overflow: hidden;
        background: var(--card);
        border: 1px solid var(--line);
        border-radius: 18px;
        box-shadow: 0 8px 24px rgba(17, 14, 9, 0.04);
        color: inherit;
        transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
      }

      .card:hover {
        transform: translateY(-3px);
        border-color: var(--line-strong);
        box-shadow: 0 8px 30px rgba(17, 14, 9, 0.07);
      }

      .card__image {
        height: 230px;
        background: #eee;
        background-size: cover;
        background-position: center;
      }

      .card__body {
        padding: 18px 20px 20px;
      }

      .price {
        display: block;
        margin-bottom: 8px;
        font-family: var(--f-display);
        font-size: 1.65rem;
        font-weight: 400;
        line-height: 1;
      }

      .address {
        margin: 0 0 8px;
        color: var(--muted);
        font-size: 0.9rem;
      }

      .meta {
        display: flex;
        flex-wrap: wrap;
        gap: 4px 10px;
        color: var(--soft);
        font-size: 0.8rem;
      }

      .meta span + span::before {
        content: "•";
        margin-right: 10px;
      }

      .desc {
        margin: 14px 0 0;
        color: var(--muted);
        font-size: 0.86rem;
        line-height: 1.65;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }

      .empty {
        padding: 70px 28px;
        border: 1px dashed var(--line-strong);
        border-radius: 22px;
        background: #fff;
        color: var(--muted);
        text-align: center;
      }

      .btn-row {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 28px;
      }

      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 42px;
        padding: 0 16px;
        border-radius: 999px;
        background: var(--green);
        color: #fff;
        font-weight: 800;
        font-size: 0.86rem;
      }

      .btn:hover {
        background: var(--green-mid);
      }

      .modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(10, 8, 5, 0.55);
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.25s;
        z-index: 800;
        backdrop-filter: blur(4px);
        -webkit-backdrop-filter: blur(4px);
      }

      .modal-overlay.open {
        opacity: 1;
        pointer-events: auto;
      }

      .panel {
        position: fixed;
        left: 50%;
        top: 0;
        width: min(860px, calc(100vw - 32px));
        max-height: 100vh;
        background: #fff;
        z-index: 900;
        overflow: hidden;
        transform: translate(-50%, -106%);
        transition: transform 0.34s cubic-bezier(0.16, 1, 0.3, 1);
        display: flex;
        flex-direction: column;
        border: 1px solid var(--line);
        border-top: 0;
        border-radius: 0 0 var(--r-2xl) var(--r-2xl);
        box-shadow: 0 24px 80px rgba(0, 0, 0, 0.16);
      }

      .panel.open {
        transform: translate(-50%, 0);
      }

      .panel__grab {
        display: none;
      }

      .panel__progress-wrap {
        position: sticky;
        top: 0;
        z-index: 8;
        background: #fff;
        border-bottom: 1px solid rgba(0, 0, 0, 0.04);
      }

      .panel__progress-track {
        height: 5px;
        width: 100%;
        background: #ece8e2;
        overflow: hidden;
      }

      .panel__progress-bar {
        height: 100%;
        width: 100%;
        background: linear-gradient(90deg, var(--green), var(--green-mid));
      }

      .panel__header {
        padding: 14px 18px;
        display: grid;
        grid-template-columns: 1fr auto auto;
        align-items: center;
        gap: 10px;
        background: #fff;
      }

      .panel__position {
        font-size: 0.76rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--muted);
      }

      .panel__header-actions {
        display: flex;
        align-items: center;
        gap: 8px;
      }

      .panel__top-btn,
      .panel__close {
        appearance: none;
        height: 36px;
        padding: 0 14px;
        border-radius: 999px;
        border: 1px solid var(--line);
        background: #fff;
        color: var(--ink);
        cursor: pointer;
        font-size: 0.8rem;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: background 0.14s, border-color 0.14s, color 0.14s, opacity 0.14s;
      }

      .panel__top-btn:hover,
      .panel__close:hover {
        background: var(--ink);
        border-color: var(--ink);
        color: #fff;
      }

      .panel__top-btn:disabled {
        opacity: 0.35;
        pointer-events: none;
      }

      .panel__close {
        width: 36px;
        padding: 0;
        color: var(--muted);
      }

      .panel__view {
        overflow-y: auto;
        flex: 1;
      }

      .panel__image-stage {
        position: relative;
        background: var(--warm);
      }

      .panel__image {
        width: 100%;
        aspect-ratio: 16 / 9;
        object-fit: cover;
        display: block;
      }

      .panel__photo-count {
        position: absolute;
        right: 14px;
        bottom: 14px;
        z-index: 2;
        background: rgba(17, 14, 9, 0.58);
        color: rgba(255, 255, 255, 0.94);
        border-radius: 999px;
        padding: 6px 10px;
        font-size: 0.72rem;
        font-weight: 600;
      }

      .photo-nav {
        position: absolute;
        top: 50%;
        z-index: 3;
        transform: translateY(-50%);
        width: 38px;
        height: 38px;
        border-radius: 999px;
        border: 1px solid rgba(255, 255, 255, 0.75);
        background: rgba(17, 14, 9, 0.48);
        color: #fff;
        font-size: 1.5rem;
        line-height: 1;
        cursor: pointer;
      }

      .photo-nav--prev {
        left: 14px;
      }

      .photo-nav--next {
        right: 14px;
      }

      .photo-nav:disabled {
        opacity: 0.25;
        cursor: default;
      }

      .panel__body {
        padding: 30px 32px;
      }

      .panel__headline {
        display: block;
        margin-bottom: 16px;
      }

      .panel__price {
        font-family: var(--f-display);
        font-size: clamp(2.1rem, 4.2vw, 3rem);
        font-weight: 400;
        letter-spacing: -0.03em;
        line-height: 1;
        color: var(--ink);
        margin: 0 0 6px;
      }

      .panel__address {
        font-size: 1.35rem;
        color: var(--muted);
        line-height: 1.42;
        margin: 0 0 10px;
      }

      .panel__meta {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin: 2px 0 18px;
        color: var(--ink);
        font-size: 0.92rem;
        font-weight: 600;
      }

      .panel__intelligence {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        min-height: 34px;
        padding: 8px 12px;
        border-radius: 999px;
        background: #eef4e9;
        border: 1px solid #b5cfa0;
        color: var(--green);
        font-size: 0.78rem;
        font-weight: 600;
        margin-bottom: 15px;
      }

      .panel__intelligence::before {
        content: "✦";
        font-size: 0.9rem;
      }

      .panel__detail-row {
        display: flex;
        flex-wrap: wrap;
        gap: 8px 14px;
        margin: 0 0 18px;
        color: var(--muted);
        font-size: 0.86rem;
        font-weight: 600;
      }

      .panel__detail-row span + span::before {
        content: "•";
        margin-right: 14px;
        color: var(--soft);
      }

      .panel__highlights {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin: 0 0 20px;
      }

      .panel__highlight-chip {
        display: inline-flex;
        align-items: center;
        min-height: 30px;
        padding: 6px 11px;
        border-radius: 999px;
        background: var(--gold-soft);
        color: #6f4f1f;
        border: 1px solid rgba(192, 155, 100, 0.38);
        font-size: 0.76rem;
        font-weight: 700;
      }

      .panel__section-title {
        margin: 0 0 8px;
        font-size: 0.78rem;
        font-weight: 800;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--gold);
      }

      .panel__desc {
        font-size: 0.9rem;
        line-height: 1.8;
        color: var(--muted);
        margin: 0;
      }

      .panel__cta-row {
        display: flex;
        justify-content: center;
        margin: 22px 0 14px;
      }

      .panel__sms-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 40px;
        padding: 0 16px;
        border-radius: 999px;
        background: var(--green);
        color: #fff;
        font-size: 0.82rem;
        font-weight: 700;
      }

      .panel__sms-btn:hover {
        background: var(--green-mid);
      }

      .panel__footer {
        display: flex;
        justify-content: center;
        padding-top: 6px;
      }

      .panel__nav-row {
        display: flex;
        justify-content: center;
        gap: 10px;
      }

      .panel__next-btn {
        appearance: none;
        background: transparent;
        border: 1px solid var(--line);
        color: var(--ink);
        padding: 10px 16px;
        border-radius: 999px;
        cursor: pointer;
        font-size: 0.82rem;
        font-weight: 600;
      }

      .panel__next-btn:hover {
        background: var(--ink);
        border-color: var(--ink);
        color: #fff;
      }

      .panel__next-btn:disabled {
        opacity: 0.35;
        pointer-events: none;
      }

      @media (max-width: 980px) {
        .shell {
          width: calc(100% - 32px);
        }

        .insight-grid {
          grid-template-columns: 1fr;
        }

        .grid {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .section-head {
          display: block;
        }

        .count {
          margin-top: 10px;
        }
      }

      @media (max-width: 640px) {
        .panel {
          left: 0;
          right: 0;
          top: 0;
          width: 100%;
          max-height: 100svh;
          border-radius: 0 0 var(--r-xl) var(--r-xl);
          transform: translateY(-106%);
        }

        .panel.open {
          transform: translateY(0);
        }

        .panel__grab {
          display: flex;
          justify-content: center;
          align-items: center;
          padding: 10px 0 2px;
          background: #fff;
          position: sticky;
          top: 0;
          z-index: 9;
        }

        .panel__grab::before {
          content: "";
          width: 42px;
          height: 4px;
          border-radius: 999px;
          background: #d4cfc7;
        }

        .panel__header {
          padding: 12px 14px;
          grid-template-columns: 1fr auto auto;
        }

        .panel__top-btn,
        .panel__close {
          height: 34px;
          font-size: 0.76rem;
        }

        .panel__body {
          padding: 20px 20px 24px;
        }
      }

      @media (max-width: 560px) {
        .shell {
          width: calc(100% - 24px);
        }

        .hero {
          padding: 46px 0 40px;
        }

        .grid {
          grid-template-columns: 1fr;
        }

        .card__image {
          height: 200px;
        }

        .insight-card,
        .quick-card {
          padding: 22px;
          border-radius: 20px;
        }
      }
    </style>
  </head>

  <body>
    <header class="hero">
      <div class="shell">
        <p class="eyebrow">{page.eyebrow}</p>
        <h1>{page.title}</h1>
        <p class="lead">{page.intro}</p>

        <div class="btn-row">
          <a class="btn" href="/agent-listings">Back to agent page</a>
        </div>
      </div>
    </header>

    <main>
      <section class="section">
        <div class="shell insight-grid">
          <article class="insight-card">
            <h2>{page.insightsTitle}</h2>

            {page.insights.map((item) => (
              <p>{item}</p>
            ))}

            <div class="meta-line">Updated {updatedLabel}</div>
          </article>

          <aside class="quick-card">
            <p class="eyebrow">Quick take</p>
            <h2>Buyer notes.</h2>

            <ul>
              {page.quickTake.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </aside>
        </div>
      </section>

      <section class="section">
        <div class="shell">
          <div class="section-head">
            <h2>Homes worth watching.</h2>
            <div class="count">
              {listings.length} {listings.length === 1 ? "home" : "homes"} found
            </div>
          </div>

          {error && <div class="empty">{error.message}</div>}

          {!error && listings.length === 0 && (
            <div class="empty">No matching homes found yet.</div>
          )}

          {!error && listings.length > 0 && (
            <section class="grid">
              {listings.map((listing: any) => {
                const image = getListingImage(listing);
                const images = getListingImages(listing).slice(0, 8);
                const address = getListingAddress(listing);
                const price = priceText(listing.price);
                const beds = getListingBeds(listing);
                const baths = getListingBaths(listing);
                const sqft = getListingSqft(listing);
                const description = getListingDescription(listing);
                const propertyType = getListingPropertyType(listing);
                const mls = getListingMls(listing);
                const dom = getListingDom(listing);

                return (
                  <button
                    type="button"
                    class="card listing-modal-trigger"
                    data-price={price}
                    data-address={address}
                    data-image={image}
                    data-images={JSON.stringify(images)}
                    data-beds={String(beds)}
                    data-baths={String(baths)}
                    data-sqft={String(sqft)}
                    data-description={description}
                    data-property-type={propertyType}
                    data-year={String(getListingYearBuilt(listing))}
                    data-lot-size={String(getListingLotSize(listing))}
                    data-area={String(getListingArea(listing))}
                    data-dom={String(dom)}
                    data-highlights={JSON.stringify(buildListingHighlights(listing))}
                    data-mls={mls}
                    data-href={`/listings?mls=${mls}`}
                  >
                    <div
                      class="card__image"
                      style={image ? `background-image:url('${image}');` : ""}
                    ></div>

                    <div class="card__body">
                      <strong class="price">{price}</strong>
                      <p class="address">{address}</p>

                      <div class="meta">
                        <span>{propertyType}</span>
                        <span>{beds} Bed</span>
                        <span>{baths} Bath</span>
                        {sqft ? <span>{sqft} Sq Ft</span> : null}
                      </div>

                      <p class="desc">{description}</p>
                    </div>
                  </button>
                );
              })}
            </section>
          )}
        </div>
      </section>
    </main>

    <div class="modal-overlay" id="listing-modal-overlay"></div>

    <aside
      class="panel"
      id="listing-modal"
      aria-hidden="true"
      data-agent-name="Chris"
      data-agent-phone="2506190390"
      data-agent-email="chris@example.com"
    >
      <div class="panel__grab" aria-hidden="true"></div>

      <div class="panel__progress-wrap">
        <div class="panel__progress-track">
          <div class="panel__progress-bar"></div>
        </div>

        <div class="panel__header">
          <div class="panel__position" id="listing-modal-position">Listing preview</div>

          <div class="panel__header-actions">
            <button class="panel__top-btn" id="listing-modal-prev" type="button">
              Previous
            </button>

            <button class="panel__top-btn" id="listing-modal-next" type="button">
              Next
            </button>
          </div>

          <button class="panel__close" id="listing-modal-close" type="button" aria-label="Close">
            Close
          </button>
        </div>
      </div>

      <div class="panel__view" id="listing-modal-scroll">
        <section class="panel__content">
          <div class="panel__image-stage">
            <img
              id="listing-modal-image"
              class="panel__image"
              src="https://placehold.co/800x600?text=Listing"
              alt=""
              loading="lazy"
              decoding="async"
            />

<button type="button" class="photo-nav photo-nav--prev" id="listing-photo-prev">Prev</button>
<button type="button" class="photo-nav photo-nav--next" id="listing-photo-next">Next</button>
            <div class="panel__photo-count" id="listing-photo-count">1 / 1 photos</div>
          </div>

          <div class="panel__body">
            <div class="panel__headline">
              <div>
                <h2 class="panel__price" id="listing-modal-price">—</h2>
                <p class="panel__address" id="listing-modal-address">Address</p>
                <div class="panel__meta" id="listing-modal-meta">—</div>
              </div>
            </div>

            <div class="panel__intelligence" id="listing-modal-intelligence">
              Fresh listing worth a closer look
            </div>

            <div class="panel__detail-row" id="listing-modal-detail-row"></div>

            <div class="panel__highlights" id="listing-modal-highlights"></div>

            <div class="panel__desc-wrap">
              <h3 class="panel__section-title">Description</h3>
              <p class="panel__desc" id="listing-modal-description">
                A quick preview of this property.
              </p>
            </div>

            <div class="panel__cta-row">
              <a class="panel__sms-btn" id="listing-modal-sms" href="#">
               Request info / showing
              </a>
            </div>

            <div class="panel__footer">
              <div class="panel__nav-row">
                <button class="panel__next-btn" id="listing-modal-bottom-prev" type="button">
  Previous
</button>

<button class="panel__next-btn" id="listing-modal-bottom-next" type="button">
  Next
</button>
              </div>
            </div>
          </div>
        </section>
      </div>
    </aside>

    <script is:inline>
      function initSeoListingModal() {
        const modal = document.getElementById("listing-modal");
        const overlay = document.getElementById("listing-modal-overlay");
        const closeBtn = document.getElementById("listing-modal-close");
        const imageEl = document.getElementById("listing-modal-image");
        const priceEl = document.getElementById("listing-modal-price");
        const addressEl = document.getElementById("listing-modal-address");
        const metaEl = document.getElementById("listing-modal-meta");
        const descEl = document.getElementById("listing-modal-description");
        const smsEl = document.getElementById("listing-modal-sms");
        const positionEl = document.getElementById("listing-modal-position");
        const intelligenceEl = document.getElementById("listing-modal-intelligence");
        const detailRowEl = document.getElementById("listing-modal-detail-row");
        const highlightsEl = document.getElementById("listing-modal-highlights");
        const photoCountEl = document.getElementById("listing-photo-count");
        const photoPrevBtn = document.getElementById("listing-photo-prev");
        const photoNextBtn = document.getElementById("listing-photo-next");
        const prevListingBtn = document.getElementById("listing-modal-prev");
        const nextListingBtn = document.getElementById("listing-modal-next");
        const bottomPrevListingBtn = document.getElementById("listing-modal-bottom-prev");
        const bottomNextListingBtn = document.getElementById("listing-modal-bottom-next");
        const scrollArea = document.getElementById("listing-modal-scroll");

        if (!modal || !overlay) return;
        if (modal.dataset.initialized === "true") return;
        modal.dataset.initialized = "true";

        let activePhotos = [];
        let activePhotoIndex = 0;
        let allCards = [];
        let activeIndex = -1;

        function parseImages(value, fallback) {
          try {
            const parsed = JSON.parse(value || "[]");
            const images = Array.isArray(parsed) ? parsed.filter(Boolean) : [];
            return Array.from(new Set([fallback, ...images].filter(Boolean)));
          } catch {
            return fallback ? [fallback] : [];
          }
        }

        function preloadImage(src) {
          if (!src) return;
          const img = new Image();
          img.src = src;
        }

        function renderPhoto() {
          if (!imageEl) return;

          const src =
            activePhotos[activePhotoIndex] ||
            "https://placehold.co/800x600?text=Listing";

          imageEl.src = src;

          preloadImage(activePhotos[activePhotoIndex + 1]);
          preloadImage(activePhotos[activePhotoIndex - 1]);

          if (photoCountEl) {
            photoCountEl.textContent = `${activePhotoIndex + 1} / ${Math.max(activePhotos.length, 1)} photos`;
          }

          if (photoPrevBtn) photoPrevBtn.disabled = activePhotoIndex === 0;
          if (photoNextBtn) photoNextBtn.disabled = activePhotoIndex >= activePhotos.length - 1;
        }

        function showPrevPhoto() {
          if (activePhotoIndex <= 0) return;
          activePhotoIndex -= 1;
          renderPhoto();
        }

        function showNextPhoto() {
          if (activePhotoIndex >= activePhotos.length - 1) return;
          activePhotoIndex += 1;
          renderPhoto();
        }

        function updateNavButtons() {
          const atStart = activeIndex <= 0;
          const atEnd = activeIndex >= allCards.length - 1;

          [prevListingBtn, bottomPrevListingBtn].forEach((btn) => {
            if (btn) btn.disabled = atStart;
          });

          [nextListingBtn, bottomNextListingBtn].forEach((btn) => {
            if (btn) btn.disabled = atEnd;
          });
        }

        function showNextListing() {
          if (!allCards.length || activeIndex >= allCards.length - 1) return;
          activeIndex += 1;
          openModal(allCards[activeIndex], false);
        }

        function showPrevListing() {
          if (!allCards.length || activeIndex <= 0) return;
          activeIndex -= 1;
          openModal(allCards[activeIndex], false);
        }

        function pickNote(seed, options) {
          const text = String(seed || "");
          const total = text.split("").reduce((sum, char) => sum + char.charCodeAt(0), 0);
          return options[total % options.length];
        }

        function buildNote(card) {
          const desc = String(card.dataset.description || "").toLowerCase();
          const propertyType = String(card.dataset.propertyType || "").toLowerCase();

          const beds = Number(card.dataset.beds || 0);
          const baths = Number(card.dataset.baths || 0);
          const sqft = Number(String(card.dataset.sqft || "").replace(/[^0-9.]/g, ""));
          const year = Number(card.dataset.year || 0);
          const dom = Number(card.dataset.dom || 0);

          const isCondo =
            propertyType.includes("condo") ||
            propertyType.includes("apartment");

          const isTownhouse =
            propertyType.includes("townhouse") ||
            propertyType.includes("townhome") ||
            propertyType.includes("row");

          const isHouse =
            propertyType.includes("house") ||
            propertyType.includes("detached") ||
            propertyType.includes("single family");

          const isNew = dom && dom <= 7;
          const hasView =
            /ocean view|water view|harbour view|harbor view|sea view|lake view|mountain view|city view|panoramic view/.test(desc);
          const hasSuite =
            isHouse && /suite|income|mortgage helper|secondary suite|legal suite/.test(desc);
          const isUpdated =
            /renovated|updated|modernized|new kitchen|new roof|contemporary/.test(desc);
          const hasParking =
            /garage|rv parking|double garage|underground parking|secure parking/.test(desc);
          const amenities =
            /pool|gym|fitness|clubhouse|elevator|storage locker|amenities/.test(desc);
          const outdoor =
            /patio|balcony|deck|yard|garden|outdoor space/.test(desc);

          if (isCondo) {
            if (sqft >= 900 && outdoor) return "Feels bigger than most condos";
            if (isUpdated) {
              return pickNote(card.dataset.mls || card.dataset.address, [
                "Move-in ready condo option",
                "Clean, easy condo choice",
                "A simpler option to step into",
                "Low-effort condo living"
              ]);
            }
            if (sqft >= 900) return "More room than the typical condo";
            if (amenities) return "Easy living with building perks";
            if (hasParking) return "Convenient everyday setup";
            if (isNew) return "Fresh option worth a look";
            return "Simple, low-maintenance living";
          }

          if (isTownhouse) {
            if (beds >= 3 && outdoor) return "Great layout for everyday living";
            if (hasParking) return "Practical townhome setup";
            if (isUpdated) return "Updated townhome option";
            if (isNew) return "New townhome worth a look";
            return "Balanced space with low upkeep";
          }

          if (isHouse) {
            const isFamilySized = beds >= 4 && baths >= 3;
            const isLarge = sqft >= 2500;
            const isNewer = year >= 2015;

            if (hasView && hasSuite) return "Strong upside with income potential";
            if (isNewer && isFamilySized && isLarge) return "Checks the boxes for a growing family";
            if (isUpdated && isLarge) return "Updated home with real space";
            if (hasSuite) return "Flexible layout with income potential";
            if (hasView) return "Nice outlook from main living areas";
            if (isNew) return "New listing worth acting on";
            return "Solid detached option to consider";
          }

          if (hasView) return "Open outlook worth noting";
          if (isUpdated) return "Updated features stand out";
          return "Worth a closer look";
        }

        function openModal(card, resetIndex = true) {
          if (resetIndex) {
            allCards = Array.from(document.querySelectorAll(".listing-modal-trigger"));
            activeIndex = allCards.indexOf(card);
          }

          const image = card.dataset.image || "";
          const address = card.dataset.address || "Address available";

          activePhotos = parseImages(card.dataset.images || "[]", image);
          activePhotoIndex = 0;

          if (priceEl) priceEl.textContent = card.dataset.price || "Price on request";
          if (addressEl) addressEl.textContent = address;
          if (imageEl) imageEl.alt = address;

          if (descEl) {
            descEl.textContent = card.dataset.description || "A quick preview of this property.";
          }

          if (positionEl) {
            positionEl.textContent = card.dataset.mls ? `MLS ${card.dataset.mls}` : "Listing preview";
          }

          if (intelligenceEl) {
            intelligenceEl.textContent = buildNote(card);
          }

          if (detailRowEl) {
            const details = [
              card.dataset.propertyType,
              card.dataset.area || "",
              card.dataset.year ? `Built ${card.dataset.year}` : "",
              card.dataset.lotSize ? `${card.dataset.lotSize} lot` : "",
              card.dataset.dom ? `${card.dataset.dom} Days on Market` : ""
            ].filter(Boolean);

            detailRowEl.innerHTML = details.map((item) => `<span>${item}</span>`).join("");
          }

          if (highlightsEl) {
            let highlights = [];

            try {
              highlights = JSON.parse(card.dataset.highlights || "[]");
            } catch {
              highlights = [];
            }

            highlightsEl.innerHTML = highlights
              .map((item) => `<span class="panel__highlight-chip">${item}</span>`)
              .join("");
          }

          if (metaEl) {
            const facts = [
              card.dataset.beds ? `${card.dataset.beds} Bed` : "",
              card.dataset.baths ? `${card.dataset.baths} Bath` : "",
              card.dataset.sqft ? `${card.dataset.sqft} Sq Ft` : ""
            ].filter(Boolean);

            metaEl.innerHTML = facts.join(" • ");
          }

          if (smsEl) {
            const phone = String(modal.dataset.agentPhone || "").replace(/[^0-9]/g, "");
            const email = modal.dataset.agentEmail || "";
            const agentName = modal.dataset.agentName || "there";

            const message = `Hi ${agentName}, I'd like more info or a showing for ${address}${card.dataset.mls ? ` MLS ${card.dataset.mls}` : ""}.`;

            const isMobile = /iPhone|iPad|iPod|Android/i.test(navigator.userAgent);

            smsEl.textContent = isMobile
              ? "Text for info / showing →"
              : "Email for info / showing →";

            if (isMobile && phone) {
              smsEl.href = `sms:${phone}?&body=${encodeURIComponent(message)}`;
            } else {
              smsEl.href = `mailto:${email}?subject=Listing Inquiry&body=${encodeURIComponent(message)}`;
            }
          }

          renderPhoto();
          updateNavButtons();

          modal.classList.add("open");
          overlay.classList.add("open");
          modal.setAttribute("aria-hidden", "false");
          document.body.classList.add("modal-open");

          requestAnimationFrame(() => {
            if (scrollArea) scrollArea.scrollTop = 0;
          });
        }

        function closeModal() {
          modal.classList.remove("open");
          overlay.classList.remove("open");
          modal.setAttribute("aria-hidden", "true");
          document.body.classList.remove("modal-open");
        }

        document.addEventListener("click", (event) => {
          const trigger = event.target.closest(".listing-modal-trigger");
          if (!trigger) return;

          event.preventDefault();
          event.stopPropagation();
          openModal(trigger);
        });

        closeBtn?.addEventListener("click", closeModal);
        overlay?.addEventListener("click", closeModal);
        photoPrevBtn?.addEventListener("click", showPrevPhoto);
        photoNextBtn?.addEventListener("click", showNextPhoto);
        prevListingBtn?.addEventListener("click", showPrevListing);
        nextListingBtn?.addEventListener("click", showNextListing);
        bottomPrevListingBtn?.addEventListener("click", showPrevListing);
        bottomNextListingBtn?.addEventListener("click", showNextListing);

        document.addEventListener("keydown", (event) => {
          if (!modal.classList.contains("open")) return;
          if (event.key === "Escape") closeModal();
          if (event.key === "ArrowLeft") showPrevPhoto();
          if (event.key === "ArrowRight") showNextPhoto();
        });
      }

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initSeoListingModal, { once: true });
      } else {
        initSeoListingModal();
      }

      document.addEventListener("astro:page-load", initSeoListingModal);
    </script>
  </body>
</html>