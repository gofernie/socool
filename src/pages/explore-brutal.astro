---
import { createClient } from "@supabase/supabase-js";

export const prerender = false;

const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.SUPABASE_SERVICE_ROLE_KEY
);

// Redirect to calm version if agent template is set to calm
try {
  const agentRes = await fetch(`${Astro.url.origin}/api/agent-page?slug=chris-crump`);
  const agentJson = await agentRes.json();
  if (agentJson?.data?.template === "calm") {
    return Astro.redirect(`/explore-calm${Astro.url.search}`);
  }
} catch {}

const url = Astro.url;

const city = url.searchParams.get("city") || "";
const area = url.searchParams.get("area") || "";
const type = url.searchParams.get("type") || "";
const minPrice = Number(url.searchParams.get("minPrice") || 0);
const maxPrice = Number(url.searchParams.get("maxPrice") || 0);
const sort = url.searchParams.get("sort") || "newest";

const clean = (value: any) =>
  String(value || "")
    .toLowerCase()
    .trim();

const typeMatches = (listingTypeValue: any, targetTypeValue: any) => {
  const listingType = clean(listingTypeValue);
  const target = clean(targetTypeValue);

  if (!target) return true;

  if (target === "house") {
    return (
      listingType.includes("house") ||
      listingType.includes("detached") ||
      listingType.includes("single family") ||
      listingType.includes("single-family") ||
      listingType.includes("residential")
    );
  }

  if (target === "condo") {
    const isMobile =
      listingType.includes("manufactured") ||
      listingType.includes("mobile") ||
      listingType.includes("park model");

    if (isMobile) return false;

    return listingType.includes("condo") || listingType.includes("apartment");
  }

  if (target === "townhouse") {
    return (
      listingType.includes("townhouse") ||
      listingType.includes("townhome") ||
      listingType.includes("row")
    );
  }

  if (target === "land") {
    return listingType.includes("land") || listingType.includes("lot");
  }

  if (target === "mobile") {
    return (
      listingType.includes("manufactured") ||
      listingType.includes("mobile") ||
      listingType.includes("park model") ||
      listingType.includes("modular")
    );
  }

  return listingType.includes(target);
};

const getListingMls = (listing: any) =>
  String(
    listing.mls_number ||
      listing.mlsNumber ||
      listing.id ||
      listing.repliers_listing_id ||
      listing.raw?.mlsNumber ||
      listing.raw?.id ||
      ""
  ).replace(/[^0-9]/g, "");

const getListingPriceNumber = (listing: any) =>
  Number(
    listing.price ||
      listing.listPrice ||
      listing.priceNumber ||
      listing.raw?.listPrice ||
      0
  );

const getListingPrice = (listing: any) => {
  const num = getListingPriceNumber(listing);

  if (Number.isFinite(num) && num > 1000) {
    return `$${Math.round(num).toLocaleString()}`;
  }

  return listing.price_text || listing.priceText || "Price on request";
};

const getListingAddress = (listing: any) =>
  listing.address ||
  listing.full_address ||
  listing.addressText ||
  listing.addressObj?.streetAddress ||
  [
    listing.addressObj?.streetNumber,
    listing.addressObj?.streetName,
    listing.addressObj?.streetSuffix
  ]
    .filter(Boolean)
    .join(" ") ||
  "Address available";

const normalizeListingImageUrl = (value: any) => {
  if (!value) return "";

  const raw =
    typeof value === "string"
      ? value
      : value.highRes ||
        value.mediumRes ||
        value.lowRes ||
        value.url ||
        value.src ||
        value.href ||
        value.path ||
        "";

  if (!raw) return "";

  if (raw.startsWith("http://") || raw.startsWith("https://")) {
    return raw;
  }

  const cleaned = raw.startsWith("/") ? raw : `/${raw}`;

  if (cleaned.startsWith("/vreb/")) {
    return `https://cdn.repliers.io${cleaned}`;
  }

  return cleaned;
};

const getListingImage = (listing: any) => {
  const image =
    listing.image_url ||
    listing.image ||
    listing.photo ||
    listing.images?.[0] ||
    listing.images?.[1] ||
    listing.raw?.images?.[0] ||
    listing.raw?.images?.[1] ||
    listing.raw?.images?.[0]?.url ||
    listing.raw?.images?.[1]?.url;

  return normalizeListingImageUrl(image);
};

const getListingImages = (listing: any) => {
  const rawImages =
    listing.images ||
    listing.photo_urls ||
    listing.photos ||
    listing.raw?.images ||
    [];

  const images = Array.isArray(rawImages)
    ? rawImages
        .map((img) => {
          if (typeof img === "string") return normalizeListingImageUrl(img);

          return normalizeListingImageUrl(
            img.highRes ||
              img.mediumRes ||
              img.lowRes ||
              img.url ||
              img.src ||
              img.href ||
              img.path ||
              ""
          );
        })
        .filter(Boolean)
    : [];

  const firstImage = getListingImage(listing);

  return Array.from(new Set([firstImage, ...images].filter(Boolean)));
};

const getListingBeds = (listing: any) =>
  listing.beds ||
  listing.bedrooms ||
  listing.details?.numBedrooms ||
  listing.raw?.details?.numBedrooms ||
  0;

const getListingBaths = (listing: any) =>
  listing.baths ||
  listing.bathrooms ||
  listing.details?.numBathrooms ||
  listing.raw?.details?.numBathrooms ||
  0;

const getListingSqft = (listing: any) =>
  listing.sqft ||
  listing.square_feet ||
  listing.squareFeet ||
  listing.details?.sqft ||
  listing.details?.squareFeet ||
  listing.raw?.details?.sqft ||
  listing.raw?.details?.squareFeet ||
  "";

const getListingDescription = (listing: any) =>
  listing.description ||
  listing.publicRemarks ||
  listing.remarks ||
  listing.details?.description ||
  listing.details?.publicRemarks ||
  listing.details?.remarks ||
  listing.raw?.description ||
  listing.raw?.publicRemarks ||
  listing.raw?.remarks ||
  listing.raw?.details?.description ||
  listing.raw?.details?.publicRemarks ||
  listing.raw?.details?.remarks ||
  "A quick preview of this property.";

const getListingDate = (listing: any) => {
  const raw =
    listing.listed_at ||
    listing.list_date ||
    listing.listDate ||
    listing.created_at ||
    listing.updated_at ||
    listing.raw?.timestamps?.listingUpdated ||
    0;

  return new Date(raw).getTime() || 0;
};

const getListingYearBuilt = (listing: any) =>
  listing.year_built ||
  listing.yearBuilt ||
  listing.details?.yearBuilt ||
  listing.raw?.details?.yearBuilt ||
  "";

const getListingLotSize = (listing: any) =>
  listing.lot_size ||
  listing.lotSize ||
  listing.details?.lotSize ||
  listing.raw?.details?.lotSize ||
  "";

const getListingArea = (listing: any) =>
  listing.normalized_area ||
  listing.area ||
  listing.neighborhood ||
  listing.addressObj?.neighborhood ||
  listing.address?.neighborhood ||
  listing.details?.area ||
  listing.details?.subArea ||
  listing.raw?.address?.neighborhood ||
  listing.raw?.details?.area ||
  listing.raw?.details?.subArea ||
  "";

const getListingPropertyType = (listing: any) =>
  String(
    listing.normalized_type ||
      listing.property_type ||
      listing.propertyType ||
      listing.type ||
      listing.details?.propertyType ||
      listing.raw?.details?.propertyType ||
      "Home"
  )
    .replace(/[_-]+/g, " ")
    .replace(/\b\w/g, (char) => char.toUpperCase());

const pageTitle = city ? `${city} homes` : "Explore homes";

const groupLabel = [
  area ? area : "",
  type ? type.replace(/-/g, " ") : "",
  maxPrice ? `under $${maxPrice}k` : "",
  minPrice ? `over $${minPrice}k` : ""
]
  .filter(Boolean)
  .join(" · ");

let listings: any[] = [];
let errorMessage = "";

try {
  let query = supabase
    .from("listing_rows")
    .select("*")
    .eq("status", "A")
    .limit(48);

  if (city) {
    query = query.eq("normalized_city", clean(city));
  }

  if (type) {
    if (type === "condo") {
      query = query.eq("normalized_type", "condo");
    } else if (type === "house") {
      query = query.eq("normalized_type", "house");
    } else if (type === "townhouse") {
      query = query.eq("normalized_type", "townhouse");
    } else if (type === "land") {
      query = query.eq("normalized_type", "land");
    } else if (type === "mobile") {
      query = query.eq("normalized_type", "mobile");
    } else {
      query = query.eq("normalized_type", clean(type));
    }
  }

  if (area) {
    query = query.eq("normalized_area", clean(area));
  }

  if (minPrice) {
    query = query.gte("price", minPrice * 1000);
  }

  if (maxPrice) {
    query = query.lte("price", maxPrice * 1000);
  }

  if (sort === "price-low" || sort === "price-asc") {
    query = query.order("price", { ascending: true });
  } else if (sort === "price-high" || sort === "price-desc") {
    query = query.order("price", { ascending: false });
  } else if (sort === "beds-high") {
    query = query.order("beds", { ascending: false });
  } else {
    query = query.order("listed_at", { ascending: false });
  }

  const { data, error } = await query;

  if (error) throw error;

  listings = data || [];

  if (type === "condo") {
    listings = listings.filter((listing: any) => {
      const text = [
        listing.normalized_type,
        listing.property_type,
        listing.propertyType,
        listing.type,
        listing.details?.propertyType,
        listing.raw?.details?.propertyType,
        listing.description,
        listing.publicRemarks,
        listing.remarks
      ]
        .filter(Boolean)
        .join(" ")
        .toLowerCase();

      const isMobile =
        text.includes("manufactured") ||
        text.includes("mobile") ||
        text.includes("modular") ||
        text.includes("park model") ||
        text.includes("mfd");

      return !isMobile;
    });
  }
} catch (error: any) {
  errorMessage = error?.message || "Could not load listings.";
}
---

<html lang="en">
  <head>
  <title>{city ? `${city} ${type ? type.replace(/-/g, " ") + "s" : "homes"} for sale${maxPrice ? ` under $${maxPrice}k` : ""}` : "Explore homes for sale"} | {city || "Listings"}</title>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={city ? `Browse ${listings.length} ${type ? type.replace(/-/g, " ") + "s" : "homes"} for sale in ${city}${maxPrice ? ` under $${maxPrice}k` : ""}${minPrice ? ` over $${minPrice}k` : ""}. View photos, prices, and listing details.` : "Browse current homes for sale. View photos, prices, and listing details from the current market."} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={Astro.url.href} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={city ? `${city} ${type ? type.replace(/-/g, " ") + "s" : "homes"} for sale${maxPrice ? ` under $${maxPrice}k` : ""}` : "Explore homes for sale"} />
    <meta property="og:description" content={city ? `Browse ${listings.length} ${type ? type.replace(/-/g, " ") + "s" : "homes"} for sale in ${city}. View photos, prices, and listing details.` : "Browse current homes for sale with photos, prices, and listing details."} />
    <meta property="og:url" content={Astro.url.href} />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={city ? `${city} ${type ? type.replace(/-/g, " ") + "s" : "homes"} for sale` : "Explore homes for sale"} />
    <meta name="twitter:description" content={city ? `${listings.length} ${type ? type.replace(/-/g, " ") + "s" : "homes"} listed in ${city}.` : "Browse current homes for sale."} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700&display=swap"
      rel="stylesheet"
    />

    <style>
      :root {
        --bg: #fafaf9;
        --surface: #ffffff;
        --ink: #0a0a0a;
        --ink-soft: #262626;
        --muted: #737373;
        --soft: #a3a3a3;
        --line: #e5e5e5;
        --line-heavy: #d4d4d4;
        --accent: #ff4d00;
        --accent-dark: #cc3d00;
        --accent-bg: #fff4f0;

        --f-display: "DM Serif Display", Georgia, serif;
        --f-body: "DM Sans", -apple-system, BlinkMacSystemFont, sans-serif;
        --ease: cubic-bezier(0.22, 1, 0.36, 1);
      }

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html,
      body {
        width: 100%;
        overflow-x: hidden;
      }

      body {
        font-family: var(--f-body);
        background: var(--bg);
        color: var(--ink);
        font-size: 15px;
        line-height: 1.5;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      body.modal-open {
        overflow: hidden;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      button {
        font: inherit;
      }

      /* ========== SHELL ========== */

      .shell {
        width: min(1600px, calc(100% - 80px));
        margin: 0 auto;
      }

      /* ========== HERO ========== */

      .hero {
        position: relative;
        background: var(--ink);
        color: var(--bg);
        padding: 140px 0 120px;
        overflow: hidden;
      }

      .hero::before {
        content: "";
        position: absolute;
        top: 0;
        right: 0;
        width: 50%;
        height: 100%;
        background: linear-gradient(135deg, transparent, rgba(255, 77, 0, 0.08));
        pointer-events: none;
      }

   .hero__inner {
        position: relative;
        z-index: 2;
        display: grid;
        grid-template-columns: 1.3fr 0.7fr;
        gap: 100px;
        align-items: center;
      }

      .eyebrow {
        display: inline-block;
        margin: 0 0 20px;
        padding: 4px 12px;
        background: transparent;
        border: 1px solid rgba(255, 255, 255, 0.2);
        color: var(--bg);
        font-size: 0.65rem;
        font-weight: 800;
        letter-spacing: 0.15em;
        text-transform: uppercase;
      }

      h1 {
        margin: 0 0 0;
        font-family: var(--f-display);
        font-size: clamp(4rem, 8vw, 8rem);
        font-weight: 400;
        line-height: 0.86;
        letter-spacing: -0.04em;
        color: var(--bg);
      }

      h1 em {
        display: block;
        font-style: italic;
        color: var(--accent);
      }

   .hero p {
        max-width: 520px;
        color: rgba(250, 250, 249, 0.6);
        font-size: 1rem;
        line-height: 1.6;
        font-weight: 400;
        margin: 0;
      }

      .hero__meta {
        position: relative;
        border: 1px solid rgba(255, 255, 255, 0.15);
        background: rgba(255, 255, 255, 0.03);
        backdrop-filter: blur(40px);
        -webkit-backdrop-filter: blur(40px);
        display: flex;
        flex-direction: column;
        overflow: hidden;
      }

      .hero__meta::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 2px;
        background: var(--accent);
      }

      .hero__meta-body {
        padding: 28px;
      }

      .hero__meta-label {
        display: inline-block;
        margin: 0 0 16px;
        padding: 4px 12px;
        border: 1px solid rgba(255, 255, 255, 0.2);
        color: var(--bg);
        font-size: 0.65rem;
        font-weight: 800;
        letter-spacing: 0.15em;
        text-transform: uppercase;
      }

      .hero__meta-desc {
        color: rgba(250, 250, 249, 0.5);
        font-size: 0.88rem;
        line-height: 1.6;
        margin: 0 0 24px;
      }

      .hero-stats {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 2px;
        background: rgba(255, 255, 255, 0.08);
        border-top: 1px solid rgba(255, 255, 255, 0.1);
      }

      .hero-stat {
        padding: 24px 28px;
        background: rgba(255, 255, 255, 0.02);
      }

      .hero-stat__label {
        display: block;
        font-size: 0.65rem;
        font-weight: 800;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: rgba(250, 250, 249, 0.35);
        margin-bottom: 8px;
      }

      .hero-stat__value {
        display: block;
        font-family: var(--f-display);
        font-size: 2.8rem;
        font-weight: 400;
        line-height: 0.9;
        letter-spacing: -0.03em;
        color: var(--bg);
      }

      /* ========== MAIN SECTION ========== */

      .section {
        padding: 80px 0 120px;
      }

      .section-head {
        display: flex;
        align-items: end;
        justify-content: space-between;
        gap: 40px;
        padding-bottom: 24px;
        margin-bottom: 32px;
        border-bottom: 2px solid var(--ink);
      }

      .section-head h2 {
        margin: 0;
        font-family: var(--f-display);
        font-size: clamp(3rem, 5vw, 5rem);
        font-weight: 400;
        line-height: 0.88;
        letter-spacing: -0.04em;
        color: var(--ink);
      }

      .count {
        flex-shrink: 0;
        color: var(--soft);
        font-size: 0.7rem;
        font-weight: 800;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        white-space: nowrap;
      }

      /* ========== BACK LINK ========== */

      .back {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 40px;
        color: var(--muted);
        font-weight: 700;
        font-size: 0.8rem;
        letter-spacing: -0.01em;
        border: 1.5px solid var(--line-heavy);
        padding: 8px 18px;
        transition: all 0.2s var(--ease);
        position: relative;
      }

      .back::before {
        content: "";
        position: absolute;
        inset: -2px;
        background: var(--ink);
        z-index: -1;
        opacity: 0;
        transition: opacity 0.2s var(--ease);
      }

      .back:hover {
        color: var(--bg);
        border-color: var(--ink);
        transform: translate(-2px, -2px);
      }

      .back:hover::before {
        opacity: 1;
      }

      /* ========== GRID ========== */

      .grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 2px;
        background: var(--line-heavy);
        border: 2px solid var(--ink);
      }

      /* ========== CARD ========== */

      .card {
        appearance: none;
        display: block;
        width: 100%;
        overflow: hidden;
        background: var(--surface);
        border: 0;
        border-radius: 0;
        box-shadow: none;
        text-align: left;
        cursor: pointer;
        color: inherit;
        padding: 0;
        transition: transform 0.35s var(--ease);
        position: relative;
      }

      .card::before {
        content: "";
        position: absolute;
        inset: 0;
        background: var(--accent-bg);
        opacity: 0;
        transition: opacity 0.35s var(--ease);
        z-index: 0;
        pointer-events: none;
      }

      .card:hover::before {
        opacity: 1;
      }

      .card:hover {
        transform: translate(-3px, -3px);
        box-shadow: 4px 4px 0 var(--ink);
        z-index: 10;
      }

      .card__image {
        height: 240px;
        background: linear-gradient(135deg, rgba(255, 77, 0, 0.1), rgba(10, 10, 10, 0.05));
        background-size: cover;
        background-position: center;
        filter: grayscale(15%);
        mix-blend-mode: multiply;
        transition: filter 0.35s var(--ease);
        position: relative;
        z-index: 1;
      }

      .card:hover .card__image {
        filter: grayscale(0%);
        mix-blend-mode: normal;
      }

      .card__body {
        padding: 20px 22px 24px;
        position: relative;
        z-index: 1;
        border-top: 2px solid var(--ink);
      }

      .price {
        display: block;
        margin-bottom: 8px;
        font-family: var(--f-display);
        font-size: 1.75rem;
        font-weight: 400;
        line-height: 1;
        letter-spacing: -0.03em;
        color: var(--ink);
      }

      .address {
        margin: 0 0 10px;
        color: var(--muted);
        font-size: 0.88rem;
        line-height: 1.4;
      }

      .meta {
        display: flex;
        flex-wrap: wrap;
        gap: 4px 10px;
        color: var(--soft);
        font-size: 0.78rem;
        font-weight: 500;
      }

      .meta span + span::before {
        content: "·";
        margin-right: 10px;
      }

      .desc {
        margin: 12px 0 0;
        color: var(--muted);
        font-size: 0.84rem;
        line-height: 1.6;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }

      /* ========== EMPTY STATE ========== */

      .empty {
        padding: 80px 28px;
        border: 2px solid var(--ink);
        background: var(--surface);
        color: var(--muted);
        text-align: center;
        font-size: 0.95rem;
      }

      /* ========== MODAL OVERLAY ========== */

      .modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(10, 10, 10, 0.8);
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.3s var(--ease);
        z-index: 800;
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
      }

      .modal-overlay.open {
        opacity: 1;
        pointer-events: auto;
      }

      /* ========== PANEL ========== */

      .panel {
        position: fixed;
        left: 50%;
        top: 0;
        width: min(960px, calc(100vw - 40px));
        max-height: 100vh;
        background: var(--surface);
        z-index: 900;
        overflow: hidden;
        transform: translate(-50%, -110%);
        transition: transform 0.5s var(--ease);
        display: flex;
        flex-direction: column;
        border: 2px solid var(--ink);
        border-top: 0;
      }

      .panel.open {
        transform: translate(-50%, 0);
      }

      .panel__grab {
        display: none;
      }

      .panel__progress-track {
        height: 3px;
        width: 100%;
        background: var(--line);
        overflow: hidden;
      }

      .panel__progress-bar {
        height: 100%;
        width: 100%;
        background: var(--accent);
      }

      .panel__header {
        padding: 20px 28px;
        display: grid;
        grid-template-columns: 1fr auto auto;
        align-items: center;
        gap: 16px;
        background: var(--surface);
        border-bottom: 1px solid var(--line);
      }

      .panel__position {
        font-size: 0.7rem;
        font-weight: 800;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--muted);
      }

      .panel__header-actions {
        display: flex;
        align-items: center;
        gap: 12px;
      }

      .panel__top-btn,
      .panel__close,
      .panel__next-btn {
        appearance: none;
        height: 42px;
        padding: 0 20px;
        border: 1.5px solid var(--ink);
        background: var(--surface);
        color: var(--ink);
        cursor: pointer;
        font: inherit;
        font-size: 0.8rem;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s var(--ease);
        position: relative;
      }

      .panel__top-btn::before,
      .panel__close::before,
      .panel__next-btn::before {
        content: "";
        position: absolute;
        inset: -2px;
        background: var(--ink);
        z-index: -1;
        opacity: 0;
        transition: opacity 0.2s var(--ease);
      }

      .panel__top-btn:hover,
      .panel__close:hover,
      .panel__next-btn:hover {
        color: var(--bg);
        transform: translate(-2px, -2px);
      }

      .panel__top-btn:hover::before,
      .panel__close:hover::before,
      .panel__next-btn:hover::before {
        opacity: 1;
      }

      .panel__top-btn:disabled,
      .panel__next-btn:disabled {
        opacity: 0.3;
        cursor: default;
        pointer-events: none;
      }

      .panel__close {
        width: 42px;
        padding: 0;
      }

      .panel__view {
        overflow-y: auto;
        flex: 1;
      }

      .panel__image-stage {
        position: relative;
        background: var(--line);
      }

      .panel__image {
        width: 100%;
        aspect-ratio: 16 / 9;
        object-fit: cover;
        display: block;
        filter: grayscale(15%);
      }

      .panel__photo-count {
        position: absolute;
        right: 20px;
        bottom: 20px;
        z-index: 2;
        background: rgba(10, 10, 10, 0.9);
        color: var(--bg);
        padding: 10px 16px;
        font-size: 0.75rem;
        font-weight: 800;
        letter-spacing: 0.05em;
      }

      .photo-nav {
        position: absolute;
        top: 50%;
        z-index: 3;
        transform: translateY(-50%);
        width: 48px;
        height: 48px;
        border: 1.5px solid var(--bg);
        background: rgba(10, 10, 10, 0.6);
        color: var(--bg);
        font-size: 1.8rem;
        line-height: 1;
        cursor: pointer;
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        transition: all 0.2s var(--ease);
      }

      .photo-nav:hover {
        background: rgba(10, 10, 10, 0.9);
      }

      .photo-nav--prev {
        left: 20px;
      }

      .photo-nav--next {
        right: 20px;
      }

      .photo-nav:disabled {
        opacity: 0.3;
        cursor: default;
      }

      .panel__body {
        padding: 40px 44px 44px;
      }

      .panel__price {
        font-family: var(--f-display);
        font-size: clamp(2.8rem, 5vw, 4rem);
        font-weight: 400;
        letter-spacing: -0.03em;
        line-height: 0.9;
        color: var(--ink);
        margin: 0 0 12px;
      }

      .panel__address {
        font-size: 1.4rem;
        color: var(--muted);
        line-height: 1.3;
        margin: 0 0 16px;
        font-weight: 500;
      }

      .panel__meta {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin: 0 0 20px;
        color: var(--ink);
        font-size: 0.9rem;
        font-weight: 700;
      }

      .panel__intelligence {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        min-height: 40px;
        padding: 12px 18px;
        background: var(--accent-bg);
        border: 1.5px solid var(--accent);
        color: var(--accent-dark);
        font-size: 0.8rem;
        font-weight: 800;
        margin-bottom: 20px;
        letter-spacing: 0.01em;
      }

      .panel__intelligence::before {
        content: "✦";
        font-size: 1.1rem;
      }

      .panel__detail-row {
        display: flex;
        flex-wrap: wrap;
        gap: 12px 20px;
        margin: 0 0 24px;
        color: var(--muted);
        font-size: 0.85rem;
        font-weight: 600;
      }

      .panel__detail-row span + span::before {
        content: "·";
        margin-right: 20px;
      }

      .panel__highlights {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin: 0 0 28px;
      }

      .panel__highlight-chip {
        display: inline-flex;
        align-items: center;
        min-height: 36px;
        padding: 10px 16px;
        background: var(--accent-bg);
        color: var(--accent-dark);
        border: 1.5px solid var(--accent);
        font-size: 0.75rem;
        font-weight: 800;
        letter-spacing: 0.02em;
      }

      .panel__section-title {
        margin: 0 0 12px;
        font-size: 0.7rem;
        font-weight: 800;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--accent);
      }

      .panel__desc {
        font-size: 0.95rem;
        line-height: 1.7;
        color: var(--muted);
        margin: 0 0 28px;
      }

      .panel__cta-row {
        display: flex;
        justify-content: center;
        margin: 8px 0 20px;
      }

      .panel__sms-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 52px;
        padding: 0 28px;
        background: var(--accent);
        color: white;
        font-size: 0.85rem;
        font-weight: 800;
        border: 2px solid var(--accent);
        transition: all 0.25s var(--ease);
        position: relative;
      }

      .panel__sms-btn::before {
        content: "";
        position: absolute;
        inset: -2px;
        background: var(--accent-dark);
        z-index: -1;
        opacity: 0;
        transition: opacity 0.25s var(--ease);
      }

      .panel__sms-btn:hover::before {
        opacity: 1;
      }

      .panel__sms-btn:hover {
        transform: translate(-3px, -3px);
      }

      .panel__nav-row {
        display: flex;
        justify-content: center;
        gap: 14px;
      }

      /* ========== RESPONSIVE ========== */

    @media (max-width: 1200px) {
        .shell {
          width: calc(100% - 60px);
        }

        .hero__inner {
          grid-template-columns: 1fr;
          gap: 60px;
        }

        .grid {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }
      }

      @media (max-width: 768px) {
        .hero {
          padding: 80px 0 70px;
        }

        .section {
          padding: 60px 0 80px;
        }

        .section-head {
          flex-direction: column;
          align-items: flex-start;
          gap: 12px;
        }
      }

      @media (max-width: 640px) {
        .shell {
          width: calc(100% - 32px);
        }

        .hero {
          padding: 60px 0 50px;
        }

        .grid {
          grid-template-columns: 1fr;
        }

        .hero-stats {
          grid-template-columns: 1fr 1fr;
        }

        .panel {
          left: 0;
          right: 0;
          top: 0;
          width: 100%;
          max-height: 100svh;
          transform: translateY(-110%);
          border-radius: 0;
        }

        .panel.open {
          transform: translateY(0);
        }

        .panel__grab {
          display: flex;
          justify-content: center;
          align-items: center;
          padding: 10px 0 6px;
          background: var(--surface);
          position: sticky;
          top: 0;
          z-index: 9;
        }

        .panel__grab::before {
          content: "";
          width: 44px;
          height: 4px;
          background: var(--line-heavy);
        }

        .panel__header {
          padding: 16px 20px;
        }

        .panel__header-actions {
          display: none;
        }

        .panel__body {
          padding: 28px 24px 32px;
        }
      }
    </style>
<script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ItemList",
      "name": city ? `${city} ${type ? type.replace(/-/g, " ") + "s" : "homes"} for sale` : "Homes for sale",
      "description": city ? `${listings.length} active listings in ${city}` : "Active real estate listings",
      "numberOfItems": listings.length,
      "url": Astro.url.href
    })}></script>
  </head>

  <body>
  <header class="hero">
      <div class="shell hero__inner">
        <div>
          <p class="eyebrow">Explore homes</p>
          <h1>
            {city || "Curated"}
            <em>{type ? type.replace(/-/g, " ") : "listings."}</em>
          </h1>
          <p style="margin-top:40px;">
            {groupLabel
              ? `A focused group of homes: ${groupLabel}.`
              : "A focused group of listings pulled from the current market."}
          </p>
        </div>

        <aside class="hero__meta">
          <div class="hero__meta-body">
            <span class="hero__meta-label">Market snapshot</span>
            <p class="hero__meta-desc">
              {city ? `Active listings in ${city}${type ? ` · ${type}` : ""}${maxPrice ? ` · under $${maxPrice}k` : ""}` : "Listings pulled from the current market."}
            </p>
          </div>
          <div class="hero-stats">
            <div class="hero-stat">
              <span class="hero-stat__label">Found</span>
              <span class="hero-stat__value">{listings.length}</span>
            </div>
            <div class="hero-stat">
              <span class="hero-stat__label">Market</span>
              <span class="hero-stat__value">{city || "All"}</span>
            </div>
          </div>
        </aside>
      </div>
    </header>

    <main class="section">
      <div class="shell">
<nav aria-label="Page navigation">
          <a class="back" href="/agent-listings">← Back to agent page</a>
        </nav>
        <div class="section-head">
<h2>{type ? `${listings.length} ${type.replace(/-/g, " ")}s in ${city || "this area"}.` : `${listings.length} homes in ${city || "this area"}.`}</h2>          <div class="count">
            {listings.length} {listings.length === 1 ? "home" : "homes"} found
          </div>
        </div>

        {errorMessage && <div class="empty">{errorMessage}</div>}

        {!errorMessage && listings.length === 0 && (
          <div class="empty">No matching homes found yet.</div>
        )}

       {!errorMessage && listings.length > 0 && (
          <ol class="grid" aria-label={`${listings.length} listings${city ? ` in ${city}` : ""}`} style="list-style:none;padding:0;margin:0;">
            {listings.map((listing: any) => {
              const image = getListingImage(listing);
              const address = getListingAddress(listing);
              const price = getListingPrice(listing);
              const beds = getListingBeds(listing);
              const baths = getListingBaths(listing);
              const sqft = getListingSqft(listing);
              const mls = getListingMls(listing);
              const propertyType = getListingPropertyType(listing);
              const description = getListingDescription(listing);
              const images = getListingImages(listing);

             return (
                <li style="display:contents;">
                <button
                  type="button"
                  class="card listing-modal-trigger"
                  data-price={price}
                  data-address={address}
                  data-image={image}
                  data-images={JSON.stringify(images)}
                  data-beds={String(beds)}
                  data-baths={String(baths)}
                  data-sqft={String(sqft)}
                  data-description={description}
                  data-property-type={propertyType}
                  data-year={String(getListingYearBuilt(listing))}
                  data-lot-size={String(getListingLotSize(listing))}
                  data-area={String(getListingArea(listing))}
                  data-highlights={JSON.stringify([
                    propertyType.toLowerCase().includes("condo") ? "Open outlook" : "",
                    description.toLowerCase().includes("parking") ? "Parking included" : "",
                    description.toLowerCase().includes("patio") ||
                    description.toLowerCase().includes("balcony")
                      ? "Outdoor space"
                      : ""
                  ].filter(Boolean))}
                  data-mls={mls}
               aria-label={`${price} — ${address}`}
                >
                  <div
                    class="card__image"
                    role="img"
                    aria-label={`Photo of ${address}`}
                    style={image ? `background-image:url('${image}');` : ""}
                  ></div>

                  <div class="card__body">
                    <strong class="price">{price}</strong>
                    <p class="address">{address}</p>

                    <div class="meta">
                      <span>{propertyType}</span>
                      <span>{beds} Bed</span>
                      <span>{baths} Bath</span>
                      {sqft ? <span>{sqft} Sq Ft</span> : null}
                    </div>

                    <p class="desc">{description}</p>
                  </div>
                </button>
                </li>
              );
            })}
          </ol>
        )}
      </div>
    </main>

    <div class="modal-overlay" id="listing-modal-overlay"></div>

    <aside class="panel" id="listing-modal" aria-hidden="true">
      <div class="panel__grab" aria-hidden="true"></div>

      <div class="panel__progress-track">
        <div class="panel__progress-bar"></div>
      </div>

      <div class="panel__header">
        <div class="panel__position" id="listing-modal-position">Listing preview</div>

        <div class="panel__header-actions">
          <button class="panel__top-btn" id="listing-modal-prev" type="button">
            ← Previous
          </button>

          <button class="panel__top-btn" id="listing-modal-next" type="button">
            Next →
          </button>
        </div>

        <button class="panel__close" id="listing-modal-close" type="button" aria-label="Close">
          ✕
        </button>
      </div>

      <div class="panel__view" id="listing-modal-scroll">
        <div class="panel__image-stage">
          <img
            id="listing-modal-image"
            class="panel__image"
            src="https://placehold.co/800x600?text=Listing"
            alt=""
            loading="eager"
            decoding="async"
          />

          <button type="button" class="photo-nav photo-nav--prev" id="listing-photo-prev">‹</button>
          <button type="button" class="photo-nav photo-nav--next" id="listing-photo-next">›</button>
          <div class="panel__photo-count" id="listing-photo-count">1 / 1 photos</div>
        </div>

        <div class="panel__body">
          <h2 class="panel__price" id="listing-modal-price">—</h2>
          <p class="panel__address" id="listing-modal-address">Address</p>
          <div class="panel__meta" id="listing-modal-meta">—</div>

          <div class="panel__intelligence" id="listing-modal-intelligence">
            Fresh listing worth a closer look
          </div>

          <div class="panel__detail-row" id="listing-modal-detail-row"></div>

          <div class="panel__highlights" id="listing-modal-highlights"></div>

          <div>
            <h3 class="panel__section-title">Description</h3>
            <p class="panel__desc" id="listing-modal-description">
              A quick preview of this property.
            </p>
          </div>

          <div class="panel__cta-row">
            <a class="panel__sms-btn" id="listing-modal-sms" href="#">
              Request info / showing →
            </a>
          </div>

          <div class="panel__nav-row">
            <button class="panel__next-btn" id="listing-modal-bottom-prev" type="button">
              ← Previous
            </button>

            <button class="panel__next-btn" id="listing-modal-bottom-next" type="button">
              Next →
            </button>
          </div>
        </div>
      </div>
    </aside>

    <script is:inline>
      function initExploreModal() {
        const modal = document.getElementById("listing-modal");
        const overlay = document.getElementById("listing-modal-overlay");
        const closeBtn = document.getElementById("listing-modal-close");
        const imageEl = document.getElementById("listing-modal-image");
        const priceEl = document.getElementById("listing-modal-price");
        const addressEl = document.getElementById("listing-modal-address");
        const metaEl = document.getElementById("listing-modal-meta");
        const descEl = document.getElementById("listing-modal-description");
        const positionEl = document.getElementById("listing-modal-position");
        const intelligenceEl = document.getElementById("listing-modal-intelligence");
        const detailRowEl = document.getElementById("listing-modal-detail-row");
        const highlightsEl = document.getElementById("listing-modal-highlights");
        const smsEl = document.getElementById("listing-modal-sms");
        const photoCountEl = document.getElementById("listing-photo-count");
        const photoPrevBtn = document.getElementById("listing-photo-prev");
        const photoNextBtn = document.getElementById("listing-photo-next");
        const prevListingBtn = document.getElementById("listing-modal-prev");
        const nextListingBtn = document.getElementById("listing-modal-next");
        const bottomPrevListingBtn = document.getElementById("listing-modal-bottom-prev");
        const bottomNextListingBtn = document.getElementById("listing-modal-bottom-next");
        const scrollArea = document.getElementById("listing-modal-scroll");

        if (!modal || !overlay) return;
        if (modal.dataset.initialized === "true") return;
        modal.dataset.initialized = "true";

        let activePhotos = [];
        let activePhotoIndex = 0;
        let allCards = [];
        let activeIndex = -1;

        function parseImages(value, fallback) {
          try {
            const parsed = JSON.parse(value || "[]");
            const images = Array.isArray(parsed) ? parsed.filter(Boolean) : [];
            return Array.from(new Set([fallback, ...images].filter(Boolean)));
          } catch {
            return fallback ? [fallback] : [];
          }
        }

        function preloadImage(src) {
          if (!src) return;
          const img = new Image();
          img.src = src;
        }

        function renderPhoto() {
          if (!imageEl) return;

          const src =
            activePhotos[activePhotoIndex] ||
            "https://placehold.co/800x600?text=Listing";

          imageEl.src = src;

          preloadImage(activePhotos[activePhotoIndex + 1]);
          preloadImage(activePhotos[activePhotoIndex - 1]);

          const lazyLoadRest = () => {
            activePhotos.slice(8).forEach(preloadImage);
          };

          if ("requestIdleCallback" in window) {
            window.requestIdleCallback(lazyLoadRest);
          } else {
            setTimeout(lazyLoadRest, 800);
          }

          if (photoCountEl) {
            photoCountEl.textContent = `${activePhotoIndex + 1} / ${Math.max(activePhotos.length, 1)} photos`;
          }

          if (photoPrevBtn) photoPrevBtn.disabled = activePhotoIndex === 0;
          if (photoNextBtn) photoNextBtn.disabled = activePhotoIndex >= activePhotos.length - 1;
        }

        function showPrevPhoto() {
          if (activePhotoIndex <= 0) return;
          activePhotoIndex -= 1;
          renderPhoto();
        }

        function showNextPhoto() {
          if (activePhotoIndex >= activePhotos.length - 1) return;
          activePhotoIndex += 1;
          renderPhoto();
        }

        function updateNavButtons() {
          const atStart = activeIndex <= 0;
          const atEnd = activeIndex >= allCards.length - 1;

          [prevListingBtn, bottomPrevListingBtn].forEach((btn) => {
            if (btn) btn.disabled = atStart;
          });

          [nextListingBtn, bottomNextListingBtn].forEach((btn) => {
            if (btn) btn.disabled = atEnd;
          });
        }

        function showNextListing() {
          if (!allCards.length || activeIndex >= allCards.length - 1) return;
          activeIndex += 1;
          openModal(allCards[activeIndex], false);
        }

        function showPrevListing() {
          if (!allCards.length || activeIndex <= 0) return;
          activeIndex -= 1;
          openModal(allCards[activeIndex], false);
        }

        function buildNote(card) {
          const desc = String(card.dataset.description || "").toLowerCase();
          const propertyType = String(card.dataset.propertyType || "").toLowerCase();
          const beds = Number(card.dataset.beds || 0);
          const baths = Number(card.dataset.baths || 0);
          const sqft = Number(String(card.dataset.sqft || "").replace(/[^0-9.]/g, ""));

          const isCondo = propertyType.includes("condo") || propertyType.includes("apartment");
          const isHouse =
            propertyType.includes("house") ||
            propertyType.includes("detached") ||
            propertyType.includes("single family");
          const isTownhouse =
            propertyType.includes("townhouse") ||
            propertyType.includes("townhome") ||
            propertyType.includes("row");

          const hasView = /ocean view|water view|harbour view|harbor view|lake view|mountain view|city view|panoramic view/.test(desc);
          const isUpdated = /renovated|updated|modernized|new kitchen|new roof|contemporary/.test(desc);
          const hasSuite = /suite|income|mortgage helper|secondary suite|legal suite/.test(desc);
          const hasParking = /garage|rv parking|double garage|underground parking|secure parking/.test(desc);
          const outdoor = /patio|balcony|deck|yard|garden|outdoor space/.test(desc);

          if (isCondo) {
            if (sqft >= 900 && outdoor) return "Feels bigger than most condos";
            if (isUpdated) return "Move-in ready condo option";
            if (hasParking) return "Convenient everyday setup";
            return "Simple, low-maintenance living";
          }

          if (isTownhouse) {
            if (beds >= 3 && outdoor) return "Great layout for everyday living";
            if (hasParking) return "Practical townhome setup";
            return "Balanced space with low upkeep";
          }

          if (isHouse) {
            if (hasView && hasSuite) return "Strong upside with income potential";
            if (beds >= 4 && baths >= 3) return "Checks the boxes for a growing family";
            if (hasSuite) return "Flexible layout with income potential";
            if (hasView) return "Nice outlook from main living areas";
            return "Solid detached option to consider";
          }

          if (hasView) return "Open outlook worth noting";
          if (isUpdated) return "Updated features stand out";

          return "Worth a closer look";
        }

        function openModal(card, resetIndex = true) {
          if (resetIndex) {
            allCards = Array.from(document.querySelectorAll(".listing-modal-trigger"));
            activeIndex = allCards.indexOf(card);
          }

          const image = card.dataset.image || "";
          const address = card.dataset.address || "Address available";
          const mls = card.dataset.mls || "";

          activePhotos = parseImages(card.dataset.images || "[]", image);
          activePhotoIndex = 0;

          if (priceEl) priceEl.textContent = card.dataset.price || "Price on request";
          if (addressEl) addressEl.textContent = address;
          if (imageEl) imageEl.alt = address;
          if (descEl) descEl.textContent = card.dataset.description || "A quick preview of this property.";
          if (positionEl) positionEl.textContent = mls ? `MLS ${mls}` : "Listing preview";
          if (intelligenceEl) intelligenceEl.textContent = buildNote(card);

          if (detailRowEl) {
            const details = [
              card.dataset.propertyType || "",
              card.dataset.area || "",
              card.dataset.year ? `Built ${card.dataset.year}` : "",
              card.dataset.lotSize ? `${card.dataset.lotSize} lot` : ""
            ].filter(Boolean);

            detailRowEl.innerHTML = details.map((item) => `<span>${item}</span>`).join("");
          }

          if (highlightsEl) {
            let highlights = [];

            try {
              highlights = JSON.parse(card.dataset.highlights || "[]");
            } catch {
              highlights = [];
            }

            highlightsEl.innerHTML = highlights
              .map((item) => `<span class="panel__highlight-chip">${item}</span>`)
              .join("");
          }

          if (metaEl) {
            metaEl.textContent = [
              card.dataset.beds ? `${card.dataset.beds} Bed` : "",
              card.dataset.baths ? `${card.dataset.baths} Bath` : "",
              card.dataset.sqft ? `${card.dataset.sqft} Sq Ft` : ""
            ]
              .filter(Boolean)
              .join(" • ");
          }

          if (smsEl) {
            const message = `Hi, I'd like more info or a showing for ${address}${mls ? ` MLS ${mls}` : ""}.`;
            smsEl.href = `mailto:?subject=Listing Inquiry&body=${encodeURIComponent(message)}`;
          }

          renderPhoto();
          updateNavButtons();

          modal.classList.add("open");
          overlay.classList.add("open");
          modal.setAttribute("aria-hidden", "false");
          document.body.classList.add("modal-open");

          requestAnimationFrame(() => {
            if (scrollArea) scrollArea.scrollTop = 0;
          });
        }

        function closeModal() {
          modal.classList.remove("open");
          overlay.classList.remove("open");
          modal.setAttribute("aria-hidden", "true");
          document.body.classList.remove("modal-open");
        }

        document.addEventListener("click", (event) => {
          const trigger = event.target.closest(".listing-modal-trigger");
          if (!trigger) return;

          event.preventDefault();
          event.stopPropagation();
          openModal(trigger);
        });

        closeBtn?.addEventListener("click", closeModal);
        overlay?.addEventListener("click", closeModal);
        photoPrevBtn?.addEventListener("click", showPrevPhoto);
        photoNextBtn?.addEventListener("click", showNextPhoto);
        prevListingBtn?.addEventListener("click", showPrevListing);
        nextListingBtn?.addEventListener("click", showNextListing);
        bottomPrevListingBtn?.addEventListener("click", showPrevListing);
        bottomNextListingBtn?.addEventListener("click", showNextListing);

        document.addEventListener("keydown", (event) => {
          if (!modal.classList.contains("open")) return;

          if (event.key === "Escape") closeModal();
          if (event.key === "ArrowLeft") showPrevPhoto();
          if (event.key === "ArrowRight") showNextPhoto();
        });
      }

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initExploreModal, { once: true });
      } else {
        initExploreModal();
      }

      document.addEventListener("astro:page-load", initExploreModal);
    </script>
  </body>
</html>