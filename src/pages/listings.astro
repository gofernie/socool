import { createSupabaseServerClient } from "../lib/supabaseServer";

const supabaseAuth = createSupabaseServerClient(Astro.cookies);

const {
  data: { user },
} = await supabaseAuth.auth.getUser();

if (!user) {
  return Astro.redirect("/login");
}

const agentId = user.id;
import {
  getListingAddress,
  getListingBaths,
  getListingBeds,
  getListingDescription,
  getListingId,
  getListingImage,
  getListingPrice,
  getListingSqft,
  getListingType,
  getListingYear
} from "../lib/repliers";
import { createClient } from "@supabase/supabase-js";

const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.SUPABASE_SERVICE_ROLE_KEY
);

export const prerender = false;

const url = new URL(Astro.request.url);

const city = url.searchParams.get("city") || "";
const beds = url.searchParams.get("beds") || "";
const baths = url.searchParams.get("baths") || "";
const type = url.searchParams.get("type") || "";
const minPrice = url.searchParams.get("minPrice") || "";
const maxPrice = url.searchParams.get("maxPrice") || "";
const area = url.searchParams.get("area") || "";
console.log("AREA PARAM", area);
const sort = url.searchParams.get("sort") || "";
const mls = url.searchParams.get("mls") || "";
const shortlistSlug = url.searchParams.get("shortlist") || "";

let listings: any[] = [];
let error: string | null = null;

const hasListingFilters = Boolean(city || area || beds || baths || type || minPrice || maxPrice || mls);

function cleanArea(value: string) {
  return String(value || "")
    .replace(/^na\s+/i, "")
    .trim();
}





function getListingAreaName(listing: any) {
  const raw =
    listing?.area ||
    listing?.normalized_area ||
    listing?.raw?.details?.subArea ||
    listing?.details?.subArea ||
    listing?.raw?.details?.area ||
    listing?.details?.area ||
    listing?.raw?.address?.neighborhood ||
    listing?.address?.neighborhood ||
    "";

  const rawArea = String(raw || "")
    .replace(/^na\s+/i, "")
    .trim();

  const addressText = String(
    listing?.address ||
      listing?.raw?.address?.streetName ||
      listing?.raw?.address?.addressKey ||
      getListingAddress(listing) ||
      ""
  ).toLowerCase();

  const SOUTH_NANAIMO_STREETS = [
    "ninth",
    "highview",
    "petroglyph",
    "howard",
    "bruce",
    "victoria",
    "harewood",
    "duke"
  ];

  if (SOUTH_NANAIMO_STREETS.some((street) => addressText.includes(street))) {
    return "South Nanaimo";
  }

  const NORTH_NANAIMO_STREETS = [
    "uplands",
    "dover",
    "edgewater",
    "blueback",
    "vista view",
    "mcrobb",
    "sentinal",
    "metral"
  ];

  if (NORTH_NANAIMO_STREETS.some((street) => addressText.includes(street))) {
    return "North Nanaimo";
  }

  const uselessAreas = [
    "other",
    "nanaimo",
    "nanaimo, city of",
    "city of nanaimo"
  ];

  if (rawArea && !uselessAreas.includes(rawArea.toLowerCase())) {
    return rawArea;
  }

  const desc = String(listing?.raw?.details?.description || "").toLowerCase();

  if (desc.includes("south nanaimo")) return "South Nanaimo";
  if (desc.includes("north nanaimo")) return "North Nanaimo";

  return rawArea;
}
function normalizeArea(value: string) {
  return String(value || "")
    .toLowerCase()
    .replace(/^na\s+/i, "")
    .replace(/[^a-z0-9]+/g, " ")
    .trim();
}

if (hasListingFilters) {
  try {
    let query = supabase
  .from("listing_rows")
  .select("*");

query = query.eq("status", "A");

if (city) {
      query = query.eq("normalized_city", city.toLowerCase());
    } else {
      query = query.eq("normalized_city", "nanaimo");
    }

 if (area) {
  const areas = area.split(",").map(a => a.trim().toLowerCase()).filter(Boolean);
  if (areas.length === 1) {
    query = query.eq("normalized_area", areas[0]);
  } else if (areas.length > 1) {
    query = query.in("normalized_area", areas);
  }
}

    if (type) {
      const typeMap: Record<string, string> = {
        detached: "house",
        condo: "condo",
        townhouse: "townhouse",
        land: "land",
        mobile: "mobile"
      };

      query = query.eq("normalized_type", typeMap[type] || type);
    }

    if (beds) {
      query = query.gte("beds", Number(beds));
    }

    if (baths) {
      query = query.gte("baths", Number(baths));
    }

    if (minPrice) {
      query = query.gte("price", Number(minPrice));
    }

    if (maxPrice) {
      query = query.lte("price", Number(maxPrice));
    }

   if (mls) {
  const cleanMls = mls.replace(/[^0-9]/g, "");

  query = query.or(
    `id.eq.${cleanMls},mls_number.eq.${cleanMls}`
  );
}

    if (sort === "price-desc") {
      query = query.order("price", { ascending: false });
    } else {
      query = query.order("price", { ascending: true });
    }

    const { data, error: dbError } = await query.limit(500);

    if (dbError) {
      throw new Error(dbError.message);
    }

    listings = data || [];

    
  } catch (err) {
    console.error("Failed to load listings:", err);
    error = err instanceof Error ? err.message : "Failed to load listings";
  }
}
