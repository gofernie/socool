function initResultsMap() {
  const mapEl = document.getElementById("results-map");
  if (!mapEl || typeof L === "undefined") return;

  const cards = Array.from(document.querySelectorAll(".card"));
  const points = cards
    .map((card) => ({ card, point: getListingLatLng(card) }))
    .filter((item) => item.point);

  if (!points.length) {
    mapEl.innerHTML = "<p style='padding:16px;'>No map locations available for these results.</p>";
    return;
  }

  if (!resultsMap) {
    resultsMap = L.map(mapEl).setView([49.1659, -123.9401], 12);

    L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
      maxZoom: 19,
      attribution: "&copy; OpenStreetMap contributors"
    }).addTo(resultsMap);
  }

  resultsMarkers.forEach((marker) => marker.remove());
  resultsMarkers = [];

  const bounds = [];

  points.forEach(({ card, point }) => {
    const marker = L.marker([point.lat, point.lng]).addTo(resultsMap);

    marker.bindPopup(`
      <strong>${card.dataset.price || "Listing"}</strong><br>
      ${card.dataset.address || ""}
    `);

    marker.on("click", () => {
      openSheetFromCard(card);
    });

    resultsMarkers.push(marker);
    bounds.push([point.lat, point.lng]);
  });

  resultsMap.fitBounds(bounds, { padding: [32, 32] });

  setTimeout(() => {
    resultsMap.invalidateSize();
  }, 100);
}
