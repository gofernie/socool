  const selectedCity = String(citySelect?.value || "").toLowerCase();
  const selectedArea = areaSelect.dataset.selectedArea || areaSelect.value || "";

  areaSelect.innerHTML = `<option value="">All areas</option>`;

  if (!selectedCity) return;

  // 🔥 HARD LOCK NANAIMO
  if (selectedCity === "nanaimo") {
    const MAIN_NANAIMO_AREAS = [
      "Cedar",
      "Central Nanaimo",
      "Chase River",
      "Departure Bay",
      "Diver Lake",
      "Hammond Bay",
      "Lower Lantzville",
      "North Jingle Pot",
      "North Nanaimo",
      "Old City",
      "Pleasant Valley",
      "South Jingle Pot",
      "South Nanaimo",
      "University District",
      "Uplands",
      "Upper Lantzville",
      "Brechin Hill"
    ];

    MAIN_NANAIMO_AREAS.forEach((areaName) => {
      const option = document.createElement("option");
      option.value = areaName;
      option.textContent = areaName;

      if (areaName === selectedArea) {
        option.selected = true;
      }

      areaSelect.appendChild(option);
    });

    return;
  }

  // fallback for other cities
  try {
    const res = await fetch(`/api/listing-areas?city=${encodeURIComponent(selectedCity)}`);
    const json = await res.json();

    const areas = Array.isArray(json?.areas) ? json.areas : [];

    areas.forEach((areaName) => {
      const option = document.createElement("option");
      option.value = areaName;
      option.textContent = areaName;

      if (areaName === selectedArea) {
        option.selected = true;
      }

      areaSelect.appendChild(option);
    });
  } catch (err) {
    console.error("Could not load areas:", err);
  }
}

updateAreaOptions();

// price shorthand: 800 → 800000
document.querySelector(".filters")?.addEventListener("submit", () => {
  ["minPrice", "maxPrice"].forEach((name) => {
    const input = document.querySelector(`input[name="${name}"]`);
    if (!input) return;

    const value = String(input.value || "").trim();

    if (/^\d{2,4}$/.test(value)) {
      input.value = String(Number(value) * 1000);
    }
  });
});

citySelect?.addEventListener("change", () => {
  if (areaSelect) areaSelect.dataset.selectedArea = "";
  updateAreaOptions();
});
    </script>
  </body>
</html>