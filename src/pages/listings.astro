function moneyToNumber(value) {
  return Number(String(value || "").replace(/[^0-9]/g, "")) || 0;
}

function numberFromText(value) {
  return Number(String(value || "").replace(/[^0-9.]/g, "")) || 0;
}

function addShortlistInsights(items) {
  const enriched = items.map((item) => {
    const price = moneyToNumber(item.price_text);
    const sqft = numberFromText(item.sqft);
    const beds = numberFromText(item.beds);
    const baths = numberFromText(item.baths);
    const year = numberFromText(item.year_built);

    return {
      ...item,
      __price: price,
      __sqft: sqft,
      __beds: beds,
      __baths: baths,
      __year: year,
      __psf: price && sqft ? Math.round(price / sqft) : null
    };
  });

  const validPsf = enriched.filter((i) => i.__psf);
  const validSqft = enriched.filter((i) => i.__sqft);
  const validPrice = enriched.filter((i) => i.__price);
  const validBeds = enriched.filter((i) => i.__beds);
  const validYear = enriched.filter((i) => i.__year);

  const lowestPsf = validPsf.sort((a, b) => a.__psf - b.__psf)[0];
  const largest = validSqft.sort((a, b) => b.__sqft - a.__sqft)[0];
  const lowestPrice = validPrice.sort((a, b) => a.__price - b.__price)[0];
  const mostBeds = validBeds.sort((a, b) => b.__beds - a.__beds)[0];
  const newest = validYear.sort((a, b) => b.__year - a.__year)[0];

  return enriched.map((item) => {
    let insight = null;

    if (lowestPsf && item.id === lowestPsf.id) {
      insight = {
        title: "Best value in this group",
        detail: `$${item.__psf}/sq ft`
      };
    } else if (largest && item.id === largest.id) {
      insight = {
        title: "Largest home in your shortlist",
        detail: `${item.__sqft.toLocaleString()} sq ft`
      };
    } else if (lowestPrice && item.id === lowestPrice.id) {
      insight = {
        title: "Lowest price in this group",
        detail: item.price_text
      };
    } else if (mostBeds && item.id === mostBeds.id) {
      insight = {
        title: "Most bedrooms in this group",
        detail: `${item.__beds} bed`
      };
    } else if (newest && item.id === newest.id) {
      insight = {
        title: "Newest home in this group",
        detail: `Built ${item.__year}`
      };
    }

    return {
      ...item,
      insight_title: insight?.title || null,
      insight_detail: insight?.detail || null
    };
  });
}
