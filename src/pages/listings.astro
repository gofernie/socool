  }

  const NORTH_NANAIMO_STREETS = [
    "uplands",
    "dover",
    "edgewater",
    "blueback",
    "vista view",
    "mcrobb",
    "sentinal",
    "metral"
  ];

  if (NORTH_NANAIMO_STREETS.some((street) => addressText.includes(street))) {
    return "North Nanaimo";
  }

  const uselessAreas = [
    "other",
    "nanaimo",
    "nanaimo, city of",
    "city of nanaimo"
  ];

  if (rawArea && !uselessAreas.includes(rawArea.toLowerCase())) {
    return rawArea;
  }

  const desc = String(listing?.raw?.details?.description || "").toLowerCase();

  if (desc.includes("south nanaimo")) return "South Nanaimo";
  if (desc.includes("north nanaimo")) return "North Nanaimo";

  return rawArea;
}
function normalizeArea(value: string) {
