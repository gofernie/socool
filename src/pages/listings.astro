<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script is:inline>
      const STORAGE_KEY = "agent-shortlist";

      const savedCountEl = document.getElementById("saved-count");
const visibleSavedCountEl = document.getElementById("visible-saved-count");
const selectAllBtn = document.getElementById("select-all-btn");
      const createBtn = document.getElementById("create-shortlist-btn");
      const statusEl = document.getElementById("status");
      const titleInput = document.getElementById("shortlist-title");
      const clientNameInput = document.getElementById("client-name");
      const clientPhoneInput = document.getElementById("client-phone");
      const agentNoteInput = document.getElementById("agent-note");

      const composer = document.querySelector(".composer");
      const composerToggle = document.getElementById("composer-toggle");
      const composerSelectedCount = document.getElementById("composer-selected-count");

      const sheet = document.getElementById("preview-sheet");
      const overlay = document.getElementById("sheet-overlay");
      const sheetImage = document.getElementById("sheet-image");
      const sheetPrice = document.getElementById("sheet-price");
      const sheetAddress = document.getElementById("sheet-address");
      const sheetMeta = document.getElementById("sheet-meta");
      const sheetType = document.getElementById("sheet-type");
      const sheetSqft = document.getElementById("sheet-sqft");
      const sheetYear = document.getElementById("sheet-year");
      const sheetLayout = document.getElementById("sheet-layout");
      const sheetDescription = document.getElementById("sheet-description");
      const sheetSaveBtn = document.getElementById("sheet-save-btn");
const sheetCloseBtn = document.getElementById("sheet-close-btn");
const sheetMapBtn = document.getElementById("sheet-map-btn");
      
      const sheetMainImage = document.getElementById("sheet-main-image");
const photoPrevBtn = document.getElementById("photo-prev");
const photoNextBtn = document.getElementById("photo-next");
const photoCount = document.getElementById("photo-count");

let activeImages = [];
let activeImageIndex = 0;

      const shortlistSlug = document.body.dataset.shortlistSlug || "";
      const isAddMode = Boolean(shortlistSlug);

      let activePreviewId = null;

      const existingShortlistMap = new Map();

     function loadShortlist() {
  try {
    const raw = localStorage.getItem(STORAGE_KEY);
    const parsed = raw ? JSON.parse(raw) : [];
    return Array.isArray(parsed) ? parsed : [];
  } catch {
    return [];
  }
}

      function saveShortlist(items) {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(items));
      }

      let shortlist = isAddMode ? [] : loadShortlist();

      function hasId(id) {
        return shortlist.some((item) => String(item.id) === String(id));
      }

      function getCardSnapshot(card) {
        return {
          id: String(card.dataset.cardId || ""),
          repliers_listing_id: String(card.dataset.mls || ""),
          address: card.dataset.address || null,
          price_text: card.dataset.price || null,
          image_url: card.dataset.image || null,
          images: JSON.parse(card.dataset.images || "[]"),
          beds: card.dataset.beds || null,
          baths: card.dataset.baths || null,
          property_type: card.dataset.type || null,
          sqft: card.dataset.sqft || null,
          year_built: card.dataset.year || null,
          description: card.dataset.description || null
        };
      }

      function getExistingEntry(cardOrId, mlsMaybe = "") {
  let id = "";
  let mls = "";

  if (cardOrId instanceof HTMLElement) {
    id = String(cardOrId.dataset.cardId || "").trim();
    mls = String(cardOrId.dataset.mls || "").trim();
  } else {
    id = String(cardOrId || "").trim();
    mls = String(mlsMaybe || "").trim();
  }

  return (
  existingShortlistMap.get(id?.trim()) ||
  existingShortlistMap.get(mls?.trim()) ||
  null
);
}

      function setCardExistingEntry(card, entry) {
        if (!(card instanceof HTMLElement)) return;
        card.dataset.shortlistItemId = entry?.shortlistItemId ? String(entry.shortlistItemId) : "";
      }

      function markButtonFlash(btn, text, fallback) {
        if (!(btn instanceof HTMLButtonElement)) return;
        btn.textContent = text;
        window.setTimeout(() => {
          btn.textContent = fallback;
        }, 1200);
      }

      function applyButtonState(btn, state) {
        if (!(btn instanceof HTMLButtonElement)) return;

        btn.classList.remove("saved", "remove");
        btn.disabled = false;

        if (state === "save") {
          btn.textContent = "Save";
          return;
        }

        if (state === "saved") {
          btn.textContent = "Saved";
          btn.classList.add("saved");
          return;
        }

        if (state === "remove") {
          btn.textContent = "Remove";
          btn.classList.add("remove");
        }
      }

      function updateSheetSaveButton() {
        if (!sheetSaveBtn) return;

        if (!activePreviewId) {
          applyButtonState(sheetSaveBtn, "save");
          return;
        }

        const card = document.querySelector(`[data-card-id="${CSS.escape(activePreviewId)}"]`);

        if (isAddMode) {
          const entry = card instanceof HTMLElement ? getExistingEntry(card) : null;
          applyButtonState(sheetSaveBtn, entry ? "remove" : "save");
          return;
        }

        const saved = hasId(activePreviewId);
        applyButtonState(sheetSaveBtn, saved ? "saved" : "save");
      }

      function setComposerOpen(isOpen) {
        if (!composer || !composerToggle || window.innerWidth >= 900) return;
        composer.classList.toggle("open", isOpen);
        composerToggle.setAttribute("aria-expanded", isOpen ? "true" : "false");
      }

      function updateUI() {
        const count = isAddMode
          ? new Set(
              Array.from(existingShortlistMap.values()).map((entry) =>
                String(entry.shortlistItemId || "")
              )
            ).size
          : shortlist.length;

      if (savedCountEl) {
  savedCountEl.textContent = String(count);
}

if (visibleSavedCountEl && isAddMode) {
  const visibleSavedCount = Array.from(document.querySelectorAll(".card.saved")).length;

  visibleSavedCountEl.textContent =
    count > visibleSavedCount
      ? ` total · ${visibleSavedCount} visible on this page`
      : "";
}

        if (composerSelectedCount) {
          composerSelectedCount.textContent = String(count);
        }

        if (selectAllBtn && !isAddMode) {
  const cards = Array.from(document.querySelectorAll(".card"));

  const allVisibleSaved =
    cards.length > 0 &&
    cards.every((card) => {
      const id = String(card.dataset.cardId || "");
      return id && hasId(id);
    });

  selectAllBtn.textContent = allVisibleSaved
    ? "Unselect all visible"
    : "Select all visible";
}

        document.querySelectorAll(".save-btn").forEach((btn) => {
          const card = btn.closest(".card");

          if (isAddMode) {
            const entry = card instanceof HTMLElement ? getExistingEntry(card) : null;
            applyButtonState(btn, entry ? "remove" : "save");
            card?.classList.toggle("saved", Boolean(entry));
            if (card instanceof HTMLElement) {
              setCardExistingEntry(card, entry);
            }
            return;
          }

          const id = String(btn.dataset.listingId || "");
          const saved = !!id && hasId(id);

          applyButtonState(btn, saved ? "saved" : "save");
          card?.classList.toggle("saved", saved);
        });

        if (createBtn) {
          createBtn.disabled = isAddMode ? true : shortlist.length === 0;
          createBtn.textContent = isAddMode ? "Editing existing shortlist" : "Create Shortlist";
        }

        if (titleInput) titleInput.disabled = isAddMode;
        if (clientNameInput) clientNameInput.disabled = isAddMode;
        if (clientPhoneInput) clientPhoneInput.disabled = isAddMode;
        if (agentNoteInput) agentNoteInput.disabled = isAddMode;

        if (statusEl) {
          if (isAddMode) {
            statusEl.textContent = "Save adds a home. Remove takes it back off this shortlist.";
          } else {
            statusEl.textContent = shortlist.length
              ? `${shortlist.length} listing${shortlist.length === 1 ? "" : "s"} ready`
              : "No listings selected";
          }
        }

        updateSheetSaveButton();
