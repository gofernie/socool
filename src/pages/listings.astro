function normalizeFilterValue(value) {
  return String(value || "").trim().toLowerCase();
}

function labelize(value) {
  return String(value || "")
    .trim()
    .replace(/[-_]+/g, " ")
    .replace(/\s+/g, " ")
    .replace(/\b\w/g, (char) => char.toUpperCase());
}

function getOptionValue(item) {
  if (!item) return "";

  if (typeof item === "object") {
    return normalizeFilterValue(
      item.value ||
        item.normalized_area ||
        item.normalized_city ||
        item.normalized_type ||
        item.name ||
        item.label ||
        ""
    );
  }

  return normalizeFilterValue(item);
}

function getOptionLabel(item) {
  if (!item) return "";

  if (typeof item === "object") {
    return (
      item.label ||
      item.display_name ||
      labelize(
        item.value ||
          item.normalized_area ||
          item.normalized_city ||
          item.normalized_type ||
          item.name ||
          ""
      )
    );
  }

  return labelize(item);
}

async function updateAreaOptions() {
  const dropdown = document.getElementById("area-dropdown");
  const trigger = document.getElementById("area-trigger");
  const hiddenInput = document.getElementById("area-hidden");
  if (!dropdown || !trigger || !hiddenInput) return;

  const selectedCity = normalizeFilterValue(citySelect?.value || "nanaimo");
  const selectedAreas = (hiddenInput.value || "").split(",").filter(Boolean);

  dropdown.innerHTML = "";

  if (!selectedCity) return;

  try {
    const res = await fetch("/api/listing-filters");
    const json = await res.json();

    const areasByCity = json?.areasByCity || {};
    const areas = Object.entries(areasByCity).find(
      ([key]) => normalizeFilterValue(key) === selectedCity
    )?.[1] || [];

    areas.forEach((areaItem) => {
      const value = getOptionValue(areaItem);
      const label = getOptionLabel(areaItem);
      if (!value) return;

      const div = document.createElement("div");
      div.className = "multi-select-option";

      const checkbox = document.createElement("input");
      checkbox.type = "checkbox";
      checkbox.value = value;
      checkbox.checked = selectedAreas.includes(value);

      const span = document.createElement("span");
      span.textContent = label;

      div.appendChild(checkbox);
      div.appendChild(span);

      div.addEventListener("click", (e) => {
        if (e.target !== checkbox) checkbox.checked = !checkbox.checked;

        const checked = Array.from(dropdown.querySelectorAll("input:checked"))
          .map((cb) => cb.value);

        hiddenInput.value = checked.join(",");
        trigger.textContent = checked.length
          ? checked.map(labelize).join(", ")
          : "All areas";
      });

      dropdown.appendChild(div);
    });

    const initialChecked = Array.from(dropdown.querySelectorAll("input:checked"))
      .map((cb) => cb.value);
    trigger.textContent = initialChecked.length
      ? initialChecked.map(labelize).join(", ")
      : "All areas";

  } catch (err) {
    console.error("Could not load dynamic areas:", err);
  }
}

document.getElementById("area-trigger")?.addEventListener("click", (e) => {
  e.preventDefault();
  const dropdown = document.getElementById("area-dropdown");
  if (dropdown) dropdown.hidden = !dropdown.hidden;
});

document.addEventListener("click", (e) => {
  const wrap = document.getElementById("area-multi-wrap");
  if (wrap && !wrap.contains(e.target)) {
    const dropdown = document.getElementById("area-dropdown");
    if (dropdown) dropdown.hidden = true;
  }
});

async function updateCityOptions() {
  if (!citySelect) return;

  const selectedCity = normalizeFilterValue(
    citySelect.dataset.selectedCity || citySelect.value || "nanaimo"
  );

  citySelect.innerHTML = `<option value="">Any city</option>`;

  try {
    const res = await fetch("/api/listing-filters");
    const json = await res.json();

    const cities = Array.isArray(json?.cities) ? json.cities : [];

    cities.forEach((cityItem) => {
      const value = normalizeFilterValue(cityItem?.value || "");
      const label = cityItem?.label || labelize(value);

      if (!value) return;

      const option = document.createElement("option");
      option.value = value;
      option.textContent = label;

      if (value === selectedCity) {
        option.selected = true;
      }

      citySelect.appendChild(option);
    });
  } catch (err) {
    console.error("Could not load dynamic cities:", err);
  }
}

updateCityOptions().then(updateAreaOptions);

// price shorthand: 800 → 800000
document.querySelector(".filters")?.addEventListener("submit", () => {
  ["minPrice", "maxPrice"].forEach((name) => {
    const input = document.querySelector(`input[name="${name}"]`);
    if (!input) return;

    const value = String(input.value || "").trim();

    if (/^\d{2,4}$/.test(value)) {
      input.value = String(Number(value) * 1000);
    }
  });
});

citySelect?.addEventListener("change", () => {
  if (areaSelect) areaSelect.dataset.selectedArea = "";
  updateAreaOptions();
});
    </script>
  </body>
</html>