        function closeSheet(skipReload = false) {
          sheet.classList.remove("dragging", "closing-down", "is-love-pulse", "is-pass-fade");

          if (isMobileSheet()) {
            sheet.style.transition = "none";
            sheet.classList.remove("open");
            overlay.classList.remove("open");
            sheet.setAttribute("aria-hidden", "true");
            document.body.style.overflow = "";
            resetSheetTransform();

            requestAnimationFrame(() => {
              sheet.style.transition = "";
            });
          } else {
            sheet.classList.remove("open");
            overlay.classList.remove("open");
            sheet.setAttribute("aria-hidden", "true");
            document.body.style.overflow = "";
            resetSheetTransform();
          }

       const needsRefresh = shouldRefreshOnClose && !skipReload;

if (needsRefresh) {
  window.location.reload();
  return;
}

          activeCard = null;
          activeItemId = "";
          activeTags = [];
          activeFavourite = false;
          activeDecision = "";
          isSaving = false;
          isShowingSummary = false;
          shouldRefreshOnClose = false;
          touchStartX = 0;
          touchStartY = 0;
          touchCurrentX = 0;
          touchCurrentY = 0;
          isDraggingSheet = false;
          dragMode = "";
          touchStartedOnInteractive = false;
          isAnimatingGesture = false;
          dragCloseY = 0;

          sheetContent?.classList.remove("open");
          sheetSummary?.classList.remove("open");
          updateDecisionButtons();

          if (sheetFeedback) {
            sheetFeedback.textContent = "";
            sheetFeedback.className = "panel__feedback";
          }

          if (sheetPosition) sheetPosition.textContent = "1 of 1";
          if (sheetProgressBar) sheetProgressBar.style.width = "0%";

          sheet.scrollTop = 0;
          
        }

        async function removeShortlistItem(card) {
          if (!isAgentView || !card) return;

          const itemId = String(card.dataset.itemId || "").trim();
          if (!itemId) {
            alert("Missing shortlist item id.");
            return;
          }

          const ok = window.confirm("Remove this home from the shortlist?");
          if (!ok) return;

          card.classList.add("is-removing");

          try {
            const res = await fetch("/api/shortlists/remove-item", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ id: itemId })
            });

            const json = await res.json().catch(() => null);

            if (!res.ok || !json?.ok) {
              throw new Error(json?.error || "Could not remove listing");
            }

            if (activeCard === card) {
              closeSheet(true);
            }

            card.remove();
            updateCounts();
          } catch (err) {
            card.classList.remove("is-removing");
            alert(err instanceof Error ? err.message : "Could not remove listing");
          }
        }

        function animateSheetBack(mode = "close") {
          if (!isMobileSheet()) return;
          isAnimatingGesture = true;
          sheet.classList.remove("dragging");

          if (mode === "nav") {
            sheet.style.transition = "transform 0.22s ease, opacity 0.22s ease";
            sheet.style.transform = "translateX(0)";
            sheet.style.opacity = "1";
            window.setTimeout(() => {
              sheet.style.transition = "";
              sheet.style.opacity = "";
              resetSheetTransform();
              isAnimatingGesture = false;
            }, 220);
            return;
          }

          sheet.style.transition = "transform 0.22s ease";
          overlay.style.transition = "opacity 0.22s ease";
          setSheetTransform("translateY(0)");
          overlay.style.opacity = "";
          window.setTimeout(() => {
            sheet.style.transition = "";
            overlay.style.transition = "";
            resetSheetTransform();
            isAnimatingGesture = false;
          }, 220);
        }

        function animateSheetOffscreenAndClose() {
          if (!isMobileSheet()) {
            closeSheet();
            return;
          }

          isAnimatingGesture = true;
          sheet.classList.remove("dragging");

          const startY = Math.max(0, dragCloseY || 0);
          sheet.style.transition = "none";
          sheet.style.transform = `translateY(${startY}px)`;

          overlay.style.transition = "opacity 0.22s ease";
          requestAnimationFrame(() => {
            sheet.classList.add("closing-down");
            overlay.style.opacity = "0";
          });

          window.setTimeout(() => {
            sheet.classList.remove("closing-down");
            sheet.style.transition = "";
            overlay.style.transition = "";
            closeSheet();
            isAnimatingGesture = false;
          }, 220);
        }

