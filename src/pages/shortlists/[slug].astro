sheetImage?.addEventListener(
  "touchstart",
  (event) => {
    event.stopPropagation();
    photoTouchStartX = event.changedTouches[0].screenX;
  },
  { passive: true }
);

sheetImage?.addEventListener(
  "touchmove",
  (event) => {
    event.stopPropagation();
  },
  { passive: true }
);

sheetImage?.addEventListener(
  "touchend",
  (event) => {
    event.stopPropagation();

    photoTouchEndX = event.changedTouches[0].screenX;

    const swipeDistance = photoTouchEndX - photoTouchStartX;

    if (Math.abs(swipeDistance) < 50) return;

    if (swipeDistance < 0) {
      showNextPhoto();
    } else {
      showPrevPhoto();
    }
  },
  { passive: true }
);


