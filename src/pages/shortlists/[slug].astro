function sortCardsByReview() {
  if (!shortlistGrid) return;

  const cards = getCards();

  cards
    .sort((a, b) => {
   const score = (card) => {
  if (card.dataset.isNew === "true") return 0;
  if (card.dataset.isFavourite === "true") return 1;
  if (card.dataset.decision === "maybe") return 2;
  if (card.dataset.decision === "pass") return 4;

  return 3;
};

      const aScore = score(a);
      const bScore = score(b);

      if (aScore !== bScore) return aScore - bScore;

      const aOrder = Number(a.dataset.originalOrder || "999999");
      const bOrder = Number(b.dataset.originalOrder || "999999");

      return aOrder - bOrder;
    })
    .forEach((card, index) => {
      shortlistGrid.appendChild(card);

      const indexEl = card.querySelector(".card__index");
      if (indexEl) {
        indexEl.textContent = `No. ${String(index + 1).padStart(2, "0")}`;
      }

      card.dataset.featured =
        index === 0 && card.dataset.isFavourite === "true" ? "true" : "false";
    });
}
