    function buildIntelligenceLabel(index, card) {
  const cards = getCards();

  const toNumber = (value) =>
    parseInt(String(value || "").replace(/[^0-9]/g, ""), 10) || 0;

  const price = toNumber(card.dataset.price);
  const beds = toNumber(card.dataset.beds);
  const baths = toNumber(card.dataset.baths);
  const sqft = toNumber(card.dataset.sqft);
  const type = String(card.dataset.type || "").toLowerCase();
  const desc = String(card.dataset.description || "").toLowerCase();
  const address = String(card.dataset.address || "").toLowerCase();
  const text = `${address} ${desc}`;

  const similar = cards.filter((c) => {
    const cPrice = toNumber(c.dataset.price);
    const cType = String(c.dataset.type || "").toLowerCase();

    if (!price || !cPrice || !type || !cType) return false;

    return (
      cType === type &&
      Math.abs(cPrice - price) <= price * 0.15
    );
  });

  const insights = [];

  if (index === 0) {
    insights.push("Best overall match in this group");
  }

  

  if (similar.length >= 3) {
    const prices = similar
      .map((c) => toNumber(c.dataset.price))
      .filter(Boolean)
      .sort((a, b) => a - b);

    const medianPrice = prices[Math.floor(prices.length / 2)];

    if (price && medianPrice && price < medianPrice * 0.95) {
      insights.push("Priced below most similar homes");
    }

    const avgBeds =
      similar.reduce((sum, c) => sum + toNumber(c.dataset.beds), 0) /
      similar.length;

    if (beds && beds > avgBeds + 0.5) {
      insights.push("More bedrooms than typical in this group");
    }

    const avgBaths =
      similar.reduce((sum, c) => sum + toNumber(c.dataset.baths), 0) /
      similar.length;

    if (baths && baths > avgBaths + 0.5) {
      insights.push("More bathrooms than most comparable homes");
    }

    const sqftValues = similar
      .map((c) => toNumber(c.dataset.sqft))
      .filter(Boolean);

    const largestSqft = sqftValues.length ? Math.max(...sqftValues) : 0;

    if (sqft && largestSqft && sqft === largestSqft) {
      insights.push("Largest home in this shortlist");
    }
  }

  const hasView = /\b(ocean view|mountain view|lake view|river view|city view|water view|panoramic view)\b/i.test(text);
  const hasGarage = /\b(garage|double garage|attached garage)\b/i.test(text);
  const hasYard = /\b(yard|backyard|garden|fully fenced|fenced)\b/i.test(text);

  const quiet = /\b(cul[- ]de[- ]sac|dead end|quiet street)\b/i.test(text);

  if (hasView) insights.push("View is a standout feature");
  if (quiet) insights.push("Quiet street setting");

  if (hasGarage) insights.push("Garage adds everyday function");
  if (hasYard) insights.push("Outdoor space is a plus");

  if (price && price < 600000) {
    insights.push("Entry-level pricing usually draws attention");
  } else if (price >= 600000 && price <= 900000) {
    insights.push("Popular mid-market price range");
  }

  if (beds && baths) {
    insights.push(`${beds} bed / ${baths} bath option`);
  }

return insights[0] || "Solid fundamentals compared with the rest";
}
