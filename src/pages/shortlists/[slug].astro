  async function saveSelectedResourceVendors() {
    if (!saveResourceVendorsBtn) return;
    const selectedIds = Array.from(document.querySelectorAll("#resource-vendor-list input[type='checkbox']:checked")).map((input) => input.value);
    const originalText = saveResourceVendorsBtn.textContent || "Save resources";
    saveResourceVendorsBtn.disabled = true;
    saveResourceVendorsBtn.textContent = "Saving...";
    try {
      const res = await fetch("/api/buyer-resources/select", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ shortlistSlug: pageSlug, vendorIds: selectedIds })
      });
      const data = await res.json();
      if (!res.ok || !data?.ok) throw new Error(data?.error || "Failed to save resources.");
      if (showResourcesToggle) showResourcesToggle.checked = true;
      await fetch("/api/shortlists/update-resource-visibility", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ slug: pageSlug, showResources: true })
      });
      saveResourceVendorsBtn.textContent = "Saved ✓";
      setTimeout(() => { window.location.reload(); }, 500);
    } catch (err) {
      alert(err instanceof Error ? err.message : "Failed to save resources.");
      saveResourceVendorsBtn.textContent = originalText;
    } finally {
      saveResourceVendorsBtn.disabled = false;
      setTimeout(() => { saveResourceVendorsBtn.textContent = originalText; }, 1200);
