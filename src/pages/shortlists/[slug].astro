function renderActivePhoto() {
  if (!sheetImage || !activePhotoUrls.length) return;

  trackActivePhotoMetric(activePhotoIndex);

  sheetImage.src = activePhotoUrls[activePhotoIndex];
  sheetImage.alt = activeCard?.dataset.address || "";

  preloadImage(activePhotoUrls[activePhotoIndex + 1]);
  preloadImage(activePhotoUrls[activePhotoIndex - 1]);

  if (sheetPhotoCount) {
    sheetPhotoCount.textContent = `${activePhotoIndex + 1} / ${activePhotoUrls.length} photos`;
  }

  if (photoPrevBtn) {
    photoPrevBtn.disabled = activePhotoIndex === 0;
  }

  if (photoNextBtn) {
    photoNextBtn.disabled = activePhotoIndex === activePhotoUrls.length - 1;
  }
}

function showPrevPhoto() {
  if (activePhotoIndex <= 0) return;
  activePhotoIndex -= 1;
  renderActivePhoto();
}

function showNextPhoto() {
  if (activePhotoIndex >= activePhotoUrls.length - 1) return;
  activePhotoIndex += 1;
  renderActivePhoto();
}

