.refine-prompt-card {
  padding: 24px;
  border-radius: 20px;
  background: #f5f9f1;
  border: 1px solid #cfe4bd;
  transition: transform 0.22s ease, box-shadow 0.22s ease, border-color 0.22s ease;
}

.refine-prompt-card:hover {
  transform: translateY(-2px);
  border-color: #9fcb7c;
  box-shadow: 0 18px 42px rgba(45, 80, 22, 0.14);
}

.refine-prompt-pill {
  display: inline-flex;
  align-items: center;
  padding: 6px 12px;
  border-radius: 999px;
  background: #edf3e7;
  color: #45642e;
  font-size: 0.82rem;
  font-weight: 800;
  transition: transform 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
}

.refine-prompt-card:hover .refine-prompt-pill {
  animation: refinePillPop 0.42s ease both;
}

.refine-prompt-card:hover .refine-prompt-pill:nth-child(2) { animation-delay: 0.05s; }
.refine-prompt-card:hover .refine-prompt-pill:nth-child(3) { animation-delay: 0.1s; }
.refine-prompt-card:hover .refine-prompt-pill:nth-child(4) { animation-delay: 0.15s; }

.refine-prompt-btn {
  appearance: none;
  display: block;
  width: 100%;
  min-height: 48px;
  padding: 0 20px;
  border: 0;
  border-radius: 14px;
  background: linear-gradient(135deg, #2d5016, #163f08);
  color: #fff;
  font-size: 0.9rem;
  font-weight: 800;
  cursor: pointer;
  box-shadow: 0 10px 24px rgba(45, 80, 22, 0.22);
  transition: transform 0.18s ease, box-shadow 0.18s ease, filter 0.18s ease;
}

.refine-prompt-card:hover .refine-prompt-btn {
  transform: translateY(-1px);
  box-shadow: 0 16px 32px rgba(45, 80, 22, 0.3);
  filter: brightness(1.04);
}

@keyframes refinePillPop {
  0% { transform: translateY(0) scale(1); }
  45% { transform: translateY(-4px) scale(1.06); }
  100% { transform: translateY(0) scale(1); }
