<script is:inline>
function initShortlistPage() {
  const body = document.body;
  const isAgentView = body?.dataset.agentView === "true";
  const pageSlug = body?.dataset.shortlistSlug || "";

  // ── Track shortlist view ──────────────────────────────────────────
  if (!isAgentView && pageSlug) {
    fetch("/api/shortlists/track-view", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ slug: pageSlug })
    }).catch(() => {});
  }

  // ── Viewed listings (for NEW badges) ─────────────────────────────
  const viewedKey = `shortlist_viewed_${pageSlug}`;

  function getViewedListings() {
    try { return new Set(JSON.parse(localStorage.getItem(viewedKey) || "[]")); }
    catch { return new Set(); }
  }

  function markListingViewed(card) {
    if (!card) return;
    const id = card.dataset.itemId || card.dataset.cardId || "";
    if (!id) return;
    const viewed = getViewedListings();
    viewed.add(id);
    localStorage.setItem(viewedKey, JSON.stringify([...viewed]));
    card.dataset.viewed = "true";
    card.dataset.isNew = "false";
    card.querySelector(".card__new-badge")?.remove();
  }

  // Mark already-viewed cards on load
  const viewedListings = getViewedListings();
  document.querySelectorAll(".original-card").forEach((card, index) => {
    card.dataset.originalOrder = String(index);
    const id = card.dataset.itemId || card.dataset.cardId || "";
    if (id && viewedListings.has(id)) {
      card.dataset.viewed = "true";
      card.dataset.isNew = "false";
      card.querySelector(".card__new-badge")?.remove();
    }
  });

// Hook into IntentModalController's openSheet to track views
  function wrapOpenSheet() {
    const _orig = window.openSheet;
    window.openSheet = function(card) {
      markListingViewed(card);
      if (typeof _orig === "function") _orig(card);
    };
  }

  if (typeof window.openSheet === "function") {
    wrapOpenSheet();
  } else {
    // IntentModalController hasn't run yet — wait for it
    const _poll = setInterval(() => {
      if (typeof window.openSheet === "function") {
        clearInterval(_poll);
        wrapOpenSheet();
      }
    }, 20);
  }

  // ── Card counts ───────────────────────────────────────────────────
  const homesCountNum = document.getElementById("homes-count-num");
  const sectionMetaCount = document.getElementById("section-meta-count");
  const shortlistGrid = document.getElementById("shortlist-grid");
  const emptyState = document.getElementById("empty-state");

  function getCards() {
    return Array.from(document.querySelectorAll(".original-card"));
  }

  function updateCounts() {
    const count = getCards().length;
    if (homesCountNum) homesCountNum.textContent = String(count).padStart(2, "0");
    if (sectionMetaCount) sectionMetaCount.textContent = `${count} ${count === 1 ? "home" : "homes"} chosen for review`;
    if (shortlistGrid && emptyState) {
      shortlistGrid.style.display = count === 0 ? "none" : "";
      emptyState.style.display = count === 0 ? "block" : "none";
    }
  }

  updateCounts();

  // ── Edit mode ─────────────────────────────────────────────────────
  let editMode = false;
  const editToggleBtn = document.getElementById("edit-shortlist-toggle");
  const editBanner = document.getElementById("edit-banner");

  function syncEditModeUI() {
    body.classList.toggle("edit-mode", editMode);
    if (editToggleBtn) {
      editToggleBtn.textContent = editMode ? "Done editing" : "Edit shortlist";
      editToggleBtn.setAttribute("data-editing", editMode ? "true" : "false");
    }
    if (editBanner) editBanner.classList.toggle("show", editMode);
  }

  editToggleBtn?.addEventListener("click", () => {
    editMode = !editMode;
    syncEditModeUI();
  });

  syncEditModeUI();

  // ── Remove shortlist item ─────────────────────────────────────────
  async function removeShortlistItem(card) {
    if (!isAgentView || !card) return;
    const itemId = String(card.dataset.itemId || "").trim();
    if (!itemId) { alert("Missing shortlist item id."); return; }
    if (!window.confirm("Remove this home from the shortlist?")) return;
    card.classList.add("is-removing");
    try {
      const res = await fetch("/api/shortlists/remove-item", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ id: itemId })
      });
      const json = await res.json().catch(() => null);
      if (!res.ok || !json?.ok) throw new Error(json?.error || "Could not remove listing");
      card.remove();
      updateCounts();
    } catch (err) {
      card.classList.remove("is-removing");
      alert(err instanceof Error ? err.message : "Could not remove listing");
    }
  }

  document.querySelectorAll("[data-remove-item-id]").forEach((btn) => {
    btn.addEventListener("click", async (e) => {
      e.preventDefault();
      e.stopPropagation();
      await removeShortlistItem(btn.closest(".original-card"));
    });
  });

  // ── SMS + note saving ─────────────────────────────────────────────
  const navSendTextBtn = document.getElementById("nav-send-text-btn");
  const navCopyLinkBtn = document.getElementById("nav-copy-link-btn");
  const saveNoteBtn = document.getElementById("save-note-btn");
  const noteInput = document.getElementById("shortlist-note-input");
  const smsMessageInput = document.getElementById("sms-message-input");
  const saveSmsMessageBtn = document.getElementById("save-sms-message-btn");
  const mastheadMessage = document.getElementById("masthead-message");
  const sendTextButtons = Array.from(document.querySelectorAll("[data-send-text]"));
  const saveSmsImageBtn = document.getElementById("save-sms-image-btn");
  const smsImageInput = document.getElementById("sms-image-url-input");
  const presetImageButtons = Array.from(document.querySelectorAll("[data-preset-image-url]"));

  async function saveSmsImageUrl(url) {
    const cleanUrl = String(url || "").trim();
    const res = await fetch("/api/shortlists/update-sms-image", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ slug: pageSlug, smsImageUrl: cleanUrl })
    });
    const data = await res.json();
    if (!res.ok || !data?.ok) throw new Error(data?.error || "Failed to save image.");
    sendTextButtons.forEach((btn) => btn.setAttribute("data-sms-image-url", cleanUrl));
    return cleanUrl;
  }

  async function sendShortlistText(sendBtn) {
    const slug = sendBtn?.getAttribute("data-shortlist-slug") || "";
    const clientName = sendBtn?.getAttribute("data-client-name") || "";
    const phone = sendBtn?.getAttribute("data-client-phone") || "";
    const note = sendBtn?.getAttribute("data-note") || "";
    const smsImageUrl = sendBtn?.getAttribute("data-sms-image-url") || "";
    if (!slug) { alert("Missing shortlist slug."); return; }
    if (!phone) { alert("No client phone number found."); return; }
    const originalText = sendBtn.textContent || "Send text";
    sendBtn.disabled = true;
    sendBtn.textContent = "Sending...";
    try {
      const res = await fetch("/api/shortlists/send-text", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ slug, clientName, phone, note, agentName: "Chris Crump", smsImageUrl })
      });
      const data = await res.json();
      if (!res.ok || !data?.ok) throw new Error(data?.error || "Failed to send text.");
      sendBtn.textContent = "Text sent ✓";
      setTimeout(() => { sendBtn.textContent = originalText; }, 1800);
    } catch (err) {
      alert(err instanceof Error ? err.message : "Failed to send text.");
      sendBtn.textContent = originalText;
    } finally {
      sendBtn.disabled = false;
    }
  }

  async function copyShortlistLink(copyBtn) {
    const path = copyBtn?.getAttribute("data-copy-link");
    if (!path) return;
    const url = `${window.location.origin}${path}`;
    try {
      await navigator.clipboard.writeText(url);
      const orig = copyBtn.textContent || "Copy link";
      copyBtn.textContent = "Copied!";
      setTimeout(() => { copyBtn.textContent = orig; }, 1400);
    } catch { alert(url); }
  }

  navSendTextBtn?.addEventListener("click", async (e) => { e.preventDefault(); await sendShortlistText(navSendTextBtn); });
  navCopyLinkBtn?.addEventListener("click", async (e) => { e.preventDefault(); await copyShortlistLink(navCopyLinkBtn); });

