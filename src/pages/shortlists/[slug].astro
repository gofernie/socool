    />

 

<style is:global>
  :root {
    --bg: #f7f6f3;
    --bg-card: #ffffff;
    --bg-overlay: #f0ede8;
    --bg-dark: #181614;
    --bg-dark-2: #211f1c;

    --text-primary: #18160f;
    --text-secondary: #6b6760;
    --text-muted: #a09c96;
    --text-on-dark: #f0ede8;
    --text-dim: rgba(240, 237, 232, 0.45);

    --accent: #2d5016;
    --accent-mid: #3d6b20;
    --accent-light: #eef4e9;
    --accent-border: #b5cfa0;

    --border: #e4e0d9;
