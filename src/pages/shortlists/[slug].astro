  const hasView = /ocean view|water view|harbour view|harbor view|sea view|lake view|mountain view|city view|panoramic view/.test(desc);
  const hasSuite = isHouse && /suite|income|mortgage helper|secondary suite|legal suite/.test(desc);
  const isUpdated = /renovated|updated|modernized|new kitchen|new roof|contemporary/.test(desc);
  const hasParking = /garage|rv parking|double garage|underground parking|secure parking/.test(desc);
  const amenities = /pool|gym|fitness|clubhouse|elevator|storage locker|amenities/.test(desc);
  const outdoor = /patio|balcony|deck|yard|garden|outdoor space/.test(desc);

  if (isCondo) {
    if (sqft >= 900 && outdoor) return "Feels bigger than most condos";
    if (isUpdated) {
      return pickNote(card.dataset.cardId || card.dataset.address, [
        "Move-in ready condo option",
        "Clean, easy condo choice",
        "A simpler option to step into",
        "Low-effort condo living"
      ]);
    }
    if (sqft >= 900) return "More room than the typical condo";
    if (amenities) return "Easy living with building perks";
    if (hasParking) return "Convenient everyday setup";
    return "Simple, low-maintenance living";
  }

  if (isTownhouse) {
    if (beds >= 3 && outdoor) return "Great layout for everyday living";
    if (hasParking) return "Practical townhome setup";
    if (isUpdated) return "Updated townhome option";
    return "Balanced space with low upkeep";
