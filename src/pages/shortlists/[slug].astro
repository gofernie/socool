---
import { supabase } from "../../lib/supabase";
import {
  fetchRepliersListings,
  getListingAddress,
  getListingBaths,
  getListingBeds,
  getListingDescription,
  getListingId,
  getListingImage,
  getListingPrice,
  getListingSqft,
  getListingType,
  getListingYear
} from "../../lib/repliers"; 

export const prerender = false;

const { slug } = Astro.params;
const isAgentView = Astro.url.searchParams.get("agent") === "1";
const clientLink = `/shortlists/${slug}`;
const sendId = Astro.url.searchParams.get("s");
function normalizeImageUrl(url: any) {
  const value = String(url || "").trim();

  if (!value) return "";

  if (value.startsWith("http://") || value.startsWith("https://")) {
    return value;
  }

  if (value.startsWith("/")) {
    return `https://cdn.repliers.io${value}`;
  }

  return value;
}
function getListingLat(listing: any) {
  return (
    listing?.lat ||
    listing?.latitude ||
    listing?.map?.lat ||
    listing?.address?.lat ||
    listing?.raw?.lat ||
    listing?.raw?.latitude ||
    listing?.raw?.address?.lat ||
    listing?.raw?.map?.lat ||
    ""
  );
}

function getListingLng(listing: any) {
  return (
    listing?.lng ||
    listing?.lon ||
    listing?.longitude ||
    listing?.map?.lng ||
    listing?.address?.lng ||
    listing?.raw?.lng ||
    listing?.raw?.lon ||
    listing?.raw?.longitude ||
    listing?.raw?.address?.lng ||
    listing?.raw?.map?.lng ||
    ""
  );
}
function normalizeLiveListing(live: any, saved: any) {
  return {
    ...saved,
    live_listing: live || null,
    repliers_listing_id:
      getListingId(live) ||
      saved?.repliers_listing_id ||
      saved?.listing_id ||
      saved?.id ||
      "",
price_text: live ? getListingPrice(live) : saved?.price_text || "Price unavailable",
   address: live ? getListingAddress(live) : saved?.address || "Address unavailable",
beds: live ? getListingBeds(live) : saved?.beds || "-",
baths: live ? getListingBaths(live) : saved?.baths || "-",
sqft: live ? getListingSqft(live) : saved?.sqft || "",
property_type: live ? getListingType(live) : saved?.property_type || "Home",
year_built: live ? getListingYear(live) : saved?.year_built || "",
lat: live ? getListingLat(live) : getListingLat(saved),
lng: live ? getListingLng(live) : getListingLng(saved),
   image_url:
  live
    ? normalizeImageUrl(getListingImage(live))
    : normalizeImageUrl(saved?.image_url) ||
      "https://placehold.co/800x600?text=Listing",

description:
  live
    ? getListingDescription(live)
    : saved?.description || "A quick preview of this property."
  };
}
const { data: shortlist } = await supabase
  .from("shortlist_sends")
.select(`
    *,
    agent:agent_id (
      id,
      name
    ),
    client:client_id (
      id,
      name,
      phone
    )
  `)
  .eq("shortlist_slug", slug)
  .single();

if (sendId) {
  await supabase.rpc("track_shortlist_send_open", {
    send_id: sendId
  });
}

let items: any[] = [];
let resources: any[] = [];

if (shortlist?.id) {
  const res = await supabase
    .from("shortlist_items")
    .select("*")
    .eq("shortlist_send_id", shortlist.id)
    .order("sort_order", { ascending: true });

  items = res.data || [];

const selectedRes = await supabase
  .from("shortlist_resource_vendors")
  .select("vendor_id, sort_order")
  .eq("shortlist_slug", slug)
  .eq("is_selected", true)
  .order("sort_order", { ascending: true });

const vendorIds = (selectedRes.data || [])
  .map((row: any) => row.vendor_id)
  .filter(Boolean);

if (vendorIds.length) {
  const vendorRes = await supabase
    .from("buyer_resource_vendors")
    .select("id, type, name, email, phone, website, note, is_active")
    .in("id", vendorIds)
    .eq("is_active", true);

  const vendorMap = new Map(
    (vendorRes.data || []).map((vendor: any) => [vendor.id, vendor])
  );

  resources = vendorIds
    .map((id: string) => vendorMap.get(id))
    .filter(Boolean);
}
}

let liveListingsById = new Map();

const savedListingIds = items
  .map((item: any) => item.repliers_listing_id || item.listing_id)
  .filter(Boolean)
  .map((id: any) => String(id).trim());

if (false && savedListingIds.length) {
  try {
    const liveData = await fetchRepliersListings({
      limit: 100
    });

    const liveListings = liveData?.listings || [];

    liveListingsById = new Map(
      liveListings
        .map((listing: any) => {
          const id = String(getListingId(listing) || "").trim();
          return [id, listing];
        })
        .filter(([id]) => Boolean(id))
    );
  } catch (err) {
    console.error("Failed to refresh shortlist listings from Repliers:", err);
  }
}
function getListingSortScore(listing: any) {
  const toNumber = (value: any) =>
    parseInt(String(value || "").replace(/[^0-9]/g, ""), 10) || 0;

  const price = toNumber(listing.price_text);
  const sqft = toNumber(listing.sqft);
  const beds = toNumber(listing.beds);
  const baths = toNumber(listing.baths);
  const year = toNumber(listing.year_built);
  const desc = String(listing.description || "").toLowerCase();

  let score = 0;
  if (listing.is_favourite) score += 100;
if (listing.decision === "maybe") score += 20;
if (listing.decision === "pass") score -= 500;

  if (price && sqft) score += Math.round((price / sqft) * -1);
  if (sqft) score += sqft * 0.02;
  if (beds) score += beds * 12;
  if (baths) score += baths * 6;
  if (year >= 2015) score += 25;

  if (/\b(ocean view|mountain view|lake view|river view|city view|water view|panoramic view)\b/i.test(desc)) score += 35;
  if (/\b(cul[- ]de[- ]sac|dead end|quiet street)\b/i.test(desc)) score += 18;
  if (/\b(move[- ]in ready|turnkey|updated|renovated|modern)\b/i.test(desc)) score += 16;
  if (/\b(garage|double garage|attached garage)\b/i.test(desc)) score += 10;
  if (/\b(yard|backyard|garden|fully fenced|fenced)\b/i.test(desc)) score += 8;

  return score;
}
const listings = [...items]
  .map((item: any) => {
    const id = String(item.repliers_listing_id || item.listing_id || "").trim();
    const live = liveListingsById.get(id);
    return normalizeLiveListing(live, item);
  })
.sort((a, b) => {
 const rank = (item) => {
  const isNew = !item?.is_favourite && !item?.decision;

  if (isNew) return 0;
  if (item?.is_favourite) return 1;
  if (item?.decision === "maybe") return 2;
  if (item?.decision === "pass") return 4;

  return 3;
};

  const aRank = rank(a);
  const bRank = rank(b);

  if (aRank !== bRank) return aRank - bRank;

  const aOrder = Number(a?.sort_order ?? 999999);
  const bOrder = Number(b?.sort_order ?? 999999);

  return aOrder - bOrder;
});

const clientDisplayName =
  shortlist?.client_name ||
  shortlist?.client?.name ||
  "";

const agentName =
  shortlist?.agent_name ||
  shortlist?.agent?.name ||
  "Chris Crump";

const pageTitle = shortlist?.client_name
  ? `${shortlist.client_name}'s shortlist`
  : "Your Shortlist";

const createdLabel = shortlist?.created_at
  ? new Date(shortlist.created_at).toLocaleDateString("en-CA", {
      year: "numeric",
      month: "short",
      day: "numeric"
    })
  : "";

const shortlistStatus = shortlist?.sent_at ? "Sent" : "Draft";

const defaultIntroMessage =
  "I pulled these homes together based on what you're looking for. Start with the first one - it’s the strongest match, then work your way through the rest.";

const heroMessage = shortlist?.note?.trim() || defaultIntroMessage;
const smsImageUrl = shortlist?.sms_image_url || "";
const presetSmsImages = [
  {
    label: "New homes added",
    url: "https://imagedelivery.net/Az3x6Ld2gouPPtikaqezkQ/aec87d01-e6d7-410d-f583-0924a6ced300/hero"
  },
  {
    label: "Mortgage info added",
    url: "https://imagedelivery.net/Az3x6Ld2gouPPtikaqezkQ/e436932a-2b37-4169-bd94-1245ca986300/hero"
  },
  {
    label: "Home inspector info",
    url: "https://imagedelivery.net/Az3x6Ld2gouPPtikaqezkQ/bd8a291a-1db0-4346-e807-eec80c70a400/hero"
  },
  {
    label: "Market update",
    url: "https://imagedelivery.net/Az3x6Ld2gouPPtikaqezkQ/27294214-7d6a-4fdf-64a4-18c4c7adba00/hero"
  }
];

const firstListingImage =
  listings?.[0]?.image_url ||
  listings?.[0]?.images?.[0]?.url ||
  "";

const previewImageUrl =
  smsImageUrl ||
  firstListingImage ||
  "https://placehold.co/1200x630?text=Shortlist";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
   <title>{pageTitle}</title>
<meta name="viewport" content="width=device-width, initial-scale=1" />

<meta property="og:title" content={pageTitle} />
<meta property="og:description" content="" />
<meta property="og:image" content={previewImageUrl} />
<meta property="og:image:secure_url" content={previewImageUrl} />
<meta property="og:type" content="website" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content="" />
<meta name="twitter:image" content={previewImageUrl} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&display=swap"
      rel="stylesheet"
    />

    <link
  rel="stylesheet"
  href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
/>
<style>
  :root {
    --bg: #f7f6f3;
    --bg-card: #ffffff;
    --bg-overlay: #f0ede8;
    --bg-dark: #181614;
    --bg-dark-2: #211f1c;

    --text-primary: #18160f;
    --text-secondary: #6b6760;
    --text-muted: #a09c96;
    --text-on-dark: #f0ede8;
    --text-dim: rgba(240, 237, 232, 0.45);

    --accent: #2d5016;
    --accent-mid: #3d6b20;
    --accent-light: #eef4e9;
    --accent-border: #b5cfa0;

    --border: #e4e0d9;
    --border-strong: #ccc8c0;

    --gold: #b07d2a;
    --gold-bg: #fdf6e8;
    --gold-border: #e8cc8a;
    --gold-soft: #f6ebcf;
    --pass: #8b1a1a;
    --pass-bg: #fdf0f0;
    --pass-border: #e8a0a0;
    --danger: #9f2f2f;
    --danger-dark: #872828;

    --shadow-soft: 0 16px 50px rgba(17, 14, 9, 0.12);
    --shadow-card: 0 8px 30px rgba(17, 14, 9, 0.07);

    --f-display: "DM Serif Display", Georgia, serif;
    --f-body: "DM Sans", system-ui, sans-serif;

    --r-sm: 4px;
    --r: 8px;
    --r-lg: 12px;
    --r-xl: 16px;
    --r-2xl: 22px;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scrollbar-gutter: stable;
    scroll-behavior: smooth;
  }

  body {
    font-family: var(--f-body);
    background: var(--bg);
    color: var(--text-primary);
    font-size: 15px;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  .agent-bar {
    position: sticky;
    top: 0;
    z-index: 900;
    background: var(--bg-dark);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    padding: 0 32px;
  }

  .agent-bar__inner {
    max-width: 1280px;
    margin: 0 auto;
    min-height: 52px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    padding: 10px 0;
  }

  .agent-bar__left {
    display: flex;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
  }

  .agent-bar__badge {
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.3);
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 3px 8px;
    border-radius: var(--r-sm);
  }

  .agent-bar__name {
    font-size: 0.82rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.75);
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .agent-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #6bc96b;
    flex-shrink: 0;
  }

  .agent-bar__sep {
    color: rgba(255, 255, 255, 0.15);
    font-size: 0.75rem;
  }

  .agent-bar__date {
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.3);
  }

  .agent-bar__actions {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .ab-btn {
    height: 30px;
    padding: 0 14px;
    border-radius: var(--r-sm);
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: transparent;
    color: rgba(255, 255, 255, 0.6);
    font: inherit;
    font-size: 0.76rem;
    font-weight: 500;
    cursor: pointer;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
  }

  .ab-btn:hover {
    background: rgba(255, 255, 255, 0.07);
    color: rgba(255, 255, 255, 0.9);
    border-color: rgba(255, 255, 255, 0.18);
  }

  .ab-btn--primary {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
    font-weight: 600;
  }

  .ab-btn--primary:hover {
    background: var(--accent-mid);
    border-color: var(--accent-mid);
    color: #fff;
  }

  .ab-btn--danger {
    border-color: rgba(255, 255, 255, 0.16);
  }

  .ab-btn--danger[data-editing="true"] {
    background: rgba(255, 255, 255, 0.09);
    color: #fff;
    border-color: rgba(255, 255, 255, 0.24);
  }

  .masthead {
    background: var(--bg-dark);
    color: var(--text-on-dark);
    padding: 0 32px;
  }

  .masthead__inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 72px 0 64px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: end;
  }

  .masthead__eyebrow {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent-border);
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .masthead__eyebrow::before {
    content: "";
    display: block;
    width: 18px;
    height: 1px;
    background: var(--accent-border);
  }

  .masthead__heading {
    font-family: var(--f-display);
    font-size: clamp(3rem, 5.5vw, 5.5rem);
    font-weight: 400;
    line-height: 1;
    letter-spacing: -0.02em;
    color: #fff;
    margin-bottom: 24px;
  }

  .masthead__heading em {
    font-style: italic;
    color: var(--text-dim);
  }

  .masthead__client {
    margin: 0 0 14px;
    font-size: 1.15rem;
    color: rgba(255, 255, 255, 0.55);
    letter-spacing: 0.01em;
  }

  .masthead__client strong {
    color: #fff;
    font-weight: 500;
  }

  .masthead__message {
    font-size: 0.9rem;
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.38);
    max-width: 70ch;
    margin-top: 16px;
  }

  .masthead__right {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    align-items: flex-end;
    padding-bottom: 8px;
    gap: 24px;
  }

  .masthead__stat-block {
    text-align: right;
  }

  .masthead__count-num {
    font-family: var(--f-display);
    font-size: clamp(5rem, 9vw, 8.5rem);
    line-height: 1;
    letter-spacing: -0.05em;
    color: rgba(255, 255, 255, 0.12);
    display: block;
  }

  .masthead__count-label {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.2);
    margin-top: 4px;
    display: block;
  }

  .masthead__hints {
    display: flex;
    flex-direction: column;
    gap: 8px;
    align-items: flex-end;
  }

  .masthead__hint {
    font-size: 0.72rem;
    color: rgba(255, 255, 255, 0.25);
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .masthead__hint::before {
    content: "";
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.15);
    flex-shrink: 0;
  }

  .body-wrap {
    max-width: 1280px;
    margin: 0 auto;
    padding: 48px 32px 100px;
  }

  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 24px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--border);
    flex-wrap: wrap;
  }

  .section-title {
    font-family: var(--f-display);
    font-size: 1.25rem;
    font-weight: 400;
    font-style: italic;
    color: var(--text-primary);
  }

  .section-meta {
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .edit-banner {
    display: none;
    margin: 0 0 20px;
    padding: 14px 16px;
    border-radius: var(--r);
    border: 1px solid var(--border);
    background: #fff;
    color: var(--text-secondary);
    font-size: 0.84rem;
  }

  .edit-banner.show {
    display: block;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 16px;
  }

 .card {
  background: var(--bg-card);
  display: flex;
  flex-direction: column;
  cursor: default;
  transition:
    background 0.2s,
    opacity 0.2s ease,
    filter 0.2s ease,
    border-color 0.2s ease,
    box-shadow 0.2s ease,
    transform 0.2s ease;
  position: relative;
  border: 2px solid rgba(122, 111, 102, 0.16);
  border-radius: 6px;
  overflow: hidden;
}

  .card[data-decision="pass"] {
    opacity: 0.2;
    filter: saturate(0.72);
  }

  .card[data-decision="pass"]:hover {
    opacity: 1;
  }

  .card:hover {
    border-color: var(--border-strong);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.07);
    transform: translateY(-2px);
  }

  .card__remove {
    position: absolute;
    top: 10px;
    left: 10px;
    z-index: 4;
    display: none;
    appearance: none;
    width: 34px;
    height: 34px;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.85);
    background: rgba(255, 255, 255, 0.96);
    color: var(--danger);
    cursor: pointer;
    font: inherit;
    font-size: 1rem;
    line-height: 1;
    align-items: center;
    justify-content: center;
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.14);
    transition: transform 0.14s ease, background 0.14s ease, color 0.14s ease;
  }

  .card__remove:hover {
    transform: scale(1.04);
    background: var(--danger);
    color: #fff;
  }

  body.edit-mode .card__remove[data-agent-only="true"] {
    display: inline-flex;
  }

  .card.is-removing {
    opacity: 0.35;
    pointer-events: none;
  }

  .card__image-wrap {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    position: relative;
    background: var(--bg-overlay);
    cursor: pointer;
  }

  .card__image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .card:hover .card__image-wrap img {
    transform: scale(1.04);
  }

  .card__image-wrap::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.32) 0%, transparent 52%);
    pointer-events: none;
  }

  .card__index {
    position: absolute;
    bottom: 10px;
    left: 12px;
    font-family: var(--f-body);
    font-size: 0.65rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.6);
    z-index: 3;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

 .card__preview-image-btn {
  position: absolute;
  right: 10px;
  bottom: 10px;
  z-index: 4;
  appearance: none;
  border: 1px solid rgba(255,255,255,0.75);
  background: rgba(255,255,255,0.94);
  color: var(--text-primary);
  border-radius: 999px;
  padding: 7px 10px;
  font: inherit;
  font-size: 0.68rem;
  font-weight: 700;
  cursor: pointer;
  box-shadow: 0 8px 22px rgba(0,0,0,0.16);
  display: none;
}

body.edit-mode .card__preview-image-btn {
  display: inline-flex;
}

.card__preview-image-btn:hover {
  background: var(--text-primary);
  color: #fff;
}

  .card__love-badge {
    position: absolute;
    top: 12px;
    left: 12px;
    z-index: 4;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 12px;
