  const originalText = saveSmsMessageBtn.textContent || "Save text message";
  const smsMessage = smsMessageInput?.value?.trim() || "";

  saveSmsMessageBtn.disabled = true;
  saveSmsMessageBtn.textContent = "Saving...";

  try {
    const res = await fetch("/api/shortlists/update-sms-message", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        slug: pageSlug,
        smsMessage
      })
    });

    const data = await res.json();

    if (!res.ok || !data?.ok) {
      throw new Error(data?.error || "Failed to save SMS message.");
    }

    saveSmsMessageBtn.textContent = "Saved ✓";

   setTimeout(() => {
  saveSmsMessageBtn.textContent = originalText;
}, 1400);
  } catch (err) {
    alert(err instanceof Error ? err.message : "Failed to save SMS message.");
    saveSmsMessageBtn.textContent = originalText;
  } finally {
    saveSmsMessageBtn.disabled = false;
  }
});
        saveNoteBtn?.addEventListener("click", async (e) => {
          e.preventDefault();

  const note = String(noteInput?.value || "").trim();
  const originalText = saveNoteBtn.textContent || "Save message";

  saveNoteBtn.disabled = true;
  saveNoteBtn.textContent = "Saving...";

  try {
    const res = await fetch("/api/shortlists/update-note", {
      method: "POST",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify({
        slug: pageSlug,
        note
      })
    });

    const data = await res.json();

    if (!res.ok || !data?.ok) {
      throw new Error(data?.error || "Failed to save message.");
    }

    if (mastheadMessage) mastheadMessage.textContent = note;

    sendTextButtons.forEach((btn) => {
      btn.setAttribute("data-note", note);
    });

    saveNoteBtn.textContent = "Saved ✓";

    setTimeout(() => {
      saveNoteBtn.textContent = originalText;
    }, 1400);
  } catch (err) {
    alert(err instanceof Error ? err.message : "Failed to save message.");
    saveNoteBtn.textContent = originalText;
  } finally {
    saveNoteBtn.disabled = false;
  }
});

        sendTextButtons.forEach((btn) => {
          if (btn === navSendTextBtn) return;
          btn.addEventListener("click", async (e) => {
            e.preventDefault();
            await sendShortlistText(btn);
          });
        });

        sheetCloseBtn?.addEventListener("click", (e) => {
          e.preventDefault();
          closeSheet();
        });

        overlay.addEventListener("click", (e) => {
          e.preventDefault();
          closeSheet();
        });

        document.addEventListener("keydown", (e) => {
          if (!sheet.classList.contains("open")) return;

          if (e.key === "Escape") closeSheet();
          if (e.key === "ArrowRight" && !sheetNextBtn?.disabled) goToNextCard();
        });

        sheet.addEventListener(
          "touchstart",
          (e) => {
            if (!sheet.classList.contains("open")) return;
            if (!isMobileSheet()) return;
            if (isAnimatingGesture) return;

            const target = e.target;
            if (!(target instanceof HTMLElement)) return;

            touchStartedOnInteractive = Boolean(
              target.closest("button, a, input, textarea, select, [data-tag], [data-decision]")
            );

            if (touchStartedOnInteractive) return;

            const touch = e.touches[0];
            touchStartX = touch.clientX;
            touchStartY = touch.clientY;
            touchCurrentX = touch.clientX;
            touchCurrentY = touch.clientY;
            isDraggingSheet = false;
            dragMode = "";
            dragCloseY = 0;
          },
          { passive: true }
        );

        sheet.addEventListener(
          "touchmove",
          (e) => {
            if (!sheet.classList.contains("open")) return;
            if (!isMobileSheet()) return;
            if (isAnimatingGesture) return;
            if (touchStartedOnInteractive) return;

            const touch = e.touches[0];
            touchCurrentX = touch.clientX;
            touchCurrentY = touch.clientY;

            const deltaX = touchCurrentX - touchStartX;
            const deltaY = touchCurrentY - touchStartY;

            if (!dragMode) {
              if (Math.abs(deltaY) > 10 && Math.abs(deltaY) > Math.abs(deltaX)) {
                if (deltaY > 0 && sheet.scrollTop <= 0) {
                  dragMode = "close";
                } else {
                  return;
                }
              } else if (Math.abs(deltaX) > 16 && Math.abs(deltaX) > Math.abs(deltaY)) {
                dragMode = "nav";
              } else {
                return;
              }
            }

            if (dragMode === "close") {
  dragMode = "";
  return;
}

            if (dragMode === "nav") {
              isDraggingSheet = true;
              sheet.classList.add("dragging");
              const limitedX = Math.max(-90, Math.min(90, deltaX));
              sheet.style.transform = `translateX(${limitedX}px)`;
              sheet.style.opacity = String(1 - Math.min(Math.abs(limitedX) / 220, 0.22));
              e.preventDefault();
            }
          },
          { passive: false }
        );

        sheet.addEventListener("touchend", () => {
          if (!sheet.classList.contains("open")) return;
          if (!isMobileSheet()) return;
          if (isAnimatingGesture) return;

          const deltaX = touchCurrentX - touchStartX;
          const deltaY = touchCurrentY - touchStartY;
          const absX = Math.abs(deltaX);
          const absY = Math.abs(deltaY);

        if (dragMode === "nav") {
            if (deltaX < -70) {
              clearInteractionState();
              animateHorizontalCardChange("next");
            } else {
              animateSheetBack("nav");
            }
          }

          if (!dragMode) {
            resetSheetTransform();
          }

          touchStartX = 0;
          touchStartY = 0;
          touchCurrentX = 0;
          touchCurrentY = 0;
          isDraggingSheet = false;
          dragMode = "";
          touchStartedOnInteractive = false;
          dragCloseY = 0;
        });

        loadResourceVendors();

saveResourceVendorsBtn?.addEventListener("click", async (e) => {
  e.preventDefault();
  await saveSelectedResourceVendors();
});

syncEditModeUI();
updateCounts();
      }

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initShortlistPage, { once: true });
      } else {
        initShortlistPage();
      }

      document.addEventListener("astro:page-load", initShortlistPage);
    </script>
  </body>
