<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content="" />
<meta name="twitter:image" content={previewImageUrl} />
    
    
    <link
      href="https://?family=DM+Serif+Display:ital@0;1&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&display=swap"
      rel="stylesheet"
    />

 

<style is:global>
  :root {
    --bg: #f7f6f3;
    --bg-card: #ffffff;
    --bg-overlay: #f0ede8;
    --bg-dark: #181614;
    --bg-dark-2: #211f1c;

    --text-primary: #18160f;
    --text-secondary: #6b6760;
    --text-muted: #a09c96;
    --text-on-dark: #f0ede8;
    --text-dim: rgba(240, 237, 232, 0.45);

    --accent: #2d5016;
    --accent-mid: #3d6b20;
    --accent-light: #eef4e9;
    --accent-border: #b5cfa0;

    --border: #e4e0d9;
    --border-strong: #ccc8c0;

    --gold: #b07d2a;
    --gold-bg: #fdf6e8;
    --gold-border: #e8cc8a;
    --gold-soft: #f6ebcf;
    --pass: #8b1a1a;
    --pass-bg: #fdf0f0;
    --pass-border: #e8a0a0;
    --danger: #9f2f2f;
    --danger-dark: #872828;

    --shadow-soft: 0 16px 50px rgba(17, 14, 9, 0.12);
    --shadow-card: 0 8px 30px rgba(17, 14, 9, 0.07);

