function pickNote(seed, options) {
  const text = String(seed || "");
  const total = text.split("").reduce((sum, char) => sum + char.charCodeAt(0), 0);
  return options[total % options.length];
}

function buildHighlightChips(card) {
  const desc = String(card.dataset.description || "").toLowerCase();
  const type = String(card.dataset.type || "").toLowerCase();
  const sqft = parseInt(String(card.dataset.sqft || "").replace(/[^0-9]/g, ""), 10) || 0;
  const beds = Number(card.dataset.beds || 0);

  const isCondo = type.includes("condo") || type.includes("apartment");
  const isTownhouse = type.includes("townhouse") || type.includes("townhome") || type.includes("row");
  const isHouse = type.includes("house") || type.includes("detached") || type.includes("single family");

  const hasView =
    /ocean view|water view|harbour view|harbor view|sea view|lake view|mountain view|city view|panoramic view/.test(desc) &&
    !/viewing|preview|virtual tour|view today|viewing appointment/.test(desc);

  const hasSuite = /suite|mortgage helper|income|secondary suite|legal suite/.test(desc);
  const isUpdated = /renovated|updated|modernized|new kitchen|new roof|contemporary/.test(desc);
  const hasParking = /garage|rv parking|double garage|underground parking|secure parking/.test(desc);
  const quiet = /cul-de-sac|quiet street|private|privacy/.test(desc);
  const amenities = /pool|gym|fitness|clubhouse|elevator|storage locker|amenities/.test(desc);
  const outdoor = /patio|balcony|deck|yard|garden|outdoor space/.test(desc);

  const highlights = [];

  if (isCondo) {
    if (hasView) highlights.push("Open outlook");
    if (amenities) highlights.push("Building amenities");
    if (hasParking) highlights.push("Parking included");
    if (outdoor) highlights.push("Outdoor space");
    if (isUpdated) highlights.push("Updated interior");
    if (sqft >= 900) highlights.push("Larger layout");
    if (!highlights.length) highlights.push("Low-maintenance living");
  } else if (isTownhouse) {
    if (beds >= 3) highlights.push("Family-friendly layout");
    if (hasParking) highlights.push("Good parking");
    if (outdoor) highlights.push("Private outdoor space");
    if (isUpdated) highlights.push("Updated features");
    if (quiet) highlights.push("Quieter setting");
    if (sqft >= 1600) highlights.push("Generous townhome space");
    highlights.push("Lock-and-leave option");
  } else if (isHouse) {
    if (sqft >= 2500) highlights.push("Generous floor plan");
    if (beds >= 4) highlights.push("Family-sized");
    if (hasView) highlights.push("View potential");
    if (hasSuite) highlights.push("Suite potential");
    if (isUpdated) highlights.push("Updated features");
    if (quiet) highlights.push("Quiet setting");
    if (hasParking) highlights.push("Good parking");
  } else {
    if (hasView) highlights.push("View setting");
    if (isUpdated) highlights.push("Updated features");
    if (hasParking) highlights.push("Good parking");
    if (outdoor) highlights.push("Outdoor space");
  }

  return Array.from(new Set(highlights)).slice(0, 3);
}
    function buildIntelligenceLabel(index, card) {
  const desc = String(card.dataset.description || "").toLowerCase();
