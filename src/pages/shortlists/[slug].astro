let googleShortlistMap = null;

function loadGoogleMapsScript() {
  return new Promise((resolve, reject) => {
    if (window.google?.maps?.Map) {
      resolve();
      return;
    }

    const key = document.body.dataset.googleMapsApiKey || "";

    if (!key) {
      reject(new Error("Missing Google Maps API key"));
      return;
    }

    const existing = document.querySelector("script[data-google-maps-script]");

    if (existing) {
      existing.addEventListener("load", resolve, { once: true });
      existing.addEventListener("error", reject, { once: true });

      setTimeout(() => {
        if (window.google?.maps?.Map) resolve();
        else reject(new Error("Google Maps script exists but did not finish loading."));
      }, 5000);

      return;
    }

    window.__initShortlistGoogleMap = () => {
      resolve();
    };

    const script = document.createElement("script");
    script.src = `https://maps.googleapis.com/maps/api/js?key=${encodeURIComponent(key)}&callback=__initShortlistGoogleMap&v=weekly`;
    script.async = true;
    script.defer = true;
    script.dataset.googleMapsScript = "true";
    script.onerror = () => reject(new Error("Google Maps script failed to load."));

    document.head.appendChild(script);

    setTimeout(() => {
      if (!window.google?.maps?.Map) {
        reject(new Error("Google Maps timed out. Check billing, API key, or referrer restrictions."));
      }
    }, 6000);
  });
}

async function renderPageMap() {
  const mapEl = document.querySelector("[data-deferred-map]");
  if (!mapEl) return;

  mapEl.style.height = "100%";
  mapEl.style.minHeight = "100%";
  mapEl.style.width = "100%";
  mapEl.innerHTML = `<div style="padding:18px;">Loading Google map...</div>`;

  try {
    await loadGoogleMapsScript();
  } catch (err) {
    console.error("Google Maps load failed:", err);
    mapEl.innerHTML = `
      <div style="padding:18px; line-height:1.5;">
        <strong>Google Maps could not load.</strong><br>
        ${err instanceof Error ? err.message : "Check your API key, billing, and referrer restrictions."}
      </div>
    `;
    return;
  }

  const geocoder = new google.maps.Geocoder();
  const cards = getCards();
  const points = [];

  for (const card of cards) {
    let lat = Number(card.dataset.lat || "");
    let lng = Number(card.dataset.lng || "");

    if (coordsLookWrong(lat, lng, card)) {
      try {
        const result = await geocoder.geocode({
          address: getGeocodeAddress(card)
        });

        const location = result?.results?.[0]?.geometry?.location;

        if (location) {
          lat = location.lat();
          lng = location.lng();
        }
      } catch (err) {
        console.warn("Google geocode failed:", card.dataset.address, err);
      }
    }

    if (Number.isFinite(lat) && Number.isFinite(lng) && lat !== 0 && lng !== 0) {
      points.push({ card, lat, lng });
    }
  }

  if (!points.length) {
    mapEl.innerHTML = `<div style="padding:18px;">No usable coordinates or addresses found.</div>`;
    return;
  }

  mapEl.innerHTML = "";

  googleShortlistMap = new google.maps.Map(mapEl, {
    center: { lat: points[0].lat, lng: points[0].lng },
    zoom: 13,
    mapTypeControl: false,
    streetViewControl: false,
    fullscreenControl: true,
    clickableIcons: false,
    gestureHandling: "greedy"
  });

  const bounds = new google.maps.LatLngBounds();

  points.forEach(({ card, lat, lng }, index) => {
 const marker = new google.maps.Marker({
 position: { lat: lat, lng: lng },
  map: googleShortlistMap,
  label: String(index + 1),
  title: card.dataset.address || "Listing"
});

    marker.addListener("click", () => {
      window.openSheet(card);
    });

    bounds.extend({ lat, lng });
  });

  googleShortlistMap.fitBounds(bounds);

  window.setTimeout(() => {
    google.maps.event.trigger(googleShortlistMap, "resize");

    if (points.length > 1) {
      googleShortlistMap.fitBounds(bounds);
    } else {
googleShortlistMap.setCenter({ lat: points[0].lat, lng: points[0].lng });     googleShortlistMap.setZoom(15);
    }
  }, 250);
}
