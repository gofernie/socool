        async function saveFeedback() {
          if (!activeItemId || isSaving || !activeCard) return false;
          isSaving = true;

          try {
            const res = await fetch("/api/shortlists/feedback", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({
                shortlistItemId: activeItemId,
                liked_tags: activeTags,
                is_favourite: activeFavourite,
                decision: activeDecision || null
              })
            });

            const json = await res.json();
            if (!res.ok || !json?.ok) throw new Error(json?.error || "Failed to save");

            const savedTags = Array.isArray(json?.item?.liked_tags) ? json.item.liked_tags : activeTags;
            const savedFav = Boolean(json?.item?.is_favourite);
            const savedDecision = json?.item?.decision || "";

            activeTags = savedTags;
            activeFavourite = savedFav;
            activeDecision = savedDecision;

       refreshCardUI(activeCard, savedTags, savedFav, savedDecision);
updateDecisionButtons();
shouldRefreshOnClose = true;

return true;
          } catch (err) {
            if (sheetFeedback) {
              sheetFeedback.textContent = err instanceof Error ? err.message : "Could not save";
              sheetFeedback.className = "panel__feedback";
            }
            return false;
          } finally {
            isSaving = false;
          }
        }

        async function handleDecision(kind) {
          if (!activeCard) return;

          if (document.activeElement instanceof HTMLElement) {
            document.activeElement.blur();
          }

          if (kind === "love") {
            activeFavourite = true;
            activeDecision = "";
            sheet.classList.remove("is-pass-fade");
            sheet.classList.add("is-love-pulse");
            if (sheetFeedback) {
              sheetFeedback.innerHTML =
                `<span class="panel__micro"><span class="panel__micro-badge panel__micro-badge--love">Saved ✓</span><span>Ready when you are</span></span>`;
              sheetFeedback.className = "panel__feedback is-love";
            }
          }

          if (kind === "maybe") {
            activeFavourite = false;
            activeDecision = "maybe";
            sheet.classList.remove("is-love-pulse", "is-pass-fade");
            if (sheetFeedback) {
              sheetFeedback.innerHTML =
                `<span class="panel__micro"><span class="panel__micro-badge panel__micro-badge--maybe">Maybe</span><span>Saved - review this one, then continue</span></span>`;
              sheetFeedback.className = "panel__feedback is-maybe";
            }
          }

          if (kind === "pass") {
            activeFavourite = false;
            activeDecision = "pass";
            sheet.classList.remove("is-love-pulse");
            sheet.classList.add("is-pass-fade");
            if (sheetFeedback) {
              sheetFeedback.innerHTML =
                `<span class="panel__micro"><span class="panel__micro-badge panel__micro-badge--pass">Passed</span><span>Saved - continue when ready</span></span>`;
              sheetFeedback.className = "panel__feedback is-pass";
            }
          }

          refreshCardUI(activeCard, activeTags, activeFavourite, activeDecision);
          updateDecisionButtons();

          const ok = await saveFeedback();

       if (ok) {
            updateHeaderProgress();
            updateDecisionButtons();

            if (sheetNextBtn) sheetNextBtn.disabled = false;
            if (sheetNextTopBtn) {
              sheetNextTopBtn.disabled = false;
              sheetNextTopBtn.textContent = "Next →";
            }
          }

          window.setTimeout(() => {
            sheet.classList.remove("is-love-pulse", "is-pass-fade");
          }, 900);
        }

