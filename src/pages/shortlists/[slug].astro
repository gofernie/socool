  .masthead {
    background: var(--bg-dark);
    color: var(--text-on-dark);
    padding: 0 32px;
  }
.masthead__inner {
  max-width: 1280px;
  height: var(--hero-height);
  margin: 0 auto;
  padding: 72px 0 0;
  display: grid;
  grid-template-columns: 1fr 1fr;
