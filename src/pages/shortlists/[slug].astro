---
import { createClient } from "@supabase/supabase-js";
import {
  getListingAddress,
  getListingBaths,
  getListingBeds,
  getListingDescription,
  getListingId,
  getListingImage,
  getListingPrice,
  getListingSqft,
  getListingType,
  getListingYear
} from "../../lib/repliers";
import IntentModalController from "../../components/IntentModalController.astro";

const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL!,
  import.meta.env.SUPABASE_SERVICE_ROLE_KEY!
);

export const prerender = false;

const { slug } = Astro.params;
const isAgentView = Astro.url.searchParams.get("agent") === "1";
const isExpandedReview = Astro.url.searchParams.has("expanded");
const clientLink = `/shortlists/${slug}`;
const sendId = Astro.url.searchParams.get("s");
const googleMapsApiKey = import.meta.env.PUBLIC_GOOGLE_MAPS_API_KEY || "";
function normalizeImageUrl(url: any) {
  const value = String(url || "").trim();

  if (!value) return "";

  if (value.startsWith("http://") || value.startsWith("https://")) {
    return value;
  }

  if (value.startsWith("/")) {
    return `https://cdn.repliers.io${value}`;
  }

  return `https://cdn.repliers.io/${value}`;
}
function getListingLat(listing: any) {
  return (
    listing?.lat ||
    listing?.latitude ||
    listing?.map?.lat ||
    listing?.map?.latitude ||
    listing?.address?.lat ||
    listing?.address?.latitude ||
    listing?.raw?.lat ||
    listing?.raw?.latitude ||
    listing?.raw?.map?.lat ||
    listing?.raw?.map?.latitude ||
    listing?.raw?.address?.lat ||
    listing?.raw?.address?.latitude ||
    listing?.coordinates?.lat ||
    listing?.coordinates?.latitude ||
    listing?.raw?.coordinates?.lat ||
    listing?.raw?.coordinates?.latitude ||
    ""
  );
}

function getListingLng(listing: any) {
  return (
    listing?.lng ||
    listing?.lon ||
    listing?.longitude ||
    listing?.map?.lng ||
    listing?.map?.lon ||
    listing?.map?.longitude ||
    listing?.address?.lng ||
    listing?.address?.lon ||
    listing?.address?.longitude ||
    listing?.raw?.lng ||
    listing?.raw?.lon ||
    listing?.raw?.longitude ||
    listing?.raw?.map?.lng ||
    listing?.raw?.map?.lon ||
    listing?.raw?.map?.longitude ||
    listing?.raw?.address?.lng ||
    listing?.raw?.address?.lon ||
    listing?.raw?.address?.longitude ||
    listing?.coordinates?.lng ||
    listing?.coordinates?.lon ||
    listing?.coordinates?.longitude ||
    listing?.raw?.coordinates?.lng ||
    listing?.raw?.coordinates?.lon ||
    listing?.raw?.coordinates?.longitude ||
    ""
  );
}
function getListingSqftFromDescription(listing: any) {
  const text = String(listing?.description || "").toLowerCase();

  const match = text.match(/(?:~|approx\.?|approximately)?\s*([\d,]+)\s*(?:sq\.?\s*ft\.?|sqft|square feet)/i);

  return match?.[1] ? match[1].replace(/,/g, "") : "";
}
function getListingDom(listing: any) {
  const direct =
    listing?.days_on_market ||
    listing?.daysOnMarket ||
    listing?.dom ||
    listing?.details?.daysOnMarket ||
    listing?.details?.dom ||
    listing?.raw?.daysOnMarket ||
    listing?.raw?.dom ||
    listing?.raw?.details?.daysOnMarket ||
    listing?.raw?.details?.dom;

  if (direct) return direct;

  const listedRaw =
    listing?.listed_at ||
    listing?.list_date ||
    listing?.listDate ||
    listing?.created_at ||
    listing?.raw?.listDate ||
    listing?.raw?.timestamps?.listingUpdated;

  const listedTime = new Date(listedRaw).getTime();
  if (!listedTime) return "";

  return Math.max(0, Math.floor((Date.now() - listedTime) / 86400000));
}


function normalizeLiveListing(live: any, saved: any) {
  return {
    ...saved,
    live_listing: live || null,
    repliers_listing_id:
      getListingId(live) ||
      saved?.repliers_listing_id ||
      saved?.listing_id ||
      saved?.id ||
      "",
price_text: saved?.price_text || getListingPrice(live) || "Price unavailable",
address: saved?.address || getListingAddress(live) || "Address unavailable",
beds: saved?.beds || getListingBeds(live) || "-",
baths: saved?.baths || getListingBaths(live) || "-",
sqft:  saved?.sqft ||
  getListingSqft(saved) ||
  getListingSqft(live) ||
  "",

property_type:
  saved?.property_type ||
  getListingType(live) ||
  "Home",

year_built:
  saved?.year_built ||
  getListingYear(live) ||
  "",

days_on_market:
  saved?.days_on_market ||
  saved?.daysOnMarket ||
  saved?.dom ||
  getListingDom(saved) ||
  getListingDom(live) ||
  "",
lat: getListingLat(saved) || getListingLat(live),
lng: getListingLng(saved) || getListingLng(live),
image_url:
  normalizeImageUrl(saved?.image_url) ||
  normalizeImageUrl(getListingImage(live)) ||
  "https://placehold.co/800x600?text=Listing",

description:
  getListingDescription(live) ||
  saved?.description ||
  live?.description ||
  live?.details?.description ||
  live?.raw?.description ||
  live?.raw?.details?.description ||
  "A quick preview of this property."
  };
}
const { data: shortlist } = await supabase
  .from("shortlist_sends")
.select(`
    *,
    agent:agent_id (
      id,
      name
    ),
    client:client_id (
      id,
      name,
      phone
    )
  `)
  .eq("shortlist_slug", slug)
  .single();

if (sendId) {
  await supabase.rpc("track_shortlist_send_open", {
    send_id: sendId
  });
}

let items: any[] = [];
let resources: any[] = [];

if (shortlist?.id) {
  const res = await supabase
    .from("shortlist_items")
    .select("*")
    .eq("shortlist_send_id", shortlist.id)
    .order("sort_order", { ascending: true });

  items = res.data || [];

const selectedRes = await supabase
  .from("shortlist_resource_vendors")
  .select("vendor_id, sort_order")
  .eq("shortlist_slug", slug)
  .eq("is_selected", true)
  .order("sort_order", { ascending: true });

const vendorIds = (selectedRes.data || [])
  .map((row: any) => row.vendor_id)
  .filter(Boolean);

if (vendorIds.length) {
  const vendorRes = await supabase
    .from("buyer_resource_vendors")
    .select("id, type, name, email, phone, website, note, is_active")
    .in("id", vendorIds)
    .eq("is_active", true);

  const vendorMap = new Map(
    (vendorRes.data || []).map((vendor: any) => [vendor.id, vendor])
  );

  resources = vendorIds
    .map((id: string) => vendorMap.get(id))
    .filter(Boolean);
}
}

let listingRowsById = new Map();

const cleanListingRowId = (value: any) =>
  String(value || "").replace(/[^0-9]/g, "").trim();

const normalizeAddressKey = (value: any) =>
  String(value || "")
    .toLowerCase()
    .replace(/[^\w\s]/g, "")
    .replace(/\s+/g, " ")
    .trim();

const rowsRes = await supabase
  .from("listing_rows")
  .select("*")
  .eq("normalized_city", "nanaimo")
  .limit(5000);

if (rowsRes.error) {
  console.error("LISTING_ROWS LOAD ERROR", rowsRes.error);
}

console.log("LISTING_ROWS LOADED", rowsRes.data?.length || 0);

listingRowsById = new Map(
  (rowsRes.data || []).flatMap((row: any) => [
    [cleanListingRowId(row.id), row],
    [cleanListingRowId(row.mls_number), row],
    [normalizeAddressKey(row.address), row]
  ])
);
function getListingSortScore(listing: any) {
  const toNumber = (value: any) =>
    parseInt(String(value || "").replace(/[^0-9]/g, ""), 10) || 0;

  const price = toNumber(listing.price_text);
  const sqft = toNumber(listing.sqft);
  const beds = toNumber(listing.beds);
  const baths = toNumber(listing.baths);
  const year = toNumber(listing.year_built);
  const desc = String(listing.description || "").toLowerCase();

  let score = 0;
  if (listing.is_favourite) score += 100;
if (listing.decision === "maybe") score += 20;
if (listing.decision === "pass") score -= 500;

  if (price && sqft) score += Math.round((price / sqft) * -1);
  if (sqft) score += sqft * 0.02;
  if (beds) score += beds * 12;
  if (baths) score += baths * 6;
  if (year >= 2015) score += 25;

  if (/\b(ocean view|mountain view|lake view|river view|city view|water view|panoramic view)\b/i.test(desc)) score += 35;
  if (/\b(cul[- ]de[- ]sac|dead end|quiet street)\b/i.test(desc)) score += 18;
  if (/\b(move[- ]in ready|turnkey|updated|renovated|modern)\b/i.test(desc)) score += 16;
  if (/\b(garage|double garage|attached garage)\b/i.test(desc)) score += 10;
  if (/\b(yard|backyard|garden|fully fenced|fenced)\b/i.test(desc)) score += 8;

  return score;
}
const normalizedListings = [...items].map((item: any) => {
  const id = item.repliers_listing_id || item.listing_id || item.mls_number || "";
  const rowId = cleanListingRowId(id);
  const addressKey = normalizeAddressKey(item.address);

  const live = null;
  const row =
    listingRowsById.get(rowId) ||
    listingRowsById.get(addressKey) ||
    {};

  const saved = {
    ...item,
    ...row,
    price_text: row.price ? `$${Number(row.price).toLocaleString()}` : item.price_text,
    image_url: row.image_url || item.image_url,
 sqft: row.sqft || getListingSqft(row) || item.sqft || getListingSqft(item),
days_on_market: getListingDom(row) || getListingDom(item),
    shortlist_item_id: item.shortlist_item_id || item.id,
    is_favourite: item.is_favourite,
    decision: item.decision,
    liked_tags: item.liked_tags,
    sort_order: item.sort_order
  };

  return normalizeLiveListing(live, saved);
});

const newestSortOrders = new Set(
  normalizedListings
    .map((item: any) => Number(item?.sort_order ?? 999999))
    .filter((value) => Number.isFinite(value))
    .sort((a, b) => b - a)
    .slice(0, 3)
);

const priceNumber = (item: any) =>
  Number(String(item?.price_text || item?.price || "").replace(/[^0-9]/g, "")) || 0;

// Simple sort by sort_order - keeps items in the order they were added/reviewed
const listings = normalizedListings.sort((a, b) => {
  return Number(a?.sort_order ?? 999999) - Number(b?.sort_order ?? 999999);
});

const clientDisplayName =
  shortlist?.client_name ||
  shortlist?.client?.name ||
  "";

const rawAgentName =
  shortlist?.agent_name ||
  shortlist?.agent?.name ||
  "";

const agentName =
  rawAgentName && !rawAgentName.includes("@")
    ? rawAgentName
    : "Chris Crump";

const pageTitle = shortlist?.client_name
  ? `${shortlist.client_name}'s shortlist`
  : "Your Shortlist";

const createdLabel = shortlist?.created_at
  ? new Date(shortlist.created_at).toLocaleDateString("en-CA", {
      year: "numeric",
      month: "short",
      day: "numeric"
    })
  : "";

const shortlistStatus = shortlist?.sent_at ? "Sent" : "Draft";

const defaultIntroMessage =
  "I pulled these homes together based on what you're looking for. Start with the first one - it’s the strongest match, then work your way through the rest.";

const heroMessage = shortlist?.note?.trim() || defaultIntroMessage;
const smsImageUrl = shortlist?.sms_image_url || "";
const { data: uploadedSmsImages } = await supabase
  .from("shortlist_sms_images")
  .select("*")
  .eq("shortlist_slug", slug)
  .order("created_at", { ascending: false });
const presetSmsImages = [
  {
    label: "New homes added",
    url: "https://imagedelivery.net/Az3x6Ld2gouPPtikaqezkQ/aec87d01-e6d7-410d-f583-0924a6ced300/hero"
  },
  {
    label: "Mortgage info added",
    url: "https://imagedelivery.net/Az3x6Ld2gouPPtikaqezkQ/e436932a-2b37-4169-bd94-1245ca986300/hero"
  },
  {
    label: "Home inspector info",
    url: "https://imagedelivery.net/Az3x6Ld2gouPPtikaqezkQ/bd8a291a-1db0-4346-e807-eec80c70a400/hero"
  },
  {
    label: "Market update",
    url: "https://imagedelivery.net/Az3x6Ld2gouPPtikaqezkQ/27294214-7d6a-4fdf-64a4-18c4c7adba00/hero"
  }
];

const firstListingImage =
  listings?.[0]?.image_url ||
  listings?.[0]?.images?.[0]?.url ||
  "";

const previewImageUrl =
  smsImageUrl ||
  firstListingImage ||
  "https://placehold.co/1200x630?text=Shortlist";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
   <title>{pageTitle}</title>
<meta name="viewport" content="width=device-width, initial-scale=1" />

<meta property="og:title" content={pageTitle} />
