  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scrollbar-gutter: stable;
    scroll-behavior: smooth;
  }

  body {
    font-family: var(--f-body);
    background: var(--bg);
    color: var(--text-primary);
    font-size: 15px;
