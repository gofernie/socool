function sortCardsByReview() {
  if (!shortlistGrid) return;

  reviewCards = null;

  const cards = Array.from(document.querySelectorAll(".card"));

  const scoreCard = (card) => {
  // HARD RULE: "Not for me" always last
  if (card.dataset.decision === "pass") return 99;

  // Then order the rest
  if (card.dataset.isFavourite === "true") return 0;
  if (card.dataset.decision === "maybe") return 1;

  // undecided
  return 2;
};

  cards
    .sort((a, b) => {
      const scoreDiff = scoreCard(a) - scoreCard(b);
      if (scoreDiff !== 0) return scoreDiff;

      return Number(a.dataset.originalOrder || 999999) - Number(b.dataset.originalOrder || 999999);
    })
    .forEach((card, index) => {
      shortlistGrid.appendChild(card);

      const indexEl = card.querySelector(".card__index");
      if (indexEl) {
        indexEl.textContent = `No. ${String(index + 1).padStart(2, "0")}`;
      }

      card.dataset.featured = index === 0 ? "true" : "false";
    });

  reviewCards = null;
}
