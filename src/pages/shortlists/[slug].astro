  }

  .agent-bar__name {
    font-size: 0.82rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.75);
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .agent-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #6bc96b;
    flex-shrink: 0;
  }

  .agent-bar__sep {
    color: rgba(255, 255, 255, 0.15);
    font-size: 0.75rem;
  }

  .agent-bar__date {
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.3);
  }

  .agent-bar__actions {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .ab-btn {
    height: 30px;
    padding: 0 14px;
    border-radius: var(--r-sm);
    border: 1px solid rgba(255, 255, 255, 0.12);
