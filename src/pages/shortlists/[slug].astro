      addResourceBtn.textContent = "Added ✓";
      await loadResourceVendors();
      resourceNameInput.value = ""; resourcePhoneInput.value = ""; resourceEmailInput.value = ""; resourceWebsiteInput.value = ""; resourceDescriptionInput.value = "";
