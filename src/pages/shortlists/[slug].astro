<script>
  import { createClient } from "@supabase/supabase-js";

  const supabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY
  );

  const fileInput = document.getElementById("sms-image-file-input") as HTMLInputElement | null;
  const urlInput = document.getElementById("sms-image-url-input") as HTMLInputElement | null;
  const statusEl = document.getElementById("sms-image-upload-status");

  fileInput?.addEventListener("change", async () => {
    const file = fileInput.files?.[0];
    if (!file || !urlInput) return;

    if (statusEl) statusEl.textContent = "Uploading image...";

    const safeName = file.name
      .toLowerCase()
      .replace(/[^a-z0-9.]+/g, "-");

    const path = `shortlist-sms/${crypto.randomUUID()}-${safeName}`;

    const { error } = await supabase.storage
      .from("public-images")
      .upload(path, file, {
        cacheControl: "3600",
        upsert: false
      });

    if (error) {
      console.error(error);
      if (statusEl) statusEl.textContent = "Upload failed.";
      return;
    }

    const { data } = supabase.storage
      .from("public-images")
      .getPublicUrl(path);

   urlInput.value = data.publicUrl;

const { data: insertedImage, error: insertError } = await supabase
  .from("shortlist_sms_images")
  .insert({
    shortlist_slug: document.body.dataset.shortlistSlug,
    image_url: data.publicUrl,
    label: "Uploaded image"
  })
  .select()
  .single();

if (insertError) {
  console.error(insertError);
  if (statusEl) statusEl.textContent = "Image uploaded, but could not save to image library.";
  return;
}

const presetGrid = document.querySelector(".preset-image-grid");

if (presetGrid) {
  const wrap = document.createElement("div");
  wrap.className = "preset-image-wrap";

  const btn = document.createElement("button");
  btn.type = "button";
  btn.className = "preset-image-btn is-selected";
  btn.dataset.presetImageUrl = data.publicUrl;

  btn.innerHTML = `
    <img src="${data.publicUrl}" alt="Uploaded custom image" loading="lazy" />
    <span>Uploaded image</span>
  `;

 const deleteBtn = document.createElement("button");
deleteBtn.type = "button";
deleteBtn.className = "preset-image-delete";
deleteBtn.dataset.deleteSmsImageId = insertedImage.id;
deleteBtn.textContent = "Delete";

  wrap.appendChild(btn);
  wrap.appendChild(deleteBtn);

  presetGrid
    .querySelectorAll(".preset-image-btn")
    .forEach((item) => item.classList.remove("is-selected"));

  presetGrid.prepend(wrap);

  btn.addEventListener("click", () => {
    presetGrid
      .querySelectorAll(".preset-image-btn")
      .forEach((item) => item.classList.remove("is-selected"));

    btn.classList.add("is-selected");
    urlInput.value = data.publicUrl;
  });

  deleteBtn.addEventListener("click", async () => {
    const confirmed = confirm("Delete this uploaded image?");
    if (!confirmed) return;

    await supabase
      .from("shortlist_sms_images")
      .delete()
      .eq("image_url", data.publicUrl);

    wrap.remove();
  });
}

if (statusEl) {
  statusEl.textContent = "Uploaded image added above. Click Save image URL.";
}
  });
document.querySelectorAll("[data-delete-sms-image-id]").forEach((btn) => {
  btn.addEventListener("click", async () => {
    const id = btn.dataset.deleteSmsImageId;
    if (!id) return;

    const confirmed = confirm("Delete this uploaded image?");
    if (!confirmed) return;

    const { error } = await supabase
      .from("shortlist_sms_images")
      .delete()
      .eq("id", id);

    if (error) {
      console.error(error);
      alert("Could not delete image.");
      return;
    }

    btn.closest(".preset-image-wrap")?.remove();
  });
});
function appendNextHigherListings(items) {
  const grid = document.getElementById("shortlist-grid");

  if (!grid) {
    alert("Could not find shortlist grid.");
    return;
  }

  const startIndex = grid.querySelectorAll(".card").length;

  items.forEach((item, index) => {
    const card = document.createElement("article");
    card.className = "card";

    card.dataset.itemId = String(item.id || item.shortlist_item_id || "");
    card.dataset.cardId = String(item.repliers_listing_id || item.listing_id || item.id || "");
    card.dataset.listingId = String(item.repliers_listing_id || item.listing_id || item.id || "");
    card.dataset.mls = String(item.mls_number || item.mls || "");
    card.dataset.price = item.price_text || item.price || "Price unavailable";
    card.dataset.address = item.address || "Address unavailable";
    card.dataset.beds = String(item.beds || "-");
    card.dataset.baths = String(item.baths || "-");
    card.dataset.sqft = String(item.sqft || "");
    card.dataset.type = item.property_type || "Home";
    card.dataset.year = String(item.year_built || "");
    card.dataset.dom = String(item.days_on_market || "");
    card.dataset.image = item.image_url || "https://placehold.co/800x600?text=Listing";
    card.dataset.images = JSON.stringify(item.images || item.photo_urls || []);
    card.dataset.description = item.description || "A quick preview of this property.";
    card.dataset.likedTags = JSON.stringify([]);
    card.dataset.isFavourite = "false";
    card.dataset.decision = "";
    card.dataset.isNew = "true";
   card.dataset.sortOrder = String(item.sort_order || startIndex + index + 1);

    const num = String(startIndex + index + 1).padStart(2, "0");
    const image = item.image_url || "https://placehold.co/800x600?text=Listing";
    const price = item.price_text || item.price || "Price unavailable";
    const address = item.address || "Address unavailable";
    const beds = item.beds || "-";
    const baths = item.baths || "-";
    const sqft = item.sqft ? ` · ${item.sqft} sqft` : "";
    const description = String(item.description || "A quick preview of this property.")
      .replace(/\s+/g, " ")
      .trim();

    card.innerHTML = `
      <div class="card__image-wrap">
        <div class="card__new-badge">
          <span>✨</span>
          <span>New</span>
        </div>

        <img src="${image}" alt="${address}" loading="lazy" />
        <span class="card__index">No. ${num}</span>
      </div>

      <div class="card__body">
        <p class="card__price">${price}</p>
        <p class="card__address">${address}</p>
        <p class="card__meta">${beds} bed · ${baths} bath${sqft}</p>
        <p class="card__desc">${description}</p>
        <button type="button" class="card__action preview-btn">View property →</button>
      </div>
    `;

    grid.appendChild(card);
    card.querySelector(".preview-btn")?.addEventListener("click", () => {
  card.click();
});

card.addEventListener("click", () => {
  const event = new CustomEvent("open-shortlist-card", {
    detail: { card }
  });

  window.dispatchEvent(event);
});
  });

  grid.scrollIntoView({ behavior: "smooth", block: "end" });
}

</script>


   
