    setTimeout(() => { resourceNameInput?.focus(); }, 350);
  });

  loadResourceVendors();

  // ── Page map (masthead map view button) ───────────────────────────
  const mapBtn = document.getElementById("page-map-btn");
  const masthead = document.querySelector(".masthead");
  let googleShortlistMap = null;

  function coordsLookWrong(lat, lng, card) {
    if (!Number.isFinite(lat) || !Number.isFinite(lng)) return true;
    if (lat === 0 || lng === 0) return true;
    const city = String(card?.dataset?.city || "").toLowerCase();
    const cityBounds = {
      nanaimo: { minLat: 49.0, maxLat: 49.35, minLng: -124.15, maxLng: -123.75 },
      lantzville: { minLat: 49.2, maxLat: 49.35, minLng: -124.15, maxLng: -123.9 },
      parksville: { minLat: 49.25, maxLat: 49.4, minLng: -124.45, maxLng: -124.2 }
    };
    const bounds = cityBounds[city];
    if (!bounds) return lat < 48.2 || lat > 50.7 || lng < -128.5 || lng > -122.9;
    return lat < bounds.minLat || lat > bounds.maxLat || lng < bounds.minLng || lng > bounds.maxLng;
  }

  function getGeocodeAddress(card) {
    const address = card.dataset.address || "";
    const city = card.dataset.city || "";
    return city ? `${address}, ${city}, BC, Canada` : `${address}, British Columbia, Canada`;
  }

  function loadGoogleMapsScript() {
    return new Promise((resolve, reject) => {
      if (window.google?.maps?.Map) { resolve(); return; }
      const key = document.body.dataset.googleMapsApiKey || "";
      if (!key) { reject(new Error("Missing Google Maps API key")); return; }
      const existing = document.querySelector("script[data-google-maps-script]");
      if (existing) {
        existing.addEventListener("load", resolve, { once: true });
        existing.addEventListener("error", reject, { once: true });
        setTimeout(() => { if (window.google?.maps?.Map) resolve(); else reject(new Error("Timed out")); }, 5000);
        return;
      }
      window.__initShortlistGoogleMap = () => { resolve(); };
      const script = document.createElement("script");
      script.src = `https://maps.googleapis.com/maps/api/js?key=${encodeURIComponent(key)}&callback=__initShortlistGoogleMap&v=weekly`;
      script.async = true; script.defer = true;
      script.dataset.googleMapsScript = "true";
      script.onerror = () => reject(new Error("Google Maps script failed to load."));
      document.head.appendChild(script);
      setTimeout(() => { if (!window.google?.maps?.Map) reject(new Error("Google Maps timed out.")); }, 6000);
    });
  }

  async function renderPageMap() {
    const mapEl = document.querySelector("[data-deferred-map]");
    if (!mapEl) return;
    mapEl.style.height = "100%"; mapEl.style.minHeight = "100%"; mapEl.style.width = "100%";
    mapEl.innerHTML = `<div style="padding:18px;">Loading Google map...</div>`;
    try {
      await loadGoogleMapsScript();
    } catch (err) {
      mapEl.innerHTML = `<div style="padding:18px;"><strong>Google Maps could not load.</strong><br>${err instanceof Error ? err.message : ""}</div>`;
      return;
    }
    const geocoder = new google.maps.Geocoder();
    const cards = getCards();
    const points = [];
    for (const card of cards) {
      let lat = Number(card.dataset.lat || "");
      let lng = Number(card.dataset.lng || "");
      if (coordsLookWrong(lat, lng, card)) {
        try {
          const result = await geocoder.geocode({ address: getGeocodeAddress(card) });
          const location = result?.results?.[0]?.geometry?.location;
          if (location) { lat = location.lat(); lng = location.lng(); }
        } catch {}
      }
      if (Number.isFinite(lat) && Number.isFinite(lng) && lat !== 0 && lng !== 0) {
        points.push({ card, lat, lng });
      }
    }
    if (!points.length) { mapEl.innerHTML = `<div style="padding:18px;">No usable coordinates found.</div>`; return; }
    mapEl.innerHTML = "";
    googleShortlistMap = new google.maps.Map(mapEl, { center: { lat: points[0].lat, lng: points[0].lng }, zoom: 13, mapTypeControl: false, streetViewControl: false, fullscreenControl: true, clickableIcons: false, gestureHandling: "greedy" });
    const bounds = new google.maps.LatLngBounds();
    points.forEach(({ card, lat, lng }, index) => {
      const marker = new google.maps.Marker({ position: { lat, lng }, map: googleShortlistMap, label: String(index + 1), title: card.dataset.address || "Listing" });
      marker.addListener("click", () => { window.openSheet(card); });
      bounds.extend({ lat, lng });
    });
    googleShortlistMap.fitBounds(bounds);
    window.setTimeout(() => {
      google.maps.event.trigger(googleShortlistMap, "resize");
      if (points.length > 1) { googleShortlistMap.fitBounds(bounds); }
      else { googleShortlistMap.setCenter({ lat: points[0].lat, lng: points[0].lng }); googleShortlistMap.setZoom(15); }
    }, 250);
  }

  mapBtn?.addEventListener("click", () => {
    const mapWrap = document.getElementById("shortlist-page-map-wrap");
    if (!mapWrap) return;
    const isOpening = mapWrap.hidden;
    mapWrap.hidden = !mapWrap.hidden;
    mapBtn.classList.toggle("is-active", isOpening);
    masthead?.classList.toggle("map-mode", isOpening);
    if (isOpening) { masthead?.scrollIntoView({ behavior: "auto", block: "start" }); renderPageMap(); }
  });

  // ── Auto-open new listings ────────────────────────────────────────
  const autoOpenParams = new URLSearchParams(window.location.search);
  if (autoOpenParams.has("openNew")) {
    autoOpenParams.delete("openNew");
    const cleanUrl = window.location.pathname + (autoOpenParams.toString() ? `?${autoOpenParams.toString()}` : "");
    window.history.replaceState({}, "", cleanUrl);
    requestAnimationFrame(() => {
      const cards = getCards();
      const batchStartIndex = Math.max(0, cards.length - 3);
      const firstNewCard = cards[batchStartIndex] || cards[0];
      if (firstNewCard) window.openSheet(firstNewCard);
    });
  }
}

if (document.readyState === "loading") {
  document.addEventListener("DOMContentLoaded", initShortlistPage, { once: true });
} else {
  initShortlistPage();
}

document.addEventListener("astro:page-load", initShortlistPage);
