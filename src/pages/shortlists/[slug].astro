  .section-title {
    font-family: var(--f-display);
    font-size: 1.25rem;
    font-weight: 400;
    font-style: italic;
    color: var(--text-primary);
  }

  .section-meta {
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
