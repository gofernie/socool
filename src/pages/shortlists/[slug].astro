  // ── Resources ─────────────────────────────────────────────────────
  const resourceVendorList = document.getElementById("resource-vendor-list");
  const saveResourceVendorsBtn = document.getElementById("save-resource-vendors-btn");
  const showResourcesToggle = document.getElementById("show-resources-toggle");
  const saveResourceVisibilityBtn = document.getElementById("save-resource-visibility-btn");
  const addResourceBtn = document.getElementById("add-resource-btn");
  const resourceTypeInput = document.getElementById("resource-type-input");
  const resourceNameInput = document.getElementById("resource-name-input");
  const resourcePhoneInput = document.getElementById("resource-phone-input");
  const resourceEmailInput = document.getElementById("resource-email-input");
  const resourceWebsiteInput = document.getElementById("resource-website-input");
  const resourceDescriptionInput = document.getElementById("resource-description-input");
  const showAddResourceBtn = document.getElementById("show-add-resource-btn");

  async function loadResourceVendors() {
    if (!resourceVendorList) return;
    resourceVendorList.textContent = "Loading resources...";
    try {
      const res = await fetch("/api/buyer-resources/vendors");
      const data = await res.json();
      const selectedRes = await fetch(`/api/buyer-resources/selected?shortlistSlug=${encodeURIComponent(pageSlug)}`);
      const selectedData = await selectedRes.json();
      const vendors = data.vendors || [];
      const selectedIds = new Set(selectedData.vendorIds || []);
      if (!vendors.length) { resourceVendorList.textContent = "No vendors added yet."; return; }
      resourceVendorList.innerHTML = vendors.map((vendor) => `
        <div class="resource-vendor-row">
          <input type="checkbox" value="${vendor.id}" ${selectedIds.has(vendor.id) ? "checked" : ""} />
          <span>
            <strong>${vendor.name}</strong>
            <small>${String(vendor.type || "Other").replace(/[_-]+/g, " ").replace(/\b\w/g, (c) => c.toUpperCase())}${vendor.email ? ` · ${vendor.email}` : ""}</small>
          </span>
          <div style="margin-left:auto; display:flex; gap:8px;">
            <button type="button" class="resource-edit-btn" data-edit-resource-id="${vendor.id}" data-resource-type="${vendor.type || ""}" data-resource-name="${vendor.name || ""}" data-resource-phone="${vendor.phone || ""}" data-resource-email="${vendor.email || ""}" data-resource-website="${vendor.website || ""}" data-resource-note="${vendor.note || ""}">Edit</button>
            <button type="button" class="resource-edit-btn" data-delete-resource-id="${vendor.id}">Delete</button>
          </div>
        </div>
      `).join("");
      resourceVendorList.querySelectorAll("[data-edit-resource-id]").forEach((btn) => {
        btn.addEventListener("click", () => {
          document.getElementById("resource-custom-type-input").value = String(btn.dataset.resourceType || "").replace(/[_-]+/g, " ").replace(/\b\w/g, (c) => c.toUpperCase());
          resourceNameInput.value = btn.dataset.resourceName || "";
          resourcePhoneInput.value = btn.dataset.resourcePhone || "";
          resourceEmailInput.value = btn.dataset.resourceEmail || "";
          resourceWebsiteInput.value = btn.dataset.resourceWebsite || "";
          resourceDescriptionInput.value = btn.dataset.resourceNote || "";
          addResourceBtn.dataset.editResourceId = btn.dataset.editResourceId || "";
          addResourceBtn.textContent = "Save resource";
          resourceNameInput.scrollIntoView({ behavior: "smooth", block: "center" });
        });
      });
      resourceVendorList.querySelectorAll("[data-delete-resource-id]").forEach((btn) => {
        btn.addEventListener("click", async () => {
          if (!confirm("Delete this vendor?")) return;
          const res = await fetch("/api/buyer-resources/delete-vendor", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ id: btn.dataset.deleteResourceId || "" })
          });
          const data = await res.json();
          if (!res.ok || !data?.ok) { alert(data?.error || "Could not delete vendor."); return; }
          await loadResourceVendors();
        });
      });
    } catch (err) {
      resourceVendorList.textContent = "Could not load resources.";
    }
