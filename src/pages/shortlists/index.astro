---
import { createSupabaseServerClient } from "../../lib/supabaseServer";

const supabaseAuth = createSupabaseServerClient(Astro.cookies);
const { data: { user } } = await supabaseAuth.auth.getUser();
if (!user) return Astro.redirect("/login");

const agentId = user.id;
import { createClient } from "@supabase/supabase-js";
export const prerender = false;

const supabaseAdmin = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.SUPABASE_SERVICE_ROLE_KEY
);

const pageSize = 20;
const pageParam = Number(Astro.url.searchParams.get("page") || "1");
const currentPage = Number.isFinite(pageParam) && pageParam > 0 ? pageParam : 1;
const searchQuery = (Astro.url.searchParams.get("q") || "").trim();
const from = (currentPage - 1) * pageSize;
const to = from + pageSize - 1;

let shortlistQuery = supabaseAdmin
  .from("shortlist_sends")
  .select(`id, shortlist_slug, shortlist_url, client_name, client_id, created_at`, { count: "exact" })
  .eq("agent_id", agentId)
  .order("created_at", { ascending: false });

if (searchQuery) {
  const safeQuery = searchQuery.replace(/[%_]/g, "\\$&");
  shortlistQuery = shortlistQuery.or(`client_name.ilike.%${safeQuery}%,shortlist_slug.ilike.%${safeQuery}%`);
}

const { data: shortlistsRaw, error: shortlistsError, count: shortlistsTotalCount } = await shortlistQuery.range(from, to);

const clientIds = (shortlistsRaw || []).map((row: any) => row.client_id).filter(Boolean);
let clientsById: Record<string, any> = {};
if (clientIds.length) {
  const { data: clientsRaw } = await supabaseAdmin.from("clients").select("id, name, phone").in("id", clientIds);
  clientsById = Object.fromEntries((clientsRaw || []).map((client: any) => [client.id, client]));
}

const shortlistIds = (shortlistsRaw || []).map((row: any) => row.id);
let itemCountsByShortlistId: Record<string, number> = {};
if (shortlistIds.length) {
  const { data: itemsRaw } = await supabaseAdmin.from("shortlist_items").select("id, shortlist_send_id").in("shortlist_send_id", shortlistIds);
  for (const item of itemsRaw || []) { itemCountsByShortlistId[item.shortlist_send_id] = (itemCountsByShortlistId[item.shortlist_send_id] || 0) + 1; }
}

const shortlists = (shortlistsRaw || []).map((row: any) => {
  const client = row.client_id ? clientsById[row.client_id] : null;
  return { id: row.id, slug: row.shortlist_slug, url: row.shortlist_url || `/shortlists/${row.shortlist_slug}`, clientName: row.client_name || client?.name || "Unnamed client", phone: client?.phone || "", createdAt: row.created_at, itemCount: itemCountsByShortlistId[row.id] || 0 };
});

const totalCount = shortlistsTotalCount || 0;
const showingFrom = totalCount === 0 ? 0 : from + 1;
const showingTo = Math.min(from + shortlists.length, totalCount);
const hasPrevPage = currentPage > 1;
const hasNextPage = showingTo < totalCount;

function formatDate(value: string | null) {
  if (!value) return "—";
  try { return new Date(value).toLocaleDateString("en-CA", { year: "numeric", month: "short", day: "numeric" }); } catch { return value; }
}

function buildPageHref(page: number) {
  const params = new URLSearchParams();
  if (page > 1) params.set("page", String(page));
  if (searchQuery) params.set("q", searchQuery);
  const qs = params.toString();
  return qs ? `/shortlists?${qs}` : "/shortlists";
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Shortlists</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;1,400&family=Nunito+Sans:opsz,wght@6..12,300;6..12,400;6..12,500;6..12,600;6..12,700&display=swap" rel="stylesheet" />

    <style>
      :root {
        --bg: #f4efe7;
        --card: #ffffff;
        --card-warm: #f9f5f0;
        --ink: #1a1917;
        --muted: #6b6b6b;
        --line: #dddddd;
        --accent: #8b6f47;
        --accent-bg: #f5ece0;
        --danger: #8b1e1e;
        --danger-bg: #fff6f6;
        --radius: 16px;
        --f-display: "Lora", Georgia, serif;
        --f-body: "Nunito Sans", system-ui, sans-serif;
        --ease: cubic-bezier(0.25, 0.46, 0.45, 0.94);
      }

      * { box-sizing: border-box; margin: 0; padding: 0; }
      html, body { font-family: var(--f-body); background: var(--bg); color: var(--ink); font-size: 15px; line-height: 1.5; -webkit-font-smoothing: antialiased; }
      a { color: inherit; text-decoration: none; }
      button { font: inherit; }

      .page { max-width: 1200px; margin: 0 auto; padding: 24px 24px 80px; }

      .topbar { display: flex; justify-content: space-between; align-items: center; gap: 16px; margin-bottom: 20px; flex-wrap: wrap; }
      .brand-head { display: flex; flex-direction: column; gap: 6px; }
      .page-logo { display: block; width: 220px; max-width: 60vw; height: 36px; object-fit: contain; object-position: left center; }
      .subtle { color: var(--muted); font-size: 0.88rem; }
      .logout-form { margin: 0; }
      .logout-btn { border: 1px solid var(--line); background: #fff; color: var(--ink); border-radius: 999px; padding: 9px 18px; font-size: 0.82rem; font-weight: 600; cursor: pointer; transition: background 0.15s; }
      .logout-btn:hover { background: #fafafa; }

      .admin-nav { display: inline-flex; gap: 4px; padding: 5px; background: #fff; border: 1px solid var(--line); border-radius: 999px; margin-bottom: 24px; box-shadow: 0 1px 4px rgba(0,0,0,0.06); }
      .admin-nav a { display: inline-flex; align-items: center; justify-content: center; padding: 7px 18px; border-radius: 999px; color: var(--muted); font-size: 0.82rem; font-weight: 600; transition: all 0.2s var(--ease); }
      .admin-nav a:hover { color: var(--ink); background: #f5f5f5; }
      .admin-nav a.active { background: var(--ink); color: #fff; }

      .page-header { display: flex; justify-content: space-between; align-items: flex-end; gap: 20px; margin-bottom: 24px; flex-wrap: wrap; }
      .page-heading { font-family: var(--f-display); font-size: clamp(1.8rem, 4vw, 2.8rem); font-weight: 400; letter-spacing: -0.02em; line-height: 1; margin-bottom: 4px; }
      .page-heading em { font-style: italic; color: var(--accent); }
      .page-desc { color: var(--muted); font-size: 0.88rem; }

      .header-actions { display: flex; gap: 10px; flex-shrink: 0; }
      .btn { display: inline-flex; align-items: center; justify-content: center; padding: 9px 18px; border-radius: 999px; font: inherit; font-size: 0.85rem; font-weight: 600; cursor: pointer; border: 1px solid var(--line); background: #fff; color: var(--ink); text-decoration: none; transition: background 0.15s; }
      .btn:hover { background: #fafafa; }
      .btn.primary { background: var(--ink); color: #fff; border-color: var(--ink); }
      .btn.primary:hover { background: #333; }

      .toolbar { display: flex; justify-content: space-between; align-items: center; gap: 16px; margin-bottom: 16px; flex-wrap: wrap; }
      .search-wrap { flex: 1 1 320px; max-width: 420px; }
      .search-input { width: 100%; min-height: 42px; appearance: none; border: 1px solid var(--line); background: #fff; color: var(--ink); padding: 10px 16px; border-radius: 999px; font: inherit; font-size: 0.88rem; outline: none; transition: border-color 0.2s, box-shadow 0.2s; }
      .search-input::placeholder { color: var(--muted); }
      .search-input:focus { border-color: #aaa; box-shadow: 0 0 0 3px rgba(0,0,0,0.05); }
      .toolbar-meta { color: var(--muted); font-size: 0.82rem; white-space: nowrap; }

      .panel { background: var(--card); border: 1px solid var(--line); border-radius: var(--radius); overflow: hidden; box-shadow: 0 1px 6px rgba(0,0,0,0.06); }
      .table-wrap { width: 100%; overflow-x: auto; }
      table { width: 100%; border-collapse: collapse; min-width: 700px; }
      thead th { text-align: left; font-size: 0.72rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--muted); background: var(--card-warm); border-bottom: 1px solid var(--line); padding: 13px 16px; }
      tbody td { padding: 14px 16px; border-bottom: 1px solid #f0f0f0; vertical-align: middle; }
      tbody tr:last-child td { border-bottom: none; }
      tbody tr:hover td { background: #fafaf8; }

      .client-name { font-family: var(--f-display); font-size: 1rem; font-weight: 500; letter-spacing: -0.01em; }
      .client-slug { font-size: 0.78rem; color: var(--muted); margin-top: 2px; }

      .count-badge { display: inline-flex; align-items: center; justify-content: center; min-width: 30px; padding: 4px 10px; border-radius: 999px; background: var(--accent-bg); color: var(--accent); font-size: 0.8rem; font-weight: 700; font-family: var(--f-display); }

      .row-actions { display: flex; gap: 6px; flex-wrap: wrap; }
      .row-btn { display: inline-flex; align-items: center; justify-content: center; padding: 6px 14px; border-radius: 999px; font: inherit; font-size: 0.78rem; font-weight: 600; cursor: pointer; border: 1px solid var(--line); background: #fff; color: var(--ink); text-decoration: none; transition: background 0.15s; }
      .row-btn:hover { background: #fafafa; }
      .row-btn.danger { color: var(--danger); border-color: #e3caca; }
      .row-btn.danger:hover { background: var(--danger-bg); }
      .row-btn:disabled { opacity: 0.4; cursor: not-allowed; }

      .empty { background: var(--card); border: 1px solid var(--line); border-radius: var(--radius); padding: 48px 32px; text-align: center; color: var(--muted); font-size: 0.95rem; }
      .empty.error { color: var(--danger); }

      .footer-bar { display: flex; justify-content: space-between; align-items: center; gap: 12px; margin-top: 20px; flex-wrap: wrap; }
      .footer-meta { color: var(--muted); font-size: 0.82rem; }
      .pager { display: flex; gap: 8px; }

      .mobile-list { display: none; }
      .mobile-card { background: var(--card); border: 1px solid var(--line); border-radius: var(--radius); padding: 16px; box-shadow: 0 1px 4px rgba(0,0,0,0.05); }
      .mobile-card + .mobile-card { margin-top: 10px; }
      .mobile-head { display: flex; justify-content: space-between; gap: 12px; align-items: start; margin-bottom: 12px; }
      .mobile-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px 16px; margin-bottom: 14px; }
      .label { font-size: 0.7rem; color: var(--muted); margin-bottom: 3px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; }
      .value { font-size: 0.9rem; }

      @media (max-width: 800px) {
        .page { padding: 18px 16px 60px; }
        .table-wrap { display: none; }
        .mobile-list { display: block; }
        .toolbar { align-items: stretch; flex-direction: column; }
        .search-wrap { max-width: none; width: 100%; }
        .page-header { flex-direction: column; align-items: flex-start; }
        .header-actions { width: 100%; }
        .header-actions .btn { flex: 1; justify-content: center; }
      }
    </style>
  </head>

  <body>
    <main class="page">
      <div class="topbar">
        <div class="brand-head">
          <img src="https://imagedelivery.net/Az3x6Ld2gouPPtikaqezkQ/7e9bec6d-9f98-48ad-253e-862ea1563e00/card" alt="Logo" class="page-logo" width="220" height="36" />
          <p class="subtle">Recent shortlists created and sent to buyers.</p>
        </div>
        <form method="post" action="/api/auth/logout" class="logout-form">
          <button type="submit" class="logout-btn">Log out</button>
        </form>
      </div>

      <nav class="admin-nav">
        <a href="/admin/buyers">Buyers</a>
        <a href="/shortlists" class="active">Shortlists</a>
        <a href="/listings">Listings</a>
      </nav>

      <div class="page-header">
        <div>
          <h1 class="page-heading">Client <em>shortlists.</em></h1>
          <p class="page-desc">All shortlists sent to buyers, with quick access to open, copy, or text.</p>
        </div>
        <div class="header-actions">
          <a class="btn primary" href="/listings">New shortlist</a>
        </div>
      </div>

      {shortlistsError ? (
        <div class="empty error">Could not load shortlists.</div>
      ) : shortlists.length === 0 ? (
        <div class="empty">{searchQuery ? `No shortlists found for "${searchQuery}".` : "No shortlists yet."}</div>
      ) : (
        <>
          <div class="toolbar">
            <div class="search-wrap">
              <form method="GET" action="/shortlists">
                <input id="shortlistSearch" class="search-input" type="text" name="q" value={searchQuery} placeholder="Search client or code..." autocomplete="off" />
              </form>
            </div>
            <div class="toolbar-meta">
              {searchQuery ? `${showingFrom}–${showingTo} of ${totalCount} matches` : `${showingFrom}–${showingTo} of ${totalCount}`}
            </div>
          </div>

          <div class="panel table-wrap">
            <table>
              <thead>
                <tr>
                  <th>Client</th>
                  <th>Phone</th>
                  <th>Homes</th>
                  <th>Created</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                {shortlists.map((item) => (
                  <tr>
                    <td>
                      <div class="client-name">{item.clientName}</div>
                      <div class="client-slug">{item.slug}</div>
                    </td>
                    <td style="color:var(--muted);font-size:0.88rem;">{item.phone || "—"}</td>
                    <td><span class="count-badge">{item.itemCount}</span></td>
                    <td style="color:var(--muted);font-size:0.88rem;">{formatDate(item.createdAt)}</td>
                    <td>
                      <div class="row-actions">
                        <a class="row-btn" href={`${item.url}${item.url.includes("?") ? "&" : "?"}agent=1`}>Open</a>
                        <button class="row-btn copy-btn" type="button" data-copy-url={item.url}>Copy link</button>
                        <button class="row-btn text-btn" type="button" data-phone={item.phone} data-url={item.url} data-client={item.clientName} disabled={!item.phone}>Text</button>
                        <button class="row-btn danger delete-btn" type="button" data-delete-id={item.id} data-client={item.clientName}>Delete</button>
                      </div>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

          <div class="mobile-list">
            {shortlists.map((item) => (
              <div class="mobile-card">
                <div class="mobile-head">
                  <div><div class="client-name">{item.clientName}</div><div class="client-slug">{item.slug}</div></div>
                  <span class="count-badge">{item.itemCount}</span>
                </div>
                <div class="mobile-grid">
                  <div><div class="label">Phone</div><div class="value">{item.phone || "—"}</div></div>
                  <div><div class="label">Created</div><div class="value">{formatDate(item.createdAt)}</div></div>
                </div>
                <div class="row-actions">
                  <a class="row-btn" href={`${item.url}${item.url.includes("?") ? "&" : "?"}agent=1`}>Open</a>
                  <button class="row-btn copy-btn" type="button" data-copy-url={item.url}>Copy link</button>
                  <button class="row-btn text-btn" type="button" data-phone={item.phone} data-url={item.url} data-client={item.clientName} disabled={!item.phone}>Text</button>
                  <button class="row-btn danger delete-btn" type="button" data-delete-id={item.id} data-client={item.clientName}>Delete</button>
                </div>
              </div>
            ))}
          </div>

          <div class="footer-bar">
            <div class="footer-meta">{searchQuery ? `Page ${currentPage} · filtered by "${searchQuery}"` : `Page ${currentPage}`}</div>
            <div class="pager">
              {hasPrevPage && <a class="btn" href={buildPageHref(currentPage - 1)}>← Previous</a>}
              {hasNextPage && <a class="btn" href={buildPageHref(currentPage + 1)}>Next →</a>}
            </div>
          </div>
        </>
      )}
    </main>

    <script is:inline>
      document.querySelectorAll("[data-copy-url]").forEach((button) => {
        button.addEventListener("click", async () => {
          const url = button.getAttribute("data-copy-url"); if (!url) return;
          const absoluteUrl = `${window.location.origin}${url}`;
          try { await navigator.clipboard.writeText(absoluteUrl); const original = button.textContent; button.textContent = "Copied ✓"; setTimeout(() => { button.textContent = original; }, 1200); } catch { alert("Could not copy link"); }
        });
      });

      document.querySelectorAll("[data-phone][data-url]").forEach((button) => {
        button.addEventListener("click", () => {
          const phone = button.getAttribute("data-phone"); const url = button.getAttribute("data-url"); const client = button.getAttribute("data-client") || "there";
          if (!phone) { alert("No phone number for this client"); return; }
          const absoluteUrl = `${window.location.origin}${url}`;
          window.location.href = `sms:${phone}?body=${encodeURIComponent(`Hi ${client} - here are a few homes I picked for you: ${absoluteUrl}`)}`;
        });
      });

      document.querySelectorAll("[data-delete-id]").forEach((button) => {
        button.addEventListener("click", async () => {
          const shortlistId = button.getAttribute("data-delete-id"); const client = button.getAttribute("data-client") || "this shortlist";
          if (!shortlistId) return;
          if (!window.confirm(`Delete shortlist for ${client}?`)) return;
          const original = button.textContent; button.textContent = "Deleting..."; button.setAttribute("disabled", "true");
          try {
            const res = await fetch("/api/shortlists/delete", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ shortlistId }) });
            const json = await res.json();
            if (!res.ok || !json.ok) throw new Error(json.error || "Delete failed");
            window.location.reload();
          } catch (err) { alert("Could not delete shortlist"); button.textContent = original; button.removeAttribute("disabled"); }
        });
      });

      const searchInput = document.getElementById("shortlistSearch");
      if (searchInput) {
        let timer;
        searchInput.addEventListener("input", () => { clearTimeout(timer); timer = setTimeout(() => { const form = searchInput.form; if (form) form.submit(); }, 350); });
      }
    </script>
  </body>
</html>
