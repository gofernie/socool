---
import { createClient } from "@supabase/supabase-js";

export const prerender = false;

const supabaseAdmin = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.SUPABASE_SERVICE_ROLE_KEY
);

const pageSize = 20;
const pageParam = Number(Astro.url.searchParams.get("page") || "1");
const currentPage = Number.isFinite(pageParam) && pageParam > 0 ? pageParam : 1;
const searchQuery = (Astro.url.searchParams.get("q") || "").trim();

const from = (currentPage - 1) * pageSize;
const to = from + pageSize - 1;

let shortlistQuery = supabaseAdmin
  .from("shortlist_sends")
  .select(
    `
      id,
      shortlist_slug,
      shortlist_url,
      client_name,
      client_id,
      created_at
    `,
    { count: "exact" }
  )
  .order("created_at", { ascending: false });

if (searchQuery) {
  const safeQuery = searchQuery.replace(/[%_]/g, "\\$&");
  shortlistQuery = shortlistQuery.or(
    `client_name.ilike.%${safeQuery}%,shortlist_slug.ilike.%${safeQuery}%`
  );
}

const {
  data: shortlistsRaw,
  error: shortlistsError,
  count: shortlistsTotalCount
} = await shortlistQuery.range(from, to);

const clientIds = (shortlistsRaw || [])
  .map((row: any) => row.client_id)
  .filter(Boolean);

let clientsById: Record<string, any> = {};

if (clientIds.length) {
  const { data: clientsRaw } = await supabaseAdmin
    .from("clients")
    .select("id, name, phone")
    .in("id", clientIds);

  clientsById = Object.fromEntries(
    (clientsRaw || []).map((client: any) => [client.id, client])
  );
}

const shortlistIds = (shortlistsRaw || []).map((row: any) => row.id);

let itemCountsByShortlistId: Record<string, number> = {};

if (shortlistIds.length) {
  const { data: itemsRaw } = await supabaseAdmin
    .from("shortlist_items")
    .select("id, shortlist_send_id")
    .in("shortlist_send_id", shortlistIds);

  for (const item of itemsRaw || []) {
    const key = item.shortlist_send_id;
    itemCountsByShortlistId[key] = (itemCountsByShortlistId[key] || 0) + 1;
  }
}

const shortlists = (shortlistsRaw || []).map((row: any) => {
  const client = row.client_id ? clientsById[row.client_id] : null;

  return {
    id: row.id,
    slug: row.shortlist_slug,
    url: row.shortlist_url || `/shortlists/${row.shortlist_slug}`,
    clientName: row.client_name || client?.name || "Unnamed client",
    phone: client?.phone || "",
    createdAt: row.created_at,
    itemCount: itemCountsByShortlistId[row.id] || 0
  };
});

const totalCount = shortlistsTotalCount || 0;
const showingFrom = totalCount === 0 ? 0 : from + 1;
const showingTo = Math.min(from + shortlists.length, totalCount);
const hasPrevPage = currentPage > 1;
const hasNextPage = showingTo < totalCount;

function formatDate(value: string | null) {
  if (!value) return " - ";

  try {
    return new Date(value).toLocaleDateString("en-CA", {
      year: "numeric",
      month: "short",
      day: "numeric"
    });
  } catch {
    return value;
  }
}

function buildPageHref(page: number) {
  const params = new URLSearchParams();
  if (page > 1) params.set("page", String(page));
  if (searchQuery) params.set("q", searchQuery);

  const qs = params.toString();
  return qs ? `/shortlists?${qs}` : "/shortlists";
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Shortlists</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <style>
      :root {
        --bg: #f7f7f5;
        --card: #ffffff;
        --text: #1f1f1f;
        --muted: #6b6b6b;
        --line: #dddddd;
        --accent: #111111;
        --radius: 16px;
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        margin: 0;
        padding: 0;
      }

      body {
        font-family: system-ui, sans-serif;
        background: var(--bg);
        color: var(--text);
      }

      .page {
        max-width: 1200px;
        margin: 0 auto;
        padding: 24px;
      }

      .topbar {
        display: flex;
        justify-content: space-between;
        align-items: end;
        gap: 16px;
        margin-bottom: 24px;
        flex-wrap: wrap;
      }

      h1 {
        margin: 0;
        font-size: 2rem;
        line-height: 1.1;
      }

      .subtle {
        margin: 6px 0 0;
        color: var(--muted);
      }

      .top-actions {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
      }

      .btn {
        appearance: none;
        border: 1px solid var(--line);
        background: #fff;
        color: var(--text);
        padding: 10px 14px;
        border-radius: 10px;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        font: inherit;
        transition: background 0.15s ease, border-color 0.15s ease;
      }

      .btn:hover {
        background: #fafafa;
      }

      .btn.primary {
        background: var(--accent);
        color: #fff;
        border-color: var(--accent);
      }

      .toolbar {
        display: flex;
        justify-content: space-between;
        align-items: end;
        gap: 16px;
        margin-bottom: 16px;
        flex-wrap: wrap;
      }

      .search-wrap {
        flex: 1 1 360px;
        max-width: 440px;
      }

      .search-form {
        width: 100%;
      }

      .search-input {
        width: 100%;
        min-height: 44px;
        appearance: none;
        border: 1px solid var(--line);
        background: #fff;
        color: var(--text);
        padding: 12px 14px;
        border-radius: 12px;
        font: inherit;
        outline: none;
      }

      .search-input::placeholder {
        color: var(--muted);
      }

      .search-input:focus {
        border-color: #bdbdbd;
        box-shadow: 0 0 0 3px rgba(0, 0, 0, 0.04);
      }

      .toolbar-meta {
        color: var(--muted);
        font-size: 0.92rem;
        white-space: nowrap;
        margin-bottom: 10px;
      }

      .panel {
        background: var(--card);
        border: 1px solid var(--line);
        border-radius: var(--radius);
        overflow: hidden;
      }

      .table-wrap {
        width: 100%;
        overflow-x: auto;
      }

      table {
        width: 100%;
        border-collapse: collapse;
        min-width: 900px;
      }

      thead th {
        text-align: left;
        font-size: 0.82rem;
        letter-spacing: 0.03em;
        text-transform: uppercase;
        color: var(--muted);
        background: #fcfcfc;
        border-bottom: 1px solid var(--line);
        padding: 14px 16px;
      }

      tbody td {
        padding: 16px;
        border-bottom: 1px solid #efefef;
        vertical-align: middle;
      }

      tbody tr:last-child td {
        border-bottom: none;
      }

      .client {
        font-weight: 600;
      }

      .meta {
        color: var(--muted);
        font-size: 0.92rem;
      }

      .count-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 36px;
        padding: 6px 10px;
        border-radius: 999px;
        border: 1px solid var(--line);
        background: #fcfcfc;
        font-weight: 600;
      }

      .actions {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
      }

      .open-link,
      .copy-btn,
      .text-btn {
        text-decoration: none;
        color: var(--text);
        border: 1px solid var(--line);
        background: #fff;
        padding: 8px 12px;
        border-radius: 10px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        font: inherit;
        transition: background 0.15s ease;
      }

      .open-link:hover,
      .copy-btn:hover,
      .text-btn:hover {
        background: #fafafa;
      }

      .text-btn:disabled {
        opacity: 0.45;
        cursor: not-allowed;
      }

      .delete-btn {
        text-decoration: none;
        color: #8b1e1e;
        border: 1px solid #e3caca;
        background: #fff;
        padding: 8px 12px;
        border-radius: 10px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        font: inherit;
        transition: background 0.15s ease;
      }

      .delete-btn:hover {
        background: #fff6f6;
      }

      .empty {
        background: var(--card);
        border: 1px solid var(--line);
        border-radius: var(--radius);
        padding: 24px;
      }

      .error {
        color: #8b1e1e;
      }

      .mobile-list {
        display: none;
      }

      .mobile-card {
        background: var(--card);
        border: 1px solid var(--line);
        border-radius: var(--radius);
        padding: 16px;
      }

      .mobile-card + .mobile-card {
        margin-top: 12px;
      }

      .mobile-head {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        align-items: start;
        margin-bottom: 10px;
      }

      .mobile-name {
        font-weight: 700;
      }

      .mobile-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px 14px;
        margin-bottom: 14px;
      }

      .label {
        font-size: 0.78rem;
        color: var(--muted);
        margin-bottom: 4px;
      }

      .value {
        font-size: 0.96rem;
      }

      .footer-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        margin-top: 16px;
        flex-wrap: wrap;
      }

      .footer-meta {
        color: var(--muted);
        font-size: 0.92rem;
      }

      .pager {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
      }

      @media (max-width: 800px) {
        .page {
          padding: 18px;
        }

        .table-wrap {
          display: none;
        }

        .mobile-list {
          display: block;
        }

        .toolbar {
          align-items: stretch;
        }

        .search-wrap {
          max-width: none;
          width: 100%;
        }

        .toolbar-meta {
          white-space: normal;
        }
      }
    </style>
  </head>

  <body>
    <main class="page">
      <div class="topbar">
        <div>
          <h1>Shortlists</h1>
          <p class="subtle">Recent client shortlists created by the agent workflow.</p>
        </div>

        <div class="top-actions">
          <a class="btn primary" href="/listings">New shortlist</a>
        </div>
      </div>

      {
        shortlistsError ? (
          <div class="empty error">
            Could not load shortlists.
          </div>
        ) : shortlists.length === 0 ? (
          <div class="empty">
            {searchQuery ? `No shortlists found for "${searchQuery}".` : "No shortlists yet."}
          </div>
        ) : (
          <>
            <div class="toolbar">
              <div class="search-wrap">
                <form class="search-form" method="GET" action="/shortlists">
                  <input
                    id="shortlistSearch"
                    class="search-input"
                    type="text"
                    name="q"
                    value={searchQuery}
                    placeholder="Search client or code..."
                    autocomplete="off"
                  />
                </form>
              </div>

              <div class="toolbar-meta" id="searchCount">
                {searchQuery
                  ? `Showing ${showingFrom} - ${showingTo} of ${totalCount} matches`
                  : `Showing ${showingFrom} - ${showingTo} of ${totalCount}`}
              </div>
            </div>

            <div class="panel table-wrap">
              <table>
                <thead>
                  <tr>
                    <th>Client</th>
                    <th>Phone</th>
                    <th>Homes</th>
                    <th>Created</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody id="shortlistTableBody">
                  {shortlists.map((item) => (
                    <tr>
                      <td>
                        <div class="client">{item.clientName}</div>
                        <div class="meta">{item.slug}</div>
                      </td>
                      <td>{item.phone || " - "}</td>
                      <td>
                        <span class="count-badge">{item.itemCount}</span>
                      </td>
                      <td>{formatDate(item.createdAt)}</td>
                      <td>
                        <div class="actions">
                          <a
                            class="open-link"
                            href={`${item.url}${item.url.includes("?") ? "&" : "?"}agent=1`}
                          >
                            Open
                          </a>
                          <button
                            class="copy-btn"
                            type="button"
                            data-copy-url={item.url}
                          >
                            Copy link
                          </button>
                          <button
                            class="text-btn"
                            type="button"
                            data-phone={item.phone}
                            data-url={item.url}
                            data-client={item.clientName}
                            disabled={!item.phone}
                          >
                            Text
                          </button>
                          <button
                            class="delete-btn"
                            type="button"
                            data-delete-id={item.id}
                            data-client={item.clientName}
                          >
                            Delete
                          </button>
                        </div>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>

            <div class="mobile-list" id="shortlistMobileList">
              {shortlists.map((item) => (
                <div class="mobile-card">
                  <div class="mobile-head">
                    <div>
                      <div class="mobile-name">{item.clientName}</div>
                      <div class="meta">{item.slug}</div>
                    </div>
                    <span class="count-badge">{item.itemCount}</span>
                  </div>

                  <div class="mobile-grid">
                    <div>
                      <div class="label">Phone</div>
                      <div class="value">{item.phone || " - "}</div>
                    </div>
                    <div>
                      <div class="label">Created</div>
                      <div class="value">{formatDate(item.createdAt)}</div>
                    </div>
                  </div>

                  <div class="actions">
                    <a
                      class="open-link"
                      href={`${item.url}${item.url.includes("?") ? "&" : "?"}agent=1`}
                    >
                      Open
                    </a>
                    <button
                      class="copy-btn"
                      type="button"
                      data-copy-url={item.url}
                    >
                      Copy link
                    </button>
                    <button
                      class="text-btn"
                      type="button"
                      data-phone={item.phone}
                      data-url={item.url}
                      data-client={item.clientName}
                      disabled={!item.phone}
                    >
                      Text
                    </button>
                    <button
                      class="delete-btn"
                      type="button"
                      data-delete-id={item.id}
                      data-client={item.clientName}
                    >
                      Delete
                    </button>
                  </div>
                </div>
              ))}
            </div>

            <div class="footer-bar">
              <div class="footer-meta">
                {searchQuery ? `Page ${currentPage} - filtered by "${searchQuery}"` : `Page ${currentPage}`}
              </div>

              <div class="pager">
                {
                  hasPrevPage && (
                    <a class="btn" href={buildPageHref(currentPage - 1)}>
                      Previous
                    </a>
                  )
                }

                {
                  hasNextPage && (
                    <a class="btn" href={buildPageHref(currentPage + 1)}>
                      Load more
                    </a>
                  )
                }
              </div>
            </div>
          </>
        )
      }
    </main>

    <script is:inline>
      document.querySelectorAll("[data-copy-url]").forEach((button) => {
        button.addEventListener("click", async () => {
          const url = button.getAttribute("data-copy-url");
          if (!url) return;

          const absoluteUrl = `${window.location.origin}${url}`;

          try {
            await navigator.clipboard.writeText(absoluteUrl);
            const original = button.textContent;
            button.textContent = "Copied";
            setTimeout(() => {
              button.textContent = original;
            }, 1200);
          } catch {
            alert("Could not copy link");
          }
        });
      });

      document.querySelectorAll("[data-phone][data-url]").forEach((button) => {
        button.addEventListener("click", () => {
          const phone = button.getAttribute("data-phone");
          const url = button.getAttribute("data-url");
          const client = button.getAttribute("data-client") || "there";

          if (!phone) {
            alert("No phone number for this client");
            return;
          }

          const absoluteUrl = `${window.location.origin}${url}`;
          const message = encodeURIComponent(
            `Hi ${client} - here are a few homes I picked for you: ${absoluteUrl}`
          );

          window.location.href = `sms:${phone}?body=${message}`;
        });
      });

      document.querySelectorAll("[data-delete-id]").forEach((button) => {
        button.addEventListener("click", async () => {
          const shortlistId = button.getAttribute("data-delete-id");
          const client = button.getAttribute("data-client") || "this shortlist";

          if (!shortlistId) return;

          const confirmed = window.confirm(`Delete shortlist for ${client}?`);
          if (!confirmed) return;

          const original = button.textContent;
          button.textContent = "Deleting...";
          button.setAttribute("disabled", "true");

          try {
            const res = await fetch("/api/shortlists/delete", {
              method: "POST",
              headers: {
                "Content-Type": "application/json"
              },
              body: JSON.stringify({ shortlistId })
            });

            const json = await res.json();

            if (!res.ok || !json.ok) {
              throw new Error(json.error || "Delete failed");
            }

            window.location.reload();
          } catch (err) {
            alert("Could not delete shortlist");
            button.textContent = original;
            button.removeAttribute("disabled");
          }
        });
      });

      const searchInput = document.getElementById("shortlistSearch");

      if (searchInput) {
        let timer;

        searchInput.addEventListener("input", () => {
          clearTimeout(timer);
          timer = setTimeout(() => {
            const form = searchInput.form;
            if (form) form.submit();
          }, 350);
        });
      }
    </script>
  </body>
</html>