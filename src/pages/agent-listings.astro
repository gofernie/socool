---
export const prerender = false;

// Stub: replace with real Supabase/DB fetch
const slug = Astro.params.slug || "chris-crump";

// In production fetch from /api/agent-page?slug=...
const page = {
  agentName: "Chris Crump",
  agentTitle: "Real Estate Advisor",
  phone: "250.619.0390",
  email: "chris@chriscrump.ca",
  city: "Nanaimo",
  heroEyebrow: "Curated by Chris Crump",
  heroHeading: "Homes worth watching",
  heroIntro: "A simple, curated place to explore homes — organised by property type, price point, and what buyers are watching right now.",
  agentPickTitle: "Not a giant listing portal.",
  agentPickText: "Just the homes and categories buyers actually ask about most.",
  agentBio: "A local real estate advisor helping buyers make sense of the market with clear, curated listing guidance.",
  cityIntro: "Nanaimo is Vancouver Island's second-largest city — and one of its most underrated markets for buyers who want value without sacrificing lifestyle.",
  cityNotes: "The market spans walkable downtown neighbourhoods, ocean-view North Nanaimo, and entry-level pockets buyers don't always know to look at.",
  linkedinUrl: "",
  twitterUrl: "",
  instagramUrl: "",
  facebookUrl: "",
  socialTitle: "Follow along.",
  socialIntro: "Market notes, listing updates, and local real estate context.",
  newListingsTitle: "New listings.",
  newListingsIntro: "The latest homes to hit the market.",
  groups: [
    { kicker: "Low-maintenance living", title: "Condos", text: "Explore condo options from the latest listing data.", href: "/explore?type=condo&sort=newest" },
    { kicker: "Room to grow", title: "Single-family homes", text: "Detached homes from the latest listing data.", href: "/explore?type=house&sort=newest" },
    { kicker: "Buyer sweet spot", title: "Popular under $800k", text: "Homes in one of the most watched price ranges.", href: "/explore?maxPrice=800&sort=newest" },
    { kicker: "Fresh to market", title: "New listings", text: "Recently listed homes worth watching.", href: "/explore?sort=newest" },
  ]
};

// Stub listing data — replace with real Supabase query
const listings: any[] = [];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>{page.agentName} — {page.agentTitle}</title>
  <meta name="description" content={page.heroIntro} />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  
  
  <link href="https://?family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet" />

  <style>
    :root {
      --bg: #f4efe7;
      --surface: #ffffff;
      --surface-soft: #fffaf1;
      --ink: #181614;
      --muted: rgba(24,22,20,0.62);
      --line: rgba(24,22,20,0.13);
      --accent: #ff4d00;
      --accent-soft: rgba(255,77,0,0.10);
      --hero-bg: #0a0a0a;
      --hero-ink: #ffffff;
      --hero-muted: rgba(255,255,255,0.65);
      --serif: "DM Serif Display", Georgia, "Times New Roman", serif;
      --sans: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      --radius-lg: 22px;
      --radius-md: 16px;
    }

    *, *::before, *::after { box-sizing: border-box; }

    body {
      margin: 0;
      background: var(--bg);
      color: var(--ink);
      font-family: var(--sans);
      font-size: 16px;
      line-height: 1.6;
    }

    a { color: inherit; text-decoration: none; }

    .page {
      max-width: 1220px;
      margin: 0 auto;
      padding: 24px 20px 100px;
    }

    /* ── HERO ───────────────────────────────── */
    .agent-hero {
      position: relative;
      overflow: hidden;
      background: var(--hero-bg);
      color: var(--hero-ink);
      border-radius: var(--radius-lg);
      padding: clamp(36px, 5vw, 62px);
      margin-bottom: 20px;
    }

    .agent-hero::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse at 80% 0%, rgba(255,77,0,0.18) 0%, transparent 52%),
        radial-gradient(ellipse at 20% 100%, rgba(255,77,0,0.07) 0%, transparent 44%);
      pointer-events: none;
    }

    .hero-inner {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: minmax(0,1.5fr) minmax(260px,0.5fr);
      gap: 40px;
      align-items: end;
    }

    .hero-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 20px;
      padding: 7px 14px;
      border-radius: 999px;
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.16);
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--hero-muted);
    }

    .hero-eyebrow-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--accent);
      flex-shrink: 0;
    }

    .agent-hero h1 {
      margin: 0;
      font-family: var(--serif);
      font-size: clamp(3.2rem, 8vw, 7rem);
      line-height: 0.88;
      letter-spacing: -0.04em;
      font-weight: 400;
      font-style: italic;
    }

    .accent-dot { color: var(--accent); }

    .hero-copy {
      max-width: 640px;
      margin: 22px 0 0;
      color: var(--hero-muted);
      font-size: clamp(1rem, 1.8vw, 1.18rem);
      line-height: 1.58;
    }

    .hero-agent-card {
      background: rgba(255,255,255,0.07);
      border: 1px solid rgba(255,255,255,0.14);
      border-radius: 18px;
      padding: 24px;
      backdrop-filter: blur(10px);
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .agent-avatar {
      width: 64px;
      height: 64px;
      border-radius: 50%;
      background: rgba(255,77,0,0.22);
      border: 2px solid rgba(255,77,0,0.5);
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--serif);
      font-size: 1.4rem;
      font-style: italic;
      color: var(--accent);
    }

    .agent-card-name {
      font-size: 1.05rem;
      font-weight: 700;
      margin: 0 0 2px;
    }

    .agent-card-title {
      font-size: 0.84rem;
      color: var(--hero-muted);
      margin: 0;
    }

    .agent-card-divider {
      height: 1px;
      background: rgba(255,255,255,0.12);
    }

    .agent-contact-row {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .agent-contact-item {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 0.88rem;
      color: var(--hero-muted);
    }

    .agent-contact-icon {
      width: 28px;
      height: 28px;
      border-radius: 8px;
      background: rgba(255,255,255,0.07);
      border: 1px solid rgba(255,255,255,0.1);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .agent-contact-icon svg {
      width: 14px;
      height: 14px;
      stroke: var(--hero-muted);
      fill: none;
      stroke-width: 1.8;
      stroke-linecap: round;
      stroke-linejoin: round;
    }

    .agent-cta-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      padding: 13px 18px;
      border-radius: 999px;
      background: var(--accent);
      color: white;
      font-weight: 700;
      font-size: 0.9rem;
      border: 0;
      cursor: pointer;
      text-align: center;
      transition: opacity 0.15s;
    }

    .agent-cta-btn:hover { opacity: 0.88; }

    .hero-stats {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 14px;
      margin-top: 36px;
    }

    .stat-card {
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.13);
      border-radius: 14px;
      padding: 18px;
    }

    .stat-value {
      font-size: 1.5rem;
      font-weight: 800;
      margin-bottom: 5px;
    }

    .stat-label {
      color: var(--hero-muted);
      font-size: 0.85rem;
    }

    /* ── PICK CARD ──────────────────────────── */
    .pick-band {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 18px;
      margin-bottom: 20px;
    }

    .pick-card {
      background: var(--surface);
      border: 1px solid var(--line);
      border-radius: var(--radius-lg);
      padding: 26px;
    }

    .pick-kicker {
      color: var(--accent);
      font-size: 0.75rem;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      margin-bottom: 10px;
    }

    .pick-card h2 {
      margin: 0 0 10px;
      font-family: var(--serif);
      font-size: clamp(1.6rem, 2.5vw, 2.4rem);
      line-height: 0.96;
      letter-spacing: -0.03em;
      font-weight: 400;
      font-style: italic;
    }

    .pick-card p {
      margin: 0;
      color: var(--muted);
      line-height: 1.6;
    }

    .pick-card--dark {
      background: var(--hero-bg);
      color: var(--hero-ink);
    }

    .pick-card--dark .pick-kicker {
      color: var(--accent);
    }

    .pick-card--dark h2 {
      color: var(--hero-ink);
    }

    .pick-card--dark p {
      color: var(--hero-muted);
    }

    /* ── LISTING GROUPS ─────────────────────── */
    .section-label {
      display: flex;
      align-items: center;
      gap: 12px;
      margin: 40px 0 18px;
    }

    .section-label h2 {
      margin: 0;
      font-family: var(--serif);
      font-size: clamp(2rem, 4vw, 3.6rem);
      line-height: 0.92;
      letter-spacing: -0.04em;
      font-weight: 400;
      font-style: italic;
    }

    .section-label .accent-dot { color: var(--accent); }

    .groups-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
      margin-bottom: 20px;
    }

    .group-card {
      position: relative;
      overflow: hidden;
      background: var(--surface);
      border: 1px solid var(--line);
      border-radius: var(--radius-md);
      padding: 22px;
      display: flex;
      flex-direction: column;
      gap: 10px;
      text-decoration: none;
      color: var(--ink);
      transition: transform 0.16s ease, box-shadow 0.16s ease;
    }

    .group-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 16px 40px rgba(24,22,20,0.10);
    }

    .group-card-kicker {
      font-size: 0.75rem;
      font-weight: 800;
      letter-spacing: 0.07em;
      text-transform: uppercase;
      color: var(--accent);
    }

    .group-card h3 {
      margin: 0;
      font-family: var(--serif);
      font-size: 1.45rem;
      line-height: 1.0;
      letter-spacing: -0.025em;
      font-weight: 400;
      font-style: italic;
    }

    .group-card p {
      margin: 0;
      color: var(--muted);
      font-size: 0.9rem;
      line-height: 1.5;
      flex: 1;
    }

    .group-card-arrow {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 0.84rem;
      font-weight: 700;
      color: var(--accent);
      margin-top: auto;
    }

    .group-card-arrow svg {
      width: 14px;
      height: 14px;
      stroke: currentColor;
      fill: none;
      stroke-width: 2;
      stroke-linecap: round;
      stroke-linejoin: round;
    }

    /* ── LIVE LISTINGS ──────────────────────── */
    .listings-band {
      position: relative;
      overflow: hidden;
      background: var(--hero-bg);
      color: var(--hero-ink);
      border-radius: var(--radius-lg);
      padding: clamp(28px, 4vw, 48px);
      margin-bottom: 20px;
    }

    .listings-band::before {
      content: "";
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse at top right, rgba(255,77,0,0.15) 0%, transparent 50%);
      pointer-events: none;
    }

    .listings-band-inner { position: relative; z-index: 1; }

    .listings-band-head {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 20px;
      margin-bottom: 26px;
    }

    .listings-band h2 {
      margin: 0;
      font-family: var(--serif);
      font-size: clamp(2.2rem, 5vw, 4.4rem);
      line-height: 0.9;
      letter-spacing: -0.045em;
      font-weight: 400;
      font-style: italic;
    }

    .listings-band-copy {
      color: var(--hero-muted);
      margin: 10px 0 0;
      font-size: 1rem;
    }

    .listings-explore-btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 12px 20px;
      border-radius: 999px;
      background: rgba(255,255,255,0.1);
      border: 1px solid rgba(255,255,255,0.18);
      color: var(--hero-ink);
      font-weight: 700;
      font-size: 0.9rem;
      white-space: nowrap;
      transition: background 0.15s;
    }

    .listings-explore-btn:hover {
      background: rgba(255,255,255,0.18);
    }

    .listings-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 16px;
    }

    .listing-card {
      background: rgba(255,255,255,0.07);
      border: 1px solid rgba(255,255,255,0.13);
      border-radius: 16px;
      overflow: hidden;
      color: var(--hero-ink);
      transition: transform 0.16s ease;
      cursor: pointer;
    }

    .listing-card:hover { transform: translateY(-3px); }

    .listing-card img {
      width: 100%;
      aspect-ratio: 16/10;
      object-fit: cover;
      display: block;
    }

    .listing-card-body { padding: 16px; }

    .listing-price {
      font-size: 1.3rem;
      font-weight: 800;
      margin-bottom: 5px;
    }

    .listing-address {
      font-size: 0.9rem;
      color: var(--hero-muted);
      margin-bottom: 8px;
      line-height: 1.35;
    }

    .listing-meta {
      font-size: 0.84rem;
      color: rgba(255,255,255,0.5);
    }

    .listings-empty {
      padding: 40px 20px;
      text-align: center;
      color: var(--hero-muted);
      font-size: 1rem;
    }

    /* ── CITY SECTION ───────────────────────── */
    .city-section {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 18px;
      margin-bottom: 20px;
    }

    .city-card {
      background: var(--surface);
      border: 1px solid var(--line);
      border-radius: var(--radius-lg);
      padding: 28px;
    }

    .city-card-kicker {
      font-size: 0.75rem;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 12px;
    }

    .city-card h2 {
      margin: 0 0 14px;
      font-family: var(--serif);
      font-size: clamp(1.8rem, 3vw, 2.8rem);
      line-height: 0.96;
      letter-spacing: -0.03em;
      font-weight: 400;
      font-style: italic;
    }

    .city-card p {
      margin: 0;
      color: var(--muted);
      line-height: 1.65;
    }

    /* ── BIO SECTION ────────────────────────── */
    .bio-section {
      position: relative;
      overflow: hidden;
      background: var(--hero-bg);
      color: var(--hero-ink);
      border-radius: var(--radius-lg);
      padding: clamp(32px, 5vw, 56px);
      margin-bottom: 20px;
      display: grid;
      grid-template-columns: minmax(0,1.2fr) minmax(280px,0.8fr);
      gap: 48px;
      align-items: center;
    }

    .bio-section::before {
      content: "";
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse at 0% 50%, rgba(255,77,0,0.10) 0%, transparent 50%);
      pointer-events: none;
    }

    .bio-inner { position: relative; z-index: 1; }

    .bio-kicker {
      font-size: 0.75rem;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 14px;
    }

    .bio-section h2 {
      margin: 0 0 18px;
      font-family: var(--serif);
      font-size: clamp(2rem, 4vw, 4rem);
      line-height: 0.92;
      letter-spacing: -0.04em;
      font-weight: 400;
      font-style: italic;
    }

    .bio-section p {
      margin: 0;
      color: var(--hero-muted);
      line-height: 1.65;
      font-size: 1.02rem;
    }

    .bio-side { position: relative; z-index: 1; }

    .bio-contact-card {
      background: rgba(255,255,255,0.07);
      border: 1px solid rgba(255,255,255,0.14);
      border-radius: 18px;
      padding: 24px;
      display: flex;
      flex-direction: column;
      gap: 14px;
    }

    .bio-contact-card strong {
      display: block;
      font-size: 0.85rem;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 4px;
    }

    .bio-contact-item {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .bio-contact-label {
      font-size: 0.8rem;
      color: rgba(255,255,255,0.45);
      font-weight: 600;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    .bio-contact-value {
      font-size: 1rem;
      color: var(--hero-ink);
      font-weight: 600;
    }

    .bio-contact-divider {
      height: 1px;
      background: rgba(255,255,255,0.1);
    }

    /* ── SOCIAL SECTION ─────────────────────── */
    .social-section {
      background: var(--surface);
      border: 1px solid var(--line);
      border-radius: var(--radius-lg);
      padding: 28px;
      margin-bottom: 20px;
    }

    .social-kicker {
      font-size: 0.75rem;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 10px;
    }

    .social-section h2 {
      margin: 0 0 8px;
      font-family: var(--serif);
      font-size: clamp(1.8rem, 3vw, 2.8rem);
      line-height: 0.96;
      letter-spacing: -0.03em;
      font-weight: 400;
      font-style: italic;
    }

    .social-section p {
      margin: 0 0 20px;
      color: var(--muted);
    }

    .social-links {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }

    .social-pill {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 16px;
      border-radius: 999px;
      background: var(--surface-soft);
      border: 1px solid var(--line);
      font-size: 0.88rem;
      font-weight: 700;
      color: var(--ink);
      transition: background 0.15s;
    }

    .social-pill:hover {
      background: var(--ink);
      color: white;
      border-color: var(--ink);
    }

    .social-pill svg {
      width: 16px;
      height: 16px;
      fill: currentColor;
    }

    /* ── RESPONSIVE ─────────────────────────── */
    @media (max-width: 900px) {
      .hero-inner { grid-template-columns: 1fr; }
      .hero-agent-card { max-width: 340px; }
      .groups-grid { grid-template-columns: 1fr 1fr; }
      .pick-band { grid-template-columns: 1fr; }
      .city-section { grid-template-columns: 1fr; }
      .bio-section { grid-template-columns: 1fr; }
      .hero-stats { grid-template-columns: 1fr 1fr; }
    }

    @media (max-width: 600px) {
      .page { padding: 14px 14px 80px; }
      .groups-grid { grid-template-columns: 1fr; }
      .hero-stats { grid-template-columns: 1fr; }
      .listings-band-head { flex-direction: column; align-items: flex-start; }
    }
  </style>
</head>

<body>
  <main class="page">

    <!-- ── HERO ─────────────────────────────── -->
    <section class="agent-hero">
      <div class="hero-inner">
        <div>
          <div class="hero-eyebrow">
            <span class="hero-eyebrow-dot"></span>
            {page.heroEyebrow}
          </div>

          <h1>
            {page.heroHeading}<span class="accent-dot">.</span>
          </h1>

          <p class="hero-copy">{page.heroIntro}</p>
        </div>

        <aside class="hero-agent-card">
          <div class="agent-avatar">
            {page.agentName.split(" ").map((n: string) => n[0]).join("")}
          </div>

          <div>
            <p class="agent-card-name">{page.agentName}</p>
            <p class="agent-card-title">{page.agentTitle} · {page.city}</p>
          </div>

          <div class="agent-card-divider"></div>

          <div class="agent-contact-row">
            {page.phone && (
              <a href={`tel:${page.phone}`} class="agent-contact-item">
                <span class="agent-contact-icon">
                  <svg viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 11.8a19.79 19.79 0 01-3.07-8.67A2 2 0 012 1h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.09 8.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
                </span>
                {page.phone}
              </a>
            )}

            {page.email && (
              <a href={`mailto:${page.email}`} class="agent-contact-item">
                <span class="agent-contact-icon">
                  <svg viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                </span>
                {page.email}
              </a>
            )}
          </div>

          <a href={`mailto:${page.email}`} class="agent-cta-btn">
            Get in touch
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </aside>
      </div>

      <div class="hero-stats">
        <div class="stat-card">
          <div class="stat-value">4</div>
          <div class="stat-label">Curated categories</div>
        </div>
        <div class="stat-card">
          <div class="stat-value">{page.city}</div>
          <div class="stat-label">Primary market</div>
        </div>
        <div class="stat-card">
          <div class="stat-value">Live</div>
          <div class="stat-label">Listing data</div>
        </div>
      </div>
    </section>

    <!-- ── AGENT PICK BAND ───────────────────── -->
    <div class="pick-band">
      <div class="pick-card">
        <div class="pick-kicker">Agent perspective</div>
        <h2>{page.agentPickTitle}</h2>
        <p>{page.agentPickText}</p>
      </div>

      <div class="pick-card pick-card--dark">
        <div class="pick-kicker">What buyers are watching</div>
        <h2>Homes that move<span class="accent-dot">.</span></h2>
        <p>Updated from live MLS data. The categories below reflect what active buyers in {page.city} are asking about most.</p>
      </div>
    </div>

    <!-- ── LISTING GROUPS ────────────────────── -->
    <div class="section-label">
      <h2>Browse by category<span class="accent-dot">.</span></h2>
    </div>

    <div class="groups-grid">
      {page.groups.map((group: any) => (
        <a href={group.href} class="group-card">
          <div class="group-card-kicker">{group.kicker}</div>
          <h3>{group.title}</h3>
          <p>{group.text}</p>
          <span class="group-card-arrow">
            Explore
            <svg viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </span>
        </a>
      ))}
    </div>

    <!-- ── LIVE LISTINGS ─────────────────────── -->
    <section class="listings-band">
      <div class="listings-band-inner">
        <div class="listings-band-head">
          <div>
            <h2>{page.newListingsTitle}<span class="accent-dot">.</span></h2>
            <p class="listings-band-copy">{page.newListingsIntro}</p>
          </div>
          <a href="/explore" class="listings-explore-btn">
            See all listings
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>

        {listings.length > 0 ? (
          <div class="listings-grid">
            {listings.slice(0, 6).map((listing: any) => (
              <article class="listing-card">
                <img
                  src={listing.image_url || "https://placehold.co/800x500?text=Listing"}
                  alt={listing.address || "Listing"}
                  loading="lazy"
                />
                <div class="listing-card-body">
                  <div class="listing-price">${(listing.price || 0).toLocaleString()}</div>
                  <div class="listing-address">{listing.address}</div>
                  <div class="listing-meta">{listing.beds || "-"} bed · {listing.baths || "-"} bath</div>
                </div>
              </article>
            ))}
          </div>
        ) : (
          <div class="listings-empty">
            Live listings load here — configure the city and filters in the editor.
          </div>
        )}
      </div>
    </section>

    <!-- ── CITY SECTION ──────────────────────── -->
    {(page.cityIntro || page.cityNotes) && (
      <div class="city-section">
        {page.cityIntro && (
          <div class="city-card">
            <div class="city-card-kicker">The market</div>
            <h2>{page.city} today<span class="accent-dot">.</span></h2>
            <p>{page.cityIntro}</p>
          </div>
        )}

        {page.cityNotes && (
          <div class="city-card">
            <div class="city-card-kicker">Local context</div>
            <h2>What to know<span class="accent-dot">.</span></h2>
            <p>{page.cityNotes}</p>
          </div>
        )}
      </div>
    )}

    <!-- ── BIO ───────────────────────────────── -->
    <section class="bio-section">
      <div class="bio-inner">
        <div class="bio-kicker">About your agent</div>
        <h2>{page.agentName}<span class="accent-dot">.</span></h2>
        <p>{page.agentBio}</p>
      </div>

      <aside class="bio-side">
        <div class="bio-contact-card">
          <strong>Get in touch</strong>

          {page.phone && (
            <div class="bio-contact-item">
              <span class="bio-contact-label">Phone</span>
              <a href={`tel:${page.phone}`} class="bio-contact-value">{page.phone}</a>
            </div>
          )}

          <div class="bio-contact-divider"></div>

          {page.email && (
            <div class="bio-contact-item">
              <span class="bio-contact-label">Email</span>
              <a href={`mailto:${page.email}`} class="bio-contact-value">{page.email}</a>
            </div>
          )}

          <div class="bio-contact-divider"></div>

          {page.city && (
            <div class="bio-contact-item">
              <span class="bio-contact-label">Market</span>
              <span class="bio-contact-value">{page.city}, BC</span>
            </div>
          )}

          <a href={`mailto:${page.email}`} class="agent-cta-btn" style="margin-top: 8px;">
            Send a message
          </a>
        </div>
      </aside>
    </section>

    <!-- ── SOCIAL ────────────────────────────── -->
    {(page.socialTitle || page.linkedinUrl || page.twitterUrl || page.instagramUrl || page.facebookUrl) && (
      <section class="social-section">
        <div class="social-kicker">Connect</div>
        <h2>{page.socialTitle || "Follow along."}</h2>
        {page.socialIntro && <p>{page.socialIntro}</p>}

        <div class="social-links">
          {page.linkedinUrl && (
            <a href={page.linkedinUrl} class="social-pill" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
              LinkedIn
            </a>
          )}

          {page.twitterUrl && (
            <a href={page.twitterUrl} class="social-pill" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2c9 5 20 0 20-11.5a4.5 4.5 0 00-.08-.83A7.72 7.72 0 0023 3z"/></svg>
              X / Twitter
            </a>
          )}

          {page.instagramUrl && (
            <a href={page.instagramUrl} class="social-pill" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
              Instagram
            </a>
          )}

          {page.facebookUrl && (
            <a href={page.facebookUrl} class="social-pill" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
              Facebook
            </a>
          )}
        </div>
      </section>
    )}

  </main>
</body>
</html>
