---
import { createClient } from "@supabase/supabase-js";
import Layout from "../../layouts/Layout.astro";
import ShortlistReviewModal from "../../components/ShortlistReviewModal.astro";
import IntentModalController from "../../components/IntentModalController.astro";
import SiteNav from "../../components/SiteNav.astro";
import { getSite } from "../../lib/getSite";
import "../../styles/intent-modal.css";
import "../../styles/area-page.css";
import "../../styles/page-hero.css";
import RelatedIntentCards from "../../components/RelatedIntentCards.astro";
import { getNavIntentPages } from "../../lib/getNavIntentPages";

export const prerender = false;
const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.SUPABASE_SERVICE_ROLE_KEY
);

const googleMapsApiKey = import.meta.env.PUBLIC_GOOGLE_MAPS_API_KEY || "";

const slug = Astro.params.slug || "";
const city = Astro.params.city || "nanaimo";

const site = await getSite(Astro.url.hostname);

const accentColor =
  site?.accent_color ||
  "#2f6f73";

const { data: page, error: pageError } = await supabase
  .from("intent_pages")
  .select("*")
  .eq("slug", slug)
  .eq("city", city)
  .single();

if (!page || pageError) {
  return Astro.redirect("/404");
}

const { data: featureRows } = await supabase
  .from("intent_page_features")
  .select("*")
  .eq("intent_page_id", page.id);

const features = (featureRows || []).map((f) => f.feature_key);
const { data: areaBoundaryRows = [] } = await supabase
  .from("area_boundaries")
  .select("area_slug, area_name")
  .eq("city", city);

const areas = areaBoundaryRows
  .map((r) => r.area_name || String(r.area_slug || "").replace(/-/g, " "))
  .filter(Boolean)
  .sort((a, b) => a.localeCompare(b));

const { data: navRows = [] } = await supabase
  .from("listing_rows")
  .select("normalized_type")
  .eq("normalized_city", city)
  .not("normalized_type", "is", null);

const propertyTypes = [...new Set(
  navRows
    .map((row) => String(row.normalized_type || "").trim())
    .filter((item) => item && item !== "unknown")
)].sort((a, b) => a.localeCompare(b));

const navIntentPages = await getNavIntentPages(supabase, city);

const { data: areaIntentPages } = await supabase
  .from("intent_pages")
  .select("area, slug, hero_heading")
 .eq("city", city)
  .eq("is_published", true)
  .not("area", "is", null)
  .order("area", { ascending: true });
let query = supabase
  .from("listing_rows")
  .select("*")
  .eq("status", "A")
  .eq("normalized_city", city);

if (page.area) {
  const normalizedPageArea = String(page.area)
    .toLowerCase()
    .trim()
    .replace(/\s+/g, " ");

  query = query.eq("normalized_area", normalizedPageArea);
}

const propertyTypeMap: Record<string, string> = {
  home: "house",
  homes: "house",
  house: "house",
  houses: "house",

  condo: "condo",
  condos: "condo",
  apartment: "condo",
  apartments: "condo",

  townhome: "townhouse",
  townhomes: "townhouse",
  townhouse: "townhouse",
  townhouses: "townhouse",

  mobile: "mobile",
  mobiles: "mobile",
  manufactured: "mobile",
  land: "land",
};

const normalizedPropertyType =
  propertyTypeMap[String(page.property_type || "").toLowerCase()] ||
  String(page.property_type || "").toLowerCase();

if (normalizedPropertyType) {
  query = query.eq("normalized_type", normalizedPropertyType);
}

if (page.price_min) {
  query = query.gte("price", page.price_min);
}

if (page.price_max) {
  query = query.lte("price", page.price_max);
}

if (page.waterfront_type === "waterfront") {
  query = query.eq("waterfront", true);
}

if (page.waterfront_type === "oceanfront") {
  if (city === "parksville") {
    query = query.eq("waterfront", true);
  } else {
    query = query
      .eq("waterfront", true)
      .ilike("view_type", "%Ocean%");
  }
}

if (page.waterfront_type === "riverfront") {
  query = query
    .eq("waterfront", true)
    .ilike("view_type", "%River%");
}

if (page.waterfront_type === "lakefront") {
  query = query
    .eq("waterfront", true)
    .ilike("view_type", "%Lake%");
}

if (!page.waterfront_type && page.requires_waterfront) {
  query = query.eq("waterfront", true);
}

if (page.requires_ocean_view) {
  query = query.eq("ocean_view", true);
}

const featureTerms: Record<string, string[]> = {
  yard: ["yard", "fenced", "outdoor"],
  garage: ["garage", "shop"],
  suite: ["suite", "income", "mortgage helper"],
  updated: ["updated", "renovated", "modern"],
  views: ["ocean view", "water view", "view"],
};

// Feature terms are used for page context/refinement,
// but should not hard-filter the initial listing set.

console.log("INTENT QUERY DEBUG", {
  slug,
  pageArea: page.area,
  propertyType: page.property_type,
  normalizedPropertyType,
  priceMin: page.price_min,
  priceMax: page.price_max,
});

const hasPolygonSearch = Boolean(page.polygon_geojson);

const listingLimit = hasPolygonSearch ? 1000 : 200;

const defaultSort = page.default_sort || "newest";

if (defaultSort === "price-asc") {
  query = query.order("price", { ascending: true });
} else if (defaultSort === "price-desc") {
  query = query.order("price", { ascending: false });
} else if (defaultSort === "beds-desc") {
  query = query.order("beds", { ascending: false });
} else if (defaultSort === "sqft-desc") {
  query = query.order("sqft", { ascending: false });
} else {
  query = query.order("listed_at", { ascending: false });
}

const { data: rawListings, error: listingsError } = await query.limit(listingLimit);

let listings = rawListings || [];
function getPolygonGeometry(geojson: any) {
  if (!geojson) return null;

  if (geojson.type === "Feature") {
    return geojson.geometry || null;
  }

  if (geojson.type === "FeatureCollection") {
    return geojson.features?.[0]?.geometry || null;
  }

  return geojson;
}

function pointInPolygon(point: [number, number], geojson: any) {
  const polygon = getPolygonGeometry(geojson);

  if (!polygon?.coordinates?.[0]) return false;

  const [x, y] = point;

  const rings =
    polygon.type === "MultiPolygon"
      ? polygon.coordinates.flat()
      : polygon.coordinates;

  return rings.some((ring: any[]) => {
    let inside = false;

    for (let i = 0, j = ring.length - 1; i < ring.length; j = i++) {
      const xi = Number(ring[i][0]);
      const yi = Number(ring[i][1]);
      const xj = Number(ring[j][0]);
      const yj = Number(ring[j][1]);

      const intersect =
        yi > y !== yj > y &&
        x < ((xj - xi) * (y - yi)) / (yj - yi) + xi;

      if (intersect) inside = !inside;
    }

    return inside;
  });
}

if (hasPolygonSearch) {  listings = listings.filter((listing) => {
    const lat = Number(listing.lat);
    const lng = Number(listing.lng);

    if (!Number.isFinite(lat) || !Number.isFinite(lng)) return false;

    return pointInPolygon(
      [lng, lat],
      page.polygon_geojson
    );
  });

  console.log(
    "POLYGON FILTER",
    listings.length,
    "matches"
  );

  console.log(
  "POLYGON GEOJSON",
  JSON.stringify(page.polygon_geojson)
);
}


console.log("INTENT LISTINGS DEBUG", {
  slug,
  count: listings?.length || 0,
  error: listingsError,
});

const { data: relatedIntentPagesRaw = [] } = await supabase
  .from("intent_pages")
  .select("*")
  .eq("city", city)
  .eq("is_published", true)
  .neq("slug", slug);

function scoreRelatedIntent(intent: any) {
  let score = 0;

  if (intent.waterfront_type && intent.waterfront_type === page.waterfront_type) {
    score += 50;
  }

  if (intent.property_type && intent.property_type === page.property_type) {
    score += 30;
  }

  if (intent.area && intent.area === page.area) {
    score += 20;
  }

  if (
    intent.price_max &&
    page.price_max &&
    Math.abs(Number(intent.price_max) - Number(page.price_max)) <= 150000
  ) {
    score += 10;
  }

  return score;
}
console.log("RELATED INTENT LOCAL DEBUG", {
  city,
  slug,
  rawCount: relatedIntentPagesRaw?.length || 0,
  sample: relatedIntentPagesRaw?.slice?.(0, 3),
});
const relatedIntentPages = relatedIntentPagesRaw
  .map((intent) => ({
    ...intent,
    related_score: scoreRelatedIntent(intent),
  }))
  .sort((a, b) => b.related_score - a.related_score)
  .slice(0, 8);

function formatPrice(price: number) {
  return `$${Number(price || 0).toLocaleString()}`;
}
function formatAddress(value: any): string {
  if (!value) return "";
  let obj = value;
  if (typeof value === "string") {
    const trimmed = value.trim();
    if (!trimmed.startsWith("{")) return trimmed;
    try { obj = JSON.parse(trimmed); } catch { return ""; }
  }
  if (typeof obj !== "object" || Array.isArray(obj)) return "";
  return [obj.streetNumber, obj.streetName || obj.streetAddress, obj.streetSuffix, obj.unitNumber ? `#${obj.unitNumber}` : ""]
    .filter(Boolean).join(" ").trim();
}

function normalizeImageUrl(url: any) {
  const value = String(url || "").trim();

  if (!value) return "";
  if (value.startsWith("http://") || value.startsWith("https://")) return value;
  if (value.startsWith("/vreb/")) return `https://cdn.repliers.io${value}`;
  if (value.startsWith("/")) return `https://cdn.repliers.io${value}`;
  if (value.startsWith("vreb/")) return `https://cdn.repliers.io/${value}`;

  return value;
}

const listingCount = listings?.length || 0;
const priceLabel = page.price_max
  ? `Under ${formatPrice(page.price_max)}`
  : page.price_min
    ? `${formatPrice(page.price_min)}+`
    : "Live market";

let interruptTitle = "Want to steer the next few matches?";
let interruptDescription =
  "Pick a direction to guide what shows up next, or keep browsing and react to homes as you go.";

if (
  page.waterfront_type === "oceanfront" ||
  slug.includes("oceanfront")
) {
  interruptTitle = "Still looking for the right stretch of waterfront?";
interruptDescription =
  "You've viewed a few oceanfront properties. What would make the next group a better fit?";
}

else if (
  page.requires_ocean_view ||
  slug.includes("ocean-view")
) {
  interruptTitle = "What's most important about the view?";
  interruptDescription =
    "Tell us what kind of ocean view property you'd like to see more of.";
}

else if (
  slug.includes("family")
) {
  interruptTitle = "What would make the next homes a better fit?";
  interruptDescription =
    "Help us narrow in on the homes your family is most likely to love.";
}

else if (
  normalizedPropertyType === "condo"
) {
  interruptTitle = "Let's refine your condo search.";
  interruptDescription =
    "What matters most in your ideal condo?";
}

const priceDirectionLabels = page.price_max
  ? [
      "Show lower-priced options",
      `Show up to ${formatPrice(Number(page.price_max) + 100000)}`,
      "Stay close to this budget",
    ]
  : [
      "Show lower-priced options",
      "Show mid-range options",
      "Show best value",
    ];

const defaultFeatureDirectionsByType: Record<string, string[]> = {
  condo: ["More modern", "Walkability", "Better value"],
  house: ["Larger yard", "Suite ready", "Better value"],
  townhouse: ["Outdoor space", "Better value", "More modern"],
  mobile: ["Better value", "Updated"],
};

const savedFeatureLabels = features.map((feature) =>
  feature
    .replaceAll("_", " ")
    .replace(/\b\w/g, (char) => char.toUpperCase())
);

const fallbackFeatureLabels =
  defaultFeatureDirectionsByType[String(page.property_type || "house").toLowerCase()] ||
  ["Better layout", "More modern", "Better value", "Outdoor space"];

let dynamicFeatureLabels: string[] = [];

if (
  page.waterfront_type === "oceanfront" ||
  slug.includes("oceanfront")
) {
 dynamicFeatureLabels = [
  "Ocean views",
  "Larger lot",
  "More bedrooms",
  "More modern",
  "Private setting",
];
}

else if (
  page.requires_ocean_view ||
  slug.includes("ocean-view")
) {
  dynamicFeatureLabels = [
    "Panoramic views",
    "Sunset views",
    "Large lot",
    "Modern interior",
    "Suite ready",
  ];
}

else if (
  slug.includes("family")
) {
  dynamicFeatureLabels = [
    "Larger yard",
    "More bedrooms",
    "Better schools",
    "Garage space",
    "Suite ready",
  ];
}

else if (
  normalizedPropertyType === "condo"
) {
  dynamicFeatureLabels = [
    "Walkability",
    "Ocean views",
    "Luxury finishes",
    "Low strata fees",
    "Best value",
  ];
}

const featureDirectionLabels =
  dynamicFeatureLabels.length
    ? dynamicFeatureLabels
    : Array.from(
        new Set([
          ...savedFeatureLabels,
          ...fallbackFeatureLabels,
          "Better value",
          "More modern",
        ])
      );

function cleanAreaLabel(value = "") {
  return String(value || "")
    .replace(/^pq\s+/i, "")
    .replace(/\s+/g, " ")
    .trim();
}

function titleCase(value = "") {
  return cleanAreaLabel(value)
    .split(" ")
    .filter(Boolean)
    .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
    .join(" ");
}

function buildSeoFallback(page: any) {
  const area = titleCase(page.area || "Nanaimo");

  let heading = page.hero_heading || "Nanaimo Homes";

  if (page.waterfront_type === "oceanfront") {
    heading = `Oceanfront Homes for Sale in ${titleCase(city)}`;
  }

  if (page.waterfront_type === "riverfront") {
    heading = `${titleCase(city)} Riverfront Homes for Sale`;
  }

  if (page.waterfront_type === "lakefront") {
    heading = `${titleCase(city)} Lakefront Properties`;
  }

  return {
    heading,

    intro: `Explore ${heading.toLowerCase()} currently available on the MLS®. Compare listings, pricing, lot sizes, and property features while monitoring new opportunities as they come to market.`,

    body: `Listings on this page update directly from MLS® data and are filtered specifically for buyers searching for ${heading.toLowerCase()}. Inventory, pricing, and availability can change quickly throughout the year.`,

    long: `${heading} appeal to buyers looking for a specific lifestyle, location, or property characteristic. Whether you're comparing value, outdoor space, views, waterfront access, or long-term investment potential, this search helps surface active opportunities currently available in the market.

Because inventory can be limited in specialized property categories, new listings often attract significant attention. Revisiting this page regularly can help you stay ahead of new listings, price changes, and market activity.`,
  };
}

const seo = buildSeoFallback(page);
const cleanHeroHeading = String(page.hero_heading || "").endsWith(".")
  ? String(page.hero_heading || "").slice(0, -1)
  : String(page.hero_heading || "");
---

<Layout
  title={page.seo_title || page.hero_heading}
  accentColor={accentColor}
  city={city}
>
 <meta
  name="description"
  content={
    page.meta_description ||
    page.seo_intro ||
    page.intro_copy ||
    ""
  }
  slot="head"
/>
{
  Array.isArray(page.faq_json) && page.faq_json.length > 0 && (
    <script
      type="application/ld+json"
      slot="head"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "FAQPage",
        mainEntity: page.faq_json.map((faq) => ({
          "@type": "Question",
          name: faq.question,
          acceptedAnswer: {
            "@type": "Answer",
            text: faq.answer,
          },
        })),
      })}
    />
  )
}





