      const card = document.querySelector(
        `[data-listing-id="${listing.id}"], [data-mls="${listing.id}"], [data-card-id="${listing.id}"]`
      );

      if (card) {
        card.click();

        if (wasOnMap) {
          const observer = new MutationObserver(() => {
            const modal = document.querySelector("[data-modal-open], .modal[open], .listing-modal.is-open, .modal-overlay.is-visible");
            if (!modal) {
              listingGrid.hidden = true;
