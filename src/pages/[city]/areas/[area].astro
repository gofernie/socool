<Layout title={`${labelize(area)} Real Estate | ${cityLabel}`} accentColor={accentColor}>  <link rel="preload" as="image" href={heroImage} slot="head" />
  <link rel="preconnect" href="https://fonts.googleapis.com" slot="head" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin slot="head" />
  <link
    href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Nunito+Sans:opsz,wght@6..12,300;6..12,400;6..12,500;6..12,600;6..12,700;6..12,800&display=optional"
    rel="stylesheet"
    slot="head"
  />

  <script is:inline slot="head">
    const savedAreaScrollY = sessionStorage.getItem("area_page_scroll_y");
    if (savedAreaScrollY) {
      history.scrollRestoration = "manual";
      document.documentElement.style.visibility = "hidden";
      window.addEventListener("DOMContentLoaded", () => {
        window.scrollTo(0, Number(savedAreaScrollY));
        sessionStorage.removeItem("area_page_scroll_y");
        document.documentElement.style.visibility = "";
      });
    }
