---
import Layout from "../../../layouts/Layout.astro";
import { createClient } from "@supabase/supabase-js";
import ListingCard from "../../../components/ListingCard.astro";
import ShortlistReviewModal from "../../../components/ShortlistReviewModal.astro";
import IntentModalController from "../../../components/IntentModalController.astro";
import SiteNav from "../../../components/SiteNav.astro";
import { getSite } from "../../../lib/getSite";
import "../../../styles/intent-modal.css";
import "../../../styles/area-page.css";
import "../../../styles/page-hero.css";

const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.SUPABASE_SERVICE_ROLE_KEY
);

const site = await getSite(Astro.url.hostname);

const accentColor =
  site?.accent_color ||
  "#2f6f73";
const googleMapsApiKey = import.meta.env.PUBLIC_GOOGLE_MAPS_API_KEY || "";
const city = String(Astro.params.city || "nanaimo")
  .toLowerCase()
  .trim();

const cityLabel = city
  .replace(/-/g, " ")
  .replace(/\b\w/g, (c) => c.toUpperCase());

const areaSlug = Astro.params.area || "";

const parksvilleAreaMap = {
  "pq-bowser-deep-bay": ["pq bowser/deep bay", "bowser", "deep bay"],
  "pq-errington-coombs-hilliers": ["pq errington/coombs/hilliers", "errington", "coombs", "hilliers"],
  "pq-fairwinds": ["pq fairwinds", "fairwinds"],
  "pq-french-creek": ["pq french creek", "french creek"],
  "pq-little-qualicum-river-village": ["pq little qualicum river village", "little qualicum river village"],
  "pq-nanoose": ["pq nanoose", "nanoose", "nanoose bay"],
  "pq-parksville": ["pq parksville", "parksville"],
  "pq-qualicum-beach": ["pq qualicum beach", "qualicum beach"],
  "pq-qualicum-north": ["pq qualicum north", "qualicum north"],
};

const areaFromSlug = (slug) =>
  String(slug || "").toLowerCase().replace(/-/g, " ");

const area = areaFromSlug(areaSlug);

const areaAliases =
  city === "parksville"
    ? parksvilleAreaMap[String(areaSlug || "").toLowerCase()] || [area]
    : [area];

const areaHeroImages = {
"university district": "https://images.unsplash.com/photo-1541339907198-e08756dedf3f?auto=format&fit=crop&w=1200&q=70",  "north nanaimo": "https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?auto=format&fit=crop&w=1200&q=70",
  "departure bay": "https://images.unsplash.com/photo-1507525428034-b723cf961d3e?auto=format&fit=crop&w=1200&q=70",
  "hammond bay": "https://images.unsplash.com/photo-1500375592092-40eb2168fd21?auto=format&fit=crop&w=1200&q=70",
  "old city": "https://images.unsplash.com/photo-1518005020951-eccb494ad742?auto=format&fit=crop&w=1200&q=70",
  "central nanaimo": "https://images.unsplash.com/photo-1494526585095-c41746248156?auto=format&fit=crop&w=1200&q=70",
  "south nanaimo": "https://images.unsplash.com/photo-1560518883-ce09059eeffa?auto=format&fit=crop&w=1200&q=70",
  "cedar": "https://images.unsplash.com/photo-1448375240586-882707db888b?auto=format&fit=crop&w=1200&q=70",
};

const fallbackHeroImage =
  "https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?auto=format&fit=crop&w=1200&q=70";
const content = {
  heroIntro: boundary?.intro_copy || `${labelize(area)} offers a mix of ${cityLabel} real estate options for buyers comparing price, location, layout, and long-term value.`,
  livingHeadline: `Convenient, connected ${cityLabel} living`,
  livingCopy: `${labelize(area)} offers access to everyday amenities, parks, schools, shopping, and major routes across ${cityLabel}.`,
  schools: [
    ["Local elementary schools", "Nearby"],
    ["Local secondary schools", "Nearby"],
    ["Community programs", "Nearby"],
  ],
  amenities: [
    ["Shopping and services", "Nearby"],
    ["Parks and trails", "Nearby"],
    ["Transit connections", "Nearby"],
    ["Restaurants and cafés", "Short drive"],
    ["Recreation options", "Short drive"],
  ],
  nearby: [],
};

const cleanAreaName = (value) =>
  String(value || "")
    .replace(/^pq[\s-]+/i, "")
    .replace(/-/g, " ")
    .replace(/\s+/g, " ")
    .trim();

const labelize = (value) =>
  cleanAreaName(value)
    .replace(/\b\w/g, (c) => c.toUpperCase());

const areaToSlug = (value) =>
  String(value || "")
    .toLowerCase()
    .replace(/&/g, "and")
    .replace(/\//g, "-")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");

const [
  { data: areaRows = [] },
  { data: cityListings = [] },
  { data: boundary, error: boundaryError },
{ data: intentPagesRaw },
] = await Promise.all([
  supabase
    .from("listing_rows")
    .select("normalized_area, normalized_type")
    .eq("normalized_city", city)
    .not("normalized_area", "is", null),
  supabase
    .from("listing_rows")
    .select("*")
    .eq("normalized_city", city)
    .eq("status", "A")
    .order("listed_at", { ascending: false }),
supabase
    .from("area_boundaries")
    .select("polygon_geojson, hero_image_url, hero_heading, seo_heading, seo_title, intro_copy")
    .eq("city", city)
    .eq("area_slug", String(areaSlug || "").toLowerCase())
    .maybeSingle(),
  supabase
    .from("intent_pages")
    .select("slug, nav_label, card_title, show_in_nav")
    .eq("city", city)
    .eq("show_in_nav", true)
    .order("nav_order", { ascending: true }),
]);

const allowedAreaLabels =
  city === "parksville"
    ? [
        "pq bowser/deep bay",
        "pq errington/coombs/hilliers",
        "pq fairwinds",
        "pq french creek",
        "pq little qualicum river village",
        "pq nanoose",
        "pq parksville",
        "pq qualicum beach",
        "pq qualicum north",
      ]
    : [];

const areas =
  city === "parksville"
    ? allowedAreaLabels
    : [...new Set(
        areaRows
          .map((r) => String(r.normalized_area || "").trim())
          .filter((a) => a && a !== "unknown")
      )].sort((a, b) => a.localeCompare(b));

const intentPages = intentPagesRaw ?? [];

console.log("AREA ROWS DEBUG", {
  city,
  count: areaRows.length,
  uniqueAreas: [...new Set(areaRows.map((r) => r.normalized_area))]
    .filter(Boolean)
    .sort(),
});

// propertyTypes removed — nav driven by intentPages from DB


function pointInPolygon(point, polygon) {
  const [lng, lat] = point;
  let inside = false;

  for (let i = 0, j = polygon.length - 1; i < polygon.length; j = i++) {
    const [xi, yi] = polygon[i];
    const [xj, yj] = polygon[j];

    const intersect =
      yi > lat !== yj > lat &&
      lng < ((xj - xi) * (lat - yi)) / (yj - yi) + xi;

    if (intersect) inside = !inside;
  }

  return inside;
}



  const heroImage =
  boundary?.hero_image_url ||
  areaHeroImages[area] ||
  fallbackHeroImage;

console.log("BOUNDARY DEBUG", {
  city,
  areaSlug,
  boundary,
  boundaryError,
});
const polygon =
  boundary?.polygon_geojson?.type === "Polygon"
    ? boundary.polygon_geojson.coordinates?.[0]
    : null;

console.log("POLYGON DEBUG", {
  polygonExists: !!polygon,
  polygonPoints: polygon?.length || 0,
  cityListings: cityListings.length,
});

const listings = polygon
  ? cityListings.filter((listing) => {
      const lat = Number(listing.lat || 0);
      const lng = Number(listing.lng || 0);

      if (!lat || !lng) return false;

      return pointInPolygon([lng, lat], polygon);
    })
  : cityListings.filter((listing) =>
      areaAliases.includes(
        String(listing.normalized_area || "").toLowerCase()
      )
    );

const initialListings = listings;

const normalizeListingImageUrl = (value) => {
  if (!value) return "";
  const raw = typeof value === "string"
    ? value
    : value.highRes || value.mediumRes || value.lowRes || value.url || "";
  if (!raw) return "";
  if (raw.startsWith("http")) return raw;
  const cleaned = raw.startsWith("/") ? raw : `/${raw}`;
 return cleaned.startsWith("/vreb/") ? `https://cdn.repliers.io${cleaned}?class=medium` : cleaned;
};

const getListingImage = (listing) =>
  normalizeListingImageUrl(
    listing.image_url ||
      listing.images?.[0] ||
      listing.raw?.images?.[0] ||
      listing.raw?.images?.[0]?.url
  );

const prices = listings
  .map((listing) => Number(listing.price || 0))
  .filter((price) => price > 0)
  .sort((a, b) => a - b);

const avgPrice = prices.length > 0
  ? Math.round(prices.reduce((sum, price) => sum + price, 0) / prices.length)
  : 0;

const medianPrice = prices.length > 0 ? prices[Math.floor(prices.length / 2)] : 0;

const houseCount = listings.filter((l) => l.normalized_type === "house").length;
const condoCount = listings.filter((l) => l.normalized_type === "condo").length;
const townhomeCount = listings.filter((l) => l.normalized_type === "townhouse").length;
const landCount = listings.filter((l) => l.normalized_type === "land").length;

const houseMedian = (() => { const p = listings.filter(l => l.normalized_type === "house").map(l => Number(l.price || 0)).filter(p => p > 0).sort((a,b) => a-b); return p.length ? p[Math.floor(p.length/2)] : null; })();
const condoMedian = (() => { const p = listings.filter(l => l.normalized_type === "condo").map(l => Number(l.price || 0)).filter(p => p > 0).sort((a,b) => a-b); return p.length ? p[Math.floor(p.length/2)] : null; })();
const townhouseMedian = (() => { const p = listings.filter(l => l.normalized_type === "townhouse").map(l => Number(l.price || 0)).filter(p => p > 0).sort((a,b) => a-b); return p.length ? p[Math.floor(p.length/2)] : null; })();
const landMedian = (() => { const p = listings.filter(l => l.normalized_type === "land").map(l => Number(l.price || 0)).filter(p => p > 0).sort((a,b) => a-b); return p.length ? p[Math.floor(p.length/2)] : null; })();

const typeSlices = [
  { label: "Houses",    count: houseCount,    color: "#1D9E75" },
  { label: "Condos",    count: condoCount,    color: "#5DCAA5" },
  { label: "Townhomes", count: townhomeCount, color: "#9FE1CB" },
  { label: "Land",      count: landCount,     color: "#378ADD" },
].filter(t => t.count > 0);

const typeCards = [
  { label: "Houses",    count: houseCount,    median: houseMedian,     color: "#1D9E75" },
  { label: "Condos",    count: condoCount,    median: condoMedian,     color: "#5DCAA5" },
  { label: "Townhomes", count: townhomeCount, median: townhouseMedian, color: "#9FE1CB" },
  { label: "Land",      count: landCount,     median: landMedian,      color: "#378ADD" },
];
const typeMaxMedian = Math.max(...typeCards.map(t => t.median || 0)) || 1;

const listingCount = listings.length || 0;
const housePercent = listingCount ? Math.round((houseCount / listingCount) * 100) : 0;
const condoPercent = listingCount ? Math.round((condoCount / listingCount) * 100) : 0;
const townhomePercent = listingCount ? Math.round((townhomeCount / listingCount) * 100) : 0;

const dominantType = housePercent >= 50 ? "houses" : condoPercent >= 35 ? "condos" : "mixed";
const highEndCount = listings.filter(l => Number(l.price || 0) >= 1500000).length;
const underHalfMilCount = listings.filter(l => Number(l.price || 0) < 500000).length;
const priceBuckets = [
  { label: "Under $500k", min: 0, max: 500000 },
  { label: "$500k-$750k", min: 500000, max: 750000 },
  { label: "$750k-$1M", min: 750000, max: 1000000 },
  { label: "$1M-$1.5M", min: 1000000, max: 1500000 },
  { label: "$1.5M+", min: 1500000, max: Infinity },
];

const mapListings = listings
  .map((listing, index) => ({
    id: listing.id,
    address: listing.address || "",
    type: listing.normalized_type || "",
    price: Number(listing.price || 0),
    beds: Number(listing.beds || 0),
    baths: listing.baths || "",
    listed: listing.listed_at || "",
    lat: Number(listing.lat || 0),
    lng: Number(listing.lng || 0),
    image: getListingImage(listing),
    images: (() => {
      const raw = listing.images || listing.raw?.images || [];
      const urls = Array.isArray(raw) ? raw.map(i => normalizeListingImageUrl(typeof i === "string" ? i : i?.url || i?.highRes || "")).filter(Boolean) : [];
      const first = getListingImage(listing);
      return urls.length > 0 ? urls : (first ? [first] : []);
    })(),
  }))
  .filter((listing) => listing.lat && listing.lng);

const mapCenter = mapListings.length > 0
  ? {
      lat: mapListings.reduce((sum, item) => sum + item.lat, 0) / mapListings.length,
      lng: mapListings.reduce((sum, item) => sum + item.lng, 0) / mapListings.length,
    }
  : { lat: 49.1659, lng: -123.9401 };

const chartData = {
  priceLabels: priceBuckets.map((bucket) => bucket.label),
  priceCounts: priceBuckets.map((bucket) =>
    listings.filter((listing) => {
      const price = Number(listing.price || 0);
      return price >= bucket.min && price < bucket.max;
    }).length
  ),
};
---

<Layout title={boundary?.seo_title || `${labelize(area)} Real Estate | ${cityLabel}`} accentColor={accentColor}>  <link rel="preload" as="image" href={heroImage} slot="head" />

  
  <link rel="preload" as="style" href="https://?family=Lora:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Nunito+Sans:opsz,wght@6..12,300;6..12,400;6..12,500;6..12,600;6..12,700;6..12,800&display=optional" onload="this.onload=null;this.rel='stylesheet'" slot="head" />
  <noscript slot="head"><link rel="stylesheet" href="https://?family=Lora:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Nunito+Sans:opsz,wght@6..12,300;6..12,400;6..12,500;6..12,600;6..12,700;6..12,800&display=optional" /></noscript>
  

<script is:inline slot="head">
    if (sessionStorage.getItem("area_page_scroll_y")) {
      history.scrollRestoration = "manual";
      document.documentElement.style.visibility = "hidden";
    }
  </script>






<SiteNav city={city} areas={areas} intentPages={intentPages} showAreaNav={false} /><header class="page-hero" style={`--hero-image: url('${heroImage}')`}>
  <div class="page-hero__inner">
    <p class="page-hero__eyebrow">{cityLabel} Area Guide</p>

   <h1 set:html={`${(boundary?.hero_heading || `${labelize(area)}\nReal Estate`).replace(/\|/g, '<br>')}`}></h1>

    <p class="page-hero__copy">{boundary?.intro_copy || content.heroIntro}</p>

    <div class="page-hero__actions">
      <a href="#area-listings">View all listings</a>
      <a href="#area-insights">Get area insights</a>
    </div>
  </div>
</header>

 <div style="height:60px;background:linear-gradient(to bottom, rgba(0,0,0,0.10), transparent);margin-bottom:-60px;pointer-events:none;"></div>

 <nav class="area-browse-nav">
    <div class="shell area-browse-nav__inner">
     <span>Explore more {cityLabel} areas</span>
      {areas.slice(0, 3).map((item) => (
        
       <a
  class:list={{ active: areaToSlug(item) === areaSlug }}
  href={`/${city}/areas/${areaToSlug(item)}`}
>
          {labelize(item)}
        </a>
      ))}
   
   {areas.length > 5 && (
        <select
          id="area-nav-select"
          onchange="if(this.value) window.location.href=this.value;"
        >
          <option value="">Browse all areas</option>
          {areas.slice(3).map((item) => (
            <option
              value={`/${city}/areas/${areaToSlug(item)}`}
              selected={item === area}
            >
              {labelize(item)}
            </option>
          ))}
        </select>
      )}
    </div>
  </nav>

<main class="shell">

    <section class="area-context-intro">
      <p>
        {labelize(area)} offers a practical mix of homes, condos, townhomes, services,
        schools, and nearby routes for buyers comparing lifestyle, price, and long-term value.
      </p>
    </section>

    <section class="area-stats">
     <a class="stat-card stat-card-link" href="#" data-filter-type="all">
        <span>Active Listings</span>
        <strong>{listings.length}</strong>
      </a>
      <div class="stat-card">
        <span>Average Price</span>
        <strong>${avgPrice.toLocaleString()}</strong>
      </div>
      <div class="stat-card">
        <span>Median Price</span>
        <strong>${medianPrice.toLocaleString()}</strong>
      </div>
      <a class="stat-card stat-card-link" href="#" data-filter-type="house">
        <span>Houses</span>
        <strong>{houseCount}</strong>
      </a>
      <a class="stat-card stat-card-link" href="#" data-filter-type="condo">
        <span>Condos</span>
        <strong>{condoCount}</strong>
      </a>
      <a class="stat-card stat-card-link" href="#" data-filter-type="townhouse">
        <span>Townhomes</span>
        <strong>{townhomeCount}</strong>
      </a>
    </section>

    <section class="filter-bar">
  <div class="view-toggle area-view-toggle">
    <button type="button" class="view-btn active" id="area-list-view-btn">☷ List</button>
    <button type="button" class="view-btn" id="area-map-view-btn">✦ Map</button>
  </div>
      <select id="area-filter">
        <option value="">Current area: {labelize(area)}</option>
        {areas
          .filter((item) => item !== area)
          .map((item) => (
            <option value={`/${city}/areas/${areaToSlug(item)}`}>
              {labelize(item)}
            </option>
          ))}
      </select>
      <select id="sort-filter">
        <option value="newest">Newest first</option>
        <option value="price-low">Price: low to high</option>
        <option value="price-high">Price: high to low</option>
        <option value="beds-high">Beds: most first</option>
      </select>
      <select id="type-filter">
        <option value="all">All property types</option>
        <option value="house">Houses</option>
        <option value="condo">Condos</option>
        <option value="townhouse">Townhomes</option>
      </select>
      <select id="price-filter">
        <option value="all">Any price</option>
        <option value="under-500">Under $500k</option>
        <option value="500-750">$500k - $750k</option>
        <option value="750-1000">$750k - $1M</option>
        <option value="1000-plus">$1M+</option>
      </select>
      <select id="beds-filter">
        <option value="all">Any beds</option>
        <option value="2">2+ beds</option>
        <option value="3">3+ beds</option>
        <option value="4">4+ beds</option>
      </select>
     
    </section>
<h2 id="listing-count-heading" style="font-size:1rem;font-weight:700;color:#555;margin:0 0 14px;font-family:var(--f-body);">Showing {listings.length} homes</h2><div id="area-listing-map" class="area-listing-map" hidden></div>

<div class="listing-grid" id="area-listings">
      {initialListings.map((listing, index) => (
     <div
          class="listing-card-wrap"
          data-type={listing.normalized_type || ""}
          data-price={listing.price || 0}
          data-beds={listing.beds || 0}
          data-listed={listing.listed_at || ""}
          data-lat={listing.lat || ""}
          data-lng={listing.lng || ""}
        >
       <ListingCard
  listing={{
    ...listing,
    address:
      typeof listing.address === "string" && listing.address.trim().startsWith("{")
        ? (() => {
            try {
              const a = JSON.parse(listing.address);
              return [a.streetNumber, a.streetName, a.streetSuffix]
                .filter(Boolean)
                .join(" ");
            } catch {
              return "Address available";
            }
          })()
        : listing.address || "Address available",
  }}
  image={getListingImage(listing)}
  priority={index < 3}
/>
        </div>
      ))}
    </div>

   

    

   <section class="market-row" id="area-insights">

      <div class="mi-stats-row">
        <div class="mi-stat">
          <p class="mi-stat-label">Active listings</p>
          <p class="mi-stat-val">{listingCount}</p>
          <p class="mi-stat-sub">{labelize(area)}</p>
        </div>
        <div class="mi-stat">
          <p class="mi-stat-label">Median price</p>
          <p class="mi-stat-val">${medianPrice >= 1000000 ? (medianPrice / 1000000).toFixed(1) + "M" : Math.round(medianPrice / 1000) + "k"}</p>
          <p class="mi-stat-sub">All types</p>
        </div>
        <div class="mi-stat">
          <p class="mi-stat-label">Avg. price</p>
          <p class="mi-stat-val">${avgPrice >= 1000000 ? (avgPrice / 1000000).toFixed(1) + "M" : Math.round(avgPrice / 1000) + "k"}</p>
          <p class="mi-stat-sub">All types</p>
        </div>
      </div>

      <div class="mi-top">
        <article class="mi-card">
          <span class="eyebrow">LISTING MIX</span>
          <h2>What's for sale</h2>
          <div class="mi-donut-wrap">
            <canvas id="donutChart" width="110" height="110" role="img" aria-label={`Property type breakdown in ${labelize(area)}`}>
              {typeSlices.map(t => `${t.label}: ${t.count} (${Math.round((t.count / listingCount) * 100)}%)`).join(", ")}
            </canvas>
            <div class="mi-legend">
              {typeSlices.map(t => (
                <div class="mi-legend-item">
                  <div class="mi-legend-dot" style={`background:${t.color}`}></div>
                  <span class="mi-legend-label">{t.label}</span>
                  <span class="mi-legend-val">{t.count}<span class="mi-legend-pct"> · {Math.round((t.count / listingCount) * 100)}%</span></span>
                </div>
              ))}
            </div>
          </div>
        </article>

        <article class="mi-card">
          <span class="eyebrow">MARKET TAKEAWAY</span>
          <h2>{labelize(area)} at a glance</h2>
          <ul class="mi-points">
            <li class="mi-point">
              <span class="mi-point-icon" aria-hidden="true">✓</span>
              {dominantType === "houses"
                ? `Houses dominate at ${housePercent}% — condo and townhome buyers may need to look nearby.`
                : dominantType === "condos"
                  ? `Condos make up ${condoPercent}% of inventory — more options than most areas.`
                  : `Inventory is balanced across types — useful for buyers comparing property styles.`}
            </li>
            <li class="mi-point">
              <span class="mi-point-icon" aria-hidden="true">✓</span>
              {"Median of $" + medianPrice.toLocaleString() + " puts most inventory in the " + (medianPrice < 500000 ? "under-$500k" : medianPrice < 750000 ? "$500k–$750k" : medianPrice < 1000000 ? "$750k–$1M" : medianPrice < 1500000 ? "$1M–$1.5M" : "$1.5M+") + " range."}
            </li>
            {highEndCount > 0 && (
              <li class="mi-point">
                <span class="mi-point-icon" aria-hidden="true">✓</span>
                {highEndCount} listing{highEndCount > 1 ? "s" : ""} over $1.5M — likely acreages, premium lots, or larger detached homes.
              </li>
            )}
            {underHalfMilCount > 0 && (
              <li class="mi-point">
