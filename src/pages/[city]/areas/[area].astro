  "North Nanaimo",
  "Hammond Bay",
  "Departure Bay",
  "Uplands",
  "Pleasant Valley",
  "Diver Lake",
  "Central Nanaimo",
  "Old City",
  "University District",
  "South Nanaimo",
  "Chase River",
  "Cedar",
  "Jingle Pot",
  "Extension",
  "Brechin Hill",
];

