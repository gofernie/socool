const labelize = (value) =>
  String(value || "")
    .replace(/-/g, " ")
    .replace(/\b\w/g, (c) => c.toUpperCase());

const areaToSlug = (value) =>
  String(value || "")
    .toLowerCase()
    .replace(/&/g, "and")
    .replace(/\//g, "-")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");

const { data: areaRows = [] } = await supabase
  .from("listing_rows")
  .select("normalized_area, normalized_type")
  .eq("normalized_city", city)
  .not("normalized_area", "is", null);

const allowedAreaLabels =
  city === "parksville"
    ? [
        "PQ Bowser/Deep Bay",
        "PQ Errington/Coombs/Hilliers",
        "PQ Fairwinds",
        "PQ French Creek",
        "PQ Little Qualicum River Village",
        "PQ Nanoose",
        "PQ Parksville",
        "PQ Qualicum Beach",
        "PQ Qualicum North",
      ]
    : [];

