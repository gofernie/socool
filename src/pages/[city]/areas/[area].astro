        async function initCharts() {
        if (!window.Chart) {
          await new Promise((resolve, reject) => {
            const script = document.createElement("script");
            script.src = "https://cdn.jsdelivr.net/npm/chart.js";
            script.onload = resolve;
            script.onerror = reject;
            document.head.appendChild(script);
          });
        }
        if (!window.Chart) return;

        const donutCanvas = document.getElementById("donutChart");
        if (donutCanvas && typeSlices.length > 0) {
          new Chart(donutCanvas, {
            type: "doughnut",
            data: {
              labels: typeSlices.map(t => t.label),
              datasets: [{
                data: typeSlices.map(t => t.count),
                backgroundColor: typeSlices.map(t => t.color),
                borderWidth: 0,
                hoverOffset: 4,
              }]
            },
            options: {
              responsive: false,
              cutout: "68%",
              plugins: { legend: { display: false }, tooltip: { enabled: true } },
            }
          });
        }

        const priceContainer = document.getElementById("miPriceRows");
        if (priceContainer && chartData) {
          const maxCount = Math.max(...chartData.priceCounts, 1);
          chartData.priceLabels.forEach((label, i) => {
            const count = chartData.priceCounts[i];
            const pct = Math.round((count / maxCount) * 100);
            const row = document.createElement("div");
            row.style.cssText = "display:flex;align-items:center;gap:12px;";
          row.innerHTML = `
              <span style="font-size:12px;color:#666;width:110px;flex-shrink:0;white-space:nowrap;">${label}</span>
              <div style="flex:1;background:rgba(0,0,0,0.07);border-radius:4px;height:28px;overflow:hidden;">
                <div style="width:${pct}%;height:100%;border-radius:4px;background:#1D9E75;display:flex;align-items:center;padding-left:10px;min-width:6px;box-sizing:border-box;">
                  ${count >= 2 ? `<span style="font-size:12px;font-weight:600;color:#fff;white-space:nowrap;">${count} listings</span>` : ""}
                </div>
              </div>
              <span style="font-size:12px;color:#999;width:28px;text-align:right;flex-shrink:0;">${count < 2 ? count : ""}</span>
            `;
            priceContainer.appendChild(row);
          });
        }
      }

     const urlParams = new URLSearchParams(window.location.search);
      const hasUrlFilters = urlParams.has("type") || urlParams.has("price") || urlParams.has("beds") || urlParams.has("sort");

      if (hasUrlFilters) {
        if (grid) grid.style.visibility = "hidden";
      }

      if (urlParams.get("type") && typeFilter) typeFilter.value = urlParams.get("type");
      if (urlParams.get("price") && priceFilter) priceFilter.value = urlParams.get("price");
      if (urlParams.get("beds") && bedsFilter) bedsFilter.value = urlParams.get("beds");
      if (urlParams.get("sort") && sortFilter) sortFilter.value = urlParams.get("sort");

      applyFilters();
      initCharts();

      if (hasUrlFilters) {
        requestAnimationFrame(() => {
          if (grid) grid.style.visibility = "visible";
        });
      }

   const restoreY = sessionStorage.getItem("area_page_scroll_y");
      if (restoreY) {
        sessionStorage.removeItem("area_page_scroll_y");
        window.scrollTo({ top: Number(restoreY), behavior: "instant" });
      }
    });

    document.addEventListener("DOMContentLoaded", () => {
      const restoreY = sessionStorage.getItem("area_page_scroll_y");
      if (restoreY) {
        sessionStorage.removeItem("area_page_scroll_y");
        window.scrollTo({ top: Number(restoreY), behavior: "instant" });
        requestAnimationFrame(() => {
          window.scrollTo({ top: Number(restoreY), behavior: "instant" });
          requestAnimationFrame(() => {
            document.documentElement.style.transition = "opacity 0.2s ease";
            document.documentElement.style.opacity = "1";
            document.documentElement.style.visibility = "visible";
          });
        });
      } else {
        document.documentElement.style.visibility = "visible";
        document.documentElement.style.opacity = "1";
      }
    });
  </script>
