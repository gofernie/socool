}

.filter-select {
  cursor: pointer;
  appearance: none;
  -webkit-appearance: none;
  padding-right: 46px;
  background-image:
    linear-gradient(45deg, transparent 50%, #181614 50%),
    linear-gradient(135deg, #181614 50%, transparent 50%);
  background-position:
    calc(100% - 23px) 50%,
    calc(100% - 17px) 50%;
