        box-shadow: 0 8px 24px rgba(28, 25, 23, 0.07);
        color: var(--ink);
        font-size: 0.88rem;
        font-weight: 850;
      }

      .filter-pill.is-active {
  background: #eadcc9;
  border-color: #c4a882;
}

.filter-form {
  display: flex;
  align-items: center;
  gap: 14px;
  flex-wrap: wrap;
}

.filter-select,
.filter-apply,
.filter-clear {
