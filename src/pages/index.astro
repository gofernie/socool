---
import { createClient } from "@supabase/supabase-js";
import ShortlistReviewModal from "../components/ShortlistReviewModal.astro";
import IntentModalController from "../components/IntentModalController.astro";
export const prerender = false;

const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.SUPABASE_SERVICE_ROLE_KEY
);

const googleMapsApiKey = import.meta.env.PUBLIC_GOOGLE_MAPS_API_KEY || "";

const url = Astro.url;

const city = url.searchParams.get("city") || "nanaimo";
const area = url.searchParams.get("area") || "";
const type = url.searchParams.get("type") || "";
const minPrice = Number(url.searchParams.get("minPrice") || 0);
const maxPrice = Number(url.searchParams.get("maxPrice") || 0);
const sort = url.searchParams.get("sort") || "newest";

const clean = (value: any) =>
  String(value || "")
    .toLowerCase()
    .trim();

const getListingMls = (listing: any) =>
  String(
    listing.mls_number ||
      listing.mlsNumber ||
      listing.id ||
      listing.repliers_listing_id ||
      listing.raw?.mlsNumber ||
      listing.raw?.id ||
      ""
  ).replace(/[^0-9]/g, "");

const getListingPrice = (listing: any) => {
  const num = Number(listing.price ?? listing.listPrice ?? listing.priceNumber ?? 0);
  if (Number.isFinite(num) && num > 1000) return `$${Math.round(num).toLocaleString()}`;
  return listing.price_text || listing.priceText || "Price on request";
};

const getListingAddress = (listing: any) =>
  listing.address ||
  listing.full_address ||
  listing.addressText ||
  listing.addressObj?.streetAddress ||
  [listing.addressObj?.streetNumber, listing.addressObj?.streetName, listing.addressObj?.streetSuffix]
    .filter(Boolean)
    .join(" ") ||
  "Address available";

const normalizeListingImageUrl = (value: any) => {
  if (!value) return "";
  const raw = typeof value === "string" ? value : value.highRes || value.mediumRes || value.lowRes || value.url || value.src || value.href || value.path || "";
  if (!raw) return "";
  if (raw.startsWith("http://") || raw.startsWith("https://")) return raw;
  const cleaned = raw.startsWith("/") ? raw : `/${raw}`;
  if (cleaned.startsWith("/vreb/")) return `https://cdn.repliers.io${cleaned}`;
  return cleaned;
};

const getListingImage = (listing: any) => {
  const image = listing.image_url || listing.image || listing.photo || listing.images?.[0] || listing.images?.[1] || listing.raw?.images?.[0] || listing.raw?.images?.[1] || listing.raw?.images?.[0]?.url || listing.raw?.images?.[1]?.url;
  return normalizeListingImageUrl(image);
};

const getListingImages = (listing: any) => {
  const rawImages = listing.images || listing.photo_urls || listing.photos || listing.raw?.images || [];
  const images = Array.isArray(rawImages)
    ? rawImages.map((img: any) => typeof img === "string" ? normalizeListingImageUrl(img) : normalizeListingImageUrl(img.highRes || img.mediumRes || img.lowRes || img.url || img.src || img.href || img.path || "")).filter(Boolean)
    : [];
  const firstImage = getListingImage(listing);
  return Array.from(new Set([firstImage, ...images].filter(Boolean)));
};

const getListingBeds = (listing: any) => listing.beds || listing.bedrooms || listing.details?.numBedrooms || listing.raw?.details?.numBedrooms || 0;
const getListingBaths = (listing: any) => listing.baths || listing.bathrooms || listing.details?.numBathrooms || listing.raw?.details?.numBathrooms || 0;
const getListingSqft = (listing: any) => listing.sqft || listing.square_feet || listing.squareFeet || listing.details?.sqft || listing.details?.squareFeet || listing.raw?.details?.sqft || listing.raw?.details?.squareFeet || "";
const getListingDescription = (listing: any) => listing.description || listing.publicRemarks || listing.remarks || listing.details?.description || listing.details?.publicRemarks || listing.details?.remarks || listing.raw?.description || listing.raw?.publicRemarks || listing.raw?.remarks || listing.raw?.details?.description || listing.raw?.details?.publicRemarks || listing.raw?.details?.remarks || "A quiet preview of this property.";
const getListingYearBuilt = (listing: any) => listing.year_built || listing.yearBuilt || listing.details?.yearBuilt || listing.raw?.details?.yearBuilt || "";
const getListingLotSize = (listing: any) => listing.lot_size || listing.lotSize || listing.details?.lotSize || listing.raw?.details?.lotSize || "";
const getListingArea = (listing: any) => listing.normalized_area || listing.area || listing.neighborhood || listing.addressObj?.neighborhood || listing.address?.neighborhood || listing.details?.area || listing.details?.subArea || listing.raw?.address?.neighborhood || listing.raw?.details?.area || listing.raw?.details?.subArea || "";
const getListingPropertyType = (listing: any) => String(listing.normalized_type || listing.property_type || listing.propertyType || listing.type || listing.details?.propertyType || listing.raw?.details?.propertyType || "Home").replace(/[_-]+/g, " ").replace(/\b\w/g, (char: string) => char.toUpperCase());
const buildFilterUrl = (updates: Record<string, string | number | null>) => {
  const params = new URLSearchParams();

  params.set("city", city || "nanaimo");

  if (area) params.set("area", area);
  if (type) params.set("type", type);
  if (minPrice) params.set("minPrice", String(minPrice));
  if (maxPrice) params.set("maxPrice", String(maxPrice));
  if (sort && sort !== "newest") params.set("sort", sort);

  Object.entries(updates).forEach(([key, value]) => {
    if (value === null || value === "" || value === 0) {
      params.delete(key);
    } else {
      params.set(key, String(value));
    }
  });

  return `?${params.toString()}`;
};
const { data: intentPageRows } = await supabase
  .from("intent_pages")
  .select(`
    *,
    intent_page_features (
      feature_key
    )
  `)
  .eq("city", clean(city || "nanaimo"))
  .eq("is_published", true)
  .order("created_at", { ascending: false });

function shortenIntentTitle(title: string) {
  const t = title.toLowerCase();

  if (t.includes("first time buyers condos") && t.includes("500")) {
    return "First-Time Buyer Condos Under $500K";
  }

  if (t.includes("first time buyers mobiles")) {
    return "First-Time Buyer Mobile Homes";
  }

  if (t.includes("homes") && t.includes("1,000,000")) {
    return "Homes Over $1M";
  }

  if (t.includes("ocean view condos")) {
    return "Ocean View Condos";
  }

  if (t.includes("walkable condos")) {
    return "Walkable Condos";
  }

  if (t.includes("downsizers")) {
    return "Condos for Downsizers";
  }

  return title
    .replace(/worth a closer look/gi, "")
    .replace(/in nanaimo$/gi, "")
    .replace(/^nanaimo\s+/i, "Nanaimo ")
    .replace(/\s+/g, " ")
    .trim();
}

function shortenIntentDescription(text: string, title = "") {
  const t = title.toLowerCase();

  if (t.includes("first-time buyer condos")) {
    return "Affordable Nanaimo condos shaped around first-time buyers.";
  }

  if (t.includes("mobile homes")) {
    return "Entry-level mobile homes for buyers looking for a practical starting point.";
  }

  if (t.includes("homes over")) {
    return "Higher-end Nanaimo homes with more space, finish, and lifestyle upside.";
  }

  if (t.includes("nanaimo homes")) {
    return "A broad look at active Nanaimo homes across different areas and price points.";
  }

  if (t.includes("townhomes")) {
    return "Nanaimo townhomes for buyers who want more space without full detached-home upkeep.";
  }

  if (t.includes("ocean view")) {
    return "Condos with ocean-view potential, coastal appeal, and low-maintenance living.";
  }

  if (t.includes("downsizers")) {
    return "Lower-maintenance condos suited to comfort, convenience, and simpler living.";
  }

  if (t.includes("walkable")) {
    return "Condos close to amenities, services, parks, and daily conveniences.";
  }

  return String(text || "")
    .replace(/react to listings as you browse and the page will help surface better matches\.?/gi, "")
    .replace(/browse active nanaimo /gi, "")
    .replace(/explore nanaimo /gi, "")
    .replace(/\s+/g, " ")
    .trim();
}

const allIntentCollections = (intentPageRows || []).map((page: any) => ({
  type: String(page.property_type || "").toLowerCase(),
  title: shortenIntentTitle(page.hero_heading || page.slug),
  href: `/${page.city}/${page.slug}`,
description: shortenIntentDescription(page.intro_copy || "", shortenIntentTitle(page.hero_heading || page.slug)),  features: (page.intent_page_features || []).map((feature: any) => feature.feature_key),
}));

let intentCollections = allIntentCollections;

if (type) {
  intentCollections = allIntentCollections.filter(
    (card) => card.type === clean(type)
  );
}

intentCollections = intentCollections.slice(0, 8);
const propertyTypeOptions = Array.from(
  new Set(
    allIntentCollections
      .map((card) => card.type)
      .filter(Boolean)
  )
).sort();

const groupLabel = [  area || "",
  type ? type.replace(/-/g, " ") : "",
  maxPrice ? `under $${maxPrice}k` : "",
  minPrice ? `over $${minPrice}k` : ""
].filter(Boolean).join(" · ");

let areaOptions: string[] = [];

try {
  const { data } = await supabase
    .from("listing_rows")
    .select("normalized_area")
    .eq("status", "A")
    .eq("normalized_city", clean(city || "nanaimo"))
    .not("normalized_area", "is", null);

 const allowedAreas = [
  "north nanaimo",
  "south nanaimo",
  "central nanaimo",
  "departure bay",
  "hammond bay",
  "uplands",
  "old city",
  "university district",
  "chase river",
  "cedar",
  "pleasant valley",
  "jingle pot",
  "diver lake",
  "brechin hill"
];

areaOptions = Array.from(
  new Set((data || []).map((row: any) => row.normalized_area).filter(Boolean))
)
  .filter((area: string) => allowedAreas.includes(area))
  .sort();
} catch {}

let listings: any[] = [];
let errorMessage = "";

try {
let query = supabase.from("listing_rows").select("*").eq("status", "A").limit(12);
  if (city) query = query.eq("normalized_city", clean(city));

  // Homepage discovery preloads a broad pool.
  // Filters are applied client-side for instant UX.

  if (sort === "price-low" || sort === "price-asc") query = query.order("price", { ascending: true });
  else if (sort === "price-high" || sort === "price-desc") query = query.order("price", { ascending: false });
  else if (sort === "beds-high") query = query.order("beds", { ascending: false });
  else query = query.order("listed_at", { ascending: false });

  const { data, error } = await query;
  if (error) throw error;
  listings = data || [];

  if (type === "condo") {
    listings = listings.filter((listing: any) => {
      const text = [listing.normalized_type, listing.property_type, listing.propertyType, listing.type, listing.details?.propertyType, listing.raw?.details?.propertyType, listing.description, listing.publicRemarks, listing.remarks].filter(Boolean).join(" ").toLowerCase();
      return !text.includes("manufactured") && !text.includes("mobile") && !text.includes("modular") && !text.includes("park model") && !text.includes("mfd");
    });
  }
} catch (error: any) {
  errorMessage = error?.message || "Could not load listings.";
}
---

<html lang="en">
  <head>
    <title>{city ? `${city} ${type ? type.replace(/-/g, " ") + "s" : "homes"} for sale${maxPrice ? ` under $${maxPrice}k` : ""}` : "Explore homes for sale"} | {city || "Listings"}</title>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={city ? `Browse ${listings.length} ${type ? type.replace(/-/g, " ") + "s" : "homes"} for sale in ${city}${maxPrice ? ` under $${maxPrice}k` : ""}${minPrice ? ` over $${minPrice}k` : ""}. View photos, prices, and listing details.` : "Browse current homes for sale. View photos, prices, and listing details."} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={Astro.url.href} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={city ? `${city} ${type ? type.replace(/-/g, " ") + "s" : "homes"} for sale` : "Explore homes for sale"} />
    <meta property="og:url" content={Astro.url.href} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Nunito+Sans:opsz,wght@6..12,300;6..12,400;6..12,500;6..12,600&display=swap" rel="stylesheet" />

    <style>
      :root {
        --bg: #f5f2ed;
        --surface: #fdfcfa;
        --surface-warm: #f9f6f1;
        --ink: #1c1917;
        --ink-soft: #3d3935;
        --muted: #6b6560;
        --soft: #9c9590;
        --line: #e8e3dc;
        --line-warm: #ddd8d0;
        --accent: #8b6f47;
        --accent-light: #c4a882;
        --accent-bg: #f7f0e6;

        --f-display: "Lora", Georgia, serif;
        --f-body: "Nunito Sans", -apple-system, BlinkMacSystemFont, sans-serif;
        --ease: cubic-bezier(0.25, 0.46, 0.45, 0.94);
        --radius: 12px;
        --radius-lg: 20px;
      }

      * { box-sizing: border-box; margin: 0; padding: 0; }
      html, body { width: 100%; overflow-x: hidden; }
      body { font-family: var(--f-body); background: var(--bg); color: var(--ink); font-size: 16px; line-height: 1.6; -webkit-font-smoothing: antialiased; }
      body.modal-open { overflow: hidden; }
      a { color: inherit; text-decoration: none; }
      button { font: inherit; }

      .shell { width: min(1400px, calc(100% - 80px)); margin: 0 auto; }

      /* ========== HERO ========== */

      .hero {
        position: relative;
        min-height: 360px;
        padding: 56px 0 46px;
        background:
          linear-gradient(90deg, rgba(253,252,250,0.98) 0%, rgba(253,252,250,0.92) 42%, rgba(253,252,250,0.42) 62%, rgba(253,252,250,0.02) 100%),
url("https://images.unsplash.com/photo-1616486338812-3dadae4b4ace?auto=format&fit=crop&w=1800&q=80");        background-position: center right;
        border-bottom: 1px solid var(--line);
      }

      .hero__inner {
        display: block;
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        margin: 0 0 18px;
        color: var(--accent);
        font-size: 0.72rem;
        font-weight: 850;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      .eyebrow::before {
        content: "";
        width: 28px;
        height: 1px;
        background: var(--accent);
      }

      h1 {
  max-width: 760px;
        font-family: var(--f-display);
        font-size: clamp(3.4rem, 6.6vw, 6rem);
        font-weight: 500;
       line-height: 1.03;
        letter-spacing: -0.06em;
        color: var(--ink);
        margin: 0 0 28px;
      }

      h1 em {
        font-style: normal;
        color: inherit;
      }

      .hero-desc {
        color: var(--muted);
        font-size: 1.1rem;
        line-height: 1.55;
          max-width: 620px;
        font-weight: 500;
      }

      .hero__meta {
        display: none;
      }

      /* ========== MAIN SECTION ========== */

           .section {
        padding: 28px 0 100px;
        background: #fffdf9;
      }

      /* ========== BACK LINK ========== */

      .back {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 36px;
        color: var(--muted);
        font-size: 0.82rem;
        font-weight: 600;
        padding: 8px 20px;
