      }

      .back:hover {
        border-color: var(--accent-light);
        color: var(--accent);
        transform: translateY(-1px);
      }

      /* ========== TOOLBAR / RESULTS HEADER ========== */

      .explore-toolbar {
        display: flex;
        align-items: center;
        gap: 14px;
        flex-wrap: wrap;
        margin-bottom: 26px;
      }

      .view-pill {
        display: inline-flex;
        padding: 4px;
        border-radius: 999px;
        background: #fff;
        border: 1px solid var(--line-warm);
        box-shadow: 0 8px 24px rgba(28, 25, 23, 0.08);
      }

      .view-pill__btn {
        appearance: none;
        border: 0;
        border-radius: 999px;
        background: transparent;
        color: var(--ink);
        min-height: 40px;
        padding: 0 18px;
        font: inherit;
        font-size: 0.88rem;
        font-weight: 850;
        cursor: pointer;
      }

      .view-pill__btn.active {
        background: #eadcc9;
      }

      .filter-pill {
        display: inline-flex;
