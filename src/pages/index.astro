---
const featuredHomes = [
  {
    id: "01",
    title: "Mountain modern retreat",
    meta: "4 bed · 3 bath · 2,480 sqft",
    price: "$1,289,000",
    note: "Best overall fit",
    address: "1910 Alpine Ridge Drive"
  },
  {
    id: "02",
    title: "Creekside family home",
    meta: "3 bed · 2 bath · 1,960 sqft",
    price: "$948,000",
    note: "Quiet location",
    address: "644 Creekside Lane"
  },
  {
    id: "03",
    title: "Downtown alpine loft",
    meta: "2 bed · 2 bath · 1,220 sqft",
    price: "$729,000",
    note: "Walkable lifestyle",
    address: "205 Pine Avenue"
  }
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Shortlist Lohomes</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&display=swap"
      rel="stylesheet"
    />

    <style>
      :root {
        --bg: #f7f6f3;
        --bg-card: #ffffff;
        --bg-overlay: #f0ede8;
        --bg-dark: #181614;
        --bg-dark-2: #211f1c;

        --text-primary: #18160f;
        --text-secondary: #6b6760;
        --text-muted: #a09c96;
        --text-on-dark: #f0ede8;
        --text-dim: rgba(240, 237, 232, 0.45);

        --accent: #2d5016;
        --accent-mid: #3d6b20;
        --accent-light: #eef4e9;
        --accent-border: #b5cfa0;

        --border: #e4e0d9;
        --border-strong: #ccc8c0;

        --shadow-soft: 0 16px 50px rgba(17, 14, 9, 0.12);
        --shadow-card: 0 8px 30px rgba(17, 14, 9, 0.07);

        --f-display: "DM Serif Display", Georgia, serif;
        --f-body: "DM Sans", system-ui, sans-serif;

        --r-sm: 4px;
        --r: 8px;
        --r-lg: 12px;
        --r-xl: 16px;
        --r-2xl: 22px;
      }

      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html {
        scrollbar-gutter: stable;
        scroll-behavior: smooth;
      }

      body {
        font-family: var(--f-body);
        background: var(--bg);
        color: var(--text-primary);
        font-size: 15px;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }

      a {
        color: inherit;
      }

      .site-shell {
        min-height: 100vh;
      }

      .topbar {
        position: sticky;
        top: 0;
        z-index: 100;
        background: rgba(247, 246, 243, 0.9);
        backdrop-filter: blur(10px);
        border-bottom: 1px solid rgba(24, 22, 15, 0.06);
      }

      .topbar__inner {
        max-width: 1280px;
        margin: 0 auto;
        min-height: 68px;
        padding: 0 32px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
      }

      .brand {
        font-family: var(--f-display);
        font-size: 1.35rem;
        letter-spacing: -0.02em;
        text-decoration: none;
      }

      .nav {
        display: flex;
        gap: 18px;
        align-items: center;
      }

      .nav a {
        text-decoration: none;
        color: var(--text-secondary);
        font-size: 0.9rem;
      }

      .nav a:hover {
        color: var(--text-primary);
      }

      .nav-cta {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 38px;
        padding: 0 14px;
        border-radius: var(--r);
        border: 1px solid var(--border);
        background: #fff;
        text-decoration: none;
        font-size: 0.84rem;
        font-weight: 600;
        color: var(--text-primary);
      }

      .nav-cta:hover {
        background: var(--text-primary);
        border-color: var(--text-primary);
        color: #fff;
      }

      .masthead {
        background: var(--bg-dark);
        color: var(--text-on-dark);
        padding: 0 32px;
      }

      .masthead__inner {
        max-width: 1280px;
        margin: 0 auto;
        padding: 82px 0 70px;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 64px;
        align-items: end;
      }

      .masthead__eyebrow {
        font-size: 0.65rem;
        font-weight: 600;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--accent-border);
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 8px;
      }

      .masthead__eyebrow::before {
        content: "";
        display: block;
        width: 18px;
        height: 1px;
        background: var(--accent-border);
      }

      .masthead__heading {
        font-family: var(--f-display);
        font-size: clamp(3.6rem, 6vw, 6.4rem);
        font-weight: 400;
        line-height: 0.96;
        letter-spacing: -0.03em;
        color: #fff;
        margin-bottom: 22px;
        max-width: 620px;
      }

      .masthead__heading em {
        font-style: italic;
        color: var(--text-dim);
      }

      .masthead__message {
        font-size: 0.96rem;
        line-height: 1.8;
        color: rgba(255, 255, 255, 0.42);
        max-width: 470px;
      }

      .masthead__actions {
        margin-top: 28px;
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
      }

      .masthead__btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 42px;
        padding: 0 16px;
        border-radius: var(--r);
        text-decoration: none;
        font-size: 0.84rem;
        font-weight: 600;
        transition: background 0.15s, border-color 0.15s, color 0.15s;
      }

      .masthead__btn--primary {
        background: var(--accent);
        border: 1px solid var(--accent);
        color: #fff;
      }

      .masthead__btn--primary:hover {
        background: var(--accent-mid);
        border-color: var(--accent-mid);
      }

      .masthead__btn--ghost {
        background: transparent;
        border: 1px solid rgba(255, 255, 255, 0.12);
        color: rgba(255, 255, 255, 0.75);
      }

      .masthead__btn--ghost:hover {
        background: rgba(255, 255, 255, 0.06);
        color: #fff;
      }

      .masthead__right {
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        align-items: flex-end;
        padding-bottom: 8px;
        gap: 24px;
      }

      .masthead__stat-block {
        text-align: right;
      }

      .masthead__count-num {
        font-family: var(--f-display);
        font-size: clamp(5rem, 9vw, 8.5rem);
        line-height: 1;
        letter-spacing: -0.05em;
        color: rgba(255, 255, 255, 0.12);
        display: block;
      }

      .masthead__count-label {
        font-size: 0.65rem;
        font-weight: 600;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.2);
        margin-top: 4px;
        display: block;
      }

      .masthead__hints {
        display: flex;
        flex-direction: column;
        gap: 8px;
        align-items: flex-end;
      }

      .masthead__hint {
        font-size: 0.72rem;
        color: rgba(255, 255, 255, 0.25);
        display: flex;
        align-items: center;
        gap: 6px;
      }

      .masthead__hint::before {
        content: "";
        width: 4px;
        height: 4px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.15);
        flex-shrink: 0;
      }

      .body-wrap {
        max-width: 1280px;
        margin: 0 auto;
        padding: 48px 32px 100px;
      }

      .section-header {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 24px;
        padding-bottom: 16px;
        border-bottom: 1px solid var(--border);
        flex-wrap: wrap;
      }

      .section-title {
        font-family: var(--f-display);
        font-size: 1.25rem;
        font-weight: 400;
        font-style: italic;
        color: var(--text-primary);
      }

      .section-meta {
        font-size: 0.72rem;
        font-weight: 500;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--text-muted);
      }

      .intro-grid {
        display: grid;
        grid-template-columns: 1.1fr 0.9fr;
        gap: 18px;
        margin-bottom: 44px;
      }

      .intro-card,
      .info-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--r-lg);
        box-shadow: var(--shadow-card);
      }

      .intro-card {
        padding: 28px;
      }

      .intro-card__kicker,
      .info-card__kicker {
        font-size: 0.68rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        font-weight: 700;
        color: var(--text-muted);
        margin-bottom: 10px;
      }

      .intro-card__title {
        font-family: var(--f-display);
        font-size: 2rem;
        line-height: 1.04;
        letter-spacing: -0.02em;
        margin-bottom: 14px;
      }

      .intro-card__copy {
        color: var(--text-secondary);
        font-size: 0.94rem;
        line-height: 1.85;
        max-width: 58ch;
      }

      .info-card {
        padding: 24px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
      }

      .info-list {
        list-style: none;
        display: grid;
        gap: 10px;
      }

      .info-list li {
        font-size: 0.86rem;
        color: var(--text-secondary);
        display: flex;
        align-items: center;
        gap: 10px;
      }

      .info-list li::before {
        content: "";
        width: 5px;
        height: 5px;
        border-radius: 50%;
        background: var(--accent-border);
        flex-shrink: 0;
      }

      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 16px;
      }

      .card {
        background: var(--bg-card);
        display: flex;
        flex-direction: column;
        transition:
          background 0.2s,
          border-color 0.2s ease,
          box-shadow 0.2s ease,
          transform 0.2s ease;
        position: relative;
        border: 2px solid rgba(122, 111, 102, 0.16);
        text-decoration: none;
        color: inherit;
      }

      .card:hover {
        border-color: var(--border-strong);
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.07);
        transform: translateY(-2px);
      }

      .card[data-featured="true"] {
        border-color: var(--accent-border);
        box-shadow: 0 8px 30px rgba(0, 0, 0, 0.08);
      }

      .card[data-featured="true"] .card__index::after {
        content: "  •  Featured";
        font-weight: 500;
        letter-spacing: 0.04em;
        opacity: 0.8;
      }

      .card__image-wrap {
        aspect-ratio: 4 / 3;
        overflow: hidden;
        position: relative;
        background: var(--bg-overlay);
      }

      .card__image-wrap::after {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(0, 0, 0, 0.24) 0%, transparent 52%);
        pointer-events: none;
      }

      .card__image {
        width: 100%;
        height: 100%;
        display: block;
        background:
          linear-gradient(140deg, rgba(255,255,255,0.18), transparent 32%),
          linear-gradient(160deg, #91877b 0%, #c7beb3 48%, #8d8377 100%);
      }

      .card__badge {
        position: absolute;
        top: 12px;
        left: 12px;
        z-index: 2;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 8px 12px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.96);
        color: var(--text-primary);
        border: 1px solid rgba(255, 255, 255, 0.92);
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.16);
        font-size: 0.72rem;
        font-weight: 600;
      }

      .card__index {
        position: absolute;
        bottom: 10px;
        left: 12px;
        font-family: var(--f-body);
        font-size: 0.65rem;
        font-weight: 600;
        color: rgba(255, 255, 255, 0.68);
        z-index: 2;
        letter-spacing: 0.06em;
        text-transform: uppercase;
      }

      .card__body {
        padding: 18px 20px 20px;
        display: flex;
        flex-direction: column;
        flex: 1;
      }

      .card__price {
        font-family: var(--f-display);
        font-size: 1.65rem;
        font-weight: 400;
        letter-spacing: -0.02em;
        color: var(--text-primary);
        line-height: 1;
        margin-bottom: 6px;
      }

      .card__address {
        font-size: 0.83rem;
        color: var(--text-secondary);
        margin-bottom: 6px;
        line-height: 1.4;
      }

      .card__meta {
        font-size: 0.72rem;
        color: var(--text-muted);
        margin-bottom: 12px;
        letter-spacing: 0.01em;
      }

      .card__desc {
        font-size: 0.8rem;
        line-height: 1.65;
        color: var(--text-secondary);
        margin-bottom: 16px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        flex: 1;
      }

      .card__action {
        appearance: none;
        background: transparent;
        border: 1px solid var(--border-strong);
        color: var(--text-primary);
        padding: 9px 14px;
        border-radius: var(--r);
        cursor: pointer;
        font: inherit;
        font-size: 0.78rem;
        font-weight: 500;
        transition: background 0.14s, border-color 0.14s, color 0.14s;
        width: 100%;
        text-align: center;
      }

      .card:hover .card__action {
        background: var(--text-primary);
        border-color: var(--text-primary);
        color: #fff;
      }

      .cta {
        margin-top: 40px;
        padding: 28px;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--r-lg);
        text-align: center;
      }

      .cta strong {
        display: block;
        font-size: 1rem;
        margin-bottom: 10px;
      }

      .cta p {
        color: var(--text-secondary);
        margin-bottom: 14px;
      }

      .cta-btn {
        display: inline-block;
        background: var(--text-primary);
        color: #fff;
        padding: 12px 18px;
        border-radius: var(--r);
        text-decoration: none;
        font-size: 0.9rem;
      }

      .cta-btn:hover {
        background: var(--bg-dark);
      }

      @media (max-width: 960px) {
        .topbar__inner,
        .masthead,
        .body-wrap {
          padding-left: 24px;
          padding-right: 24px;
        }

        .masthead__inner,
        .intro-grid {
          grid-template-columns: 1fr;
          gap: 28px;
        }

        .masthead__right {
          align-items: flex-start;
        }

        .masthead__hints {
          align-items: flex-start;
        }
      }

      @media (max-width: 640px) {
        .topbar__inner {
          min-height: 60px;
          padding-left: 16px;
          padding-right: 16px;
        }

        .nav {
          display: none;
        }

        .masthead,
        .body-wrap {
          padding-left: 16px;
          padding-right: 16px;
        }

        .masthead__inner {
          padding: 52px 0 44px;
          gap: 18px;
        }

        .masthead__right {
          display: none;
        }

        .masthead__heading {
          font-size: 3.25rem;
        }

        .body-wrap {
          padding-top: 28px;
          padding-bottom: 60px;
        }

        .grid {
          grid-template-columns: 1fr;
        }

        .card {
          width: min(100%, 420px);
        }

        .section-header {
          align-items: flex-start;
          flex-direction: column;
        }
      }
    </style>
  </head>

  <body>
    <div class="site-shell">
      <div class="topbar">
        <div class="topbar__inner">
          <a href="/" class="brand">shortlist.homes</a>

          <nav class="nav">
            <a href="#">Search</a>
            <a href="#">Neighbourhoods</a>
            <a href="#">Market</a>
            <a href="#">Shortlists</a>
          </nav>

          <a href="#" class="nav-cta">Start a shortlist</a>
        </div>
      </div>

      <header class="masthead">
        <div class="masthead__inner">
          <div class="masthead__left">
            <p class="masthead__eyebrow">Prepared with care</p>

            <h1 class="masthead__heading">
              Find your next<br /><em>home.</em>
            </h1>

            <p class="masthead__message">
              A calmer, more curated way to browse homes. Strong matches first, cleaner presentation, and less of the usual clutter.
            </p>

            <div class="masthead__actions">
              <a href="#featured" class="masthead__btn masthead__btn--primary">Browse featured homes</a>
              <a href="#" class="masthead__btn masthead__btn--ghost">See how shortlists work</a>
            </div>
          </div>

          <div class="masthead__right">
            <div class="masthead__stat-block">
              <span class="masthead__count-num">03</span>
              <span class="masthead__count-label">featured homes</span>
            </div>

            <div class="masthead__hints">
              <span class="masthead__hint">Editorial presentation style</span>
              <span class="masthead__hint">Built to feel like your shortlist flow</span>
            </div>
          </div>
        </div>
      </header>

      <main class="body-wrap">
        <div class="intro-grid">
          <section class="intro-card">
            <p class="intro-card__kicker">A better home search</p>
            <h2 class="intro-card__title">Less portal. More presentation.</h2>
            <p class="intro-card__copy">
              This homepage keeps the same visual language as your shortlist pages - serif headings, restrained borders, warm neutrals, and cleaner cards - so the experience feels connected rather than stitched together.
            </p>
          </section>

          <aside class="info-card">
            <div>
              <p class="info-card__kicker">What it emphasizes</p>
              <ul class="info-list">
                <li>Curated search over clutter</li>
                <li>Strongest matches surfaced first</li>
                <li>Cleaner buyer presentation</li>
              </ul>
            </div>
          </aside>
        </div>

        <div class="section-header" id="featured">
          <h2 class="section-title">Featured properties</h2>
          <span class="section-meta">3 homes selected for preview</span>
        </div>

        <div class="grid">
          {featuredHomes.map((home, i) => (
            <a class="card" href="#" data-featured={i === 0 ? "true" : "false"}>
              <div class="card__image-wrap">
                <div class="card__badge">{home.note}</div>
                <div class="card__image"></div>
                <span class="card__index">No. {home.id}</span>
              </div>

              <div class="card__body">
                <p class="card__price">{home.price}</p>
                <p class="card__address">{home.address}</p>
                <p class="card__meta">{home.meta}</p>
                <p class="card__desc">
                  {home.title} - presented in the same quiet, polished style as the rest of your shortlist experience.
                </p>
                <div class="card__action">View property →</div>
              </div>
            </a>
          ))}
        </div>

        <div class="cta">
          <strong>Want this to feel even closer to your shortlist page?</strong>
          <p>Next step would be wiring in your real header, exact card markup, and your actual listing modal.</p>
          <a href="#" class="cta-btn">Use this as the new homepage base</a>
        </div>
      </main>
    </div>
  </body>
</html>