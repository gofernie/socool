---
import { createClient } from "@supabase/supabase-js";
import Layout from "../layouts/Layout.astro";
import ShortlistReviewModal from "../components/ShortlistReviewModal.astro";
import IntentModalController from "../components/IntentModalController.astro";
import SiteNav from "../components/SiteNav.astro";
import "../styles/intent-modal.css";
import "../styles/page-hero.css";
export const prerender = false;
import { getSite } from "../lib/getSite";
import { getNavIntentPages } from "../lib/getNavIntentPages";

const site = await getSite(Astro.url.hostname);

const siteCity = site?.city || "nanaimo";
const siteName = site?.site_name || "Real Estate";

const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.SUPABASE_SERVICE_ROLE_KEY
);

const accentColor = site?.accent_color || "#2f6f73";

const googleMapsApiKey =
  import.meta.env.PUBLIC_GOOGLE_MAPS_API_KEY || "";

const url = Astro.url;

const city = url.searchParams.get("city") || siteCity;
const area = url.searchParams.get("area") || "";
const type = url.searchParams.get("type") || "";
const minPrice = Number(url.searchParams.get("minPrice") || 0);
const maxPrice = Number(url.searchParams.get("maxPrice") || 0);
const sort = url.searchParams.get("sort") || "newest";

const navIntentPages = await getNavIntentPages(
  supabase,
  city
);

const clean = (value: any) =>
  String(value || "")
    .toLowerCase()
    .trim();

const getListingMls = (listing: any) =>
  String(
    listing.mls_number ||
      listing.mlsNumber ||
      listing.id ||
      listing.repliers_listing_id ||
      listing.raw?.mlsNumber ||
      listing.raw?.id ||
      ""
  ).replace(/[^0-9]/g, "");

const getListingPrice = (listing: any) => {
  const num = Number(listing.price ?? listing.listPrice ?? listing.priceNumber ?? 0);
  if (Number.isFinite(num) && num > 1000) return `$${Math.round(num).toLocaleString()}`;
  return listing.price_text || listing.priceText || "Price on request";
};

const getListingAddress = (listing: any) =>
  listing.address ||
  listing.full_address ||
  listing.addressText ||
  listing.addressObj?.streetAddress ||
  [listing.addressObj?.streetNumber, listing.addressObj?.streetName, listing.addressObj?.streetSuffix]
    .filter(Boolean)
    .join(" ") ||
  "Address available";

const normalizeListingImageUrl = (value: any) => {
  if (!value) return "";
  const raw = typeof value === "string" ? value : value.highRes || value.mediumRes || value.lowRes || value.url || value.src || value.href || value.path || "";
  if (!raw) return "";
  if (raw.startsWith("http://") || raw.startsWith("https://")) return raw;
  const cleaned = raw.startsWith("/") ? raw : `/${raw}`;
  if (cleaned.startsWith("/vreb/")) return `https://cdn.repliers.io${cleaned}`;
  return cleaned;
};

const getListingImage = (listing: any) => {
  const image = listing.image_url || listing.image || listing.photo || listing.images?.[0] || listing.images?.[1] || listing.raw?.images?.[0] || listing.raw?.images?.[1] || listing.raw?.images?.[0]?.url || listing.raw?.images?.[1]?.url;
  return normalizeListingImageUrl(image);
};

const getListingImages = (listing: any) => {
  const rawImages = listing.images || listing.photo_urls || listing.photos || listing.raw?.images || [];
  const images = Array.isArray(rawImages)
    ? rawImages.map((img: any) => typeof img === "string" ? normalizeListingImageUrl(img) : normalizeListingImageUrl(img.highRes || img.mediumRes || img.lowRes || img.url || img.src || img.href || img.path || "")).filter(Boolean)
    : [];
  const firstImage = getListingImage(listing);
  return Array.from(new Set([firstImage, ...images].filter(Boolean)));
};

const getListingBeds = (listing: any) => listing.beds || listing.bedrooms || listing.details?.numBedrooms || listing.raw?.details?.numBedrooms || 0;
const getListingBaths = (listing: any) => listing.baths || listing.bathrooms || listing.details?.numBathrooms || listing.raw?.details?.numBathrooms || 0;
const getListingSqft = (listing: any) => listing.sqft || listing.square_feet || listing.squareFeet || listing.details?.sqft || listing.details?.squareFeet || listing.raw?.details?.sqft || listing.raw?.details?.squareFeet || "";
const getListingDescription = (listing: any) => listing.description || listing.publicRemarks || listing.remarks || listing.details?.description || listing.details?.publicRemarks || listing.details?.remarks || listing.raw?.description || listing.raw?.publicRemarks || listing.raw?.remarks || listing.raw?.details?.description || listing.raw?.details?.publicRemarks || listing.raw?.details?.remarks || "A quiet preview of this property.";
const getListingYearBuilt = (listing: any) => listing.year_built || listing.yearBuilt || listing.details?.yearBuilt || listing.raw?.details?.yearBuilt || "";
const getListingLotSize = (listing: any) => listing.lot_size || listing.lotSize || listing.details?.lotSize || listing.raw?.details?.lotSize || "";
const getListingArea = (listing: any) => listing.normalized_area || listing.area || listing.neighborhood || listing.addressObj?.neighborhood || listing.address?.neighborhood || listing.details?.area || listing.details?.subArea || listing.raw?.address?.neighborhood || listing.raw?.details?.area || listing.raw?.details?.subArea || "";
const getListingPropertyType = (listing: any) => String(listing.normalized_type || listing.property_type || listing.propertyType || listing.type || listing.details?.propertyType || listing.raw?.details?.propertyType || "Home").replace(/[_-]+/g, " ").replace(/\b\w/g, (char: string) => char.toUpperCase());

const titleCase = (value: any) =>
  String(value || "")
    .replace(/-/g, " ")
    .replace(/\b\w/g, (char: string) => char.toUpperCase());

const cityName = titleCase(city || "nanaimo");

const selectedAreaName = area ? titleCase(area) : "";

const pageSubject = selectedAreaName
  ? `${selectedAreaName} ${cityName} Real Estate`
  : `${cityName} Real Estate`;

const propertyLabel = type
  ? titleCase(type === "house" ? "homes" : `${type}s`)
  : "Homes";

const seoTitle = `${pageSubject} & ${propertyLabel} For Sale | MLS® Listings`;

const seoDescription = `Browse ${pageSubject.toLowerCase()} including ${propertyLabel.toLowerCase()} for sale. View active MLS® listings with photos, prices, maps, and local search details.`;

const heroHeading =
  site?.hero_heading ||
  `${(city || "Nanaimo").replace(/\b\w/g, (char) => char.toUpperCase())} Homes For Sale`;

const heroHeadingClean = heroHeading.replace(/\.$/, "");const buildFilterUrl = (updates: Record<string, string | number | null>) => {
  const params = new URLSearchParams();

  params.set("city", city || "nanaimo");

  if (area) params.set("area", area);
  if (type) params.set("type", type);
  if (minPrice) params.set("minPrice", String(minPrice));
  if (maxPrice) params.set("maxPrice", String(maxPrice));
  if (sort && sort !== "newest") params.set("sort", sort);

  Object.entries(updates).forEach(([key, value]) => {
    if (value === null || value === "" || value === 0) {
      params.delete(key);
    } else {
      params.set(key, String(value));
    }
  });

  return `?${params.toString()}`;
};
let intentPagesQuery = supabase
  .from("intent_pages")
  .select(`
    *,
    intent_page_features (
      feature_key
    )
  `)
  .eq("city", city || siteCity || "nanaimo")
  .or("is_published.eq.true,status.eq.published")
  .order("created_at", { ascending: false });

if (site?.id) {
  intentPagesQuery = intentPagesQuery.or(`site_id.eq.${site.id},site_id.is.null`);
}

const { data: intentPageRows } = await intentPagesQuery;

function shortenIntentTitle(title: string) {
  const t = title.toLowerCase();

  if (t.includes("first time buyers condos") && t.includes("500")) {
    return "First-Time Buyer Condos Under $500K";
  }

  if (t.includes("first time buyers mobiles")) {
    return "First-Time Buyer Mobile Homes";
  }

  if (t.includes("homes") && t.includes("1,000,000")) {
    return "Homes Over $1M";
  }

  if (t.includes("ocean view condos")) {
    return "Ocean View Condos";
  }

  if (t.includes("walkable condos")) {
    return "Walkable Condos";
  }

  if (t.includes("downsizers")) {
    return "Condos for Downsizers";
  }

  return title
    .replace(/worth a closer look/gi, "")
    .replace(/in nanaimo$/gi, "")
    .replace(/^nanaimo\s+/i, "Nanaimo ")
    .replace(/\s+/g, " ")
    .trim();
}

function shortenIntentDescription(text: string, title = "") {
  const t = title.toLowerCase();

  if (t.includes("first-time buyer condos")) {
    return "Affordable Nanaimo condos shaped around first-time buyers.";
  }

  if (t.includes("mobile homes")) {
    return "Entry-level mobile homes for buyers looking for a practical starting point.";
  }

  if (t.includes("homes over")) {
    return "Higher-end Nanaimo homes with more space, finish, and lifestyle upside.";
  }

  if (t.includes("nanaimo homes")) {
    return "A broad look at active Nanaimo homes across different areas and price points.";
  }

  if (t.includes("townhomes")) {
    return "Nanaimo townhomes for buyers who want more space without full detached-home upkeep.";
  }

  if (t.includes("ocean view")) {
    return "Condos with ocean-view potential, coastal appeal, and low-maintenance living.";
  }

  if (t.includes("downsizers")) {
    return "Lower-maintenance condos suited to comfort, convenience, and simpler living.";
  }

  if (t.includes("walkable")) {
    return "Condos close to amenities, services, parks, and daily conveniences.";
  }

  return String(text || "")
    .replace(/react to listings as you browse and the page will help surface better matches\.?/gi, "")
    .replace(/browse active nanaimo /gi, "")
    .replace(/explore nanaimo /gi, "")
    .replace(/\s+/g, " ")
    .trim();
}

const allIntentCollections = (intentPageRows || []).map((page: any) => ({
  type: String(page.property_type || "").toLowerCase(),
  title: shortenIntentTitle(page.hero_heading || page.slug),
  href: `/${page.city}/${page.slug}`,
description: shortenIntentDescription(page.intro_copy || "", shortenIntentTitle(page.hero_heading || page.slug)),  features: (page.intent_page_features || []).map((feature: any) => feature.feature_key),
}));

let intentCollections = allIntentCollections;

if (type) {
  intentCollections = allIntentCollections.filter(
    (card) => card.type === clean(type)
  );
}

intentCollections = intentCollections.slice(0, 8);
const propertyTypeOptions = Array.from(
  new Set(
    allIntentCollections
      .map((card) => card.type)
      .filter(Boolean)
  )
).sort();

const groupLabel = [  area || "",
  type ? type.replace(/-/g, " ") : "",
  maxPrice ? `under $${maxPrice}k` : "",
  minPrice ? `over $${minPrice}k` : ""
].filter(Boolean).join(" · ");

let areaOptions: string[] = [];

try {
  const { data } = await supabase
    .from("listing_rows")
    .select("normalized_area")
    .eq("status", "A")
    .eq("normalized_city", clean(city || "nanaimo"))
    .not("normalized_area", "is", null);

 const allowedAreas = [
  "north nanaimo",
  "south nanaimo",
  "central nanaimo",
  "departure bay",
  "hammond bay",
  "uplands",
  "old city",
  "university district",
  "chase river",
  "cedar",
  "pleasant valley",
  "jingle pot",
  "diver lake",
  "brechin hill"
];

areaOptions = Array.from(
  new Set((data || []).map((row: any) => row.normalized_area).filter(Boolean))
)
  .filter((area: string) => allowedAreas.includes(area))
  .sort();
} catch {}

let listings: any[] = [];
let errorMessage = "";

try {
let query = supabase.from("listing_rows").select("*").eq("status", "A").limit(16);  if (city) query = query.eq("normalized_city", clean(city));

  // Homepage discovery preloads a broad pool.
  // Filters are applied client-side for instant UX.

  if (sort === "price-low" || sort === "price-asc") query = query.order("price", { ascending: true });
  else if (sort === "price-high" || sort === "price-desc") query = query.order("price", { ascending: false });
  else if (sort === "beds-high") query = query.order("beds", { ascending: false });
  else query = query.order("listed_at", { ascending: false });

  const { data, error } = await query;
  if (error) throw error;
  listings = data || [];

 
  listings = listings.slice(0, 8);
} catch (error: any) {
  errorMessage = error?.message || "Could not load listings.";
}
---

<Layout
  title={seoTitle}
  accentColor={accentColor}
>
 <meta
  name="description"
  content={seoDescription}
  slot="head"
/>

  <script
    type="application/ld+json"
    slot="head"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ItemList",
      "name": city ? `${city} ${type ? type.replace(/-/g, " ") + "s" : "homes"} for sale` : "Homes for sale",
      "description": city ? `${listings.length} active listings in ${city}` : "Active real estate listings",
      "numberOfItems": listings.length,
      "url": Astro.url.href
    })}
  />

  <script
    id="home-intent-collections-json"
    type="application/json"
    set:html={JSON.stringify(allIntentCollections)}
  />

  <div
    data-intent-page-id="homepage"
    data-city={city || "nanaimo"}
    data-slug="homepage"
    data-google-maps-api-key={googleMapsApiKey}
  >
<SiteNav
  city={city}
  areas={areaOptions}
  types={propertyTypeOptions}
  intentPages={navIntentPages}
  showAreaNav={false}
/>
<header
  class="page-hero"
  style={`--hero-image: url("https://images.unsplash.com/photo-1616486338812-3dadae4b4ace?auto=format&fit=crop&w=1800&q=80")`}
>
  <div class="page-hero__inner">
    <div>
    <p class="page-hero__eyebrow">
  {site?.hero_eyebrow || "Homes worth watching"}
</p>

<h1>
  {heroHeadingClean}<span class="accent-period">.</span>
</h1>



<p class="page-hero__copy">
  {site?.hero_copy ||
    "Browse active homes for sale, including houses, condos, and townhomes."}
</p>
        </div>

       
      </div>
       </header>

    <main class="section">
      <div class="intent-content-shell">
             <section class="homepage-intro">
 <p>
  {site?.intro_copy ||
    `Explore current MLS listings, compare neighbourhoods, discover condos, townhomes, and detached houses, and find properties that match your lifestyle and budget.`}
</p>
</section>

<div class="explore-toolbar">
          <div class="view-pill">
           <button type="button" class="view-pill__btn active" id="list-view-btn">☷ List</button>
<button type="button" class="view-pill__btn" id="map-view-btn">⌖ Map</button>
          </div>
              <form class="filter-form" method="get" id="home-filter-form">
  <input type="hidden" name="city" value={city || "nanaimo"} />
<select name="area" class="filter-select" aria-label="Area">
  <option value="" selected={!area}>All Areas</option>
  {areaOptions.map((areaOption) => (
    <option value={areaOption} selected={area === areaOption}>
      {areaOption.replace(/-/g, " ").replace(/\b\w/g, (char) => char.toUpperCase())}
    </option>
  ))}
</select>
<select name="type" class="filter-select" aria-label="Property type">
  <option value="" selected={!type}>All Types</option>

  {propertyTypeOptions.map((propertyType) => (
    <option value={propertyType} selected={type === propertyType}>
      {propertyType.replace(/-/g, " ").replace(/\b\w/g, (char) => char.toUpperCase())}
    </option>
  ))}
</select>

  <select name="maxPrice" class="filter-select" aria-label="Max price">
    <option value="" selected={!maxPrice}>Any Price</option>
    <option value="500" selected={maxPrice === 500}>Under $500k</option>
    <option value="800" selected={maxPrice === 800}>Under $800k</option>
    <option value="1200" selected={maxPrice === 1200}>Under $1.2M</option>
  </select>

  <select name="sort" class="filter-select" aria-label="Sort listings">
    <option value="newest" selected={sort === "newest"}>Newest first</option>
    <option value="price-low" selected={sort === "price-low"}>Price low to high</option>
    <option value="price-high" selected={sort === "price-high"}>Price high to low</option>
  </select>

  <a href="?" class="filter-clear">Clear</a>
</form>

          </div>

       <div class="results-heading">
  <h2 id="results-heading">
    {(city || "Nanaimo").replace(/\b\w/g, (char) => char.toUpperCase())} Homes For Sale
  </h2>

  <p id="results-update-note">
    <span id="results-count">{listings.length}</span> Active Listings
  </p>
</div>

        {errorMessage && <div class="empty">{errorMessage}</div>}

               {!errorMessage && listings.length === 0 && (
          <div class="empty">No matching homes found yet.</div>
        )}

      {!errorMessage && listings.length > 0 && (
  <>
    <div id="intent-map" class="intent-map" hidden></div>

<section class="grid" aria-label={`${listings.length} listings${city ? ` in ${city}` : ""}`}> {listings.map((listing: any) => {              const image = getListingImage(listing);
              const address = getListingAddress(listing);
              const price = getListingPrice(listing);
              const beds = getListingBeds(listing);
              const baths = getListingBaths(listing);
              const sqft = getListingSqft(listing);
              const mls = getListingMls(listing);
              const propertyType = getListingPropertyType(listing);
              const description = getListingDescription(listing);
              const images = getListingImages(listing);

              return (
                                  <article
                    class="card original-card"
                    data-item-id={String(listing?.id || listing?.mls_number || "")}
                    data-card-id={String(listing?.id || listing?.mls_number || "")}
                    data-listing-id={String(listing?.id || listing?.mls_number || "")}
                    data-price={price}
                    data-raw-price={String(listing?.price || 0)}
                    data-listed-at={String(listing?.listed_at || listing?.created_at || "")}
                    data-address={address}
                    data-meta={`${beds || "-"} bed · ${baths || "-"} bath`}
                    data-image={image}
                    data-images={JSON.stringify(images)}
                    data-beds={String(beds)}
                    data-baths={String(baths)}
                    data-sqft={String(sqft)}
                    data-description={description}
                    data-property-type={propertyType}
                    data-type={String(listing?.normalized_type || listing?.property_type || type || "Home")}
                    data-year={String(getListingYearBuilt(listing))}
                    data-lot-size={String(getListingLotSize(listing))}
                    data-area={String(getListingArea(listing))}
                    data-liked-tags="[]"
                    data-is-favourite="false"
                    data-decision=""
                    data-lat={listing?.lat || ""}
                    data-lng={listing?.lng || ""}
                    data-city={String(listing?.normalized_city || listing?.city || city || "")}
                    data-mls={mls}
                    aria-label={`${price} — ${address}`}
                  >
               <div class="card-image-wrap">
  <img src={image || "https://placehold.co/800x600?text=Listing"} alt={address || "Listing"} />
</div>

                    <div class="card-body">
                      <div class="price">{price}</div>
                      <div class="address">{address}</div>
<div class="card-city">{(city || "Nanaimo").replace(/\b\w/g, (char) => char.toUpperCase())}, BC</div>
                      <div class="meta">
                        <span>🛏 {beds || "-"} bd</span>
                        <span>🛁 {baths || "-"} ba</span>
                        {sqft && <span>↗ {Number(sqft).toLocaleString()} sq ft</span>}
                      </div>

                      <div class="card-decision-badge" hidden></div>
                    </div>
                                    </article>
              );
            })}
                 </section>

<div class="homepage-interruptor">
  <div class="homepage-interruptor-copy">
    <strong>Not seeing what you're looking for?</strong>
    <p>
      Refine your search or get new listings sent to you.
    </p>
  </div>

  <div class="homepage-interruptor-actions">
  <button class="interrupt-btn interrupt-secondary" id="refine-search-btn" type="button">
  Refine My Search
</button>

  <button class="interrupt-btn interrupt-primary" id="save-search-btn" type="button">
  Save Search
</button>
  </div>
  <div class="homepage-refine-panel" id="homepage-refine-panel" hidden>
<p>
  Refine the listings above:
 <div id="refine-update-note" class="refine-update-note" hidden>
  Showing updated matches above ↑
</div>
</p>  <div class="homepage-refine-chips">
    <button type="button" data-refine="views">Views</button>
    <button type="button" data-refine="garage">Garage</button>
    <button type="button" data-refine="yard">Yard</button>
    <button type="button" data-refine="suite">Suite</button>
    <button type="button" data-refine="updated">Updated</button>
    <button type="button" data-refine="walkability">Walkable</button>
  </div>
</div>
</div>

  </>
)}

        <section class="intent-collections">
          <div class="intent-collections-head">
            <h2>Search by what matters.</h2>

            <p>
              Explore focused search paths based on lifestyle,
              property type, price point, and buyer priorities.
            </p>
          </div>

                            <div class="intent-collections-grid" id="intent-collections-grid">
  {intentCollections.map((card) => (
              <a href={card.href} class="intent-card" data-type={card.type}>
                <span class="intent-type">{card.type}</span>

                <h3>{card.title}</h3>

                <p>{card.description}</p>

                <span class="intent-link">View search →</span>
              </a>
            ))}
          </div>
        </section>
      </div>
    </main>

<ShortlistReviewModal />
<IntentModalController />

<style is:inline slot="head">

  .accent-period {
  color: var(--accent);
}
  .section {
    padding: 28px 0 100px;
    background: var(--bg);
  }

  .intent-content-shell {
    width: min(1400px, calc(100% - 80px));
    margin: 0 auto;
  }

  .homepage-intro {
    max-width: 820px;
    margin: 0 0 28px;
    padding: 22px 26px;
    border: 1px solid var(--line-warm);
    border-radius: 18px;
    background: var(--surface);
  }

  .homepage-intro p {
    margin: 0;
    color: var(--muted);
    line-height: 1.7;
    font-weight: 650;
  }

.explore-toolbar {
  display: flex;
  align-items: center;
  gap: 14px;
  flex-wrap: nowrap;
  margin-bottom: 26px;
}

.filter-form {
  display: flex;
  align-items: center;
  gap: 14px;
  flex-wrap: nowrap;
  flex: 1;
}

.filter-select {
  min-width: 140px;
}

.filter-clear {
  white-space: nowrap;
}

 .view-pill {
  display: inline-flex;
  align-items: center;
  gap: 0;
  flex: 0 0 auto;
  flex-wrap: nowrap;
  white-space: nowrap;
  min-width: max-content;
}

.view-pill__btn,
.filter-select,
.filter-clear {
  height: 34px;
  min-height: 34px;
  padding: 0 15px;
  border-radius: 999px;
  border: 1px solid var(--line-warm);
  background: var(--surface);
  color: var(--ink);
  font: inherit;
  font-size: 0.82rem;
  font-weight: 750;
  cursor: pointer;
  box-sizing: border-box;
}

.view-pill__btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  height: 28px;
  min-height: 28px;
  padding: 0 13px;
  white-space: nowrap;
  line-height: 1;
}

.view-pill__btn + .view-pill__btn {
  margin-left: -1px;
}

.view-pill__btn:first-child {
  border-top-right-radius: 0;
  border-bottom-right-radius: 0;
}

.view-pill__btn:last-child {
  border-top-left-radius: 0;
  border-bottom-left-radius: 0;
}

.view-pill__btn.active {
  background: var(--accent);
  border-color: var(--accent);
  color: #fff;
}

.filter-select {
  min-width: 140px;
}

.filter-clear {
  display: inline-flex;
