     async function loadCities() { // returns promise implicitly via async
        try {
          const res = await fetch("/api/listing-filters");
          const json = await res.json();
          const cities = Array.isArray(json?.cities) ? json.cities : [];
          const select = document.getElementById("cityInput");
          if (!select || !cities.length) return;
          const current = select.value;
const siteCity = current || "parksville";

select.innerHTML = "";

if (siteCity) {
  const opt = document.createElement("option");
  opt.value = siteCity;
  opt.textContent = siteCity.replace(/\b\w/g, (c) => c.toUpperCase());
  opt.selected = true;
  select.appendChild(opt);
}
        cities.forEach((item) => {
  const value = String(item?.value || item || "").trim().toLowerCase();
  const label = item?.label || value.replace(/\b\w/g, (c) => c.toUpperCase());

  if (!value) return;
  if (value === siteCity) return;

  const opt = document.createElement("option");
  opt.value = value;
  opt.textContent = label;
  if (value === current) opt.selected = true;

  select.appendChild(opt);
});
          updatePreview();
        } catch (err) {
          console.error("Could not load cities:", err);
        }
      }

           // loadCities runs after polygon map setup below

      async function loadAreas(city) {
        try {
          const res = await fetch("/api/listing-filters");
          const json = await res.json();
          const areasByCity = json?.areasByCity || {};
          const cityKey = Object.keys(areasByCity).find(
            (k) => k.toLowerCase() === city.toLowerCase()
          );
          const areas = cityKey ? areasByCity[cityKey] : [];
          const select = document.getElementById("areaInput");
          if (!select) return;
          select.innerHTML = `<option value="">City-wide</option>`;
          areas.forEach((item) => {
            const value = String(item?.value || item || "").trim().toLowerCase();
            const label = item?.label || value.replace(/-/g, " ").replace(/\b\w/g, (c) => c.toUpperCase());
            if (!value) return;
            const opt = document.createElement("option");
            opt.value = value;
            opt.textContent = label;
            select.appendChild(opt);
          });
        } catch (err) {
          console.error("Could not load areas:", err);
        }
      }

      document.getElementById("cityInput")?.addEventListener("change", (e) => {
        loadAreas(e.target.value);
        updatePreview();
      });

    
   const polygonBlock = document.getElementById("polygonBlock");
const polygonInput = document.getElementById("polygonGeojsonInput");
const polygonCenterLatInput = document.getElementById("polygonCenterLatInput");
const polygonCenterLngInput = document.getElementById("polygonCenterLngInput");
const polygonBoundsInput = document.getElementById("polygonBoundsInput");
const clearPolygonBtn = document.getElementById("clearPolygonBtn");

let polygonMap = null;
let activePolygon = null;
let polygonPath = [];
let polygonMarkers = [];

function savePolygon() {
  if (!polygonInput || polygonPath.length < 3) {
    polygonInput.value = "";

    if (polygonCenterLatInput) polygonCenterLatInput.value = "";
    if (polygonCenterLngInput) polygonCenterLngInput.value = "";
    if (polygonBoundsInput) polygonBoundsInput.value = "";

    return;
  }

  const coordinates = polygonPath.map((point) => [point.lng, point.lat]);
  coordinates.push(coordinates[0]);

  polygonInput.value = JSON.stringify({
    type: "Polygon",
    coordinates: [coordinates],
  });

  const avgLat =
    polygonPath.reduce((sum, p) => sum + p.lat, 0) /
    polygonPath.length;

  const avgLng =
    polygonPath.reduce((sum, p) => sum + p.lng, 0) /
    polygonPath.length;

  const lats = polygonPath.map((p) => p.lat);
  const lngs = polygonPath.map((p) => p.lng);

  const bounds = {
    north: Math.max(...lats),
    south: Math.min(...lats),
    east: Math.max(...lngs),
    west: Math.min(...lngs),
  };

  if (polygonCenterLatInput) {
    polygonCenterLatInput.value = String(avgLat);
  }

  if (polygonCenterLngInput) {
    polygonCenterLngInput.value = String(avgLng);
  }

  if (polygonBoundsInput) {
    polygonBoundsInput.value = JSON.stringify(bounds);
  }
}

function redrawPolygon() {
  if (activePolygon) {
    activePolygon.setMap(null);
  }

  if (polygonPath.length < 2) {
    savePolygon();
    return;
  }

  activePolygon = new google.maps.Polygon({
    paths: polygonPath,
    editable: true,
    draggable: false,
    strokeWeight: 2,
    fillOpacity: 0.22,
  });

  activePolygon.setMap(polygonMap);
  savePolygon();
}

function addPolygonPoint(latLng) {
  const point = {
    lat: latLng.lat(),
    lng: latLng.lng(),
  };

  polygonPath.push(point);

  const marker = new google.maps.Marker({
    position: point,
    map: polygonMap,
    label: String(polygonPath.length),
  });

  polygonMarkers.push(marker);
  redrawPolygon();
}

function initPolygonMap() {
  if (polygonMap || !window.google?.maps) return;

  polygonMap = new google.maps.Map(document.getElementById("polygonMap"), {
    center: { lat: 49.1659, lng: -123.9401 },
    zoom: 11,
    mapTypeId: "roadmap",
    draggableCursor: "crosshair",
  });

  polygonMap.addListener("click", (e) => {
    addPolygonPoint(e.latLng);
  });
}

function clearPolygon() {
  polygonPath = [];

  if (activePolygon) {
    activePolygon.setMap(null);
  }

  polygonMarkers.forEach((marker) => marker.setMap(null));
  polygonMarkers = [];
  activePolygon = null;

  if (polygonInput) {
    polygonInput.value = "";
  }
}

clearPolygonBtn?.addEventListener("click", clearPolygon);

function syncPolygonBlock() {
  const pageType = getPageType();

  if (!polygonBlock) return;

  polygonBlock.hidden = pageType !== "polygon";

  if (pageType === "polygon") {
    setTimeout(() => {
      initPolygonMap();

      if (polygonMap) {
        google.maps.event.trigger(polygonMap, "resize");
        polygonMap.setCenter({ lat: 49.1659, lng: -123.9401 });
      }
    }, 100);
  }
}
loadCities().then(() => {
  loadAreas(cityInput.value);
  updatePreview();
});
form?.addEventListener("submit", (e) => {
  if (getPageType() === "polygon" && !customNameInput?.value.trim()) {
    e.preventDefault();
    alert("Add a custom page name before creating this page.");
    return;
  }

  if (getPageType() === "polygon" && !polygonInput.value) {
    e.preventDefault();
    alert("Draw a polygon before creating this page.");
  }
});
