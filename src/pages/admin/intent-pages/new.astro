---
import { createClient } from "@supabase/supabase-js";
import AdminSidebar from "../../../components/AdminSidebar.astro";
import { getSite } from "../../../lib/getSite";
export const prerender = false;

const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.SUPABASE_SERVICE_ROLE_KEY
);
const site = await getSite(Astro.url.hostname);
let message = "";

const TEMPLATE_FEATURES = {
  first_time_buyers: ["value", "updated", "walkability"],
  downsizers: ["walkability", "updated", "views"],
  family_homes: ["yard", "garage", "suite"],
  ocean_view_homes: ["views"],
  homes_with_suites: ["suite", "income", "mortgage_helper"],
  luxury_homes: ["views", "garage", "updated"],
  investment_properties: ["suite", "income", "value"],
  waterfront: ["views", "waterfront"],
  walkable_homes: ["walkability"],
  updated_homes: ["updated"],
};

function clean(value: FormDataEntryValue | null) {
  return String(value || "").trim();
}

function slugify(value: string) {
  return value
    .toLowerCase()
    .replace(/&/g, "and")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");
}

function titleCase(value: string) {
  return value
    .replace(/[-_]+/g, " ")
    .replace(/\s+/g, " ")
    .trim()
    .replace(/\b\w/g, (char) => char.toUpperCase());
}

function pluralType(value: string) {
  if (!value) return "Homes";
  if (value === "house") return "Homes";
  if (value === "mobile") return "Mobile Homes";
  if (value === "condo") return "Condos";
  if (value === "townhouse") return "Townhomes";
  return `${titleCase(value)}s`;
}

function formatPriceLabel(priceMax: number | null, priceMin: number | null) {
  if (priceMax) return `Under $${priceMax.toLocaleString()}`;
  if (priceMin) return `$${priceMin.toLocaleString()}+`;
  return "";
}

function getPricePreset(value: string) {
  if (value === "under-500") return { price_min: null, price_max: 500000 };
  if (value === "under-650") return { price_min: null, price_max: 650000 };
  if (value === "under-800") return { price_min: null, price_max: 800000 };
  if (value === "under-1000") return { price_min: null, price_max: 1000000 };
  if (value === "800-plus") return { price_min: 800000, price_max: null };
  if (value === "luxury") return { price_min: 1200000, price_max: null };

  return { price_min: null, price_max: null };
}
let areaOptions: string[] = [];

try {
  const { data } = await supabase
    .from("listing_rows")
    .select("normalized_area")
    .eq("status", "A")
    .eq("normalized_city", site?.city || "nanaimo")
    .not("normalized_area", "is", null);

  areaOptions = Array.from(
    new Set((data || []).map((row: any) => row.normalized_area).filter(Boolean))
  ).sort();
} catch {}
if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();

  const pageType = clean(form.get("page_type") || "category").toLowerCase();
  const template = clean(form.get("template")).toLowerCase();
  const city = clean(form.get("city") || "nanaimo").toLowerCase();
  const area = clean(form.get("area")).toLowerCase();
  const propertyType = clean(form.get("property_type")).toLowerCase();
  let pricePreset = clean(form.get("price_preset"));

if (!pricePreset && template === "luxury_homes") {
  pricePreset = "luxury";
}
const customName = clean(form.get("custom_name"));
const slugOverride = clean(form.get("slug_override"));
const heroHeadingOverride = clean(form.get("hero_heading_override"));
const seoTitleOverride = clean(form.get("seo_title_override"));
const introCopyOverride = clean(form.get("intro_copy_override"));
const metaDescriptionOverride = clean(form.get("meta_description_override"));  
const sortOrder = Number(clean(form.get("sort_order"))) || 0;const polygonGeojsonRaw = clean(form.get("polygon_geojson"));
const polygonGeojson = polygonGeojsonRaw
  ? JSON.parse(polygonGeojsonRaw)
  : null;
  const polygonCenterLat =
  Number(clean(form.get("polygon_center_lat"))) || null;

const polygonCenterLng =
  Number(clean(form.get("polygon_center_lng"))) || null;

const polygonBoundsRaw =
  clean(form.get("polygon_bounds"));

const polygonBounds =
  polygonBoundsRaw
    ? JSON.parse(polygonBoundsRaw)
    : null;
  const { price_min, price_max } = getPricePreset(pricePreset);

  const areaLabel = area ? titleCase(area) : titleCase(city);
  const typeLabel = pluralType(propertyType);
  const priceLabel = formatPriceLabel(price_max, price_min);
  const templateLabel = titleCase(template);

  const features =
    pageType === "intent"
      ? TEMPLATE_FEATURES[template as keyof typeof TEMPLATE_FEATURES] || []
      : [];

 const slugParts =
  pageType === "category"
    ? [area || city, propertyType ? pluralType(propertyType) : "homes", priceLabel]
    : pageType === "polygon"
      ? [city, customName || "custom-area", propertyType ? pluralType(propertyType) : "homes", priceLabel]
      : [area || city, template, propertyType ? pluralType(propertyType) : "", priceLabel];
 const slug = slugify(slugOverride || slugParts.filter(Boolean).join(" "));

  const heroHeading =
    pageType === "category"
      ? [areaLabel, typeLabel, priceLabel, "worth a closer look"]
          .filter(Boolean)
          .join(" ")
      : [areaLabel, templateLabel.toLowerCase(), typeLabel.toLowerCase(), priceLabel, "worth a closer look"]
          .filter(Boolean)
          .join(" ");

  const seoTitle =
    pageType === "category"
      ? [areaLabel, typeLabel, priceLabel].filter(Boolean).join(" ")
      : [areaLabel, templateLabel, typeLabel, priceLabel].filter(Boolean).join(" ");
const metaDescription = [
  `Browse active ${areaLabel} ${typeLabel.toLowerCase()} for sale.`,
  priceLabel ? `View options ${priceLabel.toLowerCase()}.` : "",
  `Explore current listings and find homes that match your preferences.`,
]
  .filter(Boolean)
  .join(" ");
  const introCopy =
    pageType === "category"
      ? [
          `Browse active ${areaLabel} ${typeLabel.toLowerCase()}.`,
          priceLabel ? `This page focuses on options ${priceLabel.toLowerCase()}.` : "",
          `React to listings as you browse and the page will help surface better matches.`,
        ]
          .filter(Boolean)
          .join(" ")
      : [
          `Browse active ${areaLabel} ${typeLabel.toLowerCase()} shaped around ${templateLabel.toLowerCase()}.`,
          priceLabel ? `This page focuses on options ${priceLabel.toLowerCase()}.` : "",
          `React to listings as you browse and the page will help surface better matches.`,
        ]
          .filter(Boolean)
          .join(" ");
const { data: existingPage } = await supabase
  .from("intent_pages")
  .select("id, city, slug, site_id")
  .eq("slug", slug)
  .eq("site_id", site?.id)
  .maybeSingle();

if (existingPage) {
message = `A page with this URL already exists.||/${existingPage.city}/${existingPage.slug}||/admin/intent-pages/${existingPage.id}/edit`;} else {
  const { data: page, error } = await supabase
    .from("intent_pages")
  .insert({
  site_id: site?.id,
  slug,
  city,
  area,
  property_type: propertyType || null,
  price_min,
  price_max,
  hero_heading: heroHeadingOverride || heroHeading,
intro_copy: introCopyOverride || introCopy,
seo_title: seoTitleOverride || seoTitle,
meta_description: metaDescriptionOverride || metaDescription,
sort_order: sortOrder,
is_published: true,
  lifestyle_angle: pageType,
polygon_geojson: polygonGeojson,
polygon_center_lat: polygonCenterLat,
polygon_center_lng: polygonCenterLng,
polygon_bounds: polygonBounds,

requires_waterfront:
  pageType === "intent" &&
  template === "waterfront",

requires_ocean_view:
  pageType === "intent" &&
  template === "ocean_view_homes",

waterfront_type:
  template === "oceanfront"
    ? "ocean"
    : template === "lakefront"
    ? "lake"
    : template === "riverfront"
    ? "river"
    : null,
})
    .select("*")
    .single();

  if (error) {
    message = error.message;
  } else {
    if (features.length) {
      await supabase.from("intent_page_features").insert(
        features.map((feature) => ({
          intent_page_id: page.id,
          feature_key: feature,
        }))
      );
    }

return Astro.redirect("/admin/intent-pages");
  }
}
}
