---
import { createClient } from "@supabase/supabase-js";
export const prerender = false;

const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.SUPABASE_SERVICE_ROLE_KEY
);

const id = Astro.params.id || "";
let message = "";

const FEATURE_OPTIONS = [
  { key: "views", label: "Views" },
  { key: "waterfront", label: "Waterfront" },
  { key: "updated", label: "Updated" },
  { key: "walkability", label: "Walkability" },
  { key: "yard", label: "Yard" },
  { key: "garage", label: "Garage" },
  { key: "suite", label: "Suite" },
  { key: "income", label: "Income" },
  { key: "mortgage_helper", label: "Mortgage helper" },
  { key: "low_maintenance", label: "Low maintenance" },
  { key: "outdoor_space", label: "Outdoor space" },
  { key: "value", label: "Value" },
];

function clean(value: FormDataEntryValue | null) {
  return String(value || "").trim();
}

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();

  const features = form
    .getAll("features")
    .map((feature) => String(feature).trim().toLowerCase())
    .filter(Boolean);

  const { error } = await supabase
    .from("intent_pages")
    .update({
      slug: clean(form.get("slug")).toLowerCase(),
      city: clean(form.get("city")).toLowerCase(),
      area: clean(form.get("area")).toLowerCase(),
      property_type: clean(form.get("property_type")).toLowerCase() || null,
      price_min: form.get("price_min") ? Number(form.get("price_min")) : null,
      price_max: form.get("price_max") ? Number(form.get("price_max")) : null,
      hero_heading: clean(form.get("hero_heading")),
      intro_copy: clean(form.get("intro_copy")),
      seo_title: clean(form.get("seo_title")),
      lifestyle_angle: clean(form.get("lifestyle_angle")) || "category",
      is_published: form.get("is_published") === "on",
    })
    .eq("id", id);

  if (error) {
    message = error.message;
  } else {
    await supabase.from("intent_page_features").delete().eq("intent_page_id", id);

    if (features.length) {
      await supabase.from("intent_page_features").insert(
        features.map((feature) => ({
          intent_page_id: id,
          feature_key: feature,
        }))
      );
    }

    return Astro.redirect("/admin/intent-pages");
  }
}

const { data: page, error: pageError } = await supabase
  .from("intent_pages")
  .select(`
    *,
    intent_page_features (
      feature_key
    )
  `)
  .eq("id", id)
  .single();

if (!page || pageError) {
  return Astro.redirect("/admin/intent-pages");
}

const selectedFeatures = (page.intent_page_features || []).map(
  (feature) => feature.feature_key
);
---

<html>
  <head>
    <title>Edit Intent Page</title>

    <style>
      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: system-ui, sans-serif;
        background: #f4efe7;
        color: #181614;
      }

      .shell {
        width: min(980px, calc(100% - 32px));
        margin: 0 auto;
        padding: 44px 0;
      }

      h1 {
        margin: 0;
        font-size: clamp(2.3rem, 5vw, 3.6rem);
        letter-spacing: -0.07em;
        line-height: 0.95;
      }

      .intro {
        max-width: 720px;
        margin: 12px 0 28px;
        color: rgba(24,22,20,0.62);
        font-size: 1.02rem;
        line-height: 1.55;
      }

    .admin-nav {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin: 0 0 26px;
}

.admin-nav a {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 40px;
  padding: 0 15px;
  border-radius: 999px;
  border: 1px solid rgba(24,22,20,0.14);
  background: #fffaf1;
  color: #181614;
  font-size: 0.9rem;
  font-weight: 900;
  text-decoration: none;
}

.admin-nav a:hover {
  background: #181614;
  color: white;
}

.card {

      .field {
        margin-bottom: 22px;
      }

      .field label,
      .section-label {
        display: block;
        margin: 0 0 8px;
        font-weight: 900;
        letter-spacing: -0.02em;
      }

      input,
      textarea,
      select {
        display: block;
        width: 100%;
        min-height: 54px;
        padding: 14px 16px;
        border: 1px solid rgba(24,22,20,0.18);
        border-radius: 14px;
        font: inherit;
        background: white;
        color: #181614;
        outline: none;
      }

      input:focus,
      textarea:focus,
      select:focus {
        border-color: #181614;
        box-shadow: 0 0 0 4px rgba(24,22,20,0.08);
      }

      textarea {
        min-height: 132px;
        resize: vertical;
      }

      .grid-2 {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
        gap: 22px 28px;
      }

      .feature-section {
        margin-top: 26px;
      }

      .hint {
        margin: 0 0 18px;
        color: rgba(24,22,20,0.58);
        font-size: 0.92rem;
        line-height: 1.45;
      }

      .feature-picker {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 12px;
      }

      .feature-option {
        position: relative;
        display: flex;
        align-items: center;
        gap: 12px;
        min-height: 58px;
        margin: 0;
        padding: 13px 15px;
        border-radius: 14px;
        background: white;
        border: 1px solid rgba(24,22,20,0.14);
        font-size: 0.94rem;
        font-weight: 900;
        cursor: pointer;
        transition: transform 0.15s ease, border-color 0.15s ease, background 0.15s ease;
      }

      .feature-option:hover {
        transform: translateY(-1px);
        border-color: rgba(24,22,20,0.28);
      }

      .feature-option input {
        appearance: none;
        width: 18px;
        height: 18px;
        min-height: 18px;
        flex: 0 0 auto;
        padding: 0;
        border-radius: 5px;
        border: 2px solid rgba(24,22,20,0.24);
        background: white;
      }

      .feature-option input:checked {
        background: #181614;
        border-color: #181614;
      }

      .feature-option input:checked::after {
        content: "✓";
        display: grid;
        place-items: center;
        color: white;
        font-size: 0.78rem;
        line-height: 1;
      }

   

      .feature-option:has(input:checked) {
        background: #f8efe3;
        border-color: rgba(111,90,56,0.34);
        box-shadow: 0 0 0 3px rgba(111,90,56,0.06);
      }

      .divider {
        height: 1px;
        margin: 28px 0 22px;
        background: rgba(24,22,20,0.1);
      }

      .publish-row {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        margin: 0;
        font-weight: 900;
      }

      .publish-row input {
        appearance: none;
        width: 20px;
        height: 20px;
        min-height: 20px;
        margin-top: 2px;
        padding: 0;
        border-radius: 5px;
        border: 2px solid rgba(24,22,20,0.24);
        background: white;
      }

      .publish-row input:checked {
        background: #181614;
        border-color: #181614;
      }

      .publish-row input:checked::after {
        content: "✓";
        display: grid;
        place-items: center;
        color: white;
        font-size: 0.82rem;
        line-height: 1;
      }

      .publish-row span {
        display: block;
        color: rgba(24,22,20,0.58);
        font-weight: 500;
        margin-top: 4px;
      }

      .actions {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 30px;
      }

      button,
      a {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 48px;
        padding: 0 22px;
        border-radius: 999px;
        border: 0;
        background: #181614;
        color: white;
        font: inherit;
        font-weight: 900;
        cursor: pointer;
        text-decoration: none;
      }

      a {
        background: white;
        color: #181614;
        border: 1px solid rgba(24,22,20,0.14);
      }

      .error {
        color: #b42318;
        font-weight: 800;
      }

      @media (max-width: 820px) {
        .grid-2,
        .feature-picker {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>

<body>
  <main class="shell">

    <nav class="admin-nav">
      <a href="/admin/intent-pages">All pages</a>
      <a href="/admin/intent-pages/new">Create new</a>
      <a href="/admin/agent-page">Agent editor</a>
    </nav>

    <h1>Edit page</h1>

      <p class="intro">
        Adjust the public page copy, filters, page type, and starting feature filters.
      </p>

      {message && <p class="error">{message}</p>}

      <form method="POST" class="card">
        <div class="field">
          <label>Page type</label>
          <select name="lifestyle_angle">
            <option value="category" selected={page.lifestyle_angle === "category"}>
              Category page
            </option>
            <option value="intent" selected={page.lifestyle_angle === "intent"}>
              Intent page
            </option>
          </select>
        </div>

        <div class="grid-2">
          <div class="field">
            <label>Slug</label>
            <input name="slug" value={page.slug || ""} required />
          </div>

          <div class="field">
            <label>City</label>
            <input name="city" value={page.city || "nanaimo"} required />
          </div>
        </div>

        <div class="grid-2">
          <div class="field">
            <label>Area</label>
            <input name="area" value={page.area || ""} />
          </div>

          <div class="field">
            <label>Property type</label>
            <select name="property_type">
              <option value="" selected={!page.property_type}>Any</option>
              <option value="house" selected={page.property_type === "house"}>House</option>
              <option value="condo" selected={page.property_type === "condo"}>Condo</option>
              <option value="townhouse" selected={page.property_type === "townhouse"}>Townhouse</option>
              <option value="mobile" selected={page.property_type === "mobile"}>Mobile</option>
            </select>
          </div>
        </div>

        <div class="grid-2">
          <div class="field">
            <label>Price min</label>
            <input name="price_min" type="number" value={page.price_min || ""} placeholder="$ Enter minimum" />
          </div>

          <div class="field">
            <label>Price max</label>
            <input name="price_max" type="number" value={page.price_max || ""} placeholder="$ Enter maximum" />
          </div>
        </div>

        <div class="field">
          <label>Hero heading</label>
          <input name="hero_heading" value={page.hero_heading || ""} required />
        </div>

        <div class="field">
          <label>Intro copy</label>
          <textarea name="intro_copy" required>{page.intro_copy || ""}</textarea>
        </div>

        <div class="field">
          <label>SEO title</label>
          <input name="seo_title" value={page.seo_title || ""} required />
        </div>

        <div class="feature-section">
          <div class="section-label">Feature filters</div>
          <p class="hint">
            Leave blank for category pages. Choose one or more features for narrower intent pages.
          </p>

          <div class="feature-picker">
            {FEATURE_OPTIONS.map((feature) => (
              <label class="feature-option">
                <input
                  type="checkbox"
                  name="features"
                  value={feature.key}
                  checked={selectedFeatures.includes(feature.key)}
                />
               <span>{feature.label}</span>
              </label>
            ))}
          </div>
        </div>

        <div class="divider"></div>

        <label class="publish-row">
          <input
            type="checkbox"
            name="is_published"
            checked={page.is_published !== false}
          />

          <div>
            Published
            <span>This page will be publicly visible.</span>
          </div>
        </label>

        <div class="actions">
          <button type="submit">Save changes</button>
          <a href="/admin/intent-pages">Cancel</a>
          <a href={`/${page.city}/${page.slug}`} target="_blank">Open public page</a>
        </div>
      </form>
    </main>
  </body>
</html>