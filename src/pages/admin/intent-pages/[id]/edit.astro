---
import AdminSidebar from "../../../../components/AdminSidebar.astro";
import { createClient } from "@supabase/supabase-js";
export const prerender = false;

const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.SUPABASE_SERVICE_ROLE_KEY
);

const id = Astro.params.id || "";
let message = "";

const FEATURE_OPTIONS = [
  { key: "views", label: "Views" },
  { key: "waterfront", label: "Waterfront" },
  { key: "updated", label: "Updated" },
  { key: "walkability", label: "Walkability" },
  { key: "yard", label: "Yard" },
  { key: "garage", label: "Garage" },
  { key: "suite", label: "Suite" },
  { key: "income", label: "Income" },
  { key: "mortgage_helper", label: "Mortgage helper" },
  { key: "low_maintenance", label: "Low maintenance" },
  { key: "outdoor_space", label: "Outdoor space" },
  { key: "value", label: "Value" },
];

function clean(value: FormDataEntryValue | null) {
  return String(value || "").trim();
}

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();

  const features = form
    .getAll("features")
    .map((feature) => String(feature).trim().toLowerCase())
    .filter(Boolean);

  const { error } = await supabase
    .from("intent_pages")
    .update({
      slug: clean(form.get("slug")).toLowerCase(),
      city: clean(form.get("city")).toLowerCase(),
      area: clean(form.get("area")).toLowerCase(),
      property_type: clean(form.get("property_type")).toLowerCase() || null,
      price_min: form.get("price_min") ? Number(form.get("price_min")) : null,
      price_max: form.get("price_max") ? Number(form.get("price_max")) : null,
      hero_heading: clean(form.get("hero_heading")),
hero_image_url: clean(form.get("hero_image_url")) || null,
nav_label: clean(form.get("nav_label")) || null,
intro_copy: clean(form.get("intro_copy")),
      seo_heading: clean(form.get("seo_heading")) || null,
      seo_title: clean(form.get("seo_title")),
default_sort: clean(form.get("default_sort")) || "newest",
lifestyle_angle: clean(form.get("lifestyle_angle")) || "category",
      is_published: form.get("is_published") === "on",
show_in_nav: form.get("show_in_nav") === "on",
sort_order: form.get("sort_order") ? Number(form.get("sort_order")) : 999,
    })
    .eq("id", id);

  if (error) {
    message = error.message;
  } else {
    await supabase.from("intent_page_features").delete().eq("intent_page_id", id);

    if (features.length) {
      await supabase.from("intent_page_features").insert(
        features.map((feature) => ({
          intent_page_id: id,
          feature_key: feature,
        }))
      );
    }

    return Astro.redirect("/admin/intent-pages");
  }
}

const { data: page, error: pageError } = await supabase
  .from("intent_pages")
  .select(`
    *,
    intent_page_features (
      feature_key
    )
  `)
  .eq("id", id)
  .single();

if (!page || pageError) {
  return Astro.redirect("/admin/intent-pages");
}

const selectedFeatures = (page.intent_page_features || []).map(
  (feature) => feature.feature_key
);

---

<html>
  <head>
    <title>Edit Intent Page</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
     *, *::before, *::after { box-sizing: border-box; margin: 0; }

:root {
  --bg: #f7f4ef;
  --surface: #fff;
  --border: rgba(24,22,20,0.10);
  --border-strong: rgba(24,22,20,0.22);
  --ink: #181614;
  --muted: rgba(24,22,20,0.52);
  --radius: 16px;
  --font-body: "DM Sans", system-ui, sans-serif;
  --font-display: "Instrument Serif", Georgia, serif;
}

body {
  font-family: var(--font-body);
  background: var(--bg);
  color: var(--ink);
  font-size: 15px;
  line-height: 1.5;
}

.page {
  display: grid;
  grid-template-columns: 220px 1fr;
  min-height: 100vh;
}

.main {
  padding: 40px 48px 80px;
  max-width: 900px;
  min-width: 0;
}

.topbar {
  margin-bottom: 32px;
}

.topbar h1 {
  font-family: var(--font-display);
  font-size: 2.6rem;
  font-weight: 400;
  line-height: 1;
  letter-spacing: -0.03em;
}

.intro {
  color: var(--muted);
  margin-top: 6px;
  font-size: 0.9rem;
  line-height: 1.55;
}

   

.card {
  background: white;
  border: 1px solid rgba(24,22,20,0.12);
  border-radius: 16px;
  padding: 24px;
}

      .field {
        margin-bottom: 22px;
      }

      .field label,
      .section-label {
        display: block;
        margin: 0 0 8px;
        font-weight: 900;
        letter-spacing: -0.02em;
      }

      .readonly-field {
  min-height: 41px;
  padding: 10px 13px;
  border: 1px solid var(--border);
  border-radius: 10px;
  background: var(--bg);
  color: var(--muted);
  font-size: 0.9rem;
}

     input,
textarea,
select {
  display: block;
  width: 100%;
  padding: 10px 13px;
  border: 1px solid var(--border-strong);
  border-radius: 10px;
  font: inherit;
  font-size: 0.9rem;
  background: var(--surface);
  color: var(--ink);
  outline: none;
}

      input:focus,
      textarea:focus,
      select:focus {
        border-color: #181614;
        box-shadow: 0 0 0 4px rgba(24,22,20,0.08);
      }

    textarea {
  min-height: 80px;
  resize: vertical;
}

      .grid-2 {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
        gap: 22px 28px;
      }

      .feature-section {
        margin-top: 26px;
      }

      .hint {
        margin: 0 0 18px;
        color: rgba(24,22,20,0.58);
        font-size: 0.92rem;
        line-height: 1.45;
      }

      .feature-picker {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 12px;
      }

      .feature-option {
        position: relative;
        display: flex;
        align-items: center;
        gap: 12px;
        min-height: 58px;
        margin: 0;
        padding: 13px 15px;
        border-radius: 14px;
        background: white;
        border: 1px solid rgba(24,22,20,0.14);
        font-size: 0.94rem;
        font-weight: 900;
        cursor: pointer;
        transition: transform 0.15s ease, border-color 0.15s ease, background 0.15s ease;
      }

      .feature-option:hover {
        transform: translateY(-1px);
        border-color: rgba(24,22,20,0.28);
      }

      .feature-option input {
        appearance: none;
        width: 18px;
        height: 18px;
        min-height: 18px;
        flex: 0 0 auto;
        padding: 0;
        border-radius: 5px;
        border: 2px solid rgba(24,22,20,0.24);
        background: white;
      }

      .feature-option input:checked {
        background: #181614;
        border-color: #181614;
      }

      .feature-option input:checked::after {
        content: "✓";
        display: grid;
        place-items: center;
        color: white;
        font-size: 0.78rem;
        line-height: 1;
      }

   

      .feature-option:has(input:checked) {
        background: #f8efe3;
        border-color: rgba(111,90,56,0.34);
        box-shadow: 0 0 0 3px rgba(111,90,56,0.06);
      }

      .divider {
        height: 1px;
        margin: 28px 0 22px;
        background: rgba(24,22,20,0.1);
      }

      .publish-row {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        margin: 0;
        font-weight: 900;
      }

      .publish-row input {
        appearance: none;
        width: 20px;
        height: 20px;
        min-height: 20px;
        margin-top: 2px;
        padding: 0;
        border-radius: 5px;
        border: 2px solid rgba(24,22,20,0.24);
        background: white;
      }

      .publish-row input:checked {
        background: #181614;
        border-color: #181614;
      }

      .publish-row input:checked::after {
        content: "✓";
        display: grid;
        place-items: center;
        color: white;
        font-size: 0.82rem;
        line-height: 1;
      }

      .publish-row span {
        display: block;
        color: rgba(24,22,20,0.58);
        font-weight: 500;
        margin-top: 4px;
      }

      .actions {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 30px;
      }

      .main button,
.main a {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 48px;
        padding: 0 22px;
        border-radius: 999px;
        border: 0;
        background: #181614;
        color: white;
        font: inherit;
        font-weight: 900;
        cursor: pointer;
        text-decoration: none;
      }

      .main a {
  background: white;
  color: #181614;
  border: 1px solid rgba(24,22,20,0.14);
}

      .error {
        color: #b42318;
        font-weight: 800;
      }

    @media (max-width: 820px) {
  .page {
    grid-template-columns: 1fr;
  }

  .main {
    padding: 24px 20px 60px;
  }

  .grid-2,
  .feature-picker {
    grid-template-columns: 1fr;
  }
}
    </style>
  </head>

<body>
  <div class="page">
    <AdminSidebar active="pages" />

    <main class="main">

   <div class="topbar">
  <div>
    <h1>{page.hero_heading || "Edit page"}</h1>

    <p class="intro">
        Adjust the public page copy, filters, page type, and starting feature filters.
      </p>
  </div>
</div>

{message && <p class="error">{message}</p>}

      <form method="POST" class="card">
        <div class="field">
          <label>Page type</label>
          <select name="lifestyle_angle">
            <option value="category" selected={page.lifestyle_angle === "category"}>
              Category page
            </option>
            <option value="intent" selected={page.lifestyle_angle === "intent"}>
              Intent page
            </option>
          </select>
        </div>

      <div class="grid-2">
  <div class="field">
    <label>Slug</label>
    <div class="readonly-field">/{page.city}/{page.slug}</div>
    <input type="hidden" name="slug" value={page.slug || ""} />
  </div>

  <div class="field">
    <label>City</label>
    <div class="readonly-field">
      {(page.city || "nanaimo").replace(/-/g, " ").replace(/\b\w/g, (char) => char.toUpperCase())}
    </div>
    <input type="hidden" name="city" value={page.city || "nanaimo"} />
  </div>
</div>

        <div class="grid-2">
          <div class="field">
            <label>Area</label>
<div class="readonly-field">
  {page.area ? page.area.replace(/-/g, " ").replace(/\b\w/g, (char) => char.toUpperCase()) : "City-wide"}
</div>
<input type="hidden" name="area" value={page.area || ""} /></div>

          <div class="field">
            <label>Property type</label>
            <select name="property_type">
              <option value="" selected={!page.property_type}>Any</option>
              <option value="house" selected={page.property_type === "house"}>House</option>
              <option value="condo" selected={page.property_type === "condo"}>Condo</option>
              <option value="townhouse" selected={page.property_type === "townhouse"}>Townhouse</option>
              <option value="mobile" selected={page.property_type === "mobile"}>Mobile</option>
            </select>
          </div>
        </div>

        <div class="grid-2">
          <div class="field">
            <label>Price min</label>
            <input name="price_min" type="number" value={page.price_min || ""} placeholder="$ Enter minimum" />
          </div>

          <div class="field">
            <label>Price max</label>
            <input name="price_max" type="number" value={page.price_max || ""} placeholder="$ Enter maximum" />
          </div>
        </div>

               <div class="field">
          <label>Default sort</label>
          <select name="default_sort">
            <option value="newest" selected={(page.default_sort || "newest") === "newest"}>Newest listings first</option>
            <option value="price-asc" selected={page.default_sort === "price-asc"}>Price: low to high</option>
            <option value="price-desc" selected={page.default_sort === "price-desc"}>Price: high to low</option>
            <option value="beds-desc" selected={page.default_sort === "beds-desc"}>Most bedrooms first</option>
            <option value="sqft-desc" selected={page.default_sort === "sqft-desc"}>Largest homes first</option>
          </select>
        </div>

        

<div class="field">
  <label>Hero image URL</label>
  <input
    name="hero_image_url"
    value={page.hero_image_url || ""}
    placeholder="https://images.unsplash.com/..."
  />
</div>

<div class="field">
  <label>Nav label</label>
  <input
    name="nav_label"
    value={page.nav_label || ""}
    placeholder="Ocean View, Downsizers, Suites..."
  />
</div>

<div class="field">
  <label>Nav sort order</label>
  <input
    name="sort_order"
    type="number"
    value={page.sort_order ?? 999}
    placeholder="1"
  />
</div>

        <div class="field">
          <label>Intro copy</label>
          <textarea name="intro_copy" required>{page.intro_copy || ""}</textarea>
        </div>

      <div class="field">
          <label>Hero heading h1 <span style="font-weight:400;color:var(--muted);">— use | for line break</span></label>
          <input name="hero_heading" value={page.hero_heading || ""} />
        </div>

        <div class="field">
          <label>Section heading h2 <span style="font-weight:400;color:var(--muted);">— single line, below the hero</span></label>
          <input name="seo_heading" value={page.seo_heading || ""} placeholder="Same as hero heading if blank" />
        </div>

        <div class="field">
          <label>SEO title <span style="font-weight:400;color:var(--muted);">— browser tab</span></label>
          <input name="seo_title" value={page.seo_title || ""} />
        </div>

        <div class="feature-section">
          <div class="section-label">Feature filters</div>
          <p class="hint">
            Leave blank for category pages. Choose one or more features for narrower intent pages.
          </p>

          <div class="feature-picker">
            {FEATURE_OPTIONS.map((feature) => (
              <label class="feature-option">
                <input
                  type="checkbox"
                  name="features"
                  value={feature.key}
                  checked={selectedFeatures.includes(feature.key)}
                />
               <span>{feature.label}</span>
              </label>
            ))}
          </div>
        </div>

        <div class="divider"></div>

        <label class="publish-row">
          <input
            type="checkbox"
            name="is_published"
            checked={page.is_published !== false}
          />

          <div>
            Published
            <span>This page will be publicly visible.</span>
          </div>
        </label>

        <label class="publish-row" style="margin-top: 16px;">
  <input
    type="checkbox"
    name="show_in_nav"
    checked={page.show_in_nav === true}
  />

  <div>
    Show in main nav
    <span>This page will appear in the top navigation.</span>
  </div>
</label>

        <div class="actions">
          <button type="submit">Save changes</button>
          <a href="/admin/intent-pages">Cancel</a>
          <a href={`/${page.city}/${page.slug}`} target="_blank">Open public page</a>
        </div>
      </form>
       </main>
  </div>
</body>
</html>