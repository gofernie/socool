---
import AdminSidebar from "../../components/AdminSidebar.astro";
import { createClient } from "@supabase/supabase-js";

export const prerender = false;

const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.SUPABASE_SERVICE_ROLE_KEY
);

const googleMapsApiKey = import.meta.env.PUBLIC_GOOGLE_MAPS_API_KEY || "";

const { data: sites = [] } = await supabase
  .from("sites")
  .select("id, site_name, domain, city")
  .order("site_name", { ascending: true });

const nanaimoAreas = [
  "North Nanaimo",
  "Hammond Bay",
  "Departure Bay",
  "Uplands",
  "Pleasant Valley",
  "Diver Lake",
  "Central Nanaimo",
  "Old City",
  "University District",
  "South Nanaimo",
  "Chase River",
  "Cedar",
  "Jingle Pot",
  "Extension",
  "Brechin Hill",
];

const parksvilleAreas = [
  "PQ Bowser/Deep Bay",
  "PQ Errington/Coombs/Hilliers",
  "PQ Fairwinds",
  "PQ French Creek",
  "PQ Little Qualicum River Village",
  "PQ Nanoose",
  "PQ Parksville",
  "PQ Qualicum Beach",
  "PQ Qualicum North",
];

const areaOptions = {
  nanaimo: nanaimoAreas,
  parksville: parksvilleAreas,
};

const areasByCityJson = JSON.stringify(areaOptions);
const sitesJson = JSON.stringify(sites);

function slugify(value) {
  return String(value || "")
    .toLowerCase()
    .replace(/&/g, "and")
    .replace(/\//g, "-")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Area Boundaries</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <script
  src={`https://maps.googleapis.com/maps/api/js?key=${googleMapsApiKey}&libraries=drawing&v=weekly`}
  async
  defer
></script>

    <style>
      body {
        margin: 0;
        font-family: system-ui, sans-serif;
        background: #f7f4ef;
        color: #181614;
      }

      .page {
        display: grid;
        grid-template-columns: 220px 1fr;
        min-height: 100vh;
      }

      .main {
        padding: 40px 48px 80px;
      }

      h1 {
        margin: 0 0 8px;
        font-size: 34px;
      }

      .muted {
        color: #6f6860;
        margin: 0 0 28px;
      }

      .panel {
        background: #fff;
        border: 1px solid #e8e1d8;
        border-radius: 22px;
        padding: 22px;
        box-shadow: 0 18px 45px rgba(0,0,0,0.06);
      }

      .controls {
  display: grid;
  grid-template-columns: 1.2fr 1fr 1fr auto auto auto;
        gap: 12px;
        align-items: end;
        margin-bottom: 18px;
      }

      label {
        display: grid;
        gap: 6px;
        font-size: 13px;
        font-weight: 700;
        color: #514a43;
      }

      select,
      button {
        height: 44px;
        border-radius: 999px;
        border: 1px solid #ddd3c8;
        padding: 0 14px;
        font: inherit;
        background: #fff;
      }

      button {
        cursor: pointer;
        font-weight: 800;
      }

      .primary {
        background: #181614;
        color: #fff;
        border-color: #181614;
      }

      .danger {
        color: #9f1d1d;
        border-color: #e8bcbc;
      }

      #map {
        height: 640px;
        border-radius: 20px;
        overflow: hidden;
        border: 1px solid #e2d8cd;
        background: #e9e1d7;
      }

      .status {
        margin-top: 14px;
        font-weight: 700;
      }

      .hint {
        margin-top: 10px;
        color: #766f66;
        font-size: 14px;
      }

      @media (max-width: 900px) {
        .page {
          grid-template-columns: 1fr;
        }

        .main {
          padding: 24px 16px 60px;
        }

        .controls {
          grid-template-columns: 1fr;
        }

        #map {
          height: 520px;
        }
      }
    </style>
  </head>

  <body>
    <div class="page">
      <AdminSidebar active="areas" />

      <main class="main">
        <h1>Area Boundaries</h1>
        <p class="muted">
          Draw a hidden map boundary for each area. Public pages will use this for listing accuracy.
        </p>

        <section class="panel">
          <div class="controls">
            <label>
              Site
              <select id="siteSelect">
                {sites.map((site) => (
                  <option value={site.id} data-city={String(site.city || "").toLowerCase()}>
                    {site.site_name || site.domain || site.id}
                  </option>
                ))}
              </select>
            </label>

            <label>
              City
              <select id="citySelect">
                <option value="nanaimo">Nanaimo</option>
                <option value="parksville">Parksville</option>
              </select>
            </label>

            <label>
              Area
              <select id="areaSelect"></select>
            </label>

        <button type="button" id="drawBtn">Draw Boundary</button>
<button type="button" class="danger" id="clearBtn">Clear</button>
<button type="button" class="primary" id="saveBtn">Save Boundary</button> </div>

          <div id="map"></div>

          <div class="status" id="status">Draw a polygon on the map, then save it.</div>
          <div class="hint">
            Tip: click around the neighbourhood edge to draw. Double-click or return to the first point to finish.
          </div>
        </section>
      </main>
    </div>

    <script is:inline define:vars={{ areasByCityJson, sitesJson }}>
      const areasByCity = JSON.parse(areasByCityJson);
      const sites = JSON.parse(sitesJson);

      const siteSelect = document.getElementById("siteSelect");
      const citySelect = document.getElementById("citySelect");
      const areaSelect = document.getElementById("areaSelect");
      const drawBtn = document.getElementById("drawBtn");
const clearBtn = document.getElementById("clearBtn");
const saveBtn = document.getElementById("saveBtn");
      const statusEl = document.getElementById("status");

      let map;
let activePolygon = null;
let drawingPath = [];
let drawingMarkers = [];
let isDrawing = false;

      const cityCenters = {
        nanaimo: { lat: 49.1967, lng: -123.9401, zoom: 12 },
        parksville: { lat: 49.3193, lng: -124.3136, zoom: 11 },
      };

      function slugify(value) {
        return String(value || "")
          .toLowerCase()
          .replace(/&/g, "and")
          .replace(/\//g, "-")
          .replace(/[^a-z0-9]+/g, "-")
          .replace(/^-+|-+$/g, "");
      }

      function setStatus(message) {
        statusEl.textContent = message;
      }

      function refreshAreas() {
        const city = citySelect.value;
        const areas = areasByCity[city] || [];

        areaSelect.innerHTML = areas
          .map((area) => `<option value="${slugify(area)}">${area}</option>`)
          .join("");

        moveMapToCity();
      }

      function moveMapToCity() {
        if (!map) return;

        const center = cityCenters[citySelect.value] || cityCenters.nanaimo;
        map.setCenter({ lat: center.lat, lng: center.lng });
        map.setZoom(center.zoom);
      }
function clearPolygon(options = {}) {
  const { quiet = false } = options;

  if (activePolygon) {
    activePolygon.setMap(null);
    activePolygon = null;
  }

  drawingMarkers.forEach((marker) => marker.setMap(null));
  drawingMarkers = [];
  drawingPath = [];
  isDrawing = false;

  if (!quiet) {
    setStatus("Draw a polygon on the map, then save it.");
  }
}

async function loadBoundary() {
  if (!map || !window.google?.maps || !areaSelect.value) return;

  clearPolygon({ quiet: true });

 const response = await fetch(
  `/api/admin/area-boundary?city=${encodeURIComponent(citySelect.value)}&area_slug=${encodeURIComponent(areaSelect.value)}`
);

  if (!response.ok) {
    setStatus("No saved boundary found for this area.");
    return;
  }

  const result = await response.json();
  const polygon = result?.boundary?.polygon_geojson || result?.polygon_geojson;

  if (!polygon?.coordinates?.[0]?.length) {
    setStatus("No saved boundary found for this area.");
    return;
  }

  const coords = polygon.coordinates[0].map(([lng, lat]) => ({ lat, lng }));

  activePolygon = new google.maps.Polygon({
    paths: coords,
    map,
    editable: true,
    draggable: true,
    fillOpacity: 0.18,
    strokeWeight: 3,
  });

  const bounds = new google.maps.LatLngBounds();
  coords.forEach((point) => bounds.extend(point));

  if (!bounds.isEmpty()) {
    map.fitBounds(bounds);
  }

  setStatus(`Loaded boundary for ${result?.boundary?.area_name || result?.area_name || "this area"}.`);
}
     drawBtn?.addEventListener("click", () => {
  if (!map || !window.google?.maps) {
    setStatus("Map is not ready yet. Refresh and try again.");
    return;
  }

  clearPolygon();
  isDrawing = true;
  setStatus("Click points around the area boundary. Add at least 3 points, then save.");
});

      function polygonToGeoJson(polygon) {
        const path = polygon.getPath();
        const coordinates = [];

        for (let i = 0; i < path.getLength(); i++) {
          const point = path.getAt(i);
          coordinates.push([point.lng(), point.lat()]);
        }

        if (coordinates.length > 0) {
          const first = coordinates[0];
          const last = coordinates[coordinates.length - 1];

          if (first[0] !== last[0] || first[1] !== last[1]) {
            coordinates.push(first);
          }
        }

        return {
          type: "Polygon",
          coordinates: [coordinates],
        };
      }

      function getPolygonCenter(polygon) {
        const bounds = new google.maps.LatLngBounds();
        polygon.getPath().forEach((point) => bounds.extend(point));
        const center = bounds.getCenter();

        return {
          lat: center.lat(),
          lng: center.lng(),
        };
      }

      async function saveBoundary() {
        if (!activePolygon) {
          setStatus("Draw a polygon first.");
          return;
        }

        const selectedOption = areaSelect.options[areaSelect.selectedIndex];
        const areaName = selectedOption?.textContent || areaSelect.value;
        const center = getPolygonCenter(activePolygon);

        const payload = {
          site_id: siteSelect.value,
          city: citySelect.value,
          area_slug: areaSelect.value,
          area_name: areaName,
          polygon_geojson: polygonToGeoJson(activePolygon),
          center_lat: center.lat,
          center_lng: center.lng,
        };

        setStatus("Saving boundary...");

        const response = await fetch("/api/admin/area-boundary", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload),
        });

        const result = await response.json();

        if (!response.ok || !result.ok) {
          setStatus(`Save failed: ${result.error || "Unknown error"}`);
          return;
        }

        setStatus(`Saved boundary for ${areaName}.`);
      }

      function syncCityFromSite() {
        const selected = siteSelect.options[siteSelect.selectedIndex];
        const siteCity = selected?.dataset?.city;

        if (siteCity && areasByCity[siteCity]) {
          citySelect.value = siteCity;
          refreshAreas();
        }
      }

      function initMap() {
        const start = cityCenters.nanaimo;

        map = new google.maps.Map(document.getElementById("map"), {
          center: { lat: start.lat, lng: start.lng },
          zoom: start.zoom,
          mapTypeControl: true,
          streetViewControl: false,
          fullscreenControl: true,
        });

        map.addListener("click", (event) => {
  if (!isDrawing) return;

  drawingPath.push(event.latLng);

  const marker = new google.maps.Marker({
    position: event.latLng,
    map,
  });

  drawingMarkers.push(marker);

  if (activePolygon) activePolygon.setMap(null);

  activePolygon = new google.maps.Polygon({
    paths: drawingPath,
    map,
    editable: true,
    draggable: true,
    fillOpacity: 0.18,
    strokeWeight: 3,
  });

  setStatus(`${drawingPath.length} points added. Add at least 3, then click Save Boundary.`);
});

       
        syncCityFromSite();
        setTimeout(() => {
          loadBoundary();
        }, 300);
      }

window.addEventListener("DOMContentLoaded", () => {
  refreshAreas();
  syncCityFromSite();
});

window.addEventListener("load", () => {
  const wait = setInterval(() => {
    if (window.google?.maps) {
      clearInterval(wait);
      initMap();
    }
  }, 100);
});
siteSelect?.addEventListener("change", async () => {
  syncCityFromSite();
  await loadBoundary();
});

citySelect?.addEventListener("change", async () => {
  refreshAreas();
  await loadBoundary();
});

areaSelect?.addEventListener("change", async () => {
  await loadBoundary();
});


clearBtn?.addEventListener("click", clearPolygon);
saveBtn?.addEventListener("click", saveBoundary);
    </script>
  </body>
</html>