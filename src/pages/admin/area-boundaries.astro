---
import AdminSidebar from "../../components/AdminSidebar.astro";
import { createClient } from "@supabase/supabase-js";

export const prerender = false;

const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.SUPABASE_SERVICE_ROLE_KEY
);

const googleMapsApiKey = import.meta.env.PUBLIC_GOOGLE_MAPS_API_KEY || "";

const { data: sites = [] } = await supabase
  .from("sites")
  .select("id, site_name, domain, city")
  .order("site_name", { ascending: true });

const { data: areaBoundaryRows = [] } = await supabase
  .from("area_boundaries")
  .select("city, area_name, area_slug")
  .order("area_name", { ascending: true });

const areaOptions: Record<string, string[]> = {};
for (const row of areaBoundaryRows) {
  const city = String(row.city || "").toLowerCase().trim();
  const name = String(row.area_name || row.area_slug || "").trim();
  if (!city || !name) continue;
  if (!areaOptions[city]) areaOptions[city] = [];
  if (!areaOptions[city].includes(name)) areaOptions[city].push(name);
}
const areasByCityJson = JSON.stringify(areaOptions);
const sitesJson = JSON.stringify(sites);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Area Boundaries</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    
    <link
      href="https://?family=Instrument+Serif:ital@0;1&family=DM+Sans:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <script
      src={`https://maps.googleapis.com/maps/api/js?key=${googleMapsApiKey}&libraries=drawing&v=weekly`}
      async
      defer
    ></script>

    <style>
      :global(:root) {
        --bg: #f7f4ef;
        --ink: #181614;
        --font-body: "DM Sans", system-ui, sans-serif;
        --font-display: "Instrument Serif", Georgia, serif;
      }

      :global(body) {
        margin: 0;
        font-family: var(--font-body);
        background: var(--bg);
        color: var(--ink);
        font-size: 15px;
        line-height: 1.5;
      }

      .page {
        min-height: 100vh;
        display: grid;
        grid-template-columns: 220px 1fr;
      }

      .main {
        padding: 48px 32px 64px;
        min-width: 0;
        overflow-x: hidden;
        max-width: 1200px;
      }

    .main h1 {
        margin: 0 0 8px;
        font-family: var(--font-body);
        font-size: 2.2rem;
        font-weight: 700;
        line-height: 1;
        letter-spacing: -0.03em;
      }

      .muted {
        color: #6f6a63;
        margin: 0 0 28px;
      }

      .panel {
        background: #fff;
        border: 1px solid #e3ddd2;
        border-radius: 22px;
        padding: 22px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.04);
      }

      .controls {
        display: grid;
        grid-template-columns:
          minmax(220px, 1fr)
          minmax(220px, 1fr)
          minmax(220px, 1fr)
          minmax(220px, 1fr);
        gap: 12px;
        align-items: end;
        margin-bottom: 18px;
      }

      .control-actions {
        grid-column: 1 / -1;
        display: grid;
        grid-template-columns: repeat(5, minmax(150px, 1fr));
        gap: 12px;
      }

      .controls button {
        width: 100%;
        min-width: 0;
      }

      .main label {
        display: grid;
        gap: 6px;
        font-size: 13px;
        font-weight: 700;
        color: #514a43;
      }

      .main select,
      .main input,
      .main button {
        width: 100%;
        max-width: 100%;
        min-width: 0;
        box-sizing: border-box;
        height: 44px;
        border-radius: 999px;
        border: 1px solid #ddd3c8;
        padding: 0 14px;
        font: inherit;
        background: #fff;
      }

      .main button {
        cursor: pointer;
        font-weight: 800;
      }

      .main button.primary {
        background: #181614;
        color: #fff;
        border-color: #181614;
      }

      .danger {
        color: #9f1d1d;
        border-color: #e8bcbc;
      }

      .main button.is-active {
        background: #2f6f73 !important;
        border-color: #2f6f73 !important;
        color: #fff !important;
        box-shadow: 0 0 0 4px rgba(47, 111, 115, 0.18);
      }

      .main button.danger.is-active {
        background: #9f1d1d !important;
        border-color: #9f1d1d !important;
        color: #fff !important;
      }

      #map {
        width: 100%;
        height: 640px;
        border-radius: 20px;
        overflow: hidden;
        border: 1px solid #e2d8cd;
        background: #e9e1d7;
      }

      .status {
        margin-top: 14px;
        font-weight: 700;
      }

      .hint {
        margin-top: 10px;
        color: #766f66;
        font-size: 14px;
      }

      @media (max-width: 1150px) {
        .controls {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .control-actions {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }
      }

      @media (max-width: 900px) {
        .page {
          display: block;
        }

        .main {
          padding: 28px 18px 48px;
        }

        .controls,
        .control-actions {
          grid-template-columns: 1fr;
        }

        #map {
          height: 520px;
        }
      }
    </style>
  </head>

  <body>
    <div class="page">
      <AdminSidebar active="areas" />

      <main class="main">
        <h1>Area Boundaries</h1>
        <p class="muted">
          Draw a hidden map boundary for each area. Public pages will use this for listing accuracy.
        </p>

        <section class="panel">
          <div class="controls">
            <label>
              Site
              <select id="siteSelect">
                {sites.map((site) => (
                  <option value={site.id} data-city={String(site.city || "").toLowerCase()}>
                    {site.site_name || site.domain || site.id}
                  </option>
                ))}
              </select>
            </label>

            <label>
              City
              <select id="citySelect">
                <option value="nanaimo">Nanaimo</option>
<option value="parksville">Parksville</option>
<option value="tofino">Tofino</option>
              </select>
            </label>

            <label>
              Area
              <select id="areaSelect"></select>
            </label>

            <label>
              Short Description
              <input id="shortDescription" type="text" placeholder="Ocean views • Shopping" />
            </label>

           <label>
              Hero Image URL
              <input id="heroImageUrl" type="text" placeholder="https://images.unsplash.com/..." />
            </label>

            <label>
              Hero heading h1 <span style="font-weight:400;font-size:11px;">(use | for line break)</span>
              <input id="heroHeading" type="text" placeholder="North Nanaimo | Ocean Views" />
            </label>

            <label>
              Section heading h2
              <input id="seoHeading" type="text" placeholder="North Nanaimo real estate — active listings" />
            </label>

            <label>
              SEO title
              <input id="seoTitle" type="text" placeholder="North Nanaimo Homes for Sale | Nanaimo BC" />
            </label>

            <label>
              Intro copy
              <input id="introCopy" type="text" placeholder="North Nanaimo is known for..." />
            </label>

            <div class="control-actions">
              <button type="button" id="drawBtn">Draw Boundary</button>
              <button type="button" id="loadLinesBtn">Load Boundary Lines</button>
              <button type="button" id="buildPolygonBtn">Build Path</button>
              <button type="button" class="danger" id="clearBtn">Clear</button>
              <button type="button" class="primary" id="saveBtn">Save Boundary</button>
            </div>
          </div>

          <div id="map"></div>

          <div class="status" id="status">Draw a polygon on the map, then save it.</div>
          <div class="hint">
            Tip: load boundary lines, click only the red pieces you want, then build a path. Saving closes it into a polygon.
          </div>
        </section>
      </main>
    </div>

    <script is:inline define:vars={{ areasByCityJson, sitesJson }}>
      const areasByCity = JSON.parse(areasByCityJson);
      const sites = JSON.parse(sitesJson);

      const siteSelect = document.getElementById("siteSelect");
      const citySelect = document.getElementById("citySelect");
      const areaSelect = document.getElementById("areaSelect");
      const shortDescriptionInput = document.getElementById("shortDescription");
      const heroImageUrlInput = document.getElementById("heroImageUrl");
      const drawBtn = document.getElementById("drawBtn");
      const clearBtn = document.getElementById("clearBtn");
      const saveBtn = document.getElementById("saveBtn");
      const statusEl = document.getElementById("status");

      let map;
      let activePolygon = null;
      let importedLines = [];
      let selectedLines = [];
      let drawingPath = [];
      let drawingMarkers = [];
      let isDrawing = false;

    const cityCenters = {
  nanaimo: { lat: 49.1967, lng: -123.9401, zoom: 12 },
  parksville: { lat: 49.3193, lng: -124.3136, zoom: 11 },
  tofino: { lat: 49.1520, lng: -125.9067, zoom: 12 },
  sparwood: { lat: 49.7300, lng: -114.8850, zoom: 13 },
  fernie: { lat: 49.5037, lng: -115.0631, zoom: 13 },
  duncan: { lat: 48.7787, lng: -123.7079, zoom: 13 },
  colwood: { lat: 48.4254, lng: -123.4956, zoom: 13 },
};

      function slugify(value) {
        return String(value || "")
          .toLowerCase()
          .replace(/&/g, "and")
          .replace(/\//g, "-")
          .replace(/[^a-z0-9]+/g, "-")
          .replace(/^-+|-+$/g, "");
      }

      function setStatus(message) {
        statusEl.textContent = message;
      }

      function setActiveAction(action) {
        drawBtn?.classList.toggle("is-active", action === "draw");
        clearBtn?.classList.toggle("is-active", action === "clear");
      }

      function moveMapToCity() {
        if (!map) return;
        const center = cityCenters[citySelect.value] || cityCenters.nanaimo;
        map.setCenter({ lat: center.lat, lng: center.lng });
        map.setZoom(center.zoom);
      }

      function refreshAreas() {
        const city = citySelect.value;
        const areas = areasByCity[city] || [];

        areaSelect.innerHTML = areas
          .map((area) => `<option value="${slugify(area)}">${area}</option>`)
          .join("");

        moveMapToCity();
      }

      function addDeletePointListener(shape) {
        shape.addListener("rightclick", (event) => {
          if (event.vertex == null) return;

          const path = shape.getPath();

          if (path.getLength() <= 3) {
            setStatus("Boundary needs at least 3 points.");
            return;
          }

          path.removeAt(event.vertex);
          setStatus("Point removed. Keep cleaning the shape, then Save Boundary.");
        });
      }

      async function loadImportedLines() {
        importedLines.forEach((line) => line.setMap(null));
        importedLines = [];
        selectedLines = [];

        const response = await fetch(
          `/api/admin/imported-boundary-lines?city=${encodeURIComponent(citySelect.value)}&site_id=${encodeURIComponent(siteSelect.value)}`
        );

        const result = await response.json();

        if (!response.ok || !result.ok) {
          setStatus(`Could not load boundary lines: ${result.error || "Unknown error"}`);
          return;
        }

        result.lines.forEach((row) => {
          const coords = row.geometry_geojson.coordinates.map(([lng, lat]) => ({
            lat,
            lng,
          }));

          for (let i = 0; i < coords.length - 1; i++) {
            const line = new google.maps.Polyline({
  path: [coords[i], coords[i + 1]],
  map,
  strokeColor: "#cc4444",
  strokeOpacity: 0.55,
  strokeWeight: 2,
  clickable: false,
});

            line.__selected = false;
            line.__row = row;
            line.__segmentIndex = i;

            

            importedLines.push(line);
          }
        });

        setStatus(`${importedLines.length} boundary segments loaded. Click only the pieces you want.`);
      }

      function clearPolygon(options = {}) {
        const { quiet = false } = options;

        if (activePolygon) {
          activePolygon.setMap(null);
          activePolygon = null;
        }

        drawingMarkers.forEach((marker) => marker.setMap(null));
     drawingMarkers = [];
drawingPath = [];
isDrawing = false;

if (map) {
  map.setOptions({ draggableCursor: null });
}

        if (!quiet) {
          setStatus("Boundary cleared. Choose Draw Boundary to start again.");
        }
      }

      async function loadBoundary() {
        if (!map || !window.google?.maps || !areaSelect.value) return;

        clearPolygon({ quiet: true });
        setActiveAction(null);

        const response = await fetch(
          `/api/admin/area-boundary?city=${encodeURIComponent(citySelect.value)}&area_slug=${encodeURIComponent(areaSelect.value)}&site_id=${encodeURIComponent(siteSelect.value)}`
        );

        if (!response.ok) {
          shortDescriptionInput.value = "";
          heroImageUrlInput.value = "";
          setStatus("No saved boundary found for this area.");
          return;
        }

        const result = await response.json();

      shortDescriptionInput.value = result?.boundary?.short_description || result?.short_description || "";
        heroImageUrlInput.value = result?.boundary?.hero_image_url || result?.hero_image_url || "";
        document.getElementById("heroHeading").value = result?.boundary?.hero_heading || result?.hero_heading || "";
        document.getElementById("seoHeading").value = result?.boundary?.seo_heading || result?.seo_heading || "";
        document.getElementById("seoTitle").value = result?.boundary?.seo_title || result?.seo_title || "";
        document.getElementById("introCopy").value = result?.boundary?.intro_copy || result?.intro_copy || "";

        const polygon =
          result?.boundary?.polygon_geojson ||
          result?.polygon_geojson;

        if (!polygon?.coordinates?.[0]?.length) {
          setStatus("No saved boundary found for this area.");
          return;
        }

        const coords = polygon.coordinates[0].map(([lng, lat]) => ({ lat, lng }));

        activePolygon = new google.maps.Polygon({
          paths: coords,
          map,
          editable: true,
          draggable: true,
          fillOpacity: 0.18,
          strokeWeight: 3,
        });

        addDeletePointListener(activePolygon);

        const bounds = new google.maps.LatLngBounds();
        coords.forEach((point) => bounds.extend(point));

        if (!bounds.isEmpty()) {
          map.fitBounds(bounds);
        }

        setStatus(`Loaded boundary for ${result?.boundary?.area_name || result?.area_name || "this area"}.`);
      }

      drawBtn?.addEventListener("click", () => {
        if (!map || !window.google?.maps) {
          setStatus("Map is not ready yet. Refresh and try again.");
          return;
        }

        clearPolygon({ quiet: true });
      isDrawing = true;
map.setOptions({ draggableCursor: "crosshair" });
setActiveAction("draw");
        setStatus("Draw mode selected. Click points around the area boundary.");
      });

      function polygonToGeoJson(shape) {
        const path = shape.getPath();
        const coordinates = [];

        for (let i = 0; i < path.getLength(); i++) {
          const point = path.getAt(i);
          coordinates.push([point.lng(), point.lat()]);
        }

        if (coordinates.length > 0) {
          const first = coordinates[0];
          const last = coordinates[coordinates.length - 1];

          if (first[0] !== last[0] || first[1] !== last[1]) {
            coordinates.push(first);
          }
        }

        return {
          type: "Polygon",
          coordinates: [coordinates],
        };
      }

      function getPolygonCenter(shape) {
        const bounds = new google.maps.LatLngBounds();
        shape.getPath().forEach((point) => bounds.extend(point));
        const center = bounds.getCenter();

        return {
          lat: center.lat(),
          lng: center.lng(),
        };
      }

      function buildPolygonFromSelectedLines() {
        if (!selectedLines.length) {
          setStatus("Select boundary segments first.");
          return;
        }

        if (activePolygon) {
          activePolygon.setMap(null);
          activePolygon = null;
        }

        const segments = selectedLines.map((line) => {
          const path = line.getPath();
          const a = path.getAt(0);
          const b = path.getAt(1);

          return [
            { lat: a.lat(), lng: a.lng() },
            { lat: b.lat(), lng: b.lng() },
          ];
        });

        function key(point) {
          return `${point.lat.toFixed(6)},${point.lng.toFixed(6)}`;
        }

        const used = new Set();
        const points = [...segments[0]];
        used.add(0);

        let changed = true;

        while (changed) {
          changed = false;

          for (let i = 0; i < segments.length; i++) {
            if (used.has(i)) continue;

            const [a, b] = segments[i];
            const first = points[0];
            const last = points[points.length - 1];

            if (key(a) === key(last)) {
              points.push(b);
              used.add(i);
              changed = true;
            } else if (key(b) === key(last)) {
              points.push(a);
              used.add(i);
              changed = true;
            } else if (key(b) === key(first)) {
              points.unshift(a);
              used.add(i);
              changed = true;
            } else if (key(a) === key(first)) {
              points.unshift(b);
              used.add(i);
              changed = true;
            }
          }
        }

        if (points.length < 3) {
          setStatus("Need at least 3 connected segments.");
          return;
        }

        activePolygon = new google.maps.Polyline({
          path: points,
          map,
          editable: true,
          draggable: true,
          strokeColor: "#2563eb",
          strokeWeight: 5,
        });

        addDeletePointListener(activePolygon);

        const bounds = new google.maps.LatLngBounds();
        points.forEach((point) => bounds.extend(point));
        map.fitBounds(bounds);

        setStatus(`Editable path built from ${used.size} connected segment(s). Adjust if needed, then Save Boundary.`);
      }

      async function saveBoundary() {
        if (!activePolygon) {
          setStatus("Draw or build a boundary first.");
          return;
        }

        const selectedOption = areaSelect.options[areaSelect.selectedIndex];
        const areaName = selectedOption?.textContent || areaSelect.value;
        const center = getPolygonCenter(activePolygon);

       const payload = {
          site_id: siteSelect.value,
          city: citySelect.value,
          area_slug: areaSelect.value,
          area_name: areaName,
          short_description: shortDescriptionInput.value.trim(),
          hero_image_url: heroImageUrlInput.value.trim(),
          hero_heading: document.getElementById("heroHeading").value.trim(),
          seo_heading: document.getElementById("seoHeading").value.trim(),
          seo_title: document.getElementById("seoTitle").value.trim(),
          intro_copy: document.getElementById("introCopy").value.trim(),
          polygon_geojson: polygonToGeoJson(activePolygon),
          center_lat: center.lat,
          center_lng: center.lng,
        };

        setStatus("Saving boundary...");

        const response = await fetch("/api/admin/area-boundary", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload),
        });

        const result = await response.json();

        if (!response.ok || !result.ok) {
          setStatus(`Save failed: ${result.error || "Unknown error"}`);
          return;
        }

        setActiveAction(null);
        setStatus(`Saved boundary for ${areaName}.`);
      }

      function syncCityFromSite() {
        const selected = siteSelect.options[siteSelect.selectedIndex];
        const siteCity = selected?.dataset?.city;

        if (siteCity && areasByCity[siteCity]) {
          citySelect.value = siteCity;
          refreshAreas();
        }
      }

      function initMap() {
        const start = cityCenters.nanaimo;

        map = new google.maps.Map(document.getElementById("map"), {
          center: { lat: start.lat, lng: start.lng },
          zoom: start.zoom,
          mapTypeControl: true,
          streetViewControl: false,
          fullscreenControl: true,
        });

        map.addListener("click", (event) => {
          if (!isDrawing) return;

          drawingPath.push(event.latLng);

          const marker = new google.maps.Marker({
            position: event.latLng,
            map,
          });

          drawingMarkers.push(marker);

          if (activePolygon) activePolygon.setMap(null);

          activePolygon = new google.maps.Polygon({
            paths: drawingPath,
            map,
            editable: true,
            draggable: true,
            fillOpacity: 0.18,
            strokeWeight: 3,
          });

          addDeletePointListener(activePolygon);

          setStatus(`${drawingPath.length} points added. Add at least 3, then click Save Boundary.`);
        });

        syncCityFromSite();

        setTimeout(() => {
          loadBoundary();
        }, 300);
      }

      window.addEventListener("DOMContentLoaded", () => {
        refreshAreas();
        syncCityFromSite();
      });

      window.addEventListener("load", () => {
        const wait = setInterval(() => {
          if (window.google?.maps) {
            clearInterval(wait);
            initMap();
          }
        }, 100);
      });

      siteSelect?.addEventListener("change", async () => {
        syncCityFromSite();
        await loadBoundary();
      });

      citySelect?.addEventListener("change", async () => {
        refreshAreas();
        await loadBoundary();
      });

      areaSelect?.addEventListener("change", async () => {
        await loadBoundary();
      });

      clearBtn?.addEventListener("click", () => {
        setActiveAction("clear");
        clearPolygon();
      });

      document
        .getElementById("loadLinesBtn")
        ?.addEventListener("click", loadImportedLines);

      document
        .getElementById("buildPolygonBtn")
        ?.addEventListener("click", buildPolygonFromSelectedLines);

      saveBtn?.addEventListener("click", saveBoundary);
    </script>
  </body>
</html>






