---
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Buyer CRM</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;1,400&family=Nunito+Sans:opsz,wght@6..12,300;6..12,400;6..12,500;6..12,600;6..12,700&display=swap" rel="stylesheet" />

  <style is:global>
    :root {
      --bg: #f4efe7;
      --card: #ffffff;
      --card-warm: #f9f5f0;
      --ink: #1a1917;
      --muted: #6b6b6b;
      --line: #dddddd;
      --accent: #8b6f47;
      --accent-bg: #f5ece0;
      --success: #1f7a45;
      --danger: #8b1e1e;
      --danger-bg: #fff6f6;
      --amber-bg: #fef9ec;
      --amber: #7a5c00;
      --green-bg: #edf7f1;
      --green: #1f7a45;
      --radius: 16px;
      --f-display: "Lora", Georgia, serif;
      --f-body: "Nunito Sans", system-ui, sans-serif;
      --ease: cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }
    html { scrollbar-gutter: stable; }
    body { font-family: var(--f-body); background: var(--bg); color: var(--ink); font-size: 15px; line-height: 1.5; -webkit-font-smoothing: antialiased; }
    body.modal-open { overflow: hidden; padding-right: var(--scrollbar-width, 0px); }
    a { color: inherit; text-decoration: none; }
    button { font: inherit; }

    .page { max-width: 1200px; margin: 0 auto; padding: 24px 24px 80px; }

    .topbar { display: flex; justify-content: space-between; align-items: center; gap: 16px; margin-bottom: 20px; flex-wrap: wrap; }
    .brand-head { display: flex; flex-direction: column; gap: 6px; }
    .page-logo { display: block; width: 220px; max-width: 60vw; height: 36px; object-fit: contain; object-position: left center; }
    .subtle { color: var(--muted); font-size: 0.88rem; }
    .logout-form { margin: 0; }
    .logout-btn { border: 1px solid var(--line); background: #fff; color: var(--ink); border-radius: 999px; padding: 9px 18px; font-size: 0.82rem; font-weight: 600; cursor: pointer; transition: background 0.15s; }
    .logout-btn:hover { background: #fafafa; }

    .admin-nav { display: inline-flex; gap: 4px; padding: 5px; background: #fff; border: 1px solid var(--line); border-radius: 999px; margin-bottom: 24px; box-shadow: 0 1px 4px rgba(0,0,0,0.06); }
    .admin-nav a { display: inline-flex; align-items: center; justify-content: center; padding: 7px 18px; border-radius: 999px; color: var(--muted); font-size: 0.82rem; font-weight: 600; transition: all 0.2s var(--ease); }
    .admin-nav a:hover { color: var(--ink); background: #f5f5f5; }
    .admin-nav a.active { background: var(--ink); color: #fff; }

    .page-heading { font-family: var(--f-display); font-size: clamp(1.8rem, 4vw, 2.8rem); font-weight: 400; letter-spacing: -0.02em; line-height: 1; margin-bottom: 4px; }
    .page-heading em { font-style: italic; color: var(--accent); }
    .page-desc { color: var(--muted); font-size: 0.88rem; margin-bottom: 20px; }

    .toolbar { display: flex; gap: 10px; align-items: center; margin-bottom: 20px; }
    .toolbar label { font-size: 0.72rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: var(--muted); white-space: nowrap; }
    .toolbar select { border: 1px solid var(--line); border-radius: 999px; padding: 9px 16px; background: #fff; color: var(--ink); font: inherit; font-size: 0.85rem; font-weight: 600; cursor: pointer; outline: none; }
    .toolbar select option { background: #fff; color: var(--ink); }

    .grid { display: grid; gap: 10px; }

    .buyer-card { background: var(--card); color: var(--ink); border-radius: var(--radius); overflow: hidden; border: 1px solid var(--line); box-shadow: 0 1px 6px rgba(0,0,0,0.06); transition: box-shadow 0.2s var(--ease); }
    .buyer-card:hover { box-shadow: 0 4px 16px rgba(0,0,0,0.1); }

    .buyer-summary { width: 100%; border: 0; background: transparent; color: inherit; text-align: left; padding: 20px 22px; cursor: pointer; font-family: inherit; transition: background 0.15s; }
    .buyer-summary:hover { background: rgba(24,22,20,0.02); }

    .row { display: flex; justify-content: space-between; align-items: flex-start; gap: 16px; }
    .name { font-family: var(--f-display); font-size: 1.35rem; font-weight: 500; letter-spacing: -0.02em; line-height: 1.1; margin-bottom: 4px; }
    .meta { font-size: 0.8rem; color: var(--muted); }
    .mini-read { margin-top: 5px; font-size: 0.8rem; font-weight: 500; color: rgba(24,22,20,0.6); line-height: 1.4; }
    .expand-icon { font-size: 1.3rem; font-weight: 300; color: rgba(24,22,20,0.3); flex-shrink: 0; margin-top: 2px; }

    .buyer-priority-strip { display: grid; grid-template-columns: 2fr 0.8fr 1fr; gap: 8px; margin-top: 14px; }
    .priority-box { border-radius: 12px; padding: 12px 14px; background: rgba(24,22,20,0.04); }
    .priority-box.primary { background: var(--accent-bg); }
    .priority-box span { display: block; margin-bottom: 3px; font-size: 0.62rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--muted); }
    .priority-box strong { display: block; font-size: 0.85rem; font-weight: 600; line-height: 1.3; }

    .reaction-mini-row { display: flex; gap: 14px; margin-top: 10px; font-size: 0.82rem; font-weight: 600; color: var(--muted); }

    .buyer-expanded { display: none; padding: 0 22px 22px; border-top: 1px solid var(--line); }
    .buyer-card.is-open .buyer-expanded { display: block; }

    .looking-for { margin-top: 14px; font-size: 0.88rem; font-weight: 500; line-height: 1.55; color: rgba(24,22,20,0.72); }

    .prompt { margin-top: 12px; padding: 11px 15px; border-radius: 12px; font-weight: 600; font-size: 0.83rem; line-height: 1.4; }
    .prompt.hot { background: var(--amber-bg); color: var(--amber); }
    .prompt.nudge { background: #f5f0ea; color: rgba(24,22,20,0.72); }
    .prompt.good { background: var(--green-bg); color: var(--green); }
    .prompt.quiet { background: rgba(24,22,20,0.04); color: rgba(24,22,20,0.52); }

    .stats { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 12px; }
    .pill { display: inline-flex; align-items: center; padding: 4px 11px; border-radius: 999px; font-size: 0.75rem; font-weight: 600; background: rgba(24,22,20,0.06); color: rgba(24,22,20,0.6); }

    .actions { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 14px; }
    .action { display: inline-flex; align-items: center; justify-content: center; border: 1px solid var(--line); border-radius: 999px; padding: 8px 16px; background: var(--ink); color: #fff; font-size: 0.8rem; font-weight: 600; text-decoration: none; cursor: pointer; font-family: inherit; transition: background 0.15s; }
    .action:hover { background: #333; }
    .action.secondary { background: transparent; border: 1px solid var(--line); color: var(--muted); }
    .action.secondary:hover { background: #fafafa; }

    .detail { margin-top: 16px; padding: 16px; border-radius: 12px; background: rgba(24,22,20,0.03); border: 1px solid var(--line); }
    .detail-group + .detail-group { margin-top: 14px; }
    .detail-title { font-size: 0.68rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--muted); margin-bottom: 8px; }
    .detail-item { padding: 11px 0; border-bottom: 1px solid var(--line); font-size: 0.86rem; }
    .detail-item:last-child { border-bottom: 0; }
    .activity-listing { cursor: pointer; }
    .activity-listing:hover strong { text-decoration: underline; }
    .activity-signals { display: flex; flex-wrap: wrap; margin-top: 5px; }
    .activity-signal { font-size: 0.74rem; font-weight: 600; color: var(--muted); }
    .activity-signal:not(:last-child)::after { content: "·"; margin: 0 6px; color: rgba(24,22,20,0.25); }
    .contact-note { margin-top: 8px; padding: 8px 12px; border-radius: 10px; background: rgba(24,22,20,0.04); color: rgba(24,22,20,0.65); font-size: 0.8rem; }
    .match-preview { margin-top: 14px; }

    .modal { position: fixed; inset: 0; z-index: 50; display: grid; place-items: center; padding: 20px; background: rgba(0,0,0,0.55); overflow: hidden; backdrop-filter: blur(4px); }
    .modal-card { width: min(720px, 100%); max-height: calc(100vh - 40px); overflow-y: auto; border-radius: 20px; background: var(--card); color: var(--ink); box-shadow: 0 24px 80px rgba(0,0,0,0.25); }
    .listing-modal-card { padding: 0; overflow: hidden; overflow-y: auto; }
    .modal-topbar { display: flex; justify-content: flex-end; align-items: center; gap: 8px; padding: 12px 14px; background: rgba(255,255,255,0.96); border-bottom: 1px solid var(--line); }
    .modal-photo-wrap { position: relative; }
    .modal-hero-img, .modal-hero-placeholder { width: 100%; height: 300px; display: block; object-fit: cover; background: #e8e4de; }
    .modal-hero-placeholder { display: grid; place-items: center; font-weight: 600; color: var(--muted); }
    .photo-nav { position: absolute; top: 50%; transform: translateY(-50%); width: 38px; height: 38px; border: 0; border-radius: 999px; background: rgba(255,255,255,0.92); color: var(--ink); font-size: 1.2rem; font-weight: 700; cursor: pointer; display: grid; place-items: center; padding: 0; transition: background 0.15s; }
    .photo-nav:hover { background: white; }
    .photo-prev { left: 12px; } .photo-next { right: 12px; }
    .photo-count { position: absolute; right: 12px; bottom: 10px; padding: 4px 10px; border-radius: 999px; background: rgba(24,22,20,0.65); color: #fff; font-size: 0.7rem; font-weight: 700; }
    .listing-modal-card h2 { margin: 12px 22px 6px; font-family: var(--f-display); font-size: 1.7rem; font-weight: 500; letter-spacing: -0.02em; }
    .modal-price { margin: 0 22px; font-size: 1rem; font-weight: 600; color: var(--muted); }
    .modal-facts { display: flex; flex-wrap: wrap; gap: 6px; margin: 12px 22px; }
    .modal-facts span { padding: 5px 12px; border-radius: 999px; background: rgba(24,22,20,0.07); font-size: 0.78rem; font-weight: 600; }
    .modal-description { margin: 0 22px 24px; font-size: 0.88rem; line-height: 1.6; color: rgba(24,22,20,0.68); }
    .listing-modal-card .detail-title { margin: 16px 22px 8px; }

    @media (max-width: 700px) {
      .page { padding: 18px 16px 60px; }
      .buyer-priority-strip { grid-template-columns: 1fr; gap: 6px; }
      .buyer-summary { padding: 16px; }
      .buyer-expanded { padding: 0 16px 16px; }
      .action { width: 100%; }
    }
  </style>
</head>

<body>
  <main class="page">
    <div class="topbar">
      <div class="brand-head">
        <img src="https://imagedelivery.net/Az3x6Ld2gouPPtikaqezkQ/7e9bec6d-9f98-48ad-253e-862ea1563e00/card" alt="Logo" class="page-logo" width="220" height="36" />
        <p class="subtle">One-page client radar. See who is active and who needs follow-up.</p>
      </div>
      <form method="post" action="/api/auth/logout" class="logout-form">
        <button type="submit" class="logout-btn">Log out</button>
      </form>
    </div>

    <nav class="admin-nav">
      <a href="/admin/buyers" class="active">Buyers</a>
      <a href="/shortlists">Shortlists</a>
      <a href="/listings">Listings</a>
    </nav>

    <h1 class="page-heading">Buyer <em>CRM.</em></h1>
    <p class="page-desc">Sort, read signals, and act on the right client at the right moment.</p>

    <div class="toolbar">
      <label for="sortBuyers">Sort by</label>
      <select id="sortBuyers">
        <option value="attention">Needs attention</option>
        <option value="recent">Most recent activity</option>
        <option value="hot">Hottest buyers</option>
        <option value="loved">Most loved</option>
        <option value="maybe">Most maybes</option>
        <option value="shortlists">Most shortlists</option>
      </select>
    </div>

    <div id="grid" class="grid"></div>
    <div id="listingModal"></div>
    <div id="activityModal"></div>
  </main>

  <script>
    const grid = document.getElementById("grid");
    const sortBuyersEl = document.getElementById("sortBuyers");
    let buyers = [], currentSort = "attention", pendingMatchesByBuyer = {};

    function setScrollbarWidth() { const w = window.innerWidth - document.documentElement.clientWidth; document.documentElement.style.setProperty("--scrollbar-width", `${w}px`); }
    setScrollbarWidth(); window.addEventListener("resize", setScrollbarWidth);
    function escapeHtml(value) { return String(value || "").replaceAll("&","&amp;").replaceAll("<","&lt;").replaceAll(">","&gt;").replaceAll('"',"&quot;").replaceAll("'","&#039;"); }
    function getListingSignals(item, groupTitle = "") { const signals = []; const isPass = groupTitle.toLowerCase().includes("not for me"); const prefix = isPass ? "Disliked" : "Liked"; const description = String(item.description || "").toLowerCase(); const sqft = Number(item.sqft || 0); if (description.includes("updated") || description.includes("renovated") || description.includes("modern")) signals.push(`${prefix} updated feel`); if (description.includes("bright") || description.includes("natural light") || description.includes("open concept")) signals.push(`${prefix} bright/open layout`); if (description.includes("view") || description.includes("mountain") || description.includes("ocean")) signals.push(`${prefix} the view`); if (description.includes("patio") || description.includes("deck") || description.includes("yard") || description.includes("balcony")) signals.push(`${prefix} outdoor space`); if (description.includes("garage") || description.includes("parking")) signals.push(`${prefix} parking`); if (sqft >= 1600) signals.push(`${prefix} more space`); return signals.slice(0, 4); }
    function dateMs(d) { return d ? new Date(d).getTime() : 0; }
    function hoursSince(d) { if (!d) return Infinity; return Math.max(0, (Date.now() - dateMs(d)) / 36e5); }
    function formatAge(d) { if (!d) return "Never"; const h = hoursSince(d); if (h < 1) return "Less than 1 hour ago"; if (h < 24) return `${Math.floor(h)} hour${Math.floor(h) === 1 ? "" : "s"} ago`; const days = Math.floor(h / 24); return `${days} day${days === 1 ? "" : "s"} ago`; }
    function hasActivity(b) { return b.stats.lastActivityAt || b.stats.lastViewed || (b.stats.loved||0) > 0 || (b.stats.maybe||0) > 0 || (b.stats.notForMe||0) > 0; }
    function lastContactAt(b) { return b.stats.lastContactedAt || b.last_contacted_at || b.lastContactedAt || null; }
    function buyerStatus(b) { if ((b.stats.loved||0) >= 1 || (b.stats.maybe||0) >= 3) return "🔥 Hot buyer"; if (hasActivity(b)) return "👀 Active"; return "💤 Not viewed yet"; }
    function buyerStatusClass(b) { if ((b.stats.loved||0) >= 1 || (b.stats.maybe||0) >= 3) return "hot-pill"; if (hasActivity(b)) return "viewed"; return "cold"; }
    function momentum(b) { const s = hoursSince(b.stats.lastActivityAt || b.stats.lastViewed); const loved = b.stats.loved||0; const maybe = b.stats.maybe||0; if (s <= 24 && (loved > 0 || maybe > 0)) return { text: "↑ Heating up", className: "momentum-up" }; if (s <= 72) return { text: "→ Active", className: "momentum-flat" }; if (hasActivity(b)) return { text: "↓ Cooling off", className: "momentum-down" }; return { text: "No activity yet", className: "cold" }; }
    function lookingForSummary(b) { const loved = b.stats.loved||0, maybe = b.stats.maybe||0, pass = b.stats.notForMe||0; if (loved > 0 && maybe > 0) return `Looking for: strong match signals — ${loved} loved, ${maybe} maybe. Ask what stood out.`; if (loved > 0) return `Looking for: homes similar to the ${loved} they loved. Focus on showings.`; if (maybe > 0) return `Looking for: close-but-not-perfect options. Help narrow the maybes.`; if (pass > 0) return `Looking for: better fit needed — current shortlist is missing the mark.`; return "Looking for: not enough signal yet. Send a fresh shortlist or ask what matters most."; }
    function buyerRead(b) { const loved = b.stats.loved||0, maybe = b.stats.maybe||0, pass = b.stats.notForMe||0; if (loved > 0 && maybe > 0) return `Signal: liked ${loved}, considering ${maybe}. Worth a personal follow-up.`; if (loved > 0) return `Signal: ${loved} loved property${loved===1?"":"ies"}. Ask about showings.`; if (maybe > 0) return `Signal: ${maybe} maybe property${maybe===1?"":"ies"}. Help narrow the list.`; if (pass > 0) return `Signal: mostly passing. Send better matches.`; return "Signal: no clear preference yet."; }
    function followUpPrompt(b) { const activityAt = b.stats.lastActivityAt || b.stats.lastViewed; const contactAt = lastContactAt(b); const sinceActivity = hoursSince(activityAt); const sinceContact = hoursSince(contactAt); if (sinceContact > 24 && sinceActivity <= 24) return { text: "🔥 Text them while they are active.", className: "hot", score: 100, sms: "I saw you had a look at the shortlist. Any of those homes worth talking about?" }; if (sinceContact > 24 && (b.stats.loved||0) > 0) return { text: "❤️ Ask if they want to see the property they liked.", className: "hot", score: 90, sms: "I saw you liked one of the homes. Want me to look into it or set up a showing?" }; if (sinceContact > 24 && (b.stats.maybe||0) > 0) return { text: "🤔 Help them sort through the maybes.", className: "nudge", score: 75, sms: "I saw a couple maybes in your shortlist. Want me to help narrow down which ones are worth seeing?" }; if (sinceContact > 48 && hasActivity(b)) return { text: "👋 Reconnect before they go fully cold.", className: "nudge", score: 60, sms: "Just checking in. Want me to send a few better matches based on what you liked?" }; if (!hasActivity(b)) return { text: "💤 No activity yet. Send a fresher shortlist.", className: "quiet", score: 10, sms: "I can send over a few fresh options if you want to keep an eye on the market." }; return { text: "✅ You are in sync. No urgent follow-up needed.", className: "good", score: 30, sms: "Just checking in — anything you want me to dig into from the shortlist?" }; }
    function missedOpportunity(b) { return (b.stats.loved||0) > 0 && hoursSince(lastContactAt(b)) > 24; }
    function hotScore(b) { return (b.stats.loved||0)*3 + (b.stats.maybe||0)*2 + (b.stats.shortlists||0) + (b.stats.lastActivityAt ? 5 : 0); }
    function sortBuyers(list) { return [...list].sort((a, b) => { if (currentSort === "attention") return followUpPrompt(b).score - followUpPrompt(a).score; if (currentSort === "recent") return dateMs(b.stats.lastActivityAt) - dateMs(a.stats.lastActivityAt); if (currentSort === "hot") return hotScore(b) - hotScore(a); if (currentSort === "loved") return (b.stats.loved||0) - (a.stats.loved||0); if (currentSort === "maybe") return (b.stats.maybe||0) - (a.stats.maybe||0); if (currentSort === "shortlists") return (b.stats.shortlists||0) - (a.stats.shortlists||0); return 0; }); }

    function renderBuyers() {
      grid.innerHTML = sortBuyers(buyers).map((b) => {
        const prompt = followUpPrompt(b); const move = momentum(b); const name = b.name || "Unnamed buyer"; const safeName = escapeHtml(name);
        const phone = b.phone || b.client_phone || b.stats.phone || ""; const textBody = `Hi ${name}, ${prompt.sms}`; const note = b.stats.lastContactNote || "";
        return `<div class="buyer-card" data-name="${safeName}">
          <button class="buyer-summary" type="button">
            <div class="row">
              <div><div class="name">${safeName}</div><div class="meta">Last activity: ${formatAge(b.stats.lastActivityAt)}</div><div class="mini-read">${escapeHtml(buyerRead(b))}</div></div>
              <div class="expand-icon">+</div>
            </div>
            <div class="buyer-priority-strip">
              <div class="priority-box primary"><span>Next action</span><strong>${escapeHtml(prompt.text.replace(/^[🔥❤️🤔👋💤✅]\s*/u, ""))}</strong></div>
              <div class="priority-box"><span>Heat score</span><strong>${hotScore(b)}</strong></div>
              <div class="priority-box"><span>Momentum</span><strong>${escapeHtml(move.text)}</strong></div>
            </div>
            <div class="reaction-mini-row"><span>❤️ ${b.stats.loved||0}</span><span>🤔 ${b.stats.maybe||0}</span><span>✕ ${b.stats.notForMe||0}</span></div>
          </button>
          <div class="buyer-expanded">
            ${note ? `<div class="meta contact-note"><strong>Note:</strong> ${escapeHtml(note)}</div>` : ""}
            <div class="looking-for">${escapeHtml(lookingForSummary(b))}</div>
            ${b.stats.priceSignal ? `<div class="looking-for" style="margin-top:8px;">${escapeHtml(b.stats.priceSignal)}</div>` : ""}
            <div class="prompt ${prompt.className}">${prompt.text}</div>
            <div class="stats"><div class="pill ${buyerStatusClass(b)}">${buyerStatus(b)}</div><div class="pill ${move.className}">${move.text}</div>${missedOpportunity(b) ? `<div class="pill">⚠ Missed follow-up</div>` : ""}<div class="pill">${b.stats.shortlists||0} shortlist(s)</div></div>
            <div class="actions">
              ${phone ? `<a class="action" href="sms:${phone}?&body=${encodeURIComponent(textBody)}">Text next action</a>` : `<span class="action secondary">No phone saved</span>`}
              <button class="action better-matches" type="button" data-name="${safeName}" data-phone="${escapeHtml(phone)}">Suggest next best 3</button>
              <button class="action secondary view-activity" type="button">Show reviewed homes</button>
            </div>
          </div>
        </div>`;
      }).join("");
    }

    async function load() {
      grid.innerHTML = `<div class="meta" style="padding:24px 0;color:#999;">Loading buyers...</div>`;
      const res = await fetch("/api/buyers"); const json = await res.json();
      if (!json.ok) { grid.innerHTML = "Error loading buyers"; return; }
      buyers = json.buyers || []; renderBuyers();
    }

    sortBuyersEl?.addEventListener("change", (event) => { currentSort = event.target.value; renderBuyers(); });

    grid.addEventListener("click", (event) => {
      if (event.target.closest("a, button.action, .better-matches, .view-activity")) return;
      const card = event.target.closest(".buyer-card"); if (!card) return;
      const wasOpen = card.classList.contains("is-open");
      document.querySelectorAll(".buyer-card.is-open").forEach((c) => { c.classList.remove("is-open"); const icon = c.querySelector(".expand-icon"); if (icon) icon.textContent = "+"; });
      if (!wasOpen) { card.classList.add("is-open"); const icon = card.querySelector(".expand-icon"); if (icon) icon.textContent = "−"; }
    });

    grid.addEventListener("click", async (event) => {
      const btn = event.target.closest(".better-matches"); if (!btn) return; event.stopPropagation();
      const card = btn.closest(".buyer-card"); const name = btn.dataset.name; const phone = btn.dataset.phone;
      if (!phone) { btn.textContent = "No phone saved"; return; }
      btn.textContent = "Finding matches...";
      const res = await fetch("/api/buyers/better-matches", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ name }) });
      const json = await res.json();
      if (!json.ok) { btn.textContent = json.error || "Could not load"; return; }
      const listings = json.listings || []; pendingMatchesByBuyer[name] = listings;
      if (!listings.length) { btn.textContent = "No matches found"; return; }
      const lines = listings.map((l, i) => `${i+1}. ${l.address||l.full_address||"Listing"} - ${l.price_text||(l.price?`$${Number(l.price).toLocaleString()}`:"Price unavailable")}`);
      const message = `Hi ${name}, I found a few homes closer to what you've been reacting to:\n\n${lines.join("\n")}\n\nWant me to line up a showing?`;
      const existing = card.querySelector(".match-preview"); if (existing) existing.remove();
      const listingsHtml = listings.map((l, i) => { const price = l.priceText||l.price_text||(l.price?`$${Number(l.price).toLocaleString()}`:"Price unavailable"); const reasonHtml = (Array.isArray(l.reasons)&&l.reasons.length)?l.reasons.map((r)=>`<span class="activity-signal">${escapeHtml(r)}</span>`).join(""):`<span class="activity-signal">Similar buyer fit</span>`; return `<div class="detail-item activity-listing" data-address="${escapeHtml(l.address||l.full_address||"Listing")}" data-price="${escapeHtml(price)}" data-decision="Suggested match" data-image="${escapeHtml(l.image||l.image_url||"")}" data-images="${escapeHtml(Array.isArray(l.images)?l.images.join("|"):"")}" data-beds="${escapeHtml(l.beds||"")}" data-baths="${escapeHtml(l.baths||"")}" data-type="${escapeHtml(l.type||l.property_type||"")}" data-sqft="${escapeHtml(l.sqft||"")}" data-description="${escapeHtml(l.description||"")}"><strong>${i+1}. ${escapeHtml(l.address||l.full_address||"Listing")}</strong><div>${price}</div><div class="activity-signals">${reasonHtml}</div></div>`; }).join("");
      const preview = document.createElement("div"); preview.className = "detail match-preview";
      preview.innerHTML = `<div class="detail-title">Suggested matches to send</div>${listingsHtml}<div class="actions"><button class="action send-matches" type="button" data-name="${escapeHtml(name)}" data-phone="${escapeHtml(phone)}" data-message="${escapeHtml(message)}">Send via Twilio</button><button class="action secondary cancel-preview" type="button">Cancel</button></div>`;
      card.appendChild(preview); btn.textContent = "Refresh matches";
    });

    grid.addEventListener("click", async (event) => {
      const btn = event.target.closest(".send-matches"); if (!btn) return; event.stopPropagation(); btn.textContent = "Sending...";
      const { name, phone, message } = btn.dataset;
      const res = await fetch("/api/buyers/send-better-matches", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ name, phone, message, note: "Sent 3 better matches", listings: pendingMatchesByBuyer[name]||[] }) });
      const json = await res.json();
      if (!json.ok) { btn.textContent = json.error || "Could not send"; return; }
      btn.textContent = "Sent ✓";
      const buyer = buyers.find((b) => (b.name||"Unnamed buyer") === name);
      if (buyer) { buyer.last_contacted_at = new Date().toISOString(); buyer.stats.lastContactedAt = buyer.last_contacted_at; buyer.stats.lastContactNote = "Sent 3 better matches"; }
      setTimeout(renderBuyers, 900);
    });

    grid.addEventListener("click", (event) => { const btn = event.target.closest(".cancel-preview"); if (!btn) return; event.stopPropagation(); btn.closest(".match-preview")?.remove(); });

    grid.addEventListener("click", async (event) => {
      const btn = event.target.closest(".view-activity"); if (!btn) return; event.stopPropagation();
      const card = btn.closest(".buyer-card"); if (!card) return;
      const existing = card.querySelector(".detail:not(.match-preview)"); if (existing) { existing.remove(); return; }
      const name = card.dataset.name;
      const res = await fetch(`/api/buyer-detail?name=${encodeURIComponent(name)}`); const json = await res.json();
      const detail = document.createElement("div"); detail.className = "detail";
      const items = json.items || [];
      const loved = items.filter((i) => i.is_favourite);
      const maybe = items.filter((i) => String(i.decision||"").toLowerCase().includes("maybe"));
      const pass = items.filter((i) => { const d = String(i.decision||"").toLowerCase(); return d.includes("pass") || d.includes("not_for_me"); });
      function renderGroup(title, arr) {
        if (!arr.length) return "";
        return `<div class="detail-group"><div class="detail-title">${title}</div>${arr.map((item) => { const likedTags = Array.isArray(item.liked_tags) ? item.liked_tags : []; const metrics = item.metrics || {}; const viewedPhotos = Number(metrics.unique_images_viewed||0); const secondsViewed = Number(metrics.time_spent_seconds||0); const allImages = Array.isArray(item.images)?item.images:Array.isArray(item.photos)?item.photos:Array.isArray(item.image_urls)?item.image_urls:[]; const totalPhotos = allImages.length; const mins = Math.floor(secondsViewed/60); const secs = secondsViewed%60; const timeText = secondsViewed>0?(mins>0?`${mins}m ${secs}s viewed`:`${secs}s viewed`):""; const photoText = viewedPhotos>0?(totalPhotos>0?`${Math.min(viewedPhotos,totalPhotos)} of ${totalPhotos} photos viewed`:`${viewedPhotos} photos viewed`):""; return `<div class="detail-item activity-listing" data-address="${escapeHtml(item.address||"Unknown listing")}" data-price="${escapeHtml(item.price_text||"Price unavailable")}" data-decision="${escapeHtml(title)}" data-image="${escapeHtml(item.image_url||item.photo_url||item.thumbnail_url||item.image||item.img||"")}" data-images="${escapeHtml(Array.isArray(item.images)?item.images.join("|"):Array.isArray(item.photos)?item.photos.join("|"):Array.isArray(item.image_urls)?item.image_urls.join("|"):"")}" data-beds="${escapeHtml(item.beds||"")}" data-baths="${escapeHtml(item.baths||"")}" data-type="${escapeHtml(item.property_type||"")}" data-sqft="${escapeHtml(item.sqft||"")}" data-description="${escapeHtml(item.description||"")}" data-liked-tags="${escapeHtml(likedTags.join("|"))}"><strong>${escapeHtml(item.address||"Unknown listing")}</strong><div>${escapeHtml(item.price_text||"Price unavailable")}</div><div class="activity-signals">${timeText?`<span class="activity-signal">${escapeHtml(timeText)}</span>`:""}${photoText?`<span class="activity-signal">${escapeHtml(photoText)}</span>`:""}${likedTags.map((tag)=>`<span class="activity-signal">${title.toLowerCase().includes("not for me")?"Disliked":"Liked"}: ${escapeHtml(tag)}</span>`).join("")}${getListingSignals(item).map((s)=>`<span class="activity-signal">${escapeHtml(s)}</span>`).join("")}</div></div>`; }).join("")}</div>`;
      }
      detail.innerHTML = items.length ? `${renderGroup("❤️ Loved",loved)}${renderGroup("🤔 Maybe",maybe)}${renderGroup("✕ Not for me",pass)}` : `<p style="color:#999;padding:12px 0;">No listing activity found.</p>`;
      card.appendChild(detail);
    });

    let activityItems = [], activityIndex = 0;
    function openActivityModal(index) {
      document.body.classList.add("modal-open"); activityIndex = index;
      const item = activityItems[activityIndex]; const modal = document.getElementById("activityModal");
      const photos = item.images?.length ? item.images : item.image ? [item.image] : []; const photoIndex = item.photoIndex || 0; const currentPhoto = photos[photoIndex] || "";
      modal.innerHTML = `<div class="modal"><div class="modal-card listing-modal-card"><div class="modal-topbar"><span class="pill" style="margin-right:auto;">${activityIndex+1} of ${activityItems.length}</span><button class="action secondary activity-prev" type="button">← Prev</button><button class="action secondary activity-next" type="button">Next →</button><button class="action secondary activity-close" type="button">Close</button></div><div class="modal-photo-wrap">${currentPhoto?`<img class="modal-hero-img" src="${escapeHtml(currentPhoto)}" alt="${escapeHtml(item.address)}" />`:`<div class="modal-hero-placeholder">No image available</div>`}${photos.length>1?`<button class="photo-nav photo-prev" type="button">←</button><button class="photo-nav photo-next" type="button">→</button><div class="photo-count">${photoIndex+1} / ${photos.length}</div>`:""}</div><div class="detail-title" style="margin:16px 22px 8px;">${escapeHtml(item.decision)}</div><h2>${escapeHtml(item.address)}</h2><p class="modal-price"><strong>${escapeHtml(item.price)}</strong></p><div class="modal-facts">${item.beds?`<span>${escapeHtml(item.beds)} Bed</span>`:""}${item.baths?`<span>${escapeHtml(item.baths)} Bath</span>`:""}${item.sqft?`<span>${Number(item.sqft).toLocaleString()} Sq Ft</span>`:""}${item.type?`<span>${escapeHtml(item.type)}</span>`:""}</div><p class="modal-description">${escapeHtml(item.description||"No description saved.")}</p></div></div>`;
    }

    grid.addEventListener("click", (event) => {
      const item = event.target.closest(".activity-listing"); if (!item) return; event.stopPropagation();
      activityItems = [...document.querySelectorAll(".activity-listing")].map((el) => { const images = String(el.dataset.images||"").split("|").map((x)=>x.trim()).filter(Boolean); return { address:el.dataset.address||"Unknown listing", price:el.dataset.price||"Price unavailable", decision:el.dataset.decision||"Listing activity", image:el.dataset.image||"", images, photoIndex:0, beds:el.dataset.beds||"", baths:el.dataset.baths||"", type:el.dataset.type||"", sqft:el.dataset.sqft||"", description:el.dataset.description||"" }; });
      activityIndex = activityItems.findIndex((x)=>x.address===item.dataset.address);
      openActivityModal(Math.max(0, activityIndex));
    });

    document.addEventListener("click", (event) => {
      if (event.target.closest(".activity-close")) { event.preventDefault(); event.stopPropagation(); document.getElementById("activityModal").innerHTML = ""; document.body.classList.remove("modal-open"); return; }
      if (event.target.closest(".activity-prev")) { activityIndex = (activityIndex-1+activityItems.length)%activityItems.length; openActivityModal(activityIndex); return; }
      if (event.target.closest(".activity-next")) { activityIndex = (activityIndex+1)%activityItems.length; openActivityModal(activityIndex); return; }
      if (event.target.closest(".photo-prev")) { const item=activityItems[activityIndex]; const photos=item.images?.length?item.images:item.image?[item.image]:[]; if (photos.length) { item.photoIndex=((item.photoIndex||0)-1+photos.length)%photos.length; openActivityModal(activityIndex); } return; }
      if (event.target.closest(".photo-next")) { const item=activityItems[activityIndex]; const photos=item.images?.length?item.images:item.image?[item.image]:[]; if (photos.length) { item.photoIndex=((item.photoIndex||0)+1)%photos.length; openActivityModal(activityIndex); } return; }
    });

    load();
  </script>
</body>
</html>
