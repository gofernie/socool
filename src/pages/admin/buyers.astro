      grid.addEventListener("click", async (event) => {
        const btn = event.target.closest(".send-matches");
        if (!btn) return;

        event.stopPropagation();
        btn.textContent = "Sending...";

        const name = btn.dataset.name;
        const phone = btn.dataset.phone;
        const message = btn.dataset.message;

        const res = await fetch("/api/buyers/send-better-matches", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            name,
            phone,
            message,
            note: "Sent 3 better matches",
            listings: pendingMatchesByBuyer[name] || []
          })
        });

        const json = await res.json();

        if (!json.ok) {
          btn.textContent = json.error || "Could not send";
          return;
        }

        btn.textContent = "Sent ✓";

        const buyer = buyers.find((b) => (b.name || "Unnamed buyer") === name);
        if (buyer) {
          buyer.last_contacted_at = new Date().toISOString();
          buyer.stats.lastContactedAt = buyer.last_contacted_at;
          buyer.stats.lastContactNote = "Sent 3 better matches";
        }

        setTimeout(renderBuyers, 900);
      });

      grid.addEventListener("click", (event) => {
        const btn = event.target.closest(".cancel-preview");
        if (!btn) return;

        event.stopPropagation();
        btn.closest(".match-preview")?.remove();
      });

      grid.addEventListener("click", async (event) => {
        const btn = event.target.closest(".view-activity");
        if (!btn) return;

        event.stopPropagation();

        const card = btn.closest(".buyer-card");
        if (!card) return;

        const existing = card.querySelector(".detail:not(.match-preview)");
        if (existing) {
          existing.remove();
          return;
        }

        const name = card.dataset.name;
        const res = await fetch(`/api/buyer-detail?name=${encodeURIComponent(name)}`);
        const json = await res.json();

        const detail = document.createElement("div");
        detail.className = "detail";

        const items = json.items || [];

        const loved = items.filter((i) => i.is_favourite);
        const maybe = items.filter((i) =>
          String(i.decision || "").toLowerCase().includes("maybe")
        );
        const pass = items.filter((i) => {
          const decision = String(i.decision || "").toLowerCase();
          return decision.includes("pass") || decision.includes("not_for_me");
        });

        function renderGroup(title, arr) {
          if (!arr.length) return "";

          return `
            <div class="detail-group">
              <div class="detail-title">${title}</div>
              ${arr.map((item) => {
 const signals = getListingSignals(item);
const likedTags = Array.isArray(item.liked_tags) ? item.liked_tags : [];

const metrics = item.metrics || {};

const viewedPhotos = Number(metrics.unique_images_viewed || 0);
const secondsViewed = Number(metrics.time_spent_seconds || 0);

const allImages = Array.isArray(item.images)
  ? item.images
  : Array.isArray(item.photos)
    ? item.photos
    : Array.isArray(item.image_urls)
      ? item.image_urls
      : [];

const totalPhotos = allImages.length;

const mins = Math.floor(secondsViewed / 60);
const secs = secondsViewed % 60;

const timeText =
  secondsViewed > 0
    ? mins > 0
      ? `${mins}m ${secs}s viewed`
      : `${secs}s viewed`
    : "";

const photoText =
  viewedPhotos > 0
    ? totalPhotos > 0
      ? `${Math.min(viewedPhotos, totalPhotos)} of ${totalPhotos} photos viewed`
      : `${viewedPhotos} photos viewed`
    : "";

const depthText = "";

return `
                <div
                  class="detail-item activity-listing"
                  data-address="${escapeHtml(item.address || "Unknown listing")}"
                  data-price="${escapeHtml(item.price_text || "Price unavailable")}"
                  data-decision="${escapeHtml(title)}"
data-image="${escapeHtml(
  item.image_url ||
  item.photo_url ||
  item.thumbnail_url ||
  item.image ||
  item.img ||
  item.main_image_url ||
  item.first_image_url ||
  ""
)}"
data-images="${escapeHtml(
  Array.isArray(item.images)
    ? item.images.join("|")
    : Array.isArray(item.photos)
      ? item.photos.join("|")
      : Array.isArray(item.image_urls)
        ? item.image_urls.join("|")
        : ""
)}"
                 data-beds="${escapeHtml(item.beds || "")}"
data-baths="${escapeHtml(item.baths || "")}"
data-type="${escapeHtml(item.property_type || "")}"
data-sqft="${escapeHtml(item.sqft || "")}"
data-description="${escapeHtml(item.description || "")}"
data-liked-tags="${escapeHtml(likedTags.join("|"))}"
                >
                 <strong>${escapeHtml(item.address || "Unknown listing")}</strong>
<div>${escapeHtml(item.price_text || "Price unavailable")}</div>

<div class="activity-signals">

  ${
    timeText
      ? `<span class="activity-signal">${escapeHtml(timeText)}</span>`
      : ""
  }

  ${
    photoText
      ? `<span class="activity-signal">${escapeHtml(photoText)}</span>`
      : ""
  }

  

  ${
  likedTags.length
    ? likedTags.map((tag) => {
        const isPass = title.toLowerCase().includes("not for me");
        const label = isPass ? "Disliked" : "Liked";
        return `
          <span class="activity-signal">
            ${label}: ${escapeHtml(tag)}
          </span>
        `;
      }).join("")
    : ""
}

  ${
    getListingSignals(item).length
      ? getListingSignals(item)
          .map((signal) => `
            <span class="activity-signal">${escapeHtml(signal)}</span>
          `)
          .join("")
      : ""
  }

</div>
                </div>
              `;
      }).join("")}
            </div>
          `;
        }

        detail.innerHTML = items.length
          ? `
            ${renderGroup("❤️ Loved", loved)}
            ${renderGroup("🤔 Maybe", maybe)}
            ${renderGroup("✕ Not for me", pass)}
          `
          : `<p>No listing activity found.</p>`;

        card.appendChild(detail);
      });

      

  
let activityItems = [];
let activityIndex = 0;

function openActivityModal(index) {
  document.body.classList.add("modal-open");
  activityIndex = index;
  const item = activityItems[activityIndex];
  const modal = document.getElementById("activityModal");

  const photos = item.images?.length ? item.images : item.image ? [item.image] : [];
  const photoIndex = item.photoIndex || 0;
  const currentPhoto = photos[photoIndex] || "";

  modal.innerHTML = `
    <div class="modal">
      <div class="modal-card listing-modal-card">
        <div class="modal-topbar">
          <span class="pill cold">${activityIndex + 1} of ${activityItems.length}</span>

          <button class="action secondary activity-prev" type="button">← Prev home</button>
          <button class="action secondary activity-next" type="button">Next home →</button>
          <button class="action secondary activity-close" type="button">Close</button>
        </div>

        <div class="modal-photo-wrap">
          ${
            currentPhoto
              ? `<img class="modal-hero-img" src="${escapeHtml(currentPhoto)}" alt="${escapeHtml(item.address)}" />`
              : `<div class="modal-hero-placeholder">No image available</div>`
          }

          ${
            photos.length > 1
              ? `
                <button class="photo-nav photo-prev" type="button">←</button>
<button class="photo-nav photo-next" type="button">→</button>
                <div class="photo-count">${photoIndex + 1} / ${photos.length}</div>
              `
              : ""
          }
        </div>

        <div class="detail-title">${escapeHtml(item.decision)}</div>
        <h2>${escapeHtml(item.address)}</h2>
        <p class="modal-price"><strong>${escapeHtml(item.price)}</strong></p>

        <div class="modal-facts">
          ${item.beds ? `<span>${escapeHtml(item.beds)} Bed</span>` : ""}
          ${item.baths ? `<span>${escapeHtml(item.baths)} Bath</span>` : ""}
          ${item.sqft ? `<span>${Number(item.sqft).toLocaleString()} Sq. Ft.</span>` : ""}
          ${item.type ? `<span>${escapeHtml(item.type)}</span>` : ""}
        </div>

        <p class="modal-description">
          ${escapeHtml(item.description || "No description saved for this listing yet.")}
        </p>
      </div>
    </div>
  `;
}

grid.addEventListener("click", (event) => {
  const item = event.target.closest(".activity-listing");
  if (!item) return;

  event.stopPropagation();

activityItems = [...document.querySelectorAll(".activity-listing")].map((el) => {
  const images = String(el.dataset.images || "")
    .split("|")
    .map((x) => x.trim())
    .filter(Boolean);

  return {
    address: el.dataset.address || "Unknown listing",
    price: el.dataset.price || "Price unavailable",
    decision: el.dataset.decision || "Listing activity",
    image: el.dataset.image || "",
    images,
    photoIndex: 0,
    beds: el.dataset.beds || "",
    baths: el.dataset.baths || "",
    type: el.dataset.type || "",
    sqft: el.dataset.sqft || "",
    description: el.dataset.description || ""
  };
});

  activityIndex = activityItems.findIndex((x) => x.address === item.dataset.address);
  openActivityModal(Math.max(0, activityIndex));
});

document.addEventListener("click", (event) => {
  if (event.target.closest(".activity-close")) {
    event.preventDefault();
    event.stopPropagation();
  document.getElementById("activityModal").innerHTML = "";
  document.body.classList.remove("modal-open");
  return;
}

  if (event.target.closest(".activity-prev")) {
    activityIndex = (activityIndex - 1 + activityItems.length) % activityItems.length;
    openActivityModal(activityIndex);
    return;
  }

if (event.target.closest(".activity-next")) {
  activityIndex = (activityIndex + 1) % activityItems.length;
  openActivityModal(activityIndex);
  return;
}

if (event.target.closest(".photo-prev")) {
  const item = activityItems[activityIndex];
  const photos = item.images?.length ? item.images : item.image ? [item.image] : [];

  if (photos.length) {
    item.photoIndex = ((item.photoIndex || 0) - 1 + photos.length) % photos.length;
    openActivityModal(activityIndex);
  }

  return;
}

if (event.target.closest(".photo-next")) {
  const item = activityItems[activityIndex];
  const photos = item.images?.length ? item.images : item.image ? [item.image] : [];

  if (photos.length) {
    item.photoIndex = ((item.photoIndex || 0) + 1) % photos.length;
    openActivityModal(activityIndex);
  }

  return;
}
});
