<html>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Buyer CRM</title>

    <style is:global>
html {
  scrollbar-gutter: stable;
}

body {
    margin: 0;
    font-family: system-ui;
   background: #797975;
    color: #fffaf1;
  }

  .shell {
    width: min(1100px, calc(100% - 32px));
    margin: 0 auto;
    padding: 40px 0;
  }

  h1 {
    font-size: 42px;
    letter-spacing: -0.05em;
    margin: 0 0 8px;
  }

  .lead {
    max-width: 680px;
    font-size: 16px;
    line-height: 1.5;
    color: rgba(255, 250, 241, 0.68);
    margin: 0 0 20px;
  }

  .toolbar {
    display: flex;
    gap: 10px;
    align-items: center;
    margin-top: 10px;
  }

  .toolbar label {
    font-size: 14px;
    font-weight: 800;
    color: rgba(255, 250, 241, 0.65);
  }

  .toolbar select {
    border: 1px solid rgba(255, 250, 241, 0.16);
    border-radius: 999px;
    padding: 10px 14px;
    background: #fffaf1;
    color: #181614;
    font-weight: 800;
  }

  .grid {
    display: grid;
    gap: 22px;
    margin-top: 28px;
  }

.buyer-card {
  cursor: default;
  background: #f7f2ea;
  color: #181614;
  border: 1px solid rgba(24, 22, 20, 0.06);
  border-radius: 18px;
  padding: 24px;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.04);
}

  .row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 16px;
  }

  .name {
    font-size: 24px;
    font-weight: 900;
    letter-spacing: -0.04em;
  }

  .meta {
    font-size: 14px;
    color: rgba(24, 22, 20, 0.5);
    margin-top: 4px;
  }

  .looking-for {
    margin-top: 14px;
    padding: 0;
    border-radius: 0;
    background: transparent;
    font-size: 15px;
    line-height: 1.45;
    font-weight: 750;
    color: rgba(24, 22, 20, 0.78);
  }

  .mini-read {
    margin-top: 8px;
    font-size: 14px;
    font-weight: 650;
    line-height: 1.45;
    color: rgba(24, 22, 20, 0.58);
  }

  .prompt {
    margin-top: 18px;
    padding: 14px 16px;
    border-radius: 18px;
    font-weight: 850;
    font-size: 14px;
    line-height: 1.4;
    border: 0;
    box-shadow: none;
  }

  .prompt.hot {
    background: #f3d8ae;
    color: #181614;
  }

  .prompt.nudge {
    background: #eee5d7;
    color: #181614;
  }

  .prompt.good {
    background: #e7eee3;
    color: #181614;
  }

  .prompt.quiet {
    background: #efefef;
    color: rgba(24, 22, 20, 0.75);
  }

  .stats {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 14px;
    margin-top: 14px;
    padding-top: 2px;
  }

  .pill {
    padding: 0;
    border-radius: 0;
    background: transparent !important;
    font-size: 13px;
    font-weight: 750;
    color: rgba(24, 22, 20, 0.55);
    line-height: 1;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 18px;
  }

  .action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border: 0;
  border-radius: 999px;
  padding: 9px 14px;
  background: #2b2722;
  color: #fffaf1;
  font-size: 12.5px;
  font-weight: 800;
  text-decoration: none;
  cursor: pointer;
  font-family: inherit;
  transition: opacity 0.2s ease, transform 0.2s ease;
}

.buyer-card {
  padding: 0;
  overflow: hidden;
}

.buyer-summary {
  width: 100%;
  border: 0;
  background: transparent;
  color: inherit;
  text-align: left;
  padding: 24px;
  cursor: pointer;
  font-family: inherit;
}

.buyer-summary:hover {
  background: rgba(24, 22, 20, 0.025);
}

.buyer-expanded {
  display: none;
  padding: 0 24px 24px;
}

.buyer-card.is-open .buyer-expanded {
  display: block;
}

.expand-icon {
  font-size: 24px;
  font-weight: 900;
  color: rgba(24, 22, 20, 0.45);
}

.behaviour-strip {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10px;
  margin-top: 18px;
}

.behaviour-box {
  border-radius: 16px;
  padding: 14px;
  background: rgba(24, 22, 20, 0.045);
}

.behaviour-box strong {
  display: block;
  font-size: 24px;
}

.behaviour-box span {
  font-size: 12px;
  font-weight: 800;
  color: rgba(24, 22, 20, 0.5);
}
.action:hover {
  opacity: 0.88;
  transform: translateY(-1px);
}

  .action.secondary {
    background: transparent;
    color: rgba(24, 22, 20, 0.6);
    padding-left: 0;
    padding-right: 0;
    font-weight: 750;
  }

  .detail {
    margin-top: 22px;
    padding: 20px;
    border-radius: 14px;
    background: rgba(24, 22, 20, 0.03);
    border: 1px solid rgba(24, 22, 20, 0.06);
  }

  .detail-group + .detail-group {
    margin-top: 18px;
  }

  .detail-title {
    font-size: 12px;
    font-weight: 850;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(24, 22, 20, 0.42);
    margin-bottom: 10px;
  }

  .detail-item {
    padding: 16px 0;
    border-bottom: 1px solid rgba(24, 22, 20, 0.06);
    font-size: 14px;
  }

  .detail-item:last-child {
    border-bottom: 0;
  }

  .activity-listing {
    cursor: pointer;
  }

  .activity-listing:hover strong {
    text-decoration: underline;
  }

  .activity-signals {
    display: flex;
    flex-wrap: wrap;
    gap: 0;
    margin-top: 8px;
  }

  .activity-signal {
    padding: 0;
    border-radius: 0;
    background: transparent;
    color: rgba(24, 22, 20, 0.5);
    font-size: 12px;
    font-weight: 700;
    position: relative;
  }

  .activity-signal:not(:last-child)::after {
    content: "·";
    margin: 0 8px;
    color: rgba(24, 22, 20, 0.28);
  }

  .contact-note {
    margin-top: 8px;
    padding: 8px 10px;
    border-radius: 12px;
    background: rgba(24, 22, 20, 0.05);
    color: rgba(24, 22, 20, 0.72);
  }

  .modal {
    position: fixed;
    inset: 0;
    z-index: 50;
    display: grid;
    place-items: center;
    padding: 20px;
    background: rgba(0, 0, 0, 0.72);
  }

  .modal-card {
    width: min(760px, 100%);
    max-height: 88vh;
    overflow: auto;
    border-radius: 24px;
    background: #fffaf1;
    color: #181614;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.38);
  }

  .listing-modal-card {
    padding: 0;
    overflow: hidden;
  }

  .modal-hero-img,
  .modal-hero-placeholder {
    width: 100%;
    height: 360px;
    display: block;
    object-fit: cover;
    background: rgba(24, 22, 20, 0.08);
  }

  .modal-photo-wrap {
    position: relative;
  }

.modal {
  display: grid;
  place-items: center;
  overflow: hidden;
}

.modal-card {
  max-height: calc(100vh - 40px);
  overflow-y: auto;
  margin: 0;
}

.listing-modal-card {
  overflow-y: auto;
}

  .photo-nav {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  width: 42px;
  height: 42px;
  border: 0;
  border-radius: 999px;
  background: rgba(255, 250, 241, 0.9);
  color: #181614;
  font-size: 22px;
  font-weight: 900;
  cursor: pointer;

  display: grid;
  place-items: center;
  line-height: 1;
  padding: 0;
}

  .photo-prev {
    left: 14px;
  }

  .photo-next {
    right: 14px;
  }

  .photo-count {
    position: absolute;
    right: 14px;
    bottom: 14px;
    padding: 6px 10px;
    border-radius: 999px;
    background: rgba(24, 22, 20, 0.72);
    color: #fffaf1;
    font-size: 12px;
    font-weight: 900;
  }

  .modal-hero-placeholder {
    display: grid;
    place-items: center;
    font-weight: 900;
    color: rgba(24, 22, 20, 0.5);
  }

  .listing-modal-card .modal-close {
    position: sticky;
    top: 14px;
    float: right;
    margin: 14px;
    z-index: 2;
  }

  .listing-modal-card .detail-title,
  .listing-modal-card h2,
  .listing-modal-card .modal-price,
  .listing-modal-card .modal-facts,
  .listing-modal-card .modal-description {
    margin-left: 22px;
    margin-right: 22px;
  }

  .listing-modal-card h2 {
    margin-top: 8px;
    margin-bottom: 6px;
    font-size: 30px;
    letter-spacing: -0.04em;
  }

  .modal-price {
    font-size: 18px;
  }

  .modal-facts {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 14px;
  }

  .modal-facts span {
    padding: 7px 10px;
    border-radius: 999px;
    background: rgba(24, 22, 20, 0.08);
    font-size: 13px;
    font-weight: 900;
  }

  .modal-description {
    padding-bottom: 24px;
    line-height: 1.55;
    color: rgba(24, 22, 20, 0.76);
  }

  .modal-topbar {
  position: relative;
  top: auto;
    z-index: 5;
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 8px;
    padding: 10px 12px;
    background: rgba(255, 250, 241, 0.94);
    backdrop-filter: blur(10px);
  }

  .listing-modal-card .detail-title {
    margin-top: 24px;
  }

 body.modal-open {
  overflow: hidden;
  padding-right: var(--scrollbar-width, 0px);
}

  .buyer-priority-strip {
  display: grid;
  grid-template-columns: 2fr 0.8fr 1fr;
  gap: 10px;
  margin-top: 18px;
}

.priority-box {
  border-radius: 16px;
  padding: 14px;
  background: rgba(24, 22, 20, 0.045);
}

.priority-box.primary {
  background: #efe0c8;
}

.priority-box span {
  display: block;
  margin-bottom: 5px;
  font-size: 11px;
  font-weight: 900;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: rgba(24, 22, 20, 0.46);
}

.priority-box strong {
  display: block;
  font-size: 15px;
  line-height: 1.25;
  letter-spacing: -0.02em;
}

.reaction-mini-row {
  display: flex;
  gap: 14px;
  margin-top: 12px;
  font-size: 13px;
  font-weight: 850;
  color: rgba(24, 22, 20, 0.5);
}

@media (max-width: 700px) {
  .shell {
    width: min(100% - 18px, 100%);
    padding: 22px 0;
  }

  h1 {
    font-size: 28px;
    letter-spacing: -0.04em;
  }

  .lead {
    font-size: 13px;
    line-height: 1.45;
    margin-bottom: 14px;
  }

  .toolbar {
    flex-wrap: wrap;
  }

  .toolbar label,
  .toolbar select {
    width: 100%;
  }

  .grid {
    gap: 12px;
    margin-top: 18px;
  }

  .buyer-summary {
    padding: 16px;
  }

  .name {
    font-size: 18px;
  }

  .meta {
    font-size: 11px;
  }

  .mini-read {
    font-size: 12px;
  }

  .buyer-priority-strip {
    grid-template-columns: 1fr;
    gap: 8px;
    margin-top: 14px;
  }

  .priority-box {
    padding: 11px 12px;
    border-radius: 13px;
  }

  .priority-box span {
    font-size: 9px;
  }

  .priority-box strong {
    font-size: 12px;
  }

  .buyer-expanded {
    padding: 0 16px 16px;
  }

  .action {
    width: 100%;
    padding: 11px 13px;
  }
}

.admin-nav {
  display: flex;
  gap: 10px;
  margin: 0 0 22px;
  padding: 6px;
  width: fit-content;
  border: 1px solid rgba(24, 22, 20, 0.1);
  border-radius: 999px;
  background: rgba(255, 250, 241, 0.75);
}

.admin-nav a {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 9px 16px;
  border-radius: 999px;
  color: #5f574f;
  font-size: 0.88rem;
  font-weight: 750;
  text-decoration: none;
}

.admin-nav a.active {
  background: #181614;
  color: #fffaf1;
}
</style>
  </head>

  <body>
    <main class="shell">
      <h1>Buyer CRM</h1>
      <nav class="admin-nav">
  <a href="/admin/buyers" class={Astro.url.pathname.startsWith("/admin/buyers") ? "active" : ""}>
    Buyers
  </a>
  <a href="/shortlists" class={Astro.url.pathname.startsWith("/shortlists") ? "active" : ""}>
    Shortlists
  </a>
</nav>
      <p class="lead">
        One-page client radar. See who is active, what they are looking at, and who needs a follow-up.
      </p>

      <div class="toolbar">
        <label for="sortBuyers">Sort by</label>
        <select id="sortBuyers">
          <option value="attention">Needs attention</option>
          <option value="recent">Most recent activity</option>
          <option value="hot">Hottest buyers</option>
          <option value="loved">Most loved</option>
          <option value="maybe">Most maybes</option>
          <option value="shortlists">Most shortlists</option>
        </select>
      </div>

      <div id="grid" class="grid"></div>
      <div id="listingModal"></div>
      <div id="activityModal"></div>
    </main>

    <script>
      const grid = document.getElementById("grid");
      const sortBuyersEl = document.getElementById("sortBuyers");

  let buyers = [];
let currentSort = "attention";
let pendingMatchesByBuyer = {};

function setScrollbarWidth() {
  const scrollbarWidth = window.innerWidth - document.documentElement.clientWidth;
  document.documentElement.style.setProperty("--scrollbar-width", `${scrollbarWidth}px`);
}

setScrollbarWidth();
window.addEventListener("resize", setScrollbarWidth);

      function escapeHtml(value) {
        return String(value || "")
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;")
          .replaceAll("'", "&#039;");
      }

      

function getListingSignals(item, groupTitle = "") {
  const signals = [];
  const isPass = groupTitle.toLowerCase().includes("not for me");
  const prefix = isPass ? "Disliked" : "Liked";

  const description = String(item.description || "").toLowerCase();
  const type = String(item.property_type || item.type || "").toLowerCase();
  const price = Number(item.price || 0);
  const sqft = Number(item.sqft || 0);

  if (description.includes("updated") || description.includes("renovated") || description.includes("modern")) {
    signals.push(`${prefix} updated feel`);
  }

  if (description.includes("bright") || description.includes("natural light") || description.includes("open concept")) {
    signals.push(`${prefix} bright/open layout`);
  }

  if (description.includes("view") || description.includes("mountain") || description.includes("ocean")) {
    signals.push(`${prefix} the view`);
  }

  if (description.includes("patio") || description.includes("deck") || description.includes("yard") || description.includes("balcony")) {
    signals.push(`${prefix} outdoor space`);
  }

  if (description.includes("garage") || description.includes("parking")) {
    signals.push(`${prefix} parking`);
  }

  if (sqft >= 900 && type.includes("condo")) {
    signals.push(`${prefix} larger condo layout`);
  } else if (sqft >= 1600) {
    signals.push(`${prefix} more space`);
  }

  if (price > 0 && price < 450000) {
    signals.push(`${prefix} lower price point`);
  }

  return signals.slice(0, 4);
}

      function dateMs(d) {
        return d ? new Date(d).getTime() : 0;
      }

      function hoursSince(d) {
        if (!d) return Infinity;
        return Math.max(0, (Date.now() - dateMs(d)) / 36e5);
      }

      function formatAge(d) {
        if (!d) return "Never";
        const h = hoursSince(d);

        if (h < 1) return "Less than 1 hour ago";
        if (h < 24) return `${Math.floor(h)} hour${Math.floor(h) === 1 ? "" : "s"} ago`;

        const days = Math.floor(h / 24);
        return `${days} day${days === 1 ? "" : "s"} ago`;
      }

      function hasActivity(b) {
        return (
          b.stats.lastActivityAt ||
          b.stats.lastViewed ||
          (b.stats.loved || 0) > 0 ||
          (b.stats.maybe || 0) > 0 ||
          (b.stats.notForMe || 0) > 0
        );
      }

      function lastContactAt(b) {
        return b.stats.lastContactedAt || b.last_contacted_at || b.lastContactedAt || null;
      }

      function buyerStatus(b) {
        if ((b.stats.loved || 0) >= 1 || (b.stats.maybe || 0) >= 3) return "🔥 Hot buyer";
        if (hasActivity(b)) return "👀 Active";
        return "💤 Not viewed yet";
      }

      function buyerStatusClass(b) {
        if ((b.stats.loved || 0) >= 1 || (b.stats.maybe || 0) >= 3) return "hot-pill";
        if (hasActivity(b)) return "viewed";
        return "cold";
      }

      function momentum(b) {
        const sinceActivity = hoursSince(b.stats.lastActivityAt || b.stats.lastViewed);
        const loved = b.stats.loved || 0;
        const maybe = b.stats.maybe || 0;

        if (sinceActivity <= 24 && (loved > 0 || maybe > 0)) {
          return { text: "↑ Heating up", className: "momentum-up" };
        }

        if (sinceActivity <= 72) {
          return { text: "→ Active", className: "momentum-flat" };
        }

        if (hasActivity(b)) {
          return { text: "↓ Cooling off", className: "momentum-down" };
        }

        return { text: "No activity yet", className: "cold" };
      }

      function lookingForSummary(b) {
        const loved = b.stats.loved || 0;
        const maybe = b.stats.maybe || 0;
        const pass = b.stats.notForMe || 0;

        if (loved > 0 && maybe > 0) {
          return `Looking for: strong match signals - ${loved} loved, ${maybe} maybe. Ask what stood out.`;
        }

        if (loved > 0) {
          return `Looking for: homes similar to the ${loved} they loved. Focus on showings.`;
        }

        if (maybe > 0) {
          return `Looking for: close-but-not-perfect options. Help narrow the maybes.`;
        }

        if (pass > 0) {
          return `Looking for: better fit needed - current shortlist is missing the mark.`;
        }

        return "Looking for: not enough signal yet. Send a fresh shortlist or ask what matters most.";
      }

      function buyerRead(b) {
        const loved = b.stats.loved || 0;
        const maybe = b.stats.maybe || 0;
        const pass = b.stats.notForMe || 0;

        if (loved > 0 && maybe > 0) {
          return `Signal: liked ${loved}, considering ${maybe}. Worth a personal follow-up.`;
        }

        if (loved > 0) {
          return `Signal: ${loved} loved property${loved === 1 ? "" : "ies"}. Ask about showings.`;
        }

        if (maybe > 0) {
          return `Signal: ${maybe} maybe property${maybe === 1 ? "" : "ies"}. Help narrow the list.`;
        }

        if (pass > 0) {
          return `Signal: mostly passing. Send better matches.`;
        }

        return "Signal: no clear preference yet.";
      }

      function followUpPrompt(b) {
        const activityAt = b.stats.lastActivityAt || b.stats.lastViewed;
        const contactAt = lastContactAt(b);

        const sinceActivity = hoursSince(activityAt);
        const sinceContact = hoursSince(contactAt);

        if (sinceContact > 24 && sinceActivity <= 24) {
          return {
            text: "🔥 Next best action: text them while they are active.",
            className: "hot",
            score: 100,
            sms: "I saw you had a look at the shortlist. Any of those homes worth talking about?"
          };
        }

        if (sinceContact > 24 && (b.stats.loved || 0) > 0) {
          return {
            text: "❤️ Next best action: ask if they want to see the property they liked.",
            className: "hot",
            score: 90,
            sms: "I saw you liked one of the homes. Want me to look into it or set up a showing?"
          };
        }

        if (sinceContact > 24 && (b.stats.maybe || 0) > 0) {
          return {
            text: "🤔 Next best action: help them sort through the maybes.",
            className: "nudge",
            score: 75,
            sms: "I saw a couple maybes in your shortlist. Want me to help narrow down which ones are actually worth seeing?"
          };
        }

        if (sinceContact > 48 && hasActivity(b)) {
          return {
            text: "👋 Next best action: reconnect before they go fully cold.",
            className: "nudge",
            score: 60,
            sms: "Just checking in. Want me to send a few better matches based on what you liked and passed on?"
          };
        }

        if (!hasActivity(b)) {
          return {
            text: "💤 No activity yet - maybe send a fresher shortlist later.",
            className: "quiet",
            score: 10,
            sms: "I can send over a few fresh options if you want to keep an eye on the market."
          };
        }

        return {
          text: "✅ You are in sync - no urgent follow-up needed.",
          className: "good",
          score: 30,
          sms: "Just checking in - anything you want me to dig into from the shortlist?"
        };
      }

      function missedOpportunity(b) {
        return (b.stats.loved || 0) > 0 && hoursSince(lastContactAt(b)) > 24;
      }

      function hotScore(b) {
        return (
          (b.stats.loved || 0) * 3 +
          (b.stats.maybe || 0) * 2 +
          (b.stats.shortlists || 0) +
          (b.stats.lastActivityAt ? 5 : 0)
        );
      }

      function sortBuyers(list) {
        return [...list].sort((a, b) => {
          if (currentSort === "attention") return followUpPrompt(b).score - followUpPrompt(a).score;
          if (currentSort === "recent") return dateMs(b.stats.lastActivityAt) - dateMs(a.stats.lastActivityAt);
          if (currentSort === "hot") return hotScore(b) - hotScore(a);
          if (currentSort === "loved") return (b.stats.loved || 0) - (a.stats.loved || 0);
          if (currentSort === "maybe") return (b.stats.maybe || 0) - (a.stats.maybe || 0);
          if (currentSort === "shortlists") return (b.stats.shortlists || 0) - (a.stats.shortlists || 0);
          return 0;
        });
      }

      function renderBuyers() {
  grid.innerHTML = sortBuyers(buyers).map((b) => {
    const prompt = followUpPrompt(b);
    const move = momentum(b);
