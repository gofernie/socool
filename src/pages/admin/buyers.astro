      document.addEventListener("click", (event) => {
        const close = event.target.closest(".modal-close");
        if (!close) return;

        document.getElementById("listingModal").innerHTML = "";
      });
let activityItems = [];
let activityIndex = 0;

function openActivityModal(index) {
  activityIndex = index;
  const item = activityItems[activityIndex];
  const modal = document.getElementById("activityModal");

  modal.innerHTML = `
    <div class="modal">
      <div class="modal-card listing-modal-card">
      <div class="modal-topbar">
  <span class="pill cold">${activityIndex + 1} of ${activityItems.length}</span>

  <button class="action secondary activity-prev" type="button">← Prev</button>
  <button class="action secondary activity-next" type="button">Next →</button>
  <button class="action secondary activity-close" type="button">Close</button>
</div>

        ${
          item.image
            ? `<img class="modal-hero-img" src="${escapeHtml(item.image)}" alt="${escapeHtml(item.address)}" />`
            : `<div class="modal-hero-placeholder">No image available</div>`
        }

        <div class="detail-title">${escapeHtml(item.decision)}</div>
        <h2>${escapeHtml(item.address)}</h2>
        <p class="modal-price"><strong>${escapeHtml(item.price)}</strong></p>

        <div class="modal-facts">
          ${item.beds ? `<span>${escapeHtml(item.beds)} Bed</span>` : ""}
          ${item.baths ? `<span>${escapeHtml(item.baths)} Bath</span>` : ""}
          ${item.sqft ? `<span>${Number(item.sqft).toLocaleString()} Sq. Ft.</span>` : ""}
          ${item.type ? `<span>${escapeHtml(item.type)}</span>` : ""}
        </div>

        <p class="modal-description">
          ${escapeHtml(item.description || "No description saved for this listing yet.")}
        </p>

       
      </div>
    </div>
  `;
}

grid.addEventListener("click", (event) => {
  const item = event.target.closest(".activity-listing");
  if (!item) return;

  event.stopPropagation();

  activityItems = [...document.querySelectorAll(".activity-listing")].map((el) => ({
    address: el.dataset.address || "Unknown listing",
    price: el.dataset.price || "Price unavailable",
    decision: el.dataset.decision || "Listing activity",
    image: el.dataset.image || "",
    beds: el.dataset.beds || "",
    baths: el.dataset.baths || "",
    type: el.dataset.type || "",
    sqft: el.dataset.sqft || "",
    description: el.dataset.description || ""
  }));

  activityIndex = activityItems.findIndex((x) => x.address === item.dataset.address);
  openActivityModal(Math.max(0, activityIndex));
});

document.addEventListener("click", (event) => {
  if (event.target.closest(".activity-close")) {
    document.getElementById("activityModal").innerHTML = "";
    return;
  }

  if (event.target.closest(".activity-prev")) {
    activityIndex = (activityIndex - 1 + activityItems.length) % activityItems.length;
    openActivityModal(activityIndex);
    return;
  }

  if (event.target.closest(".activity-next")) {
    activityIndex = (activityIndex + 1) % activityItems.length;
    openActivityModal(activityIndex);
  }
});
