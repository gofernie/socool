}

      async function load() {
        grid.innerHTML = `<div class="meta">Loading buyers...</div>`;

        const res = await fetch("/api/buyers");
        const json = await res.json();

        if (!json.ok) {
          grid.innerHTML = "Error loading buyers";
          return;
        }

        buyers = json.buyers || [];
        renderBuyers();
      }

      sortBuyersEl?.addEventListener("change", (event) => {
        currentSort = event.target.value;
        renderBuyers();
      });

grid.addEventListener("click", (event) => {
  if (event.target.closest("a, button.action, .better-matches, .view-activity")) return;

  const card = event.target.closest(".buyer-card");
  if (!card) return;

  const wasOpen = card.classList.contains("is-open");

  document.querySelectorAll(".buyer-card.is-open").forEach((openCard) => {
    openCard.classList.remove("is-open");

    const icon = openCard.querySelector(".expand-icon");
    if (icon) icon.textContent = "+";
  });

  if (!wasOpen) {
    card.classList.add("is-open");

    const icon = card.querySelector(".expand-icon");
    if (icon) icon.textContent = "−";
  }
});

      grid.addEventListener("click", async (event) => {
        const btn = event.target.closest(".better-matches");
        if (!btn) return;

        event.stopPropagation();

        const card = btn.closest(".buyer-card");
        const name = btn.dataset.name;
        const phone = btn.dataset.phone;

        if (!phone) {
          btn.textContent = "No phone saved";
          return;
        }

        btn.textContent = "Finding matches...";

        const res = await fetch("/api/buyers/better-matches", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ name })
        });

        const json = await res.json();

        if (!json.ok) {
          console.error("Better matches failed:", json.error);
          btn.textContent = json.error || "Could not load";
          return;
        }

        const listings = json.listings || [];
        pendingMatchesByBuyer[name] = listings;

        if (!listings.length) {
          btn.textContent = "No matches found";
          return;
        }

        const lines = listings.map((listing, index) => {
          const address = listing.address || listing.full_address || "Listing";
          const price = listing.price_text || (listing.price ? `$${Number(listing.price).toLocaleString()}` : "Price unavailable");
          return `${index + 1}. ${address} - ${price}`;
        });

        const message = `Hi ${name}, I found a few homes closer to what you’ve been reacting to:\n\n${lines.join("\n")}\n\nWant me to line up a showing or dig into any of these?`;

       const existing = card.querySelector(".match-preview");
if (existing) existing.remove();

const listingsHtml = listings.map((listing, index) => {
  const reasons = Array.isArray(listing.reasons) ? listing.reasons : [];

  const price =
    listing.priceText ||
    listing.price_text ||
    (listing.price ? `$${Number(listing.price).toLocaleString()}` : "Price unavailable");

  const reasonHtml = reasons.length
    ? reasons.map((reason) =>
        `<span class="activity-signal">${escapeHtml(reason)}</span>`
      ).join("")
    : `
      <span class="activity-signal">Similar buyer fit</span>
      <span class="activity-signal">Close to liked homes</span>
    `;

  return `
    <div
  class="detail-item activity-listing"
  data-address="${escapeHtml(listing.address || listing.full_address || "Listing")}"
  data-price="${escapeHtml(price)}"
  data-decision="Suggested match"
  data-image="${escapeHtml(listing.image || listing.image_url || "")}"
  data-images="${escapeHtml(Array.isArray(listing.images) ? listing.images.join("|") : "")}"
  data-beds="${escapeHtml(listing.beds || "")}"
  data-baths="${escapeHtml(listing.baths || "")}"
  data-type="${escapeHtml(listing.type || listing.property_type || "")}"
  data-sqft="${escapeHtml(listing.sqft || "")}"
  data-description="${escapeHtml(listing.description || "")}"
>
      <strong>${index + 1}. ${escapeHtml(listing.address || listing.full_address || "Listing")}</strong>
      <div>${price}</div>
      <div class="activity-signals">${reasonHtml}</div>
    </div>
  `;
}).join("");

const preview = document.createElement("div");
preview.className = "detail match-preview";
preview.innerHTML = `
  <div class="detail-title">Suggested matches to send</div>

  ${listingsHtml}

  <div class="actions">
    <button class="action send-matches" type="button"
      data-name="${escapeHtml(name)}"
