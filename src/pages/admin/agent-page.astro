---
import AdminSidebar from "../../components/AdminSidebar.astro";
import { getSite } from "../../lib/getSite";

const site = await getSite(Astro.url.hostname);
const currentSiteId = site?.id || "";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Agent Editor</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <style is:global>
      @media (min-width: 769px) { .mobile-topbar, .drawer-overlay { display: none !important; } }
      @media (max-width: 768px) { .mobile-topbar { display: flex !important; width: 100% !important; } }
    </style>
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; }

      :root {
        --bg: #f7f4ef;
        --surface: #fff;
        --border: rgba(24,22,20,0.10);
        --border-strong: rgba(24,22,20,0.22);
        --ink: #181614;
        --muted: rgba(24,22,20,0.52);
        --accent: #181614;
        --accent-hover: #333;
        --radius: 16px;
        --font-body: "DM Sans", system-ui, sans-serif;
        --font-display: "Instrument Serif", Georgia, serif;
      }

      body {
        font-family: var(--font-body);
        background: var(--bg);
        color: var(--ink);
        font-size: 15px;
        line-height: 1.5;
      }

.page {
  display: grid;
  grid-template-columns: 220px 1fr;
  min-height: 100vh;
}

           /* ── Main ── */
.main {
  padding: 40px 48px 80px;
  max-width: 860px;
  min-width: 0;
}

      .page-header {
        margin-bottom: 36px;
      }

      .page-header h1 {
        font-family: var(--font-display);
        font-size: 2.6rem;
        font-weight: 400;
        line-height: 1;
        letter-spacing: -0.03em;
      }

      .page-header p {
        color: var(--muted);
        margin-top: 6px;
        font-size: 0.9rem;
      }

      /* ── Accordion sections ── */
      .section {
        border: 1px solid var(--border);
        border-radius: var(--radius);
        background: var(--surface);
        margin-bottom: 10px;
        overflow: hidden;
      }

      .section__trigger {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 18px 22px;
        background: none;
        border: none;
        cursor: pointer;
        font: inherit;
        text-align: left;
        gap: 16px;
      }

      .section__trigger:hover { background: rgba(24,22,20,0.02); }

      .section__trigger-left {
        display: flex;
        align-items: center;
        gap: 12px;
      }

      .section__icon {
        width: 34px;
        height: 34px;
        border-radius: 10px;
        background: var(--bg);
        border: 1px solid var(--border);
        display: grid;
        place-items: center;
        font-size: 1rem;
        flex-shrink: 0;
      }

      .section__title {
        font-size: 0.92rem;
        font-weight: 700;
        color: var(--ink);
      }

      .section__subtitle {
        font-size: 0.76rem;
        color: var(--muted);
        margin-top: 1px;
      }

      .section__chevron {
        width: 20px;
        height: 20px;
        color: var(--muted);
        transition: transform 0.22s ease;
        flex-shrink: 0;
      }

      .section.is-open .section__chevron {
        transform: rotate(180deg);
      }

      .section__body {
        display: none;
        padding: 0 22px 22px;
        border-top: 1px solid var(--border);
      }

      .section.is-open .section__body { display: block; }

      /* ── Form fields ── */
      .field { margin-top: 16px; }

      .field label {
        display: block;
        font-size: 0.76rem;
        font-weight: 700;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 6px;
      }

      .field input,
      .field textarea,
      .field select {
        width: 100%;
        padding: 10px 13px;
        border: 1px solid var(--border-strong);
        border-radius: 10px;
        font: inherit;
        font-size: 0.9rem;
        background: #fff;
        color: var(--ink);
        transition: border-color 0.14s, box-shadow 0.14s;
      }

      .field input:focus,
      .field textarea:focus,
      .field select:focus {
        outline: none;
        border-color: var(--ink);
        box-shadow: 0 0 0 3px rgba(24,22,20,0.08);
      }

      .field textarea { min-height: 80px; resize: vertical; }

      .field select {
        appearance: none;
        background-image: url("data:image/svg+xml,%3Csvg width='10' height='6' viewBox='0 0 10 6' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1l4 4 4-4' stroke='%23181614' stroke-width='1.5' fill='none' stroke-linecap='round'/%3E%3C/svg%3E");
        background-repeat: no-repeat;
        background-position: right 13px center;
        padding-right: 36px;
      }

      .hint {
        font-size: 0.78rem;
        color: var(--muted);
        margin-top: 5px;
        line-height: 1.4;
      }

      .grid-2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
      }

      /* ── Template picker ── */
      .template-options {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
        margin-top: 16px;
      }

      .template-option { position: relative; cursor: pointer; }

      .template-option input[type="radio"] {
        position: absolute;
        opacity: 0;
        width: 0;
        height: 0;
      }

      .template-option__card {
        border: 2px solid var(--border);
        border-radius: 12px;
        overflow: hidden;
        transition: border-color 0.18s, box-shadow 0.18s;
      }

      .template-option input:checked + .template-option__card {
        border-color: var(--ink);
        box-shadow: 0 0 0 3px rgba(24,22,20,0.1);
      }

      .template-option__preview {
        height: 80px;
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        padding: 10px;
        position: relative;
        overflow: hidden;
      }

      .template-option--brutal .template-option__preview { background: #0a0a0a; }
      .template-option--calm .template-option__preview { background: #f5f2ed; }

      .template-option__preview-accent {
        height: 3px;
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
      }

      .template-option--brutal .template-option__preview-accent { background: #ff4d00; }
      .template-option--calm .template-option__preview-accent { background: #8b6f47; }

      .template-option__preview-title {
        font-weight: 800;
        font-size: 0.82rem;
      }

      .template-option--brutal .template-option__preview-title { color: white; }
      .template-option--calm .template-option__preview-title { color: #1c1917; font-family: Georgia, serif; font-style: italic; font-weight: 400; }

      .template-option__label {
        padding: 9px 12px;
        background: white;
        border-top: 1px solid var(--border);
      }

      .template-option__label strong { display: block; font-size: 0.8rem; font-weight: 700; }
      .template-option__label span { font-size: 0.72rem; color: var(--muted); }
      .template-option input:checked + .template-option__card .template-option__label { background: #f7f4ef; }

      /* ── Colour picker ── */
      .colour-presets {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 16px;
        margin-bottom: 14px;
      }

    .preset-swatch {
        width: 44px;
        height: 44px;
        border-radius: 999px;
        border: 2px solid transparent;
        cursor: pointer;
        position: relative;
        transition: transform 0.14s, box-shadow 0.14s, border-color 0.14s;
      }

      .preset-swatch:hover { transform: scale(1.12); box-shadow: 0 4px 14px rgba(0,0,0,0.18); }

      .preset-swatch.is-selected {
        border-color: var(--ink);
        box-shadow: 0 0 0 3px rgba(24,22,20,0.12);
        transform: scale(1.08);
      }

      .preset-swatch.is-selected::after {
        content: "✓";
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 0.9rem;
        font-weight: 900;
        text-shadow: 0 1px 3px rgba(0,0,0,0.5);
      }

      .colour-picker-row {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 14px;
      }

      .colour-picker-wrap {
        display: flex;
        align-items: center;
        gap: 8px;
      }

      .colour-picker-wrap input[type="color"] {
        width: 40px;
        height: 40px;
        padding: 2px;
        border-radius: 10px;
        border: 1px solid var(--border-strong);
        cursor: pointer;
        background: none;
      }

      .colour-picker-wrap label {
        font-size: 0.82rem;
        font-weight: 600;
        color: var(--muted);
      }

      #accentColorHex {
        width: 110px !important;
        font-family: monospace;
        font-size: 0.88rem;
      }

      .colour-preview-strip {
        display: flex;
        gap: 6px;
        margin-bottom: 8px;
      }

      .swatch-preview {
        flex: 1;
        height: 32px;
        border-radius: 7px;
        border: 1px solid rgba(24,22,20,0.07);
        transition: background 0.22s;
      }

   .saved-section {
        margin-top: 10px;
        padding-top: 10px;
        border-top: 1px dashed var(--border);
        display: none;
      }
      .saved-section.has-customs { display: block; }
      .saved-section__label {
        font-size: 0.72rem;
        font-weight: 700;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-bottom: 8px;
      }
   .preset-swatch.is-custom .remove-btn {
        position: absolute;
        top: -5px; right: -5px;
        width: 16px; height: 16px;
        border-radius: 999px;
        background: #fff;
        border: 1px solid rgba(0,0,0,0.2);
        font-size: 9px; font-weight: 900;
        color: #555; cursor: pointer;
        z-index: 2;
        display: none;
        align-items: center; justify-content: center;
        pointer-events: auto;
      }
      .preset-swatch.is-custom:hover .remove-btn { display: flex; }

      .colour-label {
        font-size: 0.74rem;
        font-weight: 700;
        color: var(--muted);
        margin-top: 5px;
        line-height: 1.4;
      }

      /* ── Group editors ── */
      .group-editor {
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 16px;
        margin-top: 12px;
      }

      .group-editor__header {
        font-size: 0.78rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--muted);
        margin-bottom: 12px;
      }

      /* ── Intent pages ── */
      .intent-pages-grid { display: grid; gap: 8px; margin-top: 14px; }

      .intent-page-card {
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 12px;
        align-items: start;
        padding: 12px;
        border-radius: 10px;
        border: 1px solid var(--border);
        background: var(--bg);
        cursor: pointer;
        transition: border-color 0.14s;
      }

      .intent-page-card:hover { border-color: var(--border-strong); }

      .intent-page-card input[type="checkbox"] {
        width: 16px;
        height: 16px;
        margin-top: 3px;
        accent-color: var(--ink);
      }

      .intent-page-meta strong { display: block; font-size: 0.88rem; margin-bottom: 3px; }
      .intent-page-meta p { color: var(--muted); font-size: 0.8rem; line-height: 1.4; margin: 0; }

      .intent-page-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 5px;
        margin-top: 7px;
      }

      .intent-page-tags span {
        display: inline-flex;
        align-items: center;
        min-height: 20px;
        padding: 0 7px;
        border-radius: 999px;
        background: rgba(24,22,20,0.07);
        color: var(--muted);
        font-size: 0.68rem;
        font-weight: 700;
      }

      /* ── Footer actions ── */
      .form-footer {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-top: 28px;
        padding-top: 22px;
        border-top: 1px solid var(--border);
      }

      .btn {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 11px 20px;
        border-radius: 999px;
        border: 1px solid transparent;
        font: inherit;
        font-size: 0.86rem;
        font-weight: 700;
        cursor: pointer;
        text-decoration: none;
        transition: background 0.14s, color 0.14s, border-color 0.14s;
      }

      .btn--primary {
        background: var(--ink);
        color: #fff;
        border-color: var(--ink);
      }

      .btn--primary:hover { background: #333; border-color: #333; }

      .btn--ghost {
        background: transparent;
        color: var(--ink);
        border-color: var(--border-strong);
      }

      .btn--ghost:hover { background: rgba(24,22,20,0.05); }

      .status {
        font-size: 0.82rem;
        font-weight: 600;
        color: #2d7a2d;
        margin-left: auto;
      }

      .status.is-error { color: #b33; }

 @media (max-width: 860px) {
  .page {
    display: block !important;
    grid-template-columns: none !important;
  }

.page > aside,
  .page > .drawer-overlay {
    display: none !important;
  }

  .main {
    width: 100% !important;
    max-width: none !important;
    padding: 16px !important;
  }

  .grid-2,
  .template-options {
    grid-template-columns: 1fr !important;
  }

  .colour-presets,
  #customSwatches {
    display: grid !important;
    grid-template-columns: repeat(4, 44px);
    gap: 10px;
  }

  .colour-picker-row {
    display: flex !important;
    flex-direction: column;
    align-items: stretch;
    gap: 10px;
  }

  #accentColorHex,
  #saveCustomBtn {
    width: 100% !important;
  }
}
    </style>
  </head>

<body>
    <AdminSidebar active="sites">
  <nav class="sidebar__section-links">
    <a href="#s-agent">Agent</a>
    <a href="#s-colour">Colour</a>
    <a href="#s-template">Template</a>
    <a href="#s-intent">Intent pages</a>
    <a href="#s-hero">Hero</a>
    <a href="#s-social">Social</a>
    <a href="#s-sections">Listing sections</a>
    <a href="#s-live">Live listings</a>
    <a href="#s-city">City</a>
    <a href="#s-bio">Bio</a>
  </nav>
</AdminSidebar>
    <div class="page">
      <!-- Main -->
      <main class="main" data-site-id={currentSiteId}>
        <div class="page-header">
      <h1>Site settings</h1>
<p>Configure colours, homepage copy, hero content, and branding for this site.</p>
        </div>

        <form id="agentForm">

          <!-- Agent -->
          <div class="section is-open" id="s-agent">
            <button type="button" class="section__trigger" data-toggle>
              <div class="section__trigger-left">
                <div class="section__icon">ID</div>
                <div>
                  <div class="section__title">Agent</div>
                  <div class="section__subtitle">Name, contact, city</div>
                </div>
              </div>
              <svg class="section__chevron" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M5 7.5l5 5 5-5"/></svg>
            </button>
            <div class="section__body">
              <div class="grid-2">
                <div class="field"><label>Agent name</label><input name="agentName" /></div>
                <div class="field"><label>Title</label><input name="agentTitle" /></div>
              </div>
              <div class="grid-2">
                <div class="field"><label>Phone</label><input name="phone" /></div>
                <div class="field"><label>Email</label><input name="email" /></div>
              </div>
              <div class="field"><label>City</label><input name="city" /></div>
            </div>
          </div>

          <!-- Colour -->
          <div class="section" id="s-colour">
            <button type="button" class="section__trigger" data-toggle>
              <div class="section__trigger-left">
             <div class="section__icon">CLR</div>
                <div>
                  <div class="section__title">Site colour</div>
                  <div class="section__subtitle">Accent colour and full palette</div>
                </div>
              </div>
              <svg class="section__chevron" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M5 7.5l5 5 5-5"/></svg>
            </button>
            <div class="section__body">
              <div class="colour-presets">
                <button type="button" class="preset-swatch" data-colour="#2f6f73" title="Teal" style="background:#2f6f73;"></button>
                <button type="button" class="preset-swatch" data-colour="#2d5016" title="Forest" style="background:#2d5016;"></button>
                <button type="button" class="preset-swatch" data-colour="#7c3a2d" title="Terracotta" style="background:#7c3a2d;"></button>
                <button type="button" class="preset-swatch" data-colour="#1a3a5c" title="Navy" style="background:#1a3a5c;"></button>
                <button type="button" class="preset-swatch" data-colour="#5c3d8f" title="Plum" style="background:#5c3d8f;"></button>
                <button type="button" class="preset-swatch" data-colour="#8f5c1a" title="Amber" style="background:#8f5c1a;"></button>
                <button type="button" class="preset-swatch" data-colour="#1a5c4a" title="Emerald" style="background:#1a5c4a;"></button>
                <button type="button" class="preset-swatch" data-colour="#181614" title="Charcoal" style="background:#181614;"></button>
              </div>
<div class="saved-section" id="savedSection">
                <div class="saved-section__label">Saved customs</div>
                <div class="colour-presets" id="customSwatches"></div>
              </div>

              <div class="colour-picker-row">                <div class="colour-picker-wrap">
                  <input type="color" id="accentColorPicker" name="accentColor" value="#2f6f73" />
                  <label for="accentColorPicker">Custom</label>
                </div>
              <input type="text" id="accentColorHex" class="field" placeholder="#2f6f73" maxlength="7" />
                <button type="button" class="btn btn--ghost" id="saveCustomBtn" style="white-space:nowrap; padding: 9px 16px; border-radius: 999px; font-size: 0.82rem;">Save colour</button>
              </div>
              <div class="colour-preview-strip">
                <div class="swatch-preview" id="swatchAccent"></div>
                <div class="swatch-preview" id="swatchAccentLight"></div>
                <div class="swatch-preview" id="swatchAccentSoft"></div>
                <div class="swatch-preview" id="swatchBg"></div>
                <div class="swatch-preview" id="swatchCard"></div>
                <div class="swatch-preview" id="swatchSection"></div>
              </div>
              <p class="colour-label" id="colourLabel">Teal</p>
            </div>
          </div>

          <!-- Template -->
          <div class="section" id="s-template">
            <button type="button" class="section__trigger" data-toggle>
              <div class="section__trigger-left">
              <div class="section__icon">TPL</div>
                <div>
                  <div class="section__title">Page template</div>
                  <div class="section__subtitle">Visual style</div>
                </div>
              </div>
              <svg class="section__chevron" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M5 7.5l5 5 5-5"/></svg>
            </button>
            <div class="section__body">
              <div class="template-options">
                <label class="template-option template-option--brutal">
                  <input type="radio" name="template" value="brutal" />
                  <div class="template-option__card">
                    <div class="template-option__preview">
                      <div class="template-option__preview-accent"></div>
                      <div class="template-option__preview-title" style="color:white;">Nanaimo <span style="color:#ff4d00;">homes.</span></div>
                    </div>
                    <div class="template-option__label">
                      <strong>Brutalist</strong>
                      <span>Bold, high contrast</span>
                    </div>
                  </div>
                </label>
                <label class="template-option template-option--calm">
                  <input type="radio" name="template" value="calm" />
                  <div class="template-option__card">
                    <div class="template-option__preview">
                      <div class="template-option__preview-accent"></div>
                      <div class="template-option__preview-title">Nanaimo <span style="color:#8b6f47;">homes.</span></div>
                    </div>
                    <div class="template-option__label">
                      <strong>Calm</strong>
                      <span>Warm, approachable</span>
                    </div>
                  </div>
                </label>
              </div>
            </div>
          </div>

          <!-- Intent pages -->
          <div class="section" id="s-intent">
            <button type="button" class="section__trigger" data-toggle>
              <div class="section__trigger-left">
              <div class="section__icon">INT</div>
                <div>
                  <div class="section__title">Intent pages</div>
                  <div class="section__subtitle">Buyer pages on homepage</div>
                </div>
              </div>
              <svg class="section__chevron" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M5 7.5l5 5 5-5"/></svg>
            </button>
            <div class="section__body">
              <a class="btn btn--ghost" href="/admin/intent-pages/new" style="margin-top:4px; margin-bottom:4px;">+ New intent page</a>
              <div id="intentPagesGrid" class="intent-pages-grid">
                <p class="hint">Loading...</p>
              </div>
            </div>
          </div>

          <!-- Hero -->
          <div class="section" id="s-hero">
            <button type="button" class="section__trigger" data-toggle>
              <div class="section__trigger-left">
              <div class="section__icon">HRO</div>
                <div>
                  <div class="section__title">Hero</div>
                  <div class="section__subtitle">Heading, intro, featured listing</div>
                </div>
              </div>
              <svg class="section__chevron" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M5 7.5l5 5 5-5"/></svg>
            </button>
            <div class="section__body">
              <div class="field"><label>Eyebrow</label><input name="heroEyebrow" /></div>
              <div class="field"><label>Hero heading (use | for line break)</label><input name="heroHeading" /></div>
              <div class="field"><label>Section heading (below hero, single line)</label><input name="seoHeading" /></div>
              <div class="field"><label>Intro</label><textarea name="heroIntro"></textarea></div>
              <div class="grid-2">
                <div class="field"><label>Agent pick title</label><input name="agentPickTitle" /></div>
                <div class="field"><label>Featured MLS #</label><input name="featuredListingMls" inputmode="numeric" placeholder="e.g. 1032478" /></div>
              </div>
              <div class="field"><label>Agent pick text</label><textarea name="agentPickText"></textarea></div>
            </div>
          </div>

          <!-- Social -->
          <div class="section" id="s-social">
