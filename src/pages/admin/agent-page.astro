          <!-- Footer -->
          <div class="form-footer">
            <button type="submit" class="btn btn--primary">Save page</button>
<a class="btn btn--ghost" id="previewLink" href="/agent-listings" target="_blank">Preview &nearr;</a>            <span class="status" id="status"></span>
          </div>

        </form>
      </main>
    </div>

    <script is:inline>
    const params = new URLSearchParams(window.location.search);
const siteId =
  params.get("id") ||
  document.querySelector(".main")?.dataset.siteId ||
  "";
      const form = document.getElementById("agentForm");
      const status = document.getElementById("status");

      // ── Accordion ──────────────────────────────────────────
      document.querySelectorAll("[data-toggle]").forEach((btn) => {
        btn.addEventListener("click", () => {
          const section = btn.closest(".section");
          section.classList.toggle("is-open");
        });
      });

      // ── State ──────────────────────────────────────────────
      let intentPages = [];
      let filterOptions = { cities: [], areasByCity: {}, types: [] };

      const defaults = {
        agentName: "Chris Crump", agentTitle: "Real Estate Advisor",
        phone: "250.619.0390", email: "chris@example.com", city: "",
        template: "brutal", accentColor: "#2f6f73",
        heroEyebrow: "Curated by Chris Crump", heroHeading: "Homes worth watching.",
        seoHeading: "",
        heroIntro: "A simple, curated place to explore homes - organized by property type, price point, and what buyers are watching right now.",
        agentPickTitle: "Not a giant listing portal.", agentPickText: "Just the homes and categories buyers actually ask about most.",
        featuredListingMls: "", linkedinUrl: "", twitterUrl: "", instagramUrl: "", facebookUrl: "",
        socialTitle: "Follow along.", socialIntro: "Market notes, listing updates, and local real estate context from your agent.",
        socialFeedType: "", socialFeedUrl: "", socialFeedEmbed: "",
        cityIntro: "", cityNotes: "",
        agentBio: "A local real estate advisor helping buyers make sense of the market with clear, curated listing guidance.",
        newListingsTitle: "New listings.", newListingsIntro: "The latest homes to hit the market.",
        newListingsCity: "", newListingsArea: "", newListingsType: "",
        newListingsMinPrice: "", newListingsMaxPrice: "", newListingsSort: "newest", newListingsLimit: "6",
        enabledIntentPageSlugs: [],
        groups: [
          { title: "Condos", kicker: "Low-maintenance living", text: "Explore condo options from the latest listing data.", city: "", area: "", type: "condo", minPrice: "", maxPrice: "", sort: "newest" },
          { title: "Single-family homes", kicker: "Room to grow", text: "Detached homes from the latest listing data.", city: "", area: "", type: "house", minPrice: "", maxPrice: "", sort: "newest" },
          { title: "Popular under $800k", kicker: "Buyer sweet spot", text: "Homes in one of the most watched price ranges.", city: "", area: "", type: "", minPrice: "", maxPrice: "800", sort: "newest" },
          { title: "New listings", kicker: "Fresh to market", text: "Recently listed homes worth watching.", city: "", area: "", type: "", minPrice: "", maxPrice: "", sort: "newest" }
        ]
      };

      // ── Helpers ────────────────────────────────────────────
      const nv = (v) => String(v || "").trim().toLowerCase();
      const tc = (v) => String(v || "").trim().replace(/[-_]+/g, " ").replace(/\b\w/g, c => c.toUpperCase());

      function optionValue(item) {
        if (!item) return "";
        if (typeof item === "object") return nv(item.value || item.normalized_value || item.normalized_area || item.normalized_city || item.normalized_type || item.name || item.label || "");
        return nv(item);
      }

      function optionLabel(item) {
        if (!item) return "";
        if (typeof item === "object") return tc(item.label || item.display_name || item.name || item.value || item.normalized_value || item.normalized_area || item.normalized_city || item.normalized_type || "");
        return tc(item);
      }

      function uniqueOptions(items) {
        const seen = new Set();
        return (Array.isArray(items) ? items : [])
          .map(item => ({ value: optionValue(item), label: optionLabel(item) || tc(optionValue(item)) }))
          .filter(item => { if (!item.value || seen.has(item.value)) return false; seen.add(item.value); return true; })
          .sort((a, b) => a.label.localeCompare(b.label));
      }

      function getPrimaryCity() {
        return nv(form.elements.newListingsCity?.value) || nv(form.elements.city?.value) || nv(filterOptions.cities?.[0]?.value) || "nanaimo";
      }

      function buildExploreHref(group) {
        const params = new URLSearchParams();
        if (group.city) params.set("city", nv(group.city));
        if (group.area) params.set("area", nv(group.area));
        if (group.type) params.set("type", nv(group.type));
        if (group.minPrice) params.set("minPrice", String(Number(group.minPrice) * 1000));
        if (group.maxPrice) params.set("maxPrice", String(Number(group.maxPrice) * 1000));
        if (group.sort) params.set("sort", group.sort);
        const q = params.toString();
        return q ? `/explore?${q}` : "/explore";
      }

      async function fetchJsonSafe(url) {
        try { const res = await fetch(url); if (!res.ok) return null; return await res.json(); } catch { return null; }
      }

      // ── Template ───────────────────────────────────────────
      function setSelectedTemplate(value) {
        form.querySelectorAll('input[name="template"]').forEach(r => r.checked = r.value === value);
        const link = document.getElementById("previewLink");
        if (link) link.href = value === "calm" ? "/agent-listings-calm" : "/agent-listings";
      }

      form.querySelectorAll('input[name="template"]').forEach(r => {
        r.addEventListener("change", () => {
          const link = document.getElementById("previewLink");
          if (link) link.href = r.value === "calm" ? "/agent-listings-calm" : "/agent-listings";
        });
      });

      // ── Colour picker ──────────────────────────────────────
      const colourPresets = [
        { colour: "#2f6f73", name: "Teal" }, { colour: "#2d5016", name: "Forest" },
        { colour: "#7c3a2d", name: "Terracotta" }, { colour: "#1a3a5c", name: "Navy" },
        { colour: "#5c3d8f", name: "Plum" }, { colour: "#8f5c1a", name: "Amber" },
        { colour: "#1a5c4a", name: "Emerald" }, { colour: "#181614", name: "Charcoal" },
      ];

      function hexToRgb(hex) {
        return { r: parseInt(hex.slice(1,3),16), g: parseInt(hex.slice(3,5),16), b: parseInt(hex.slice(5,7),16) };
      }

  function mix(hex, w, warm = true) {
        const {r,g,b} = hexToRgb(hex);
        // Warm base: blend between accent and #f4efe7, then nudge toward white
        // This matches the original site's warm sandy bg feel regardless of accent
        const warmBase = { r: 244, g: 239, b: 231 };
        const white = { r: 255, g: 255, b: 255 };
        const base = warm
          ? { r: Math.round(warmBase.r * 0.82 + white.r * 0.18), g: Math.round(warmBase.g * 0.82 + white.g * 0.18), b: Math.round(warmBase.b * 0.82 + white.b * 0.18) }
          : white;
        const t = w/100;
        return `rgb(${Math.round(r+(base.r-r)*t)},${Math.round(g+(base.g-g)*t)},${Math.round(b+(base.b-b)*t)})`;
      }

      function updateSwatches(hex) {
        const set = (id, c) => { const el = document.getElementById(id); if (el) el.style.background = c; };
  set("swatchAccent", hex); set("swatchAccentLight", mix(hex,65));
        set("swatchAccentSoft", mix(hex,88)); set("swatchBg", mix(hex,96));
        set("swatchCard", "#ffffff"); set("swatchSection", mix(hex,94));
      }

      function applyColour(hex, source) {
        if (!/^#[0-9a-f]{6}$/i.test(hex)) return;
        hex = hex.toLowerCase();
        const picker = document.getElementById("accentColorPicker");
        const hexInput = document.getElementById("accentColorHex");
        const label = document.getElementById("colourLabel");
        if (picker && source !== "picker") picker.value = hex;
        if (hexInput && source !== "hex") hexInput.value = hex;
        if (label) label.textContent = colourPresets.find(p => p.colour.toLowerCase() === hex)?.name || "Custom";
        updateSwatches(hex);
      document.querySelectorAll(".preset-swatch").forEach(btn => {
          btn.classList.toggle("is-selected", btn.dataset.colour.toLowerCase() === hex);
        });
        if (typeof syncSaveBtn === "function") syncSaveBtn();
      }

      document.querySelectorAll(".preset-swatch").forEach(btn => {
        btn.addEventListener("click", () => applyColour(btn.dataset.colour, "preset"));
      });

      document.getElementById("accentColorPicker")?.addEventListener("input", (e) => applyColour(e.target.value, "picker"));

      document.getElementById("accentColorHex")?.addEventListener("input", (e) => {
        let val = e.target.value.trim();
        if (!val.startsWith("#")) val = "#" + val;
        if (/^#[0-9a-f]{6}$/i.test(val)) applyColour(val, "hex");
      });

let customColours = [];

      function isBuiltin(hex) { return colourPresets.some(p => p.colour.toLowerCase() === hex.toLowerCase()); }
      function isAlreadySaved(hex) { return customColours.some(c => c.colour.toLowerCase() === hex.toLowerCase()); }

      function renderCustomSwatches() {
        const container = document.getElementById("customSwatches");
        const section = document.getElementById("savedSection");
        container.innerHTML = "";
        if (!customColours.length) { section.classList.remove("has-customs"); return; }
        section.classList.add("has-customs");
        customColours.forEach(c => {
          const btn = document.createElement("button");
        btn.type = "button";
          btn.className = "preset-swatch is-custom";
          btn.dataset.colour = c.colour;
          btn.title = c.name;
          btn.style.cssText = `background:${c.colour};width:44px;height:44px;border-radius:999px;border:2px solid transparent;cursor:pointer;position:relative;flex-shrink:0;transition:transform 0.14s,box-shadow 0.14s,border-color 0.14s;`;
    btn.addEventListener("click", () => applyColour(c.colour, "preset"));
          const rmv = document.createElement("button");
          rmv.type = "button";
          rmv.className = "remove-btn";
          rmv.textContent = "\u2715";
          rmv.title = "Remove";
rmv.style.cssText = "position:absolute;top:-6px;right:-6px;width:20px;height:20px;border-radius:999px;background:#fff;border:1px solid rgba(0,0,0,0.2);font-size:11px;font-weight:900;color:#555;cursor:pointer;display:none;align-items:center;justify-content:center;z-index:10;padding:0;line-height:1;";          rmv.addEventListener("mouseenter", () => rmv.style.display = "flex");
        rmv.addEventListener("click", (e) => {
            e.stopPropagation();
            e.preventDefault();
            if (!confirm("Remove this saved colour?")) return;
            customColours = customColours.filter(x => x.colour !== c.colour);
           
            renderCustomSwatches();
            syncSaveBtn();
          });
          btn.addEventListener("mouseenter", () => rmv.style.display = "flex");
          btn.addEventListener("mouseleave", () => rmv.style.display = "none");
          btn.appendChild(rmv);
          container.appendChild(btn);
        });
        const hex = document.getElementById("accentColorPicker")?.value?.toLowerCase();
        if (hex) container.querySelectorAll(".preset-swatch").forEach(b => b.classList.toggle("is-selected", b.dataset.colour.toLowerCase() === hex));
      }

      function syncSaveBtn() {
        const hex = (document.getElementById("accentColorHex")?.value || "").toLowerCase();
        const btn = document.getElementById("saveCustomBtn");
        if (!btn) return;
        const exists = isBuiltin(hex) || isAlreadySaved(hex);
        btn.disabled = exists;
        btn.textContent = exists ? "Saved \u2713" : "Save colour";
      }

      document.getElementById("saveCustomBtn")?.addEventListener("click", () => {
        const hex = (document.getElementById("accentColorHex")?.value || "").toLowerCase();
        if (!hex || !/^#[0-9a-f]{6}$/.test(hex) || isBuiltin(hex) || isAlreadySaved(hex)) return;
        customColours.push({ colour: hex, name: hex.toUpperCase() });
        
        renderCustomSwatches();
        syncSaveBtn();
      });

      window.seedAccentColour = (hex) => { if (hex && /^#[0-9a-f]{6}$/i.test(hex)) applyColour(hex, "seed"); };
      applyColour("#2f6f73", "seed");
      renderCustomSwatches();
      syncSaveBtn();

      // ── Intent pages ───────────────────────────────────────
      async function loadIntentPages(selected = []) {
        const city = nv(form.elements.city?.value) || "nanaimo";
        const json = await fetchJsonSafe(`/api/intent-pages?city=${encodeURIComponent(city)}`);
        intentPages = Array.isArray(json?.pages) ? json.pages : [];
        const grid = document.getElementById("intentPagesGrid");
        if (!grid) return;
        if (!intentPages.length) { grid.innerHTML = `<p class="hint">No published intent pages found.</p>`; return; }
        grid.innerHTML = intentPages.map(page => {
          const checked = selected.includes(page.slug);
          return `<label class="intent-page-card">
            <input type="checkbox" class="intent-page-checkbox" value="${page.slug}" ${checked ? "checked" : ""} />
            <div class="intent-page-meta">
              <strong>${page.hero_heading || page.slug}</strong>
              <p>${page.intro_copy || ""}</p>
              <div class="intent-page-tags">
                ${page.property_type ? `<span>${page.property_type}</span>` : ""}
                ${page.lifestyle_angle ? `<span>${String(page.lifestyle_angle).replaceAll("_"," ")}</span>` : ""}
                ${page.price_max ? `<span>Under $${Number(page.price_max).toLocaleString()}</span>` : ""}
              </div>
            </div>
          </label>`;
        }).join("");
      }

      // ── Filter dropdowns ───────────────────────────────────
      async function loadFilterOptions() {
        const json = await fetchJsonSafe("/api/listing-filters");
        if (json) {
          filterOptions.cities = uniqueOptions(json.cities || []);
          filterOptions.types = uniqueOptions(json.types || json.propertyTypes || []);
          const abc = json.areasByCity || {};
          filterOptions.areasByCity = Object.fromEntries(Object.entries(abc).map(([city,areas]) => [nv(city), uniqueOptions(areas)]));
        }
      }

      function populateCitySelects() {
        document.querySelectorAll(".city-select").forEach(select => {
          const current = nv(select.value) || getPrimaryCity();
          select.innerHTML = [`<option value="">Any city</option>`, ...filterOptions.cities.map(c => `<option value="${c.value}" ${c.value===current?"selected":""}>${c.label}</option>`)].join("");
        });
      }

      function populateTypeSelects() {
        document.querySelectorAll(".type-select").forEach(select => {
          const current = nv(select.value);
          select.innerHTML = [`<option value="">Any type</option>`, ...filterOptions.types.map(t => `<option value="${t.value}" ${t.value===current?"selected":""}>${t.label}</option>`)].join("");
        });
      }

      function getCityForAreaSelect(areaSelect) {
        if (areaSelect.name === "newListingsArea") return nv(form.elements.newListingsCity?.value || getPrimaryCity());
        const n = areaSelect.name.match(/\d+/)?.[0];
        return nv(form.elements[`group${n}City`]?.value || getPrimaryCity());
      }

      function populateAreaSelects() {
        document.querySelectorAll(".area-select").forEach(select => {
          const current = nv(select.value);
          const city = getCityForAreaSelect(select);
          const areas = filterOptions.areasByCity[city] || [];
          select.innerHTML = [`<option value="">Any area</option>`, ...areas.map(a => `<option value="${a.value}" ${a.value===current?"selected":""}>${a.label}</option>`)].join("");
        });
      }

      function populateDropdowns() { populateCitySelects(); populateTypeSelects(); populateAreaSelects(); }

      // ── Fill form ──────────────────────────────────────────
      function fillForm(data) {
        const savedGroups = Array.isArray(data?.groups) ? data.groups : [];
        const mergedGroups = [0,1,2,3].map(i => {
          const saved = savedGroups[i] || {};
          const fallback = defaults.groups[i] || {};
          const isBlank = !saved.kicker && !saved.title && !saved.text && !saved.city && !saved.area && !saved.type && !saved.minPrice && !saved.maxPrice;
          return isBlank ? fallback : { ...fallback, ...saved };
        });
        const merged = { ...defaults, ...(data || {}), groups: mergedGroups };

        setSelectedTemplate(merged.template || "brutal");

        Object.entries(merged).forEach(([key, value]) => {
          if (["groups","template","enabledIntentPageSlugs"].includes(key)) return;
          const field = form.elements[key];
          if (!field) return;
          field.value = ["city","newListingsCity","newListingsArea","newListingsType"].includes(key) ? nv(value) : (value || "");
        });

        [1,2,3,4].forEach(num => {
          const g = merged.groups[num-1] || {};
          form.elements[`group${num}Kicker`].value = g.kicker || "";
          form.elements[`group${num}Title`].value = g.title || "";
          form.elements[`group${num}Text`].value = g.text || "";
          form.elements[`group${num}City`].value = nv(g.city);
          form.elements[`group${num}Area`].value = nv(g.area);
          form.elements[`group${num}Type`].value = nv(g.type);
          form.elements[`group${num}Sort`].value = g.sort || "newest";
          form.elements[`group${num}MinPrice`].value = g.minPrice || "";
          form.elements[`group${num}MaxPrice`].value = g.maxPrice || "";
        });

customColours = Array.isArray(merged.savedColours)
  ? merged.savedColours
  : [];

renderCustomSwatches();

if (typeof window.seedAccentColour === "function")
  window.seedAccentColour(merged.accentColor || "#2f6f73");
      }

      // ── Load ───────────────────────────────────────────────
      async function loadPage() {
        const res = await fetch(`/api/site-settings?id=${encodeURIComponent(siteId)}`);
        const json = await res.json();
        const data = json?.data || defaults;
        fillForm(data);
        await loadIntentPages(data?.enabledIntentPageSlugs || []);
        await loadFilterOptions();
        populateDropdowns();
        fillForm(data);
        populateDropdowns();
        await loadIntentPages(data?.enabledIntentPageSlugs || []);
      }

      form.addEventListener("change", async (e) => {
        if (e.target?.classList?.contains("city-select")) populateAreaSelects();
        if (e.target?.name === "city") await loadIntentPages(Array.from(document.querySelectorAll(".intent-page-checkbox:checked")).map(el => el.value));
      });

      // ── Save ───────────────────────────────────────────────
      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        status.textContent = "Saving…";
        status.className = "status";

        const formData = new FormData(form);
        const data = Object.fromEntries(formData.entries());
        data.city = nv(data.city);
        data.newListingsCity = nv(data.newListingsCity);
        data.newListingsArea = nv(data.newListingsArea);
        data.newListingsType = nv(data.newListingsType);
        data.template = data.template || "brutal";
        data.accentColor = data.accentColor || "#2f6f73";

        data.groups = [1,2,3,4].map(num => {
          const g = { kicker: data[`group${num}Kicker`]||"", title: data[`group${num}Title`]||"", text: data[`group${num}Text`]||"", city: nv(data[`group${num}City`]), area: nv(data[`group${num}Area`]), type: nv(data[`group${num}Type`]), minPrice: data[`group${num}MinPrice`]||"", maxPrice: data[`group${num}MaxPrice`]||"", sort: data[`group${num}Sort`]||"newest" };
          return { ...g, href: buildExploreHref(g) };
        }).filter(g => g.title || g.text || g.href);

        [1,2,3,4].forEach(num => ["Kicker","Title","Text","City","Area","Type","Sort","MinPrice","MaxPrice"].forEach(f => delete data[`group${num}${f}`]));

        data.newListingsLimit = data.newListingsLimit || "6";
        data.enabledIntentPageSlugs = Array.from(document.querySelectorAll(".intent-page-checkbox:checked")).map(el => el.value);
data.savedColours = customColours;
const res = await fetch("/api/site-settings", {
  method: "POST",
  headers: { "Content-Type": "application/json" },
  body: JSON.stringify({
  id: siteId || null,
  data
})
});
        const json = await res.json();

status.textContent = json.ok ? "Saved \u2713" : json.error || "Save failed";        if (!json.ok) status.className = "status is-error";
      });

    // ── Sidebar section nav ─────────────────────────────
document.querySelectorAll(".sidebar__section-links a").forEach((link) => {
  link.addEventListener("click", (e) => {
    e.preventDefault();
    const targetId = link.getAttribute("href").slice(1);
    const target = document.getElementById(targetId);
    if (!target) return;

    document.querySelectorAll(".section").forEach((s) => {
      s.classList.remove("is-open");
    });

    document.querySelectorAll(".sidebar__section-links a").forEach((l) => {
      l.classList.remove("active");
    });

    target.classList.add("is-open");
    link.classList.add("active");
    target.scrollIntoView({ behavior: "smooth", block: "start" });
  });
});

if (!siteId) {
  status.textContent = "Site not found. Add localhost to the sites table or open this page from the live domain.";
  status.className = "status is-error";
} else {
  loadPage();
}
    </script>
  </body>
</html>
