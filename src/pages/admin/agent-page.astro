              <div class="grid-2">
                <div class="field"><label>Min price (000s)</label><input name="newListingsMinPrice" inputmode="numeric" placeholder="0" /></div>
                <div class="field"><label>Max price (000s)</label><input name="newListingsMaxPrice" inputmode="numeric" placeholder="800" /></div>
