---
const slug = "chris-crump";
---

<html>
  <head>
    <title>Agent Page Editor</title>
    <style>
      body {
        margin: 0;
        font-family: system-ui, sans-serif;
        background: #f4efe7;
        color: #181614;
      }

      .shell {
        width: min(900px, calc(100% - 32px));
        margin: 0 auto;
        padding: 40px 0;
      }

      h1 {
        font-size: 42px;
        letter-spacing: -0.06em;
      }

      label {
        display: block;
        margin: 18px 0 6px;
        font-weight: 700;
      }

      * {
        box-sizing: border-box;
      }

      input,
      textarea,
      select {
        width: 100%;
        padding: 12px;
        border: 1px solid rgba(24, 22, 20, 0.18);
        border-radius: 12px;
        font: inherit;
        background: white;
      }

      textarea {
        min-height: 100px;
      }

      button,
      a.preview {
        display: inline-flex;
        margin-top: 22px;
        margin-right: 10px;
        padding: 12px 16px;
        border-radius: 999px;
        border: 0;
        background: #181614;
        color: white;
        font-weight: 800;
        cursor: pointer;
        text-decoration: none;
      }

      .status {
        margin-top: 14px;
        color: #6f5a38;
        font-weight: 700;
      }

     .admin-nav {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin: 0 0 26px;
}

.admin-nav a {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 40px;
  padding: 0 15px;
  border-radius: 999px;
  border: 1px solid rgba(24,22,20,0.14);
  background: #fffaf1;
  color: #181614;
  font-size: 0.9rem;
  font-weight: 900;
  text-decoration: none;
}

.admin-nav a:hover,
.admin-nav a.is-active {
  background: #181614;
  color: white;
  border-color: #181614;
}

.card {
  background: #fffaf1;
  border: 1px solid rgba(24, 22, 20, 0.12);
  border-radius: 24px;
  padding: 22px;
  margin-top: 22px;
}

      .group-editor {
        border-top: 1px solid rgba(24, 22, 20, 0.12);
        margin-top: 18px;
        padding-top: 18px;
      }

      .group-editor h3 {
        margin: 0 0 10px;
      }

      .grid-2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
      }

      .hint {
        margin: 8px 0 0;
        color: rgba(24, 22, 20, 0.62);
        font-size: 0.9rem;
        line-height: 1.45;
      }

      .template-options {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
        margin-top: 12px;
      }

      .template-option {
        position: relative;
        cursor: pointer;
      }

      .template-option input[type="radio"] {
        position: absolute;
        opacity: 0;
        width: 0;
        height: 0;
      }

      .template-option__card {
        border: 2px solid rgba(24, 22, 20, 0.15);
        border-radius: 16px;
        overflow: hidden;
        transition: border-color 0.2s, box-shadow 0.2s;
      }

      .template-option input:checked + .template-option__card {
        border-color: #181614;
        box-shadow: 0 0 0 3px rgba(24, 22, 20, 0.12);
      }

      .template-option__preview {
        height: 100px;
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        padding: 12px;
        position: relative;
        overflow: hidden;
      }

      .template-option--brutal .template-option__preview {
        background: #0a0a0a;
      }

      .template-option--calm .template-option__preview {
        background: #f5f2ed;
      }

      .template-option__preview-title {
        font-weight: 800;
        font-size: 0.85rem;
        letter-spacing: -0.03em;
      }

      .template-option--brutal .template-option__preview-title {
        color: white;
        font-size: 1rem;
      }

      .template-option--calm .template-option__preview-title {
        color: #1c1917;
        font-family: Georgia, serif;
        font-style: italic;
        font-weight: 400;
        font-size: 0.95rem;
      }

      .template-option__preview-accent {
        height: 3px;
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
      }

      .template-option--brutal .template-option__preview-accent {
        background: #ff4d00;
      }

      .template-option--calm .template-option__preview-accent {
        background: #8b6f47;
      }

      .template-option__label {
        padding: 10px 14px;
        background: white;
        border-top: 1px solid rgba(24,22,20,0.1);
      }

      .template-option__label strong {
        display: block;
        font-size: 0.85rem;
        font-weight: 700;
        margin-bottom: 2px;
      }

      .template-option__label span {
        font-size: 0.75rem;
        color: rgba(24, 22, 20, 0.55);
      }

      .template-option input:checked + .template-option__card .template-option__label {
        background: #f4efe7;
      }

      .intent-pages-grid {
        display: grid;
        gap: 12px;
        margin-top: 18px;
      }

      .intent-page-card {
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 14px;
        align-items: start;
        padding: 14px;
        border-radius: 16px;
        border: 1px solid rgba(24,22,20,0.12);
        background: white;
      }

      .intent-page-card input[type="checkbox"] {
        width: 18px;
        height: 18px;
        margin-top: 4px;
      }

      .intent-page-meta strong {
        display: block;
        margin-bottom: 4px;
        font-size: 0.95rem;
      }

      .intent-page-meta p {
        margin: 0;
        color: rgba(24,22,20,0.62);
        font-size: 0.88rem;
        line-height: 1.5;
      }

      .intent-page-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        margin-top: 10px;
      }

      .intent-page-tags span {
        display: inline-flex;
        align-items: center;
        min-height: 24px;
        padding: 0 8px;
        border-radius: 999px;
        background: #f4efe7;
        color: #6f5a38;
        font-size: 0.72rem;
        font-weight: 700;
      }

      @media (max-width: 700px) {
        .grid-2 {
          grid-template-columns: 1fr;
        }

        .template-options {
          grid-template-columns: 1fr;
        }

        .intent-page-card {
          grid-template-columns: auto 1fr;
        }
      }
    </style>
  </head>

 <body>
  <main class="shell">
    <nav class="admin-nav">
      <a href="/admin/intent-pages">All pages</a>
      <a href="/admin/intent-pages/new">Create new</a>
      <a class="is-active" href="/admin/agent-page">Agent editor</a>
    </nav>

    <h1>Agent page editor</h1>
      <form id="agentForm">
        <div class="card">
          <h2>Agent</h2>

          <label>Agent name</label>
          <input name="agentName" />

          <label>Agent title</label>
          <input name="agentTitle" />

          <label>Phone</label>
          <input name="phone" />

          <label>Email</label>
          <input name="email" />

          <label>City</label>
          <input name="city" />
        </div>

        <div class="card">
          <h2>Page template</h2>
          <p class="hint">Choose the visual style for this agent's landing page.</p>

          <div class="template-options">
            <label class="template-option template-option--brutal">
              <input type="radio" name="template" value="brutal" />
              <div class="template-option__card">
                <div class="template-option__preview">
                  <div class="template-option__preview-accent"></div>
                  <div class="template-option__preview-title">Nanaimo<br/><span style="color:#ff4d00;">homes.</span></div>
                </div>
                <div class="template-option__label">
                  <strong>Template 1 — Brutalist</strong>
                  <span>Bold, high contrast, editorial</span>
                </div>
              </div>
            </label>

            <label class="template-option template-option--calm">
              <input type="radio" name="template" value="calm" />
              <div class="template-option__card">
                <div class="template-option__preview">
                  <div class="template-option__preview-accent"></div>
                  <div class="template-option__preview-title">Nanaimo<br/><span style="color:#8b6f47;">homes.</span></div>
                </div>
                <div class="template-option__label">
                  <strong>Template 2 — Calm</strong>
                  <span>Warm, soft, approachable</span>
                </div>
              </div>
            </label>
          </div>
        </div>
<div class="card">
  <h2>Intent pages</h2>

  <p class="hint">
    Choose which intent-driven buyer pages appear on the homepage.
  </p>

  <a class="preview" href="/admin/intent-pages/new">
    + Create new intent page
  </a>

  <div id="intentPagesGrid" class="intent-pages-grid">
    <p class="hint">Loading intent pages...</p>
  </div>
</div>

        <div class="card">
          <h2>Hero</h2>

          <label>Hero eyebrow</label>
          <input name="heroEyebrow" />

          <label>Hero heading</label>
          <input name="heroHeading" />

          <label>Hero intro</label>
          <textarea name="heroIntro"></textarea>

          <label>Agent pick title</label>
          <input name="agentPickTitle" />

          <label>Agent pick text</label>
          <textarea name="agentPickText"></textarea>

          <label>Featured listing MLS number</label>
          <input name="featuredListingMls" inputmode="numeric" placeholder="Example: 1032478" />
          <p class="hint">Optional. Enter the MLS number only - no # symbol, spaces, or extra text.</p>
        </div>

        <div class="card">
          <h2>Social links and feeds</h2>
          <p class="hint">Add profile links for the buttons.</p>

          <div class="grid-2">
            <div>
              <label>LinkedIn profile URL</label>
              <input name="linkedinUrl" placeholder="https://www.linkedin.com/in/..." />
            </div>
            <div>
              <label>X / Twitter profile URL</label>
              <input name="twitterUrl" placeholder="https://twitter.com/..." />
            </div>
          </div>

          <div class="grid-2">
            <div>
              <label>Instagram URL</label>
              <input name="instagramUrl" placeholder="https://www.instagram.com/..." />
            </div>
            <div>
              <label>Facebook URL</label>
              <input name="facebookUrl" placeholder="https://www.facebook.com/..." />
            </div>
          </div>

          <label>Social section title</label>
          <input name="socialTitle" />

          <label>Social section intro</label>
          <textarea name="socialIntro"></textarea>

          <label>Feed type</label>
          <select name="socialFeedType">
            <option value="">No embedded feed</option>
            <option value="twitter">X / Twitter profile feed</option>
            <option value="manual">Manual embed / custom content</option>
          </select>

          <label>Feed URL</label>
          <input name="socialFeedUrl" placeholder="Example: https://twitter.com/chriscrump" />

          <label>Social feed embed</label>
          <textarea name="socialFeedEmbed"></textarea>
          <p class="hint">Use this for a simple note, embed code, or a manually pasted public post block.</p>
        </div>

        <div class="card">
          <h2>Listing sections</h2>
          <p class="hint">These are the four curated cards near the top of the page.</p>

          {[1, 2, 3, 4].map((num) => (
            <div class="group-editor">
              <h3>Section {num}</h3>

              <label>Small label</label>
              <input name={`group${num}Kicker`} />

              <label>Title</label>
              <input name={`group${num}Title`} />

              <label>Description</label>
              <textarea name={`group${num}Text`}></textarea>

              <div class="grid-2">
                <div>
                  <label>City</label>
                  <select name={`group${num}City`} class="city-select group-city-select">
                    <option value="">Loading cities...</option>
                  </select>
                </div>
                <div>
                  <label>Area / neighbourhood</label>
                  <select name={`group${num}Area`} class="area-select">
                    <option value="">Choose city first</option>
                  </select>
                </div>
              </div>

              <div class="grid-2">
                <div>
                  <label>Type</label>
                  <select name={`group${num}Type`} class="type-select">
                    <option value="">Loading types...</option>
                  </select>
                </div>
                <div>
                  <label>Sort</label>
                  <select name={`group${num}Sort`}>
                    <option value="newest">Newest first</option>
                    <option value="price-low">Price low to high</option>
                    <option value="price-high">Price high to low</option>
                    <option value="beds-high">Most bedrooms</option>
                  </select>
                </div>
              </div>

              <div class="grid-2">
                <div>
                  <label>Min price in 000s</label>
                  <input name={`group${num}MinPrice`} inputmode="numeric" placeholder="0" />
                </div>
                <div>
                  <label>Max price in 000s</label>
                  <input name={`group${num}MaxPrice`} inputmode="numeric" placeholder="Example: 800" />
                </div>
              </div>
            </div>
          ))}
        </div>

        <div class="card">
          <h2>Live listings section</h2>
          <p class="hint">Change the city, area, property type, price, sort, or limit to show a different live listing group.</p>

          <label>Section title</label>
          <input name="newListingsTitle" />

          <label>Section intro</label>
          <textarea name="newListingsIntro"></textarea>

          <div class="grid-2">
            <div>
              <label>Listing city</label>
              <select name="newListingsCity" id="newListingsCitySelect" class="city-select">
                <option value="">Loading cities...</option>
              </select>
            </div>
            <div>
              <label>Area / neighbourhood</label>
              <select name="newListingsArea" id="newListingsAreaSelect" class="area-select">
                <option value="">Choose city first</option>
              </select>
            </div>
          </div>

          <div class="grid-2">
            <div>
              <label>Property type</label>
              <select name="newListingsType" class="type-select">
                <option value="">Loading types...</option>
              </select>
            </div>
            <div>
              <label>Sort</label>
              <select name="newListingsSort">
                <option value="newest">Newest first</option>
                <option value="price-low">Price low to high</option>
                <option value="price-high">Price high to low</option>
                <option value="beds-high">Most bedrooms</option>
              </select>
            </div>
          </div>

          <div class="grid-2">
            <div>
              <label>Min price in 000s</label>
              <input name="newListingsMinPrice" inputmode="numeric" placeholder="0" />
            </div>
            <div>
              <label>Max price in 000s</label>
              <input name="newListingsMaxPrice" inputmode="numeric" placeholder="Example: 800" />
            </div>
          </div>

          <label>Number to show</label>
          <input name="newListingsLimit" inputmode="numeric" placeholder="6" />
        </div>

        <div class="card">
          <h2>City section</h2>

          <label>City intro</label>
          <textarea name="cityIntro"></textarea>

          <label>City notes</label>
          <textarea name="cityNotes"></textarea>
        </div>

        <div class="card">
          <h2>Agent bio</h2>

          <label>Bio</label>
          <textarea name="agentBio"></textarea>
        </div>

        <button type="submit">Save page</button>
        <a class="preview" id="previewLink" href="/agent-listings" target="_blank">Preview page</a>

        <div class="status" id="status"></div>
      </form>
    </main>

    <script is:inline>
      const slug = "chris-crump";
      const form = document.getElementById("agentForm");
      const status = document.getElementById("status");

      let intentPages = [];

      let filterOptions = {
        cities: [],
        areasByCity: {},
        types: []
      };

      const defaults = {
        agentName: "Chris Crump",
        agentTitle: "Real Estate Advisor",
        phone: "250.619.0390",
        email: "chris@example.com",
        city: "",
        template: "brutal",
        heroEyebrow: "Curated by Chris Crump",
        heroHeading: "Homes worth watching.",
        heroIntro: "A simple, curated place to explore homes - organized by property type, price point, and what buyers are watching right now.",
        agentPickTitle: "Not a giant listing portal.",
        agentPickText: "Just the homes and categories buyers actually ask about most.",
        featuredListingMls: "",
        linkedinUrl: "",
        twitterUrl: "",
        instagramUrl: "",
        facebookUrl: "",
        socialTitle: "Follow along.",
        socialIntro: "Market notes, listing updates, and local real estate context from your agent.",
        socialFeedType: "",
        socialFeedUrl: "",
        socialFeedEmbed: "",
        cityIntro: "",
        cityNotes: "",
        agentBio: "A local real estate advisor helping buyers make sense of the market with clear, curated listing guidance.",
        newListingsTitle: "New listings.",
        newListingsIntro: "The latest homes to hit the market.",
        newListingsCity: "",
        newListingsArea: "",
        newListingsType: "",
        newListingsMinPrice: "",
        newListingsMaxPrice: "",
        newListingsSort: "newest",
        newListingsLimit: "6",
        enabledIntentPageSlugs: [],
        groups: [
          { title: "Condos", kicker: "Low-maintenance living", text: "Explore condo options from the latest listing data.", city: "", area: "", type: "condo", minPrice: "", maxPrice: "", sort: "newest", href: "/explore?type=condo&sort=newest" },
          { title: "Single-family homes", kicker: "Room to grow", text: "Detached homes from the latest listing data.", city: "", area: "", type: "house", minPrice: "", maxPrice: "", sort: "newest", href: "/explore?type=house&sort=newest" },
          { title: "Popular under $800k", kicker: "Buyer sweet spot", text: "Homes in one of the most watched price ranges for active buyers.", city: "", area: "", type: "", minPrice: "", maxPrice: "800", sort: "newest", href: "/explore?maxPrice=800&sort=newest" },
          { title: "New listings", kicker: "Fresh to market", text: "Recently listed homes worth watching before they get buried.", city: "", area: "", type: "", minPrice: "", maxPrice: "", sort: "newest", href: "/explore?sort=newest" }
        ]
      };

      function getSelectedTemplate() {
        const radios = form.querySelectorAll('input[name="template"]');
        for (const radio of radios) {
          if (radio.checked) return radio.value;
        }
        return "brutal";
      }

      function setSelectedTemplate(value) {
        const radios = form.querySelectorAll('input[name="template"]');
        for (const radio of radios) {
          radio.checked = radio.value === value;
        }
        updatePreviewLink(value);
      }

      function updatePreviewLink(template) {
        const link = document.getElementById("previewLink");
        if (!link) return;
        link.href = template === "calm" ? "/agent-listings-calm" : "/agent-listings";
      }

      form.querySelectorAll('input[name="template"]').forEach((radio) => {
        radio.addEventListener("change", () => updatePreviewLink(radio.value));
      });

      function normalizeFilterValue(value) {
        return String(value || "").trim().toLowerCase();
      }

      function titleCase(value) {
        return String(value || "")
          .trim()
          .replace(/[-_]+/g, " ")
          .replace(/\s+/g, " ")
          .replace(/\b\w/g, (char) => char.toUpperCase());
      }

      function optionValue(item) {
        if (!item) return "";
        if (typeof item === "object") {
          return normalizeFilterValue(
            item.value ||
              item.normalized_value ||
              item.normalized_area ||
              item.normalized_city ||
              item.normalized_type ||
              item.name ||
              item.label ||
              ""
          );
        }
        return normalizeFilterValue(item);
      }

      function optionLabel(item) {
        if (!item) return "";
        if (typeof item === "object") {
          return titleCase(
            item.label ||
              item.display_name ||
              item.name ||
              item.value ||
              item.normalized_value ||
              item.normalized_area ||
              item.normalized_city ||
              item.normalized_type ||
              ""
          );
        }
        return titleCase(item);
      }

      function uniqueOptions(items) {
        const seen = new Set();
        return (Array.isArray(items) ? items : [])
          .map((item) => {
            const value = optionValue(item);
            return {
              value,
              label: optionLabel(item) || titleCase(value)
            };
          })
          .filter((item) => {
            if (!item.value || seen.has(item.value)) return false;
            seen.add(item.value);
            return true;
          })
          .sort((a, b) => a.label.localeCompare(b.label));
      }

      function getPrimaryCity() {
        return (
          normalizeFilterValue(form.elements.newListingsCity?.value) ||
          normalizeFilterValue(form.elements.city?.value) ||
          normalizeFilterValue(filterOptions.cities?.[0]?.value) ||
          "nanaimo"
        );
      }

      function buildExploreHref(group) {
        const params = new URLSearchParams();
        const city = normalizeFilterValue(group.city);
        const area = normalizeFilterValue(group.area);
        const type = normalizeFilterValue(group.type);

        if (city) params.set("city", city);
        if (area) params.set("area", area);
        if (type) params.set("type", type);
        if (group.minPrice) params.set("minPrice", String(Number(group.minPrice) * 1000));
        if (group.maxPrice) params.set("maxPrice", String(Number(group.maxPrice) * 1000));
        if (group.sort) params.set("sort", group.sort);

        const query = params.toString();
        return query ? `/explore?${query}` : "/explore";
      }

      async function fetchJsonSafe(url) {
        try {
          const res = await fetch(url);
          if (!res.ok) return null;
          return await res.json();
        } catch {
          return null;
        }
      }

      async function loadIntentPages(selected = []) {
        const city = normalizeFilterValue(form.elements.city?.value) || "nanaimo";

        const json = await fetchJsonSafe(
          `/api/intent-pages?city=${encodeURIComponent(city)}`
        );

        intentPages = Array.isArray(json?.pages) ? json.pages : [];

        renderIntentPages(selected);
      }

      function renderIntentPages(selected = []) {
        const grid = document.getElementById("intentPagesGrid");

        if (!grid) return;

        if (!intentPages.length) {
          grid.innerHTML = `<p class="hint">No published intent pages found for this city.</p>`;
          return;
        }

        grid.innerHTML = intentPages
          .map((page) => {
            const checked = selected.includes(page.slug);

            return `
              <label class="intent-page-card">
                <input
                  type="checkbox"
                  class="intent-page-checkbox"
                  value="${page.slug}"
                  ${checked ? "checked" : ""}
                />

                <div class="intent-page-meta">
                  <strong>${page.hero_heading || page.slug}</strong>

                  <p>${page.intro_copy || ""}</p>

                  <div class="intent-page-tags">
                    ${
                      page.property_type
                        ? `<span>${page.property_type}</span>`
                        : ""
                    }

                    ${
                      page.lifestyle_angle
                        ? `<span>${String(page.lifestyle_angle).replaceAll("_", " ")}</span>`
                        : ""
                    }

                    ${
                      page.price_max
                        ? `<span>Under $${Number(page.price_max).toLocaleString()}</span>`
                        : ""
                    }
                  </div>
                </div>
              </label>
            `;
          })
          .join("");
      }

      async function loadFilterOptions() {
        status.textContent = "Loading listing filters...";

        const filtersJson = await fetchJsonSafe("/api/listing-filters");

        if (filtersJson) {
          filterOptions.cities = uniqueOptions(filtersJson.cities || []);
          filterOptions.types = uniqueOptions(filtersJson.types || filtersJson.propertyTypes || []);

          const areasByCity = filtersJson.areasByCity || {};

          filterOptions.areasByCity = Object.fromEntries(
            Object.entries(areasByCity).map(([city, areas]) => [
              normalizeFilterValue(city),
              uniqueOptions(areas)
            ])
          );

          status.textContent = "";
          return;
        }

        filterOptions.cities = [];
        filterOptions.types = [];
        filterOptions.areasByCity = {};
        status.textContent = "Could not load listing filters.";
      }

      function populateCitySelects() {
        Array.from(document.querySelectorAll(".city-select")).forEach((select) => {
          const current = normalizeFilterValue(select.value) || getPrimaryCity();

          select.innerHTML = [
            `<option value="">Any city</option>`,
            ...filterOptions.cities.map((city) =>
              `<option value="${city.value}" ${city.value === current ? "selected" : ""}>${city.label}</option>`
            )
          ].join("");
        });
      }

      function populateTypeSelects() {
        Array.from(document.querySelectorAll(".type-select")).forEach((select) => {
          const current = normalizeFilterValue(select.value);

          select.innerHTML = [
            `<option value="">Any type</option>`,
            ...filterOptions.types.map((type) =>
              `<option value="${type.value}" ${type.value === current ? "selected" : ""}>${type.label}</option>`
            )
          ].join("");
        });
      }

      function getCityForAreaSelect(areaSelect) {
        if (areaSelect.name === "newListingsArea") {
          return normalizeFilterValue(form.elements.newListingsCity?.value || getPrimaryCity());
        }

        const groupNum = areaSelect.name.match(/\d+/)?.[0];
        return normalizeFilterValue(form.elements[`group${groupNum}City`]?.value || getPrimaryCity());
      }

      function populateAreaSelects() {
        Array.from(document.querySelectorAll(".area-select")).forEach((select) => {
          const current = normalizeFilterValue(select.value);
          const city = getCityForAreaSelect(select);
          const areas = filterOptions.areasByCity[city] || [];

          select.innerHTML = [
            `<option value="">Any area</option>`,
            ...areas.map((area) =>
              `<option value="${area.value}" ${area.value === current ? "selected" : ""}>${area.label}</option>`
            )
          ].join("");
        });
      }

      function populateDropdowns() {
        populateCitySelects();
        populateTypeSelects();
        populateAreaSelects();
      }

      function fillForm(data) {
        const savedGroups = Array.isArray(data?.groups) ? data.groups : [];

        const mergedGroups = [1, 2, 3, 4].map((_, index) => {
          const saved = savedGroups[index] || {};
          const fallback = defaults.groups[index] || {};

          const isBlank =
            !saved.kicker &&
            !saved.title &&
            !saved.text &&
            !saved.href &&
            !saved.city &&
            !saved.area &&
            !saved.type &&
            !saved.minPrice &&
            !saved.maxPrice;

          return isBlank ? fallback : { ...fallback, ...saved };
        });

        const merged = {
          ...defaults,
          ...(data || {}),
          groups: mergedGroups
        };

        setSelectedTemplate(merged.template || "brutal");

        Object.entries(merged).forEach(([key, value]) => {
          if (key === "groups" || key === "template" || key === "enabledIntentPageSlugs") return;

          const field = form.elements[key];

          if (!field) return;

          if (
            key === "city" ||
            key === "newListingsCity" ||
            key === "newListingsArea" ||
            key === "newListingsType"
          ) {
            field.value = normalizeFilterValue(value);
            return;
          }

          field.value = value || "";
        });

        [1, 2, 3, 4].forEach((num) => {
          const group = merged.groups[num - 1] || {};

          form.elements[`group${num}Kicker`].value = group.kicker || "";
          form.elements[`group${num}Title`].value = group.title || "";
          form.elements[`group${num}Text`].value = group.text || "";
          form.elements[`group${num}City`].value = normalizeFilterValue(group.city);
          form.elements[`group${num}Area`].value = normalizeFilterValue(group.area);
          form.elements[`group${num}Type`].value = normalizeFilterValue(group.type);
          form.elements[`group${num}Sort`].value = group.sort || "newest";
          form.elements[`group${num}MinPrice`].value = group.minPrice || "";
          form.elements[`group${num}MaxPrice`].value = group.maxPrice || "";
        });
      }

      function normalizeSavedData(data) {
        data.city = normalizeFilterValue(data.city);
        data.newListingsCity = normalizeFilterValue(data.newListingsCity);
        data.newListingsArea = normalizeFilterValue(data.newListingsArea);
        data.newListingsType = normalizeFilterValue(data.newListingsType);
        return data;
      }

      async function loadPage() {
        const res = await fetch(`/api/agent-page?slug=${encodeURIComponent(slug)}`);
        const json = await res.json();
        const data = json?.data || defaults;

        fillForm(data);

        await loadIntentPages(data?.enabledIntentPageSlugs || []);

        await loadFilterOptions();
        populateDropdowns();

        fillForm(data);
        populateDropdowns();

        await loadIntentPages(data?.enabledIntentPageSlugs || []);
      }

      form.addEventListener("change", async (event) => {
        if (event.target?.classList?.contains("city-select")) {
          populateAreaSelects();
        }

        if (event.target?.name === "city") {
          await loadIntentPages(
            Array.from(document.querySelectorAll(".intent-page-checkbox:checked"))
              .map((el) => el.value)
          );
        }
      });

      form.addEventListener("submit", async (event) => {
        event.preventDefault();
        status.textContent = "Saving...";

        const formData = new FormData(form);
        const data = normalizeSavedData(Object.fromEntries(formData.entries()));

        data.template = data.template || "brutal";

        data.groups = [1, 2, 3, 4]
          .map((num) => {
            const group = {
              kicker: data[`group${num}Kicker`] || "",
              title: data[`group${num}Title`] || "",
              text: data[`group${num}Text`] || "",
              city: normalizeFilterValue(data[`group${num}City`]),
              area: normalizeFilterValue(data[`group${num}Area`]),
              type: normalizeFilterValue(data[`group${num}Type`]),
              minPrice: data[`group${num}MinPrice`] || "",
              maxPrice: data[`group${num}MaxPrice`] || "",
              sort: data[`group${num}Sort`] || "newest"
            };

            return {
              ...group,
              href: buildExploreHref(group)
            };
          })
          .filter((group) => group.title || group.text || group.href);

        [1, 2, 3, 4].forEach((num) => {
          delete data[`group${num}Kicker`];
          delete data[`group${num}Title`];
          delete data[`group${num}Text`];
          delete data[`group${num}City`];
          delete data[`group${num}Area`];
          delete data[`group${num}Type`];
          delete data[`group${num}Sort`];
          delete data[`group${num}MinPrice`];
          delete data[`group${num}MaxPrice`];
        });

        data.newListingsLimit = data.newListingsLimit || "6";
        data.newListingsMinPrice = data.newListingsMinPrice || "";
        data.newListingsMaxPrice = data.newListingsMaxPrice || "";
        data.newListingsSort = data.newListingsSort || "newest";
        data.featuredListingMls = data.featuredListingMls || "";
        data.linkedinUrl = data.linkedinUrl || "";
        data.twitterUrl = data.twitterUrl || "";
        data.instagramUrl = data.instagramUrl || "";
        data.facebookUrl = data.facebookUrl || "";
        data.socialTitle = data.socialTitle || "";
        data.socialIntro = data.socialIntro || "";
        data.socialFeedType = data.socialFeedType || "";
        data.socialFeedUrl = data.socialFeedUrl || "";
        data.socialFeedEmbed = data.socialFeedEmbed || "";

        data.enabledIntentPageSlugs = Array.from(
          document.querySelectorAll(".intent-page-checkbox:checked")
        ).map((el) => el.value);

        const res = await fetch("/api/agent-page", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ slug, data })
        });

        const json = await res.json();

        status.textContent = json.ok ? "Saved." : json.error || "Save failed.";
      });

      loadPage();
    </script>
  </body>
</html>