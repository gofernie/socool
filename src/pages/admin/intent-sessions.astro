---
import { createClient } from "@supabase/supabase-js";
import AdminSidebar from "../../components/AdminSidebar.astro";

export const prerender = false;

const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.SUPABASE_SERVICE_ROLE_KEY
);

const { data: reactions, error } = await supabase
  .from("intent_listing_reactions")
  .select("*")
  .order("created_at", { ascending: false })
  .limit(500);

const rows = reactions || [];

const { data: leads } = await supabase
  .from("intent_leads")
  .select("*")
  .order("created_at", { ascending: false });

const leadBySessionId = new Map();

(leads || []).forEach((lead) => {
  if (!lead.session_id) return;

  const existing = leadBySessionId.get(lead.session_id);

  if (
    !existing ||
    new Date(lead.created_at).getTime() > new Date(existing.created_at).getTime()
  ) {
    leadBySessionId.set(lead.session_id, lead);
  }
});

const sessions = Object.values(
  rows.reduce((acc, row) => {
    const key = row.session_id;

    if (!acc[key]) {
      acc[key] = {
        session_id: row.session_id,
        slug: row.slug,
        city: row.city || "nanaimo",
        last_activity: row.created_at,
        reactions: [],
        lead: leadBySessionId.get(row.session_id) || null,
      };
    }

    acc[key].reactions.push(row);

    if (new Date(row.created_at) > new Date(acc[key].last_activity)) {
      acc[key].last_activity = row.created_at;
    }

    return acc;
  }, {})
);

function fmtDate(value) {
  if (!value) return "";
  return new Date(value).toLocaleString();
}

function countDecision(reactions, decision) {
  return reactions.filter((r) => r.decision === decision).length;
}

function byDecision(reactions, decision) {
  return reactions.filter((r) => r.decision === decision);
}

function getTags(row) {
  if (Array.isArray(row.liked_tags)) return row.liked_tags;

  try {
    return JSON.parse(row.liked_tags || "[]");
  } catch {
    return [];
  }
}

function parsePrice(value) {
  return Number(
    String(value || "")
      .replace(/\$/g, "")
      .replace(/,/g, "")
      .trim()
  ) || 0;
}

function avgPrice(rows) {
  const prices = rows.map((r) => parsePrice(r.price)).filter((p) => p > 0);
  if (!prices.length) return 0;

  return Math.round(prices.reduce((sum, price) => sum + price, 0) / prices.length);
}

function priceRange(rows) {
  const prices = rows.map((r) => parsePrice(r.price)).filter((p) => p > 0);
  if (!prices.length) return "";

  const min = Math.min(...prices);
  const max = Math.max(...prices);

  if (min === max) return formatMoney(min);

  return `${formatMoney(min)} - ${formatMoney(max)}`;
}

function formatMoney(price) {
  if (!price) return "Unknown";
  return `$${Number(price).toLocaleString()}`;
}

function inferPriceTrend(reactions) {
  const loves = byDecision(reactions, "love");
  const maybes = byDecision(reactions, "maybe");
  const passes = byDecision(reactions, "pass");

  const loveAvg = avgPrice(loves);
  const maybeAvg = avgPrice(maybes);
  const passAvg = avgPrice(passes);

  if (loveAvg && passAvg && loveAvg > passAvg * 1.08) {
    return `Buyer is leaning higher-budget. Loved listings average ${formatMoney(loveAvg)}, while passes average ${formatMoney(passAvg)}.`;
  }

  if (loveAvg && passAvg && loveAvg < passAvg * 0.92) {
    return `Buyer may be value-sensitive. Loved listings average ${formatMoney(loveAvg)}, below passed listings at ${formatMoney(passAvg)}.`;
  }

  if (loveAvg) return `Loved-listing price centre is around ${formatMoney(loveAvg)}.`;
  if (maybeAvg) return `Soft interest is clustering around ${formatMoney(maybeAvg)}.`;

  return `Not enough price signal yet.`;
}

function inferSession(reactions) {
  const loves = byDecision(reactions, "love");
  const maybes = byDecision(reactions, "maybe");
  const passes = byDecision(reactions, "pass");

  const lovedAreas = [...new Set(loves.map((r) => r.area).filter(Boolean))];
  const passedAreas = [...new Set(passes.map((r) => r.area).filter(Boolean))];

  if (loves.length && passes.length) {
    return `Loved ${lovedAreas.join(", ") || "one listing"} but passed on ${passedAreas.join(", ") || "another option"} - likely not choosing on price alone.`;
  }

  if (loves.length) return `Positive signal - this session has at least one strong match.`;
  if (maybes.length && !loves.length) return `Interest is soft - buyer may need a better fit or more refined options.`;
  if (passes.length && !loves.length && !maybes.length) return `Mostly negative signal - current page may not be matching their intent.`;

  return `Not enough behaviour yet.`;
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Intent Sessions</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; }

      :root {
        --bg: #f7f4ef;
        --surface: #fff;
        --border: rgba(24,22,20,0.10);
        --border-strong: rgba(24,22,20,0.22);
        --ink: #181614;
        --muted: rgba(24,22,20,0.52);
        --accent: #181614;
        --radius: 16px;
        --font-body: "DM Sans", system-ui, sans-serif;
        --font-display: "Instrument Serif", Georgia, serif;
      }

      body {
        font-family: var(--font-body);
        background: var(--bg);
        color: var(--ink);
        font-size: 15px;
        line-height: 1.5;
        margin: 0;
      }

      .page {
        display: grid;
        grid-template-columns: 220px 1fr;
        min-height: 100vh;
      }

     
      /* ── Main ── */
      .main {
        padding: 40px 48px 80px;
        max-width: 1000px;
      }

      .page-header {
        margin-bottom: 32px;
      }

      .page-header h1 {
        font-family: var(--font-display);
        font-size: 2.6rem;
        font-weight: 400;
        line-height: 1;
        letter-spacing: -0.03em;
        margin: 0 0 6px;
      }

      .page-header p {
        color: var(--muted);
        font-size: 0.9rem;
        margin: 0;
      }

      /* ── Session cards ── */
      .session {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        margin-bottom: 10px;
        overflow: hidden;
      }

      .session-trigger {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 18px 22px;
        background: none;
        border: none;
        cursor: pointer;
        font: inherit;
        text-align: left;
        gap: 16px;
      }

      .session-trigger:hover { background: rgba(24,22,20,0.02); }

      .session.is-open { background: #edeae3; }

      .session-trigger-left {
        display: flex;
        align-items: center;
        gap: 12px;
      }

      .session-icon {
        width: 34px;
        height: 34px;
        border-radius: 10px;
        background: var(--bg);
        border: 1px solid var(--border);
        display: grid;
        place-items: center;
        font-size: 0.7rem;
        font-weight: 900;
        flex-shrink: 0;
        color: var(--ink);
      }

      .session-title {
        font-size: 0.92rem;
        font-weight: 700;
        color: var(--ink);
      }

      .session-meta {
        font-size: 0.76rem;
        color: var(--muted);
        margin-top: 1px;
      }

      .session-chevron {
        width: 20px;
        height: 20px;
        color: var(--muted);
        transition: transform 0.22s ease;
        flex-shrink: 0;
      }

      .session.is-open .session-chevron { transform: rotate(180deg); }

      .session-body {
        display: none;
        padding: 0 22px 22px;
        border-top: 1px solid var(--border);
      }

      .session.is-open .session-body { display: block; }

      .badges {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        align-items: center;
      }

      .badge {
        padding: 5px 10px;
        border-radius: 999px;
        font-size: 0.76rem;
        font-weight: 700;
        background: var(--bg);
        border: 1px solid var(--border);
        color: var(--muted);
      }

      /* ── Inner blocks ── */
      .block {
        margin-top: 16px;
        padding: 16px;
        border-radius: 12px;
        background: var(--bg);
        border: 1px solid var(--border);
      }

      .block-label {
        font-size: 0.68rem;
        font-weight: 800;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 10px;
      }

      .insight {
        margin-top: 16px;
        padding: 14px 16px;
        border-radius: 12px;
        background: var(--bg);
        border: 1px solid var(--border);
        font-size: 0.9rem;
        color: var(--ink);
      }

      .columns {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 12px;
        margin-top: 16px;
      }

      .col {
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 14px;
        background: var(--surface);
      }

      .col summary {
        cursor: pointer;
        list-style: none;
        font-size: 0.76rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--muted);
      }

      .col summary::-webkit-details-marker { display: none; }
      .col summary::after { content: " +"; }
      .col[open] summary::after { content: " −"; }

      .col h3 {
        margin: 0 0 10px;
        font-size: 0.76rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--muted);
      }

      .listing {
        padding: 10px 0;
        border-top: 1px solid var(--border);
        font-size: 0.88rem;
      }

      .listing:first-of-type { border-top: 0; }
      .listing strong { display: block; font-size: 0.9rem; }
      .listing span { display: block; color: var(--muted); font-size: 0.82rem; margin-top: 2px; }

      .intent-open-btn {
        display: inline-flex;
        margin-top: 6px;
        padding: 5px 10px;
        border-radius: 999px;
        background: var(--surface);
        color: var(--ink);
        border: 1px solid var(--border-strong);
        font: inherit;
        font-size: 0.72rem;
        font-weight: 700;
        cursor: pointer;
        text-decoration: none;
        transition: background 0.14s;
      }

      .intent-open-btn:hover { background: var(--bg); }

      .tag-row {
        display: flex;
        flex-wrap: wrap;
        gap: 5px;
        margin-top: 7px;
      }

      .tag {
        display: inline-flex;
        align-items: center;
        padding: 4px 8px;
        border-radius: 999px;
        background: var(--bg);
        color: var(--muted);
        border: 1px solid var(--border);
        font-size: 0.68rem;
        font-weight: 700;
        text-transform: capitalize;
      }

      .empty {
        color: var(--muted);
        font-size: 0.88rem;
        padding: 8px 0;
      }

      .readiness-score {
        font-family: var(--font-display);
        font-size: 2.8rem;
        font-weight: 400;
        line-height: 1;
        letter-spacing: -0.04em;
        margin-bottom: 4px;
      }

      .readiness-label {
        font-size: 0.68rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--muted);
        margin-bottom: 16px;
      }

      .scout-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 14px;
      }

      .scout-cell strong {
        display: block;
        font-size: 0.8rem;
        margin-bottom: 4px;
      }

      .scout-cell div {
        color: var(--muted);
        font-size: 0.88rem;
      }

      .next-move {
        margin-top: 14px;
        padding: 12px 14px;
        border-radius: 10px;
        background: var(--surface);
        border: 1px solid var(--border);
        font-size: 0.88rem;
      }

      .next-move strong {
        display: block;
        font-size: 0.72rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--muted);
        margin-bottom: 6px;
      }

      .lead-block {
        margin-top: 16px;
        padding: 14px 16px;
        border-radius: 12px;
        background: var(--bg);
        border: 1px solid var(--border);
      }

      .lead-block .block-label { color: #2d7a2d; }
@media (max-width: 860px) {
  .page { grid-template-columns: 1fr; }
  .main { padding: 24px 20px 60px; }
  .columns { grid-template-columns: 1fr; }
}
    </style>
  </head>

  <body>
    <div class="page">
   <AdminSidebar active="sessions" />

      <main class="main">
        <div class="page-header">
          <h1>Intent sessions</h1>
          <p>Anonymous buyer behaviour from intent pages — grouped by session and page.</p>
        </div>

      {error && <p>Error loading sessions: {error.message}</p>}

      {sessions.map((session) => {
        const loves = byDecision(session.reactions, "love");
        const maybes = byDecision(session.reactions, "maybe");
        const passes = byDecision(session.reactions, "pass");
        const city = session.city || "nanaimo";

        return (
       <article class="session">
            <button type="button" class="session-trigger">
              <div class="session-trigger-left">
                <div class="session-icon">{countDecision(session.reactions, "love")}♥</div>
                <div>
                  <div class="session-title">{session.slug}</div>
                  <div class="session-meta">{city} · Last active: {fmtDate(session.last_activity)}</div>
                </div>
              </div>
              <div class="badges">
                <span class="badge">{session.reactions.length} reactions</span>
                <span class="badge">{countDecision(session.reactions, "love")} loves</span>
                <span class="badge">{countDecision(session.reactions, "maybe")} maybe</span>
                <span class="badge">{countDecision(session.reactions, "pass")} pass</span>
              </div>
              <svg class="session-chevron" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M5 7.5l5 5 5-5"/></svg>
            </button>

            <div class="session-body">
            <div class="insight">
              {inferSession(session.reactions)}
            </div>

         <div class="block">
              <div class="block-label">Price signal</div>

              <div style="font-weight:850;margin-bottom:10px;">
                {inferPriceTrend(session.reactions)}
              </div>

              <div style="display:flex;flex-wrap:wrap;gap:8px;">
                <span class="badge">Loved avg: {formatMoney(avgPrice(loves))}</span>
                <span class="badge">Loved range: {priceRange(loves) || "Unknown"}</span>
                <span class="badge">Maybe avg: {formatMoney(avgPrice(maybes))}</span>
                <span class="badge">Pass avg: {formatMoney(avgPrice(passes))}</span>
              </div>
           </div>

{(() => {
  const loves = byDecision(session.reactions, "love");
  const maybes = byDecision(session.reactions, "maybe");
  const passes = byDecision(session.reactions, "pass");

  const allTags = [
    ...loves.flatMap((r) => getTags(r)),
    ...maybes.flatMap((r) => getTags(r)),
  ];

  const tagCounts = {};

  allTags.forEach((tag) => {
    tagCounts[tag] = (tagCounts[tag] || 0) + 1;
  });

  const strongestTags = Object.entries(tagCounts)
    .sort((a, b) => b[1] - a[1])
    .slice(0, 4);

  const lovedAreas = {};

  loves.forEach((r) => {
    if (!r.area) return;
    lovedAreas[r.area] = (lovedAreas[r.area] || 0) + 1;
  });

  const topAreas = Object.entries(lovedAreas)
    .sort((a, b) => b[1] - a[1])
    .slice(0, 3);

  const readiness =
    Math.min(
      100,
      loves.length * 12 +
      maybes.length * 5 +
      session.reactions.length * 2
    );

  return (
   <div class="block">
        <div class="block-label">Buyer Scout Report</div>
        <div class="readiness-score">{readiness}/100</div>
        <div class="readiness-label">Buyer Readiness</div>
        <div class="scout-grid">
          <div class="scout-cell">
            <strong>Searching</strong>
            <div>{(session.slug || "").replaceAll("-", " ")}</div>
          </div>
          <div class="scout-cell">
            <strong>Target Price</strong>
            <div>{priceRange(loves) || "Unknown"}</div>
          </div>
          <div class="scout-cell">
            <strong>Strongest Preferences</strong>
            <div>{strongestTags.length ? strongestTags.map(([tag]) => <div>✓ {tag.replaceAll("_", " ")}</div>) : <div>No clear preference yet</div>}</div>
          </div>
          <div class="scout-cell">
            <strong>Top Areas</strong>
            <div>{topAreas.length ? topAreas.map(([area]) => <div>{area}</div>) : <div>Still exploring</div>}</div>
          </div>
        </div>
        <div class="next-move">
          <strong>Suggested Next Move</strong>
          {loves.length >= 3 ? "Book showing for top 3 matches." : maybes.length >= 3 ? "Refine search and surface stronger matches." : "Gather more behaviour."}
        </div>
      </div>
  );
})()}

{session.lead && (
              <div class="lead-block">
                <div class="block-label">Lead captured</div>
                <div style="font-weight:700;">{session.lead.name || "Unnamed buyer"}</div>
                {session.lead.email && <div style="color:var(--muted);margin-top:4px;">{session.lead.email}</div>}
                {session.lead.phone && <div style="color:var(--muted);margin-top:4px;">{session.lead.phone}</div>}
              </div>
            )}

            <div class="columns">
        <details class="col">
<summary>Loved Listings ({loves.length})</summary>
{loves.length ? loves.slice(0, 10).map((r) => (
  
  <div class="listing">
                    <strong>{r.address}</strong>
                    <span>{r.price} · {r.beds} bed · {r.baths} bath · {r.sqft} sqft</span>
                    <span>{r.area}</span>

                    <a
                      class="intent-open-btn"
href={`/${city}/${session.slug}?listing_id=${encodeURIComponent(r.listing_id || r.mls_number || r.address || "")}`}                      target="_blank"
                    >
                      Open listing
                    </a>

                    {getTags(r).length > 0 && (
                      <div class="tag-row">
                        {getTags(r).map((tag) => (
                          <span class="tag">{tag.replaceAll("_", " ")}</span>
                        ))}
                      </div>
                    )}
                  </div>
                )) : <div class="empty">No loves yet.</div>}
                {loves.length > 10 && (
  <div class="empty">
    + {loves.length - 10} more loved listings
  </div>
)}
              </details>

              <details class="col">
<h3>
  <a href={`/${city}/${session.slug}?intent=maybe`}>
    Kinda Liked ({maybes.length})
  </a>
</h3>{maybes.length ? maybes.slice(0, 10).map((r) => (                  <div class="listing">
                    <strong>{r.address}</strong>
                    <span>{r.price} · {r.beds} bed · {r.baths} bath · {r.sqft} sqft</span>
                    <span>{r.area}</span>

                    <a
                      class="intent-open-btn"
href={`/${city}/${session.slug}?listing_id=${encodeURIComponent(r.listing_id || r.mls_number || r.address || "")}`}                      target="_blank"
                    >
                      Open listing
                    </a>

                    {getTags(r).length > 0 && (
                      <div class="tag-row">
                        {getTags(r).map((tag) => (
                          <span class="tag">{tag.replaceAll("_", " ")}</span>
                        ))}
                      </div>
                    )}
                  </div>
             )) : <div class="empty">No maybes yet.</div>}

{maybes.length > 10 && (
  <div class="empty">
    + {maybes.length - 10} more kinda liked listings
  </div>
)}
</section>

              <section class="col">
<h3>
  <a href={`/${city}/${session.slug}?intent=pass`}>
    Passed ({passes.length})
  </a>
</h3>              {passes.length ? passes.slice(0, 10).map((r) => (
                  <div class="listing">
                    <strong>{r.address}</strong>
                    <span>{r.price} · {r.beds} bed · {r.baths} bath · {r.sqft} sqft</span>
                    <span>{r.area}</span>

                    <a
                      class="intent-open-btn"
href={`/${city}/${session.slug}?listing_id=${encodeURIComponent(r.listing_id || r.mls_number || r.address || "")}`}                      target="_blank"
                    >
                      Open listing
                    </a>
                  </div>
           )) : <div class="empty">No passes yet.</div>}

{passes.length > 10 && (
  <div class="empty">
    + {passes.length - 10} more passed listings
  </div>
)}
</section>
            </div>
         </div>
          </article>
        );
      })}
</main>
    </div>

    <script>
      document.querySelectorAll(".session-trigger").forEach((btn) => {
        btn.addEventListener("click", () => {
          const session = btn.closest(".session");
          session.classList.toggle("is-open");
        });
      });
    </script>
  </body>
</html>