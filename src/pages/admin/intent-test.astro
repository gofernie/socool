---
const intentPages = [
  {
    title: "Family Homes With Yards",
    slug: "family-homes-with-yards",
    type: "House",
    angle: "Family",
  },
  {
    title: "Family Homes With Garages",
    slug: "family-homes-with-garages",
    type: "House",
    angle: "Family",
  },
  {
    title: "Nanaimo Condos for Downsizers",
    slug: "downsizer-condos",
    type: "Condo",
    angle: "Downsizer",
  },
  {
    title: "Walkable Condos",
    slug: "walkable-condos",
    type: "Condo",
    angle: "Walkable",
  },
  {
    title: "Ocean View Condos",
    slug: "ocean-view-condos",
    type: "Condo",
    angle: "Ocean view",
  },
  {
    title: "Family Homes Under $800K",
    slug: "family-homes-under-800k",
    type: "House",
    angle: "Family",
  },
  {
    title: "Updated Family Homes",
    slug: "updated-family-homes",
    type: "House",
    angle: "Updated",
  },
  {
    title: "Investment Properties With Suites",
    slug: "investment-properties-with-suites",
    type: "House",
    angle: "Investment",
  },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Intent Page Test Links</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <style>
      body {
        margin: 0;
        font-family: system-ui, sans-serif;
        background: #f4efe7;
        color: #181614;
      }

      main {
        max-width: 980px;
        margin: 0 auto;
        padding: 40px 20px 80px;
      }

      h1 {
        margin: 0 0 10px;
        font-family: Georgia, serif;
        font-size: clamp(2.5rem, 6vw, 5rem);
        line-height: 0.92;
        letter-spacing: -0.06em;
        font-weight: 500;
      }

      p {
        color: rgba(24, 22, 20, 0.62);
        line-height: 1.5;
      }

      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: 16px;
        margin-top: 28px;
      }

      .card {
        display: block;
        padding: 20px;
        border-radius: 20px;
        background: #fff;
        border: 1px solid rgba(24, 22, 20, 0.12);
        text-decoration: none;
        transition: transform 0.16s ease, box-shadow 0.16s ease;
      }

      .card:hover {
        transform: translateY(-3px);
        box-shadow: 0 14px 34px rgba(24, 22, 20, 0.12);
      }

      .pill-row {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-bottom: 14px;
      }

      .pill {
        padding: 6px 10px;
        border-radius: 999px;
        background: #fffaf1;
        border: 1px solid rgba(24, 22, 20, 0.1);
        font-size: 0.78rem;
        font-weight: 800;
      }

      h2 {
        margin: 0 0 10px;
        font-size: 1.18rem;
        letter-spacing: -0.03em;
      }

      .url {
        color: rgba(24, 22, 20, 0.56);
        font-size: 0.9rem;
      }
    </style>
  </head>

  <body>
    <main>
      <h1>Intent page test links.</h1>

      <p>
        Use this page to quickly test each published Nanaimo intent page, modal,
        map mode, reactions, refine flow, and save-search CTA.
      </p>

      <section class="grid">
        {intentPages.map((page) => (
          <a class="card" href={`/nanaimo/${page.slug}`}>
            <div class="pill-row">
              <span class="pill">{page.type}</span>
              <span class="pill">{page.angle}</span>
            </div>

            <h2>{page.title}</h2>

            <div class="url">/nanaimo/{page.slug}</div>
          </a>
        ))}
      </section>
    </main>
  </body>
</html>