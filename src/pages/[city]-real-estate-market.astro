---
import { createClient } from "@supabase/supabase-js";
import Layout from "../layouts/Layout.astro";
import ListingCard from "../components/ListingCard.astro";
import ShortlistReviewModal from "../components/ShortlistReviewModal.astro";
import IntentModalController from "../components/IntentModalController.astro";
import SiteNav from "../components/SiteNav.astro";
import { getSite } from "../lib/getSite";
import "../styles/area-page.css";
import "../styles/page-hero.css";
import "../styles/intent-modal.css";
import { getNavIntentPages } from "../lib/getNavIntentPages";

const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.SUPABASE_SERVICE_ROLE_KEY
);

const site = await getSite(Astro.url.hostname);

const city =
  String(
    Astro.url.searchParams.get("city") ||
    Astro.params.city ||
    site?.city ||
    "nanaimo"
  )
    .toLowerCase()
    .trim();

    console.log({
  hostname: Astro.url.hostname,
  paramCity: Astro.params.city,
  siteCity: site?.city,
  finalCity: city,
});



const cityLabel = city.replace(/-/g, " ").replace(/\b\w/g, (c) => c.toUpperCase());

const agentPageSlug =
  site?.city?.toLowerCase() === "parksville"
    ? "parksville"
    : "chris-crump";

const { data: agentPage } = await supabase
  .from("agent_pages")
  .select("data")
  .eq("slug", agentPageSlug)
  .maybeSingle();

const accentColor =
  site?.accent_color ||
  "#2f6f73";

console.log("COLOUR SOURCE DEBUG", {
  city,
  agentPageSlug,
  agentPageAccent: agentPage?.data?.accentColor,
  siteAccent: site?.accent_color,
  finalAccent: accentColor,
});

const { data: allListings = [], error } = await supabase
  .from("listing_rows")
  .select("*")
  .eq("normalized_city", city)
  .eq("status", "A");

const { data: featuredIntentPages = [], error: featuredIntentError } =
  await supabase
    .from("intent_pages")
    .select("slug, hero_heading, intro_copy")
    .eq("site_id", site?.id || "00000000-0000-0000-0000-000000000000")
    .limit(6);

console.log("FEATURED INTENT PAGES", {
  count: featuredIntentPages.length,
  rows: featuredIntentPages,
  error: featuredIntentError,
});

if (error) {
  console.error(`${cityLabel} market page error:`, error);
}

const normalizeListingImageUrl = (value: any) => {
  if (!value) return "";
  const raw =
    typeof value === "string"
      ? value
      : value.highRes ||
        value.mediumRes ||
        value.lowRes ||
        value.url ||
        value.src ||
        value.href ||
        value.path ||
        "";
  if (!raw) return "";
  if (raw.startsWith("http://") || raw.startsWith("https://")) return raw;
  const cleaned = raw.startsWith("/") ? raw : `/${raw}`;
  if (cleaned.startsWith("/vreb/")) {
    return `https://cdn.repliers.io${cleaned}`;
  }
  return cleaned;
};

const getListingImage = (listing: any) =>
  normalizeListingImageUrl(
    listing.image_url ||
      listing.image ||
      listing.photo ||
      listing.images?.[0] ||
      listing.images?.[1] ||
      listing.raw?.images?.[0] ||
      listing.raw?.images?.[1] ||
      listing.raw?.images?.[0]?.url ||
      listing.raw?.images?.[1]?.url ||
      listing.raw?.images?.[0]?.mediumRes ||
      listing.raw?.images?.[1]?.mediumRes ||
      listing.raw?.images?.[0]?.highRes ||
      listing.raw?.images?.[1]?.highRes
  );

const listings = [...allListings]
  .sort((a, b) => {
    const da = new Date(a.listed_at || a.updated_at || 0).getTime();
    const db = new Date(b.listed_at || b.updated_at || 0).getTime();
    return db - da;
  })
  .slice(0, 12);

const activeListings = allListings.length;

const prices = allListings
  .map((l) => Number(l.price || 0))
  .filter((p) => p > 0)
  .sort((a, b) => a - b);

const avgPrice =
  prices.length > 0
    ? Math.round(prices.reduce((sum, p) => sum + p, 0) / prices.length)
    : 0;

const medianPrice = prices.length > 0 ? prices[Math.floor(prices.length / 2)] : 0;

const condoCount    = allListings.filter((l) => l.normalized_type === "condo").length;
const houseCount    = allListings.filter((l) => l.normalized_type === "house").length;
const townhomeCount = allListings.filter((l) => l.normalized_type === "townhouse").length;

let areaCounts = allListings.reduce((acc, listing) => {
  const area = listing.normalized_area || "other";
  acc[area] = (acc[area] || 0) + 1;
  return acc;
}, {});

let topAreas = Object.entries(areaCounts)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 10);

const areaToSlug = (value) =>
  String(value || "")
    .toLowerCase()
    .replace(/&/g, "and")
    .replace(/\//g, "-")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");

const { data: areaMetaRows = [] } = await supabase
  .from("area_boundaries")
  .select("area_slug, area_name, short_description, polygon_geojson")
  .ilike("city", city);

const navAreaCountMap = Object.fromEntries(
  Object.entries(areaCounts).map(([label, count]) => [label.toLowerCase(), count])
);

const navAreas = areaMetaRows
  .map((r) => r.area_name || String(r.area_slug || "").replace(/-/g, " "))
  .filter(Boolean)
  .sort((a, b) => (navAreaCountMap[b.toLowerCase()] || 0) - (navAreaCountMap[a.toLowerCase()] || 0));

const navTypes = ["house", "condo", "townhouse", "land"];

const cleanAreaName = (value) =>
  String(value || "")
    .replace(/^pq[\s-]+/i, "")
    .split("-")
    .join(" ")
    .replace(/\s+/g, " ")
    .trim();

const labelize = (value) =>
  cleanAreaName(value)
    .replace(/\b\w/g, (c) => c.toUpperCase());

function areaHue(areaName, index) {
  let hash = 0;

  for (const char of String(areaName || "")) {
    hash = char.charCodeAt(0) + ((hash << 5) - hash);
  }

  const hues = [355, 18, 34, 48, 205, 178, 155, 285, 315, 12, 92, 230];
  return hues[Math.abs(hash + index * 7) % hues.length];
}

const priceBuckets = [
  { label: "Under $500k", min: 0, max: 500000 },
  { label: "$500k–$750k", min: 500000, max: 750000 },
  { label: "$750k–$1M", min: 750000, max: 1000000 },
  { label: "$1M–$1.5M", min: 1000000, max: 1500000 },
  { label: "$1.5M+", min: 1500000, max: Infinity },
];

const priceBucketCounts = priceBuckets.map((bucket) =>
  allListings.filter((listing) => {
    const price = Number(listing.price || 0);
    return price >= bucket.min && price < bucket.max;
  }).length
);





  const areaBoundariesBySlug = Object.fromEntries(
  areaMetaRows
    .filter((row) => row.polygon_geojson?.coordinates?.[0]?.length)
    .map((row) => [row.area_slug, row.polygon_geojson])
);

function pointInPolygon(point, polygon) {
  const [lng, lat] = point;
  let inside = false;

  for (let i = 0, j = polygon.length - 1; i < polygon.length; j = i++) {
    const [xi, yi] = polygon[i];
    const [xj, yj] = polygon[j];

    const intersect =
      yi > lat !== yj > lat &&
      lng < ((xj - xi) * (lat - yi)) / (yj - yi) + xi;

    if (intersect) inside = !inside;
  }

  return inside;
}

areaCounts = Object.fromEntries(
  (areaMetaRows || []).map((row: any) => {
    const slug = areaToSlug(row.area_slug || row.area_name);
    const label = row.area_name || String(row.area_slug || "").replace(/-/g, " ");
    const polygon = row.polygon_geojson?.coordinates?.[0];

   const count = polygon?.length
  ? allListings.filter((listing) => {
      const lat = Number(listing.lat || 0);
      const lng = Number(listing.lng || 0);

      if (!lat || !lng) return false;

      return pointInPolygon([lng, lat], polygon);
    }).length
  : 0;

    return [label, count];
  })
);

topAreas = Object.entries(areaCounts)
  .sort((a, b) => Number(b[1]) - Number(a[1]));

function getAreaCardCount(area, fallbackCount) {
  const boundary = areaBoundariesBySlug[areaToSlug(area)];
  const polygon = boundary?.coordinates?.[0];

  if (!polygon?.length) {
    return fallbackCount;
  }

const normalizedAreaListings = allListings.filter(
  (listing) => areaToSlug(listing.normalized_area) === areaToSlug(area)
);

return allListings.filter((listing) => {
  const lat = Number(listing.lat || 0);
  const lng = Number(listing.lng || 0);

  if (!lat || !lng) {
    return false;
  }

  return pointInPolygon([lng, lat], polygon);
}).length;
}

const areaDescriptions = Object.fromEntries(
  areaMetaRows.map((row) => [
    row.area_slug,
    row.short_description,
  ])
);



function areaTagIcon(tag: string) {
  const clean = String(tag || "").toLowerCase();

  if (clean.includes("ocean") || clean.includes("waterfront") || clean.includes("beach") || clean.includes("harbour")) return "🏖";
  if (clean.includes("shopping") || clean.includes("services") || clean.includes("convenience")) return "🛍";
  if (clean.includes("park") || clean.includes("trail") || clean.includes("recreation")) return "🌳";
  if (clean.includes("walk")) return "🚶";
  if (clean.includes("viu") || clean.includes("school")) return "🎓";
  if (clean.includes("investment") || clean.includes("value")) return "💰";
  if (clean.includes("family")) return "🏡";
  if (clean.includes("character")) return "🏛";
  if (clean.includes("rural") || clean.includes("space") || clean.includes("lots")) return "🌲";
  if (clean.includes("quiet")) return "🌿";
  if (clean.includes("condos")) return "🏢";
  if (clean.includes("ferry")) return "⛴️";

  return "📍";
}

const chartData = {
  priceLabels: priceBuckets.map((b) => b.label),
  priceCounts: priceBucketCounts,

  areaLabels: topAreas.map(([area]) =>
    labelize(area)
      .replace("North Nanaimo", "North")
      .replace("South Nanaimo", "South")
      .replace("Central Nanaimo", "Central")
      .replace("University District", "University")
      .replace("Departure Bay", "Departure")
      .replace("Pleasant Valley", "Pleasant")
  ),

  areaCounts: topAreas.map(([, count]) => count),
};

const navIntentPages = await getNavIntentPages(supabase, city);

---
{console.log("LAYOUT ACCENT", {
  city,
  agentPageSlug,
  agentPage,
  accentColor
})}
<Layout title={`${cityLabel} Real Estate Market Report`} accentColor={accentColor} city={city}>
 
  


<SiteNav
  city={city}
  areas={navAreas}
  types={navTypes}
  intentPages={navIntentPages}
  showAreaNav={false}
/>
  <!-- ── Hero ── -->
 <header
  class="page-hero"
  style={`--hero-image: url('https://images.unsplash.com/photo-1600585154340-be6161a56a0c?auto=format&fit=crop&w=1200&q=70')`}
>
  <div class="page-hero__inner">
    <p class="page-hero__eyebrow">{cityLabel} Market Report</p>

    <h1>{cityLabel} Real Estate<br />Market</h1>

    <p class="page-hero__copy">
      Explore active listings, inventory levels, pricing trends and
      neighbourhood activity across {cityLabel}.
    </p>
  </div>
</header>

  <!-- ── Area browse nav ── -->
 <nav class="area-browse-nav">
  <div class="shell area-browse-nav__inner">
    <span>Explore more {cityLabel} areas</span>

   {navAreas.slice(0, 4).map((item) => (
 <a href={`/${city}/areas/${areaToSlug(item)}`}>
  {labelize(item)}
</a>
))}

    {navAreas.length > 4 && (
      <select onchange="if(this.value) window.location.href=this.value;">
        <option value="">+{navAreas.length - 4} more areas</option>
        {navAreas.slice(4).map((item) => (
         <option value={`/${city}/areas/${areaToSlug(item)}`}>
  {labelize(item)}
</option>
        ))}
      </select>
    )}
  </div>
</nav>

  <main class="shell">

    <section class="content-card area-picker">
  <div class="section-heading">
   <span class="eyebrow">Browse by Area</span>
    <h2 id="browse-by-area">Choose a {cityLabel} neighbourhood</h2>
    <p>Start with an area, then filter by property type, price, beds, and more.</p>
  </div>

 <div class="area-card-grid">
  {topAreas.map(([area, count], index) => (
    <a
      class="area-pick-card"
href={`/${city}/areas/${areaToSlug(area)}`}
style={(() => {
  const slug = areaToSlug(area);
  let hash = 0;
  for (let i = 0; i < slug.length; i++) hash = slug.charCodeAt(i) + ((hash << 5) - hash);
  const tint = 6 + (Math.abs(hash) % 12);
  const border = 14 + (Math.abs(hash >> 3) % 10);
  return `--area-tint:${tint}%; --area-border:${border}%;`;
})()}
    >
     <strong>{labelize(area)}</strong>

      <div class="area-pick-card-body">
        <div class="area-count">
          {getAreaCardCount(area, count) === 1
  ? "1 listing"
  : `${getAreaCardCount(area, count)} listings`}
        </div>

        {areaDescriptions[areaToSlug(area)] && (
          <div class="area-highlights">
            {areaDescriptions[areaToSlug(area)]
              .split("•")
              .filter(Boolean)
              .slice(0, 2)
              .map((tag) => (
                <div class="area-highlight">
                  <span class="area-highlight-icon">{areaTagIcon(tag)}</span>
                  <span>{tag.trim()}</span>
                </div>
              ))}
          </div>
        )}

        <span class="area-card-link">View area →</span>
      </div>
    </a>
  ))}
</div>
</section>

   <!-- ── Latest listings ── -->
<section class="listings-section">
  <div class="section-heading" style="margin-bottom: 24px;">
    <span class="eyebrow">Latest Listings</span>
    <h2>Newest {cityLabel} Listings</h2>
    <p>
      A quick look at some of the newest active listings currently available
      across {cityLabel}.
    </p>
  </div>

  <div class="listing-grid">
    {listings.map((listing, index) => (
      <div
        class="listing-card-wrap"
        data-type={listing.normalized_type || ""}
        data-price={listing.price || 0}
        data-beds={listing.beds || 0}
        data-listed={listing.listed_at || ""}
      >
        <ListingCard
  listing={listing}
  image={getListingImage(listing)}
  priority={index < 3}
/>
      </div>
    ))}
  </div>
</section>

<!-- ── Stats ── -->
<section class="area-stats">
  <div class="stat-card">
    <strong>{activeListings}</strong>
    <span>Active Listings</span>
  </div>
  <div class="stat-card">
    <strong>${avgPrice.toLocaleString()}</strong>
    <span>Average Price</span>
  </div>
  <div class="stat-card">
    <strong>${medianPrice.toLocaleString()}</strong>
    <span>Median Price</span>
  </div>
  <div class="stat-card">
    <strong>{houseCount}</strong>
    <span>Houses</span>
  </div>
  <div class="stat-card">
    <strong>{condoCount}</strong>
    <span>Condos</span>
  </div>
  <div class="stat-card">
    <strong>{townhomeCount}</strong>
    <span>Townhomes</span>
  </div>
</section>

<!-- ── Charts ── -->
<section class="market-row">
  <section class="chart-card">
    <div>
      <span class="eyebrow">Price Distribution</span>
      <h2>Where {cityLabel} Inventory Sits by Price</h2>
    </div>
    <div class="chart-wrap">
      <canvas id="priceChart"></canvas>
    </div>
  </section>

  <section class="chart-card">
    <div>
      <span class="eyebrow">Area Activity</span>
      <h2>Top Areas by Listing Count</h2>
    </div>
    <div class="chart-wrap">
      <canvas id="areaChart"></canvas>
    </div>
  </section>
</section>

    <!-- ── Intent interrupter ── -->
    <section class="intent-interrupter">
      <div class="intent-interrupter__inner">
        <span class="eyebrow" style="color: rgba(255,255,255,0.6);">Explore {cityLabel} Homes</span>
        <h2>Browse Curated Collections</h2>
        <p>
          Looking for something specific? Explore some of {cityLabel}'s most popular
home searches.
        </p>
        <div class="intent-grid">
          {featuredIntentPages.map((intentPage) => (
            <a href={`/${city}/${intentPage.slug}`} class="intent-tile">
              <strong>{intentPage.hero_heading}</strong>
              <span>
                {intentPage.intro_copy ||
                  `Explore this curated ${cityLabel} real estate search.`}
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    

    <!-- ── Popular searches ── -->
    <section class="content-card">
    <h2>Popular {cityLabel} Searches</h2>
     <ul>
  {featuredIntentPages.map((intentPage) => (
    <li>
      <a href={`/${city}/${intentPage.slug}`}>
        {intentPage.hero_heading}
      </a>
    </li>
  ))}
</ul>
    </section>

  </main>

  <ShortlistReviewModal />
  <IntentModalController />

 <script is:inline define:vars={{ chartData }}>
  window.addEventListener("DOMContentLoaded", () => {
      if (!window.Chart) {
        console.error("Chart.js did not load");
        return;
      }

      const priceCanvas = document.getElementById("priceChart");
      const areaCanvas  = document.getElementById("areaChart");
      if (!priceCanvas || !areaCanvas) return;

      const sharedOptions = {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: { displayColors: false },
        },
        scales: {
          x: {
            grid: { display: false },
            ticks: { maxRotation: 0, minRotation: 0, font: { size: 10 } },
          },
          y: {
            beginAtZero: true,
            border: { display: false },
            grid: { color: "rgba(28,25,23,0.08)" },
            ticks: { precision: 0, font: { size: 10 } },
          },
        },
      };

      new Chart(priceCanvas, {
        type: "bar",
        data: {
          labels: chartData.priceLabels,
          datasets: [{ label: "Listings", data: chartData.priceCounts }],
        },
        options: sharedOptions,
      });

      new Chart(areaCanvas, {
        type: "bar",
        data: {
          labels: chartData.areaLabels,
          datasets: [{ label: "Listings", data: chartData.areaCounts }],
        },
        options: sharedOptions,
      });
    });
  </script>
</Layout>

<style>
