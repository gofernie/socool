---
import { createClient } from "@supabase/supabase-js";
import Layout from "../layouts/Layout.astro";
import ListingCard from "../components/ListingCard.astro";
import ShortlistReviewModal from "../components/ShortlistReviewModal.astro";
import IntentModalController from "../components/IntentModalController.astro";
import SiteNav from "../components/SiteNav.astro";
import { getSite } from "../lib/getSite";
import "../styles/area-page.css";
import "../styles/intent-modal.css";

const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.SUPABASE_SERVICE_ROLE_KEY
);

const site = await getSite(Astro.url.hostname);

const city =
  String(Astro.params.city || site?.city || "nanaimo")
    .toLowerCase()
    .trim();

    console.log({
  hostname: Astro.url.hostname,
  paramCity: Astro.params.city,
  siteCity: site?.city,
  finalCity: city,
});



const cityLabel = city.replace(/-/g, " ").replace(/\b\w/g, (c) => c.toUpperCase());

const agentPageSlug =
  site?.city?.toLowerCase() === "parksville"
    ? "parksville"
    : "chris-crump";

const { data: agentPage } = await supabase
  .from("agent_pages")
  .select("data")
  .eq("slug", agentPageSlug)
  .maybeSingle();

const accentColor =
  agentPage?.data?.accentColor ||
  site?.accent_color ||
  "#2f6f73";

console.log("COLOUR SOURCE DEBUG", {
  city,
  agentPageSlug,
  agentPageAccent: agentPage?.data?.accentColor,
  siteAccent: site?.accent_color,
  finalAccent: accentColor,
});

const { data: allListings = [], error } = await supabase
  .from("listing_rows")
  .select("*")
.eq("normalized_city", city);

const { data: featuredIntentPages = [], error: featuredIntentError } =
  await supabase
    .from("intent_pages")
    .select("slug, hero_heading, intro_copy")
    .eq("site_id", site?.id || "00000000-0000-0000-0000-000000000000")
    .limit(6);

console.log("FEATURED INTENT PAGES", {
  count: featuredIntentPages.length,
  rows: featuredIntentPages,
  error: featuredIntentError,
});

if (error) {
  console.error(`${cityLabel} market page error:`, error);
}

const normalizeListingImageUrl = (value: any) => {
  if (!value) return "";
  const raw =
    typeof value === "string"
      ? value
      : value.highRes ||
        value.mediumRes ||
        value.lowRes ||
        value.url ||
        value.src ||
        value.href ||
        value.path ||
        "";
  if (!raw) return "";
  if (raw.startsWith("http://") || raw.startsWith("https://")) return raw;
  const cleaned = raw.startsWith("/") ? raw : `/${raw}`;
  if (cleaned.startsWith("/vreb/")) {
    return `https://cdn.repliers.io${cleaned}`;
  }
  return cleaned;
};

const getListingImage = (listing: any) =>
  normalizeListingImageUrl(
    listing.image_url ||
      listing.image ||
      listing.photo ||
      listing.images?.[0] ||
      listing.images?.[1] ||
      listing.raw?.images?.[0] ||
      listing.raw?.images?.[1] ||
      listing.raw?.images?.[0]?.url ||
      listing.raw?.images?.[1]?.url ||
      listing.raw?.images?.[0]?.mediumRes ||
      listing.raw?.images?.[1]?.mediumRes ||
      listing.raw?.images?.[0]?.highRes ||
      listing.raw?.images?.[1]?.highRes
  );

const listings = [...allListings]
  .sort((a, b) => {
    const da = new Date(a.listed_at || a.updated_at || 0).getTime();
    const db = new Date(b.listed_at || b.updated_at || 0).getTime();
    return db - da;
  })
  .slice(0, 12);

const activeListings = allListings.length;

const prices = allListings
  .map((l) => Number(l.price || 0))
  .filter((p) => p > 0)
  .sort((a, b) => a - b);

const avgPrice =
  prices.length > 0
    ? Math.round(prices.reduce((sum, p) => sum + p, 0) / prices.length)
    : 0;

const medianPrice = prices.length > 0 ? prices[Math.floor(prices.length / 2)] : 0;

const condoCount    = allListings.filter((l) => l.normalized_type === "condo").length;
const houseCount    = allListings.filter((l) => l.normalized_type === "house").length;
const townhomeCount = allListings.filter((l) => l.normalized_type === "townhouse").length;

const areaCounts = allListings.reduce((acc, listing) => {
  const area = listing.normalized_area || "other";
  acc[area] = (acc[area] || 0) + 1;
  return acc;
}, {});

const topAreas = Object.entries(areaCounts)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 10);

const navAreas = Object.keys(areaCounts)
  .filter((area) => area && area !== "unknown" && area !== "other")
  .sort((a, b) => a.localeCompare(b));

const navTypes = [
  ...new Set(
    allListings
      .map((listing) => String(listing.normalized_type || "").trim())
      .filter((type) => type && type !== "unknown")
  ),
].sort((a, b) => a.localeCompare(b));

const labelize = (value) =>
  String(value || "")
    .split("-")
    .join(" ")
    .replace(/\b\w/g, (c) => c.toUpperCase());

const priceBuckets = [
  { label: "Under $500k", min: 0, max: 500000 },
  { label: "$500k–$750k", min: 500000, max: 750000 },
  { label: "$750k–$1M", min: 750000, max: 1000000 },
  { label: "$1M–$1.5M", min: 1000000, max: 1500000 },
  { label: "$1.5M+", min: 1500000, max: Infinity },
];

const priceBucketCounts = priceBuckets.map((bucket) =>
  allListings.filter((listing) => {
    const price = Number(listing.price || 0);
    return price >= bucket.min && price < bucket.max;
  }).length
);

const chartData = {
  priceLabels: priceBuckets.map((b) => b.label),
  priceCounts: priceBucketCounts,
  areaLabels: topAreas.map(([area]) =>
    labelize(area)
      .replace("North Nanaimo", "North")
      .replace("South Nanaimo", "South")
      .replace("Central Nanaimo", "Central")
      .replace("University District", "University")
      .replace("Departure Bay", "Departure")
      .replace("Pleasant Valley", "Pleasant")
  ),
  areaCounts: topAreas.map(([, count]) => count),
};


---
{console.log("LAYOUT ACCENT", {
  city,
  agentPageSlug,
  agentPage,
  accentColor
})}
<Layout title={`${cityLabel} Real Estate Market Report`} accentColor={accentColor}>
 
  
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

  <SiteNav city={city} areas={navAreas} types={navTypes} showAreaNav={false} />

  <!-- ── Hero ── -->
  <header
    class="area-hero"
    style="--hero-image: url('https://images.unsplash.com/photo-1506744038136-46273834b3fb?auto=format&fit=crop&w=1800&q=80'); background-position: center right;"
  >
    <div class="shell area-hero__inner">
      <p class="area-eyebrow">{cityLabel} Market Report</p>
<h1>{cityLabel} Real Estate<br />Market</h1>
<p class="area-intro">
  Explore active listings, inventory levels, pricing trends and
  neighbourhood activity across {cityLabel}.
</p>
    </div>
  </header>

  <!-- ── Area browse nav ── -->
  <nav class="area-browse-nav">
    <div class="shell area-browse-nav__inner">
   <span>Explore {cityLabel} areas</span>
      {navAreas.slice(0, 8).map((item) => (
       <a href={`/${city}/areas/${item.replace(/\s+/g, "-")}`}>
          {labelize(item)}
        </a>
      ))}
    </div>
  </nav>

  <main class="shell">

    <!-- ── Stats ── -->
    <section class="area-stats">
      <div class="stat-card">
        <strong>{activeListings}</strong>
        <span>Active Listings</span>
      </div>
      <div class="stat-card">
        <strong>${avgPrice.toLocaleString()}</strong>
        <span>Average Price</span>
      </div>
      <div class="stat-card">
        <strong>${medianPrice.toLocaleString()}</strong>
        <span>Median Price</span>
      </div>
      <div class="stat-card">
        <strong>{houseCount}</strong>
        <span>Houses</span>
      </div>
      <div class="stat-card">
        <strong>{condoCount}</strong>
        <span>Condos</span>
      </div>
      <div class="stat-card">
        <strong>{townhomeCount}</strong>
        <span>Townhomes</span>
      </div>
    </section>

    <!-- ── Charts ── -->
    <section class="market-row">
      <section class="chart-card">
        <div>
          <span class="eyebrow">Price Distribution</span>
          <h2>Where {cityLabel} Inventory Sits by Price</h2>
        </div>
        <div class="chart-wrap">
          <canvas id="priceChart"></canvas>
        </div>
      </section>

      <section class="chart-card">
        <div>
          <span class="eyebrow">Area Activity</span>
          <h2>Top Areas by Listing Count</h2>
        </div>
        <div class="chart-wrap">
          <canvas id="areaChart"></canvas>
        </div>
      </section>
    </section>

    <!-- ── Latest listings ── -->
    <section class="listings-section">
      <div class="section-heading" style="margin-bottom: 24px;">
        <span class="eyebrow">Latest Listings</span>
       <h2>Newest {cityLabel} Listings</h2>
<p>
  A quick look at some of the newest active listings currently available
  across {cityLabel}.
</p>
      </div>

      <div class="listing-grid">
        {listings.map((listing) => (
          <div
            class="listing-card-wrap"
            data-type={listing.normalized_type || ""}
            data-price={listing.price || 0}
            data-beds={listing.beds || 0}
            data-listed={listing.listed_at || ""}
          >
            <ListingCard listing={listing} image={getListingImage(listing)} />
          </div>
        ))}
      </div>
    </section>

    <!-- ── Intent interrupter ── -->
    <section class="intent-interrupter">
      <div class="intent-interrupter__inner">
        <span class="eyebrow" style="color: rgba(255,255,255,0.6);">Explore {cityLabel} Homes</span>
        <h2>Browse Curated Collections</h2>
        <p>
          Looking for something specific? Explore some of {cityLabel}'s most popular
home searches.
        </p>
        <div class="intent-grid">
          {featuredIntentPages.map((intentPage) => (
            <a href={`/${city}/${intentPage.slug}`} class="intent-tile">
              <strong>{intentPage.hero_heading}</strong>
              <span>
                {intentPage.intro_copy ||
                  `Explore this curated ${cityLabel} real estate search.`}
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ── Area table ── -->
    <section class="content-card">
      <h2>Market Activity by Area</h2>
      <div class="area-table">
        {topAreas.map(([area, count]) => (
          <a
            class="area-row"
            href={`/${city}/areas/${String(area).replace(/\s+/g, "-")}`}
          >
            <span>{labelize(area)}</span>
            <strong>{count} listings</strong>
          </a>
        ))}
      </div>
    </section>

    <!-- ── Popular searches ── -->
    <section class="content-card">
    <h2>Popular {cityLabel} Searches</h2>
     <ul>
  {featuredIntentPages.map((intentPage) => (
    <li>
      <a href={`/${city}/${intentPage.slug}`}>
        {intentPage.hero_heading}
      </a>
    </li>
  ))}
</ul>
    </section>

  </main>

  <ShortlistReviewModal />
  <IntentModalController />

 <script is:inline define:vars={{ chartData }}>
  window.addEventListener("DOMContentLoaded", () => {
      if (!window.Chart) {
        console.error("Chart.js did not load");
        return;
      }

      const priceCanvas = document.getElementById("priceChart");
      const areaCanvas  = document.getElementById("areaChart");
      if (!priceCanvas || !areaCanvas) return;

      const sharedOptions = {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: { displayColors: false },
        },
        scales: {
          x: {
            grid: { display: false },
            ticks: { maxRotation: 0, minRotation: 0, font: { size: 10 } },
          },
          y: {
            beginAtZero: true,
            border: { display: false },
            grid: { color: "rgba(28,25,23,0.08)" },
            ticks: { precision: 0, font: { size: 10 } },
          },
        },
      };

      new Chart(priceCanvas, {
        type: "bar",
        data: {
          labels: chartData.priceLabels,
          datasets: [{ label: "Listings", data: chartData.priceCounts }],
        },
        options: sharedOptions,
      });

      new Chart(areaCanvas, {
        type: "bar",
        data: {
          labels: chartData.areaLabels,
          datasets: [{ label: "Listings", data: chartData.areaCounts }],
        },
        options: sharedOptions,
      });
    });
  </script>
</Layout>

<style>

  .chart-wrap {
  position: relative;
  height: 280px;
  min-height: 280px;
}

.chart-wrap canvas {
  width: 100% !important;
  height: 100% !important;
}
  /* ── Page-specific styles only — shared tokens come from Layout + area-page.css ── */

  /* Stats: 6-col on this page (area-page.css defaults to 6 already, matches) */

  /* Charts side-by-side (market-row already handles this in area-page.css) */

  /* Listings section spacing */
  .listings-section {
    margin-bottom: 54px;
  }

  /* Content cards */
  .content-card {
    padding: 34px 0 46px;
    border-top: 1px solid var(--line);
  }

  .content-card h2 {
    font-family: var(--f-display);
    font-size: clamp(2.2rem, 4vw, 3.2rem);
    line-height: 0.98;
    letter-spacing: -0.06em;
    font-weight: 500;
    margin-bottom: 20px;
  }

  .content-card ul {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 12px;
    list-style: none;
    margin-top: 18px;
  }

  .content-card li a {
    display: block;
    padding: 18px;
    border-radius: 16px;
    background: var(--card-bg);
    border: 1px solid var(--line-warm);
    font-weight: 700;
    transition: all 0.2s var(--ease);
  }

  .content-card li a:hover {
    transform: translateY(-2px);
    border-color: var(--accent-light);
    box-shadow: 0 12px 28px rgba(28, 25, 23, 0.08);
  }

  /* Area table */
  .area-table {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
    margin-top: 18px;
  }

  .area-row {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding: 15px 18px;
    border-radius: 12px;
    background: var(--card-bg);
    border: 1px solid var(--line-warm);
    color: inherit;
    font-weight: 700;
    text-decoration: none;
    transition: all 0.2s var(--ease);
  }

  .area-row:hover {
    transform: translateY(-2px);
    border-color: var(--accent-light);
    box-shadow: 0 12px 28px rgba(28, 25, 23, 0.08);
  }

  /* Intent interrupter */
  .intent-interrupter {
    margin: 20px 0 54px;
  }

  .intent-interrupter__inner {
    padding: 48px;
    border-radius: 28px;
    background: #181614;
    color: #ffffff;
  }

  .intent-interrupter h2 {
    margin: 0 0 12px;
    font-family: var(--f-display);
    font-size: clamp(2.4rem, 4vw, 4rem);
    line-height: 0.95;
    letter-spacing: -0.06em;
    font-weight: 500;
    color: #fff;
  }

  .intent-interrupter p {
    max-width: 620px;
    margin-bottom: 30px;
    color: rgba(255, 255, 255, 0.72);
  }

  .intent-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .intent-tile {
    display: block;
    padding: 22px;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.08);
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .intent-tile:hover {
    transform: translateY(-3px);
    background: rgba(255, 255, 255, 0.1);
  }

  .intent-tile strong {
    display: block;
    margin-bottom: 8px;
    font-size: 1rem;
    color: #fff;
  }

  .intent-tile span {
    display: block;
    color: rgba(255, 255, 255, 0.68);
    font-size: 0.9rem;
    line-height: 1.5;
  }

  @media (max-width: 640px) {
    .intent-grid { grid-template-columns: 1fr; }
    .intent-interrupter__inner { padding: 28px; }
    .area-table { grid-template-columns: 1fr; }
  }
</style>
