---
import { loadAgentPage, getListingImage, getListingImages, getListingPrice, getListingAddress, getListingBeds, getListingBaths, getListingSqft, getListingYearBuilt, getListingLotSize, getListingArea, getListingPropertyType, getListingDom, getListingDescription, getListingMls } from "../lib/agent-listings";

export const prerender = false;

const slug = "chris-crump";

const {
  page,
  agent,
  groups,
  newListings,
  featuredListing,
  marketStats,
  socialLinks,
  hasSocialSection,
  newListingsHref,
  heroHeadingMain,
  heroHeadingAccent,
  listingCity,
} = await loadAgentPage(slug, Astro, import.meta.env);

if (page.template !== "calm") {
  return Astro.redirect("/brutal");
}
---

<html lang="en">
  <head>
    <title>{agent.city} homes with {agent.name}</title>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={`Explore homes in ${agent.city} with ${agent.name}. Curated listings, local context, and honest guidance.`} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Nunito+Sans:opsz,wght@6..12,300;6..12,400;6..12,500;6..12,600&display=swap" rel="stylesheet" />

    <style>
      :root {
        --bg: #f5f2ed;
        --surface: #fdfcfa;
        --surface-warm: #f9f6f1;
        --ink: #1c1917;
        --ink-soft: #3d3935;
        --muted: #6b6560;
        --soft: #9c9590;
        --line: #e8e3dc;
        --line-warm: #ddd8d0;
        --accent: #8b6f47;
        --accent-light: #c4a882;
        --accent-bg: #f7f0e6;

        --f-display: "Lora", Georgia, serif;
        --f-body: "Nunito Sans", -apple-system, BlinkMacSystemFont, sans-serif;
        --ease: cubic-bezier(0.25, 0.46, 0.45, 0.94);
        --radius: 12px;
        --radius-lg: 20px;
      }

      * { box-sizing: border-box; margin: 0; padding: 0; }
      html, body { width: 100%; overflow-x: hidden; }
      body { font-family: var(--f-body); background: var(--bg); color: var(--ink); font-size: 16px; line-height: 1.6; -webkit-font-smoothing: antialiased; }
      body.modal-open { overflow: hidden; }
      a { color: inherit; text-decoration: none; }
      button { font: inherit; }
      .page { min-height: 100vh; }
      .shell { width: min(1400px, calc(100% - 80px)); margin: 0 auto; }

      /* HEADER */
      .agent-header { position: sticky; top: 0; z-index: 100; background: rgba(245, 242, 237, 0.92); backdrop-filter: blur(16px) saturate(160%); -webkit-backdrop-filter: blur(16px) saturate(160%); border-bottom: 1px solid var(--line); padding: 18px 0; }
      .agent-header__inner { display: flex; justify-content: space-between; align-items: center; gap: 24px; }
      .agent-brand { display: flex; flex-direction: column; gap: 2px; }
      .agent-brand strong { font-family: var(--f-display); font-size: 1.1rem; font-weight: 600; letter-spacing: -0.01em; color: var(--ink); }
      .agent-brand span { font-size: 0.78rem; color: var(--muted); font-weight: 400; }
      .agent-contact { background: var(--accent); color: white; padding: 10px 22px; border-radius: 999px; font-size: 0.82rem; font-weight: 600; transition: all 0.2s var(--ease); }
      .agent-contact:hover { background: var(--ink); transform: translateY(-1px); box-shadow: 0 4px 16px rgba(28, 25, 23, 0.18); }

      /* HERO */
      .hero { padding: 80px 0 60px; background: var(--surface); border-bottom: 1px solid var(--line); }
      .hero__grid { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center; }
      .eyebrow { display: inline-flex; align-items: center; gap: 8px; margin: 0 0 24px; color: var(--accent); font-size: 0.75rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; }
      .eyebrow::before { content: ""; width: 24px; height: 1px; background: var(--accent-light); }
      .hero-title { font-family: var(--f-display); font-size: clamp(3rem, 6vw, 5.5rem); font-weight: 400; line-height: 1.08; letter-spacing: -0.02em; color: var(--ink); margin: 0 0 28px; }
      .hero-title em { font-style: italic; color: var(--accent); }
      .hero-intro { color: var(--muted); font-size: 1.05rem; line-height: 1.75; max-width: 480px; margin: 0 0 36px; font-weight: 300; }
      .btn-row { display: flex; flex-wrap: wrap; gap: 12px; }
      .btn { display: inline-flex; align-items: center; justify-content: center; min-height: 48px; padding: 0 28px; font-size: 0.88rem; font-weight: 600; border-radius: 999px; transition: all 0.22s var(--ease); }
      .btn--primary { background: var(--accent); color: white; border: 2px solid var(--accent); }
      .btn--primary:hover { background: var(--ink); border-color: var(--ink); transform: translateY(-2px); box-shadow: 0 6px 20px rgba(28, 25, 23, 0.18); }
      .btn--secondary { background: transparent; color: var(--ink-soft); border: 1.5px solid var(--line-warm); }
      .btn--secondary:hover { border-color: var(--accent-light); color: var(--accent); transform: translateY(-2px); }

      /* HERO CARD */
      .hero-card { background: var(--surface-warm); border-radius: var(--radius-lg); border: 1px solid var(--line-warm); overflow: hidden; box-shadow: 0 8px 40px rgba(28, 25, 23, 0.08); transition: transform 0.3s var(--ease), box-shadow 0.3s var(--ease); }
      .hero-card:hover { transform: translateY(-4px); box-shadow: 0 16px 60px rgba(28, 25, 23, 0.12); }
      .hero-card__placeholder { padding: 40px; min-height: 380px; display: flex; flex-direction: column; justify-content: center; }
      .hero-card__placeholder-eyebrow { font-size: 0.72rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--accent-light); margin-bottom: 16px; }
      .hero-card__placeholder strong { font-family: var(--f-display); font-size: 1.6rem; font-weight: 500; color: var(--ink); display: block; margin-bottom: 12px; line-height: 1.3; }
      .hero-card__placeholder p { color: var(--muted); font-size: 0.95rem; line-height: 1.6; font-weight: 300; }
      .featured-listing-btn { appearance: none; border: 0; background: transparent; padding: 0; cursor: pointer; color: inherit; text-align: left; width: 100%; display: flex; flex-direction: column; }
      .featured-listing__image { width: 100%; height: 260px; background: linear-gradient(135deg, var(--accent-bg), var(--line-warm)); background-size: cover; background-position: center; position: relative; flex-shrink: 0; }
      .featured-listing__image::after { content: ""; position: absolute; inset: 0; background: linear-gradient(to top, rgba(28, 25, 23, 0.55), transparent 50%); }
      .featured-listing__badge { position: absolute; top: 16px; left: 16px; z-index: 2; background: white; color: var(--accent); padding: 5px 12px; border-radius: 999px; font-size: 0.68rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; }
      .featured-listing__body { padding: 24px 28px 28px; }
      .featured-listing__price { font-family: var(--f-display); font-size: 1.9rem; font-weight: 500; color: var(--ink); letter-spacing: -0.02em; margin-bottom: 6px; }
      .featured-listing__address { color: var(--muted); font-size: 0.9rem; font-weight: 300; }

      /* STATS */
      .stats-strip { padding: 40px 0; background: var(--bg); border-bottom: 1px solid var(--line); }
      .stats-strip__inner { display: grid; grid-template-columns: repeat(3, 1fr); background: var(--surface); border-radius: var(--radius-lg); border: 1px solid var(--line-warm); overflow: hidden; box-shadow: 0 2px 16px rgba(28, 25, 23, 0.05); }
      .stat-cell { padding: 28px 32px; border-right: 1px solid var(--line); transition: background 0.2s var(--ease); }
      .stat-cell:last-child { border-right: 0; }
      .stat-cell:hover { background: var(--accent-bg); }
      .stat-cell__label { display: block; font-size: 0.7rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--soft); margin-bottom: 10px; }
      .stat-cell__value { display: block; font-family: var(--f-display); font-size: 2.8rem; font-weight: 400; line-height: 1; letter-spacing: -0.02em; color: var(--ink); margin-bottom: 6px; }
      .stat-cell__meta { font-size: 0.82rem; color: var(--muted); font-weight: 300; }

      /* SECTIONS */
      .section { padding: 80px 0; }
      .section--alt { background: var(--surface); border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); }
      .section-label { display: inline-flex; align-items: center; gap: 8px; margin-bottom: 16px; color: var(--accent); font-size: 0.72rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; }
      .section-label::before { content: ""; width: 20px; height: 1px; background: var(--accent-light); }
      .section-title { font-family: var(--f-display); font-size: clamp(2rem, 4vw, 3.2rem); font-weight: 400; line-height: 1.15; letter-spacing: -0.02em; color: var(--ink); margin-bottom: 16px; }
      .section-intro { color: var(--muted); font-size: 1rem; line-height: 1.7; max-width: 520px; font-weight: 300; }
      .section-head { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: end; margin-bottom: 48px; }

      /* GROUP CARDS */
      .group-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; }
      .group-card { background: var(--surface); border-radius: var(--radius-lg); border: 1px solid var(--line-warm); padding: 32px; display: flex; flex-direction: column; justify-content: space-between; min-height: 240px; transition: all 0.28s var(--ease); position: relative; overflow: hidden; }
      .group-card::before { content: ""; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: linear-gradient(90deg, var(--accent), var(--accent-light)); opacity: 0; transition: opacity 0.28s var(--ease); }
      .group-card:hover::before { opacity: 1; }
      .group-card:hover { transform: translateY(-4px); box-shadow: 0 12px 40px rgba(28, 25, 23, 0.1); border-color: var(--accent-light); }
      .group-card__kicker { display: inline-block; font-size: 0.7rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--accent); margin-bottom: 14px; }
      .group-card__title { font-family: var(--f-display); font-size: 1.5rem; font-weight: 500; line-height: 1.2; letter-spacing: -0.01em; color: var(--ink); margin-bottom: 12px; }
      .group-card__text { color: var(--muted); font-size: 0.92rem; line-height: 1.65; font-weight: 300; flex: 1; }
      .group-card__link { display: inline-flex; align-items: center; gap: 6px; margin-top: 24px; font-size: 0.85rem; font-weight: 600; color: var(--accent); transition: gap 0.2s var(--ease); }
      .group-card__link::after { content: "→"; transition: transform 0.2s var(--ease); }
      .group-card:hover .group-card__link::after { transform: translateX(4px); }

      /* CITY */
      .city-section { display: grid; grid-template-columns: 0.8fr 1.2fr; gap: 80px; align-items: start; }
      .city-section__title { font-family: var(--f-display); font-size: clamp(2.5rem, 5vw, 4rem); font-weight: 400; line-height: 1.1; letter-spacing: -0.02em; color: var(--ink); margin-bottom: 24px; }
      .city-section__title em { font-style: italic; color: var(--accent); }
      .city-section__right p { color: var(--muted); font-size: 1rem; line-height: 1.8; margin-bottom: 20px; font-weight: 300; }
      .city-section__right p:last-child { margin-bottom: 0; }

      /* LISTINGS */
      .listing-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
      .listing-card { appearance: none; background: var(--surface); border-radius: var(--radius-lg); border: 1px solid var(--line-warm); overflow: hidden; cursor: pointer; color: inherit; text-align: left; padding: 0; transition: all 0.28s var(--ease); }
      .listing-card:hover { transform: translateY(-4px); box-shadow: 0 16px 48px rgba(28, 25, 23, 0.1); border-color: var(--accent-light); }
      .listing-card__image { width: 100%; height: 200px; background: linear-gradient(135deg, var(--accent-bg), var(--line-warm)); background-size: cover; background-position: center; position: relative; }
      .listing-card__image::after { content: ""; position: absolute; inset: 0; background: linear-gradient(to top, rgba(28, 25, 23, 0.3), transparent 60%); }
      .listing-card__body { padding: 20px 22px 22px; }
      .listing-card__price { font-family: var(--f-display); font-size: 1.5rem; font-weight: 500; letter-spacing: -0.02em; color: var(--ink); margin-bottom: 6px; }
      .listing-card__address { color: var(--muted); font-size: 0.88rem; margin-bottom: 10px; font-weight: 300; line-height: 1.4; }
      .listing-card__meta { display: flex; flex-wrap: wrap; gap: 4px 12px; font-size: 0.78rem; color: var(--soft); font-weight: 500; }
      .listing-card__meta span + span::before { content: "·"; margin-right: 12px; }
      .listing-card__desc { margin: 10px 0 0; color: var(--muted); font-size: 0.82rem; line-height: 1.55; font-weight: 300; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }

      /* BIO */
      .bio-section { display: grid; grid-template-columns: 320px 1fr; gap: 60px; align-items: start; }
      .bio-photo { aspect-ratio: 4/5; background: linear-gradient(135deg, var(--accent-bg), var(--line-warm)); border-radius: var(--radius-lg); border: 1px solid var(--line-warm); }
      .bio-name { font-family: var(--f-display); font-size: 2.8rem; font-weight: 400; letter-spacing: -0.02em; line-height: 1.1; color: var(--ink); margin-bottom: 8px; }
      .bio-title-tag { display: inline-block; background: var(--accent-bg); color: var(--accent); padding: 5px 14px; border-radius: 999px; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.05em; margin-bottom: 24px; }
      .bio-text { color: var(--muted); font-size: 1rem; line-height: 1.8; margin-bottom: 32px; font-weight: 300; }

      /* SOCIAL */
      .social-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
      .social-card { background: var(--surface); border-radius: var(--radius-lg); border: 1px solid var(--line-warm); padding: 28px 24px; display: flex; flex-direction: column; justify-content: space-between; min-height: 180px; transition: all 0.25s var(--ease); }
      .social-card:hover { transform: translateY(-3px); box-shadow: 0 8px 32px rgba(28, 25, 23, 0.08); border-color: var(--accent-light); }
      .social-card__platform { font-size: 0.68rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--accent); margin-bottom: 10px; }
      .social-card__name { font-family: var(--f-display); font-size: 1.4rem; font-weight: 500; color: var(--ink); }
      .social-card__cta { font-size: 0.82rem; font-weight: 600; color: var(--muted); margin-top: 16px; }

      /* FOOTER */
      footer { padding: 48px 0; border-top: 1px solid var(--line); background: var(--surface); }
      .footer__inner { display: flex; justify-content: space-between; align-items: center; gap: 24px; }
      .footer__brand { font-family: var(--f-display); font-size: 1rem; font-weight: 500; color: var(--ink-soft); }
      .footer__disclaimer { color: var(--soft); font-size: 0.78rem; font-weight: 300; max-width: 480px; text-align: right; }

      /* MODAL */
      .modal-overlay { position: fixed; inset: 0; background: rgba(28, 25, 23, 0.6); opacity: 0; pointer-events: none; transition: opacity 0.3s var(--ease); z-index: 800; backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px); }
      .modal-overlay.open { opacity: 1; pointer-events: auto; }
      .panel { position: fixed; left: 50%; top: 0; width: min(920px, calc(100vw - 40px)); max-height: 100vh; background: var(--surface); z-index: 900; overflow: hidden; transform: translate(-50%, -110%); transition: transform 0.45s var(--ease); display: flex; flex-direction: column; border-radius: 0 0 var(--radius-lg) var(--radius-lg); box-shadow: 0 24px 80px rgba(28, 25, 23, 0.2); }
      .panel.open { transform: translate(-50%, 0); }
      .panel__grab { display: none; }
      .panel__progress-track { height: 3px; background: var(--line); overflow: hidden; }
      .panel__progress-bar { height: 100%; width: 100%; background: linear-gradient(90deg, var(--accent), var(--accent-light)); }
      .panel__header { padding: 18px 28px; display: grid; grid-template-columns: 1fr auto auto; align-items: center; gap: 14px; background: var(--surface); border-bottom: 1px solid var(--line); }
      .panel__position { font-size: 0.72rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--soft); }
      .panel__header-actions { display: flex; align-items: center; gap: 10px; }
      .panel__top-btn, .panel__close, .panel__next-btn { appearance: none; height: 38px; padding: 0 16px; border-radius: 999px; border: 1.5px solid var(--line-warm); background: var(--surface); color: var(--ink-soft); cursor: pointer; font: inherit; font-size: 0.8rem; font-weight: 600; display: inline-flex; align-items: center; justify-content: center; transition: all 0.2s var(--ease); }
      .panel__top-btn:hover, .panel__close:hover, .panel__next-btn:hover { background: var(--ink); border-color: var(--ink); color: white; }
      .panel__top-btn:disabled, .panel__next-btn:disabled { opacity: 0.3; cursor: default; pointer-events: none; }
      .panel__close { width: 38px; padding: 0; }
      .panel__view { overflow-y: auto; flex: 1; }
      .panel__image-stage { position: relative; background: var(--line); }
      .panel__image { width: 100%; aspect-ratio: 16 / 9; object-fit: cover; display: block; }
      .panel__photo-count { position: absolute; right: 16px; bottom: 16px; z-index: 2; background: rgba(28, 25, 23, 0.75); color: white; padding: 6px 12px; border-radius: 999px; font-size: 0.72rem; font-weight: 600; }
      .photo-nav { position: absolute; top: 50%; z-index: 3; transform: translateY(-50%); width: 40px; height: 40px; border-radius: 999px; border: 1.5px solid rgba(255,255,255,0.7); background: rgba(28, 25, 23, 0.5); color: white; font-size: 1.5rem; line-height: 1; cursor: pointer; transition: all 0.2s var(--ease); }
      .photo-nav:hover { background: rgba(28, 25, 23, 0.85); }
      .photo-nav--prev { left: 16px; }
      .photo-nav--next { right: 16px; }
      .photo-nav:disabled { opacity: 0.25; cursor: default; }
      .panel__body { padding: 36px 40px 44px; }
      .panel__price { font-family: var(--f-display); font-size: clamp(2.2rem, 4vw, 3.2rem); font-weight: 500; letter-spacing: -0.02em; line-height: 1; color: var(--ink); margin: 0 0 10px; }
      .panel__address { font-size: 1.2rem; color: var(--muted); line-height: 1.4; margin: 0 0 16px; font-weight: 300; }
      .panel__meta { display: flex; flex-wrap: wrap; gap: 8px; margin: 0 0 20px; color: var(--ink-soft); font-size: 0.9rem; font-weight: 500; }
      .panel__intelligence { display: inline-flex; align-items: center; gap: 8px; min-height: 36px; padding: 8px 16px; background: var(--accent-bg); border: 1px solid var(--accent-light); border-radius: 999px; color: var(--accent); font-size: 0.8rem; font-weight: 600; margin-bottom: 20px; }
      .panel__intelligence::before { content: "✦"; }
      .panel__detail-row { display: flex; flex-wrap: wrap; gap: 8px 16px; margin: 0 0 20px; color: var(--muted); font-size: 0.85rem; font-weight: 400; }
      .panel__detail-row span + span::before { content: "·"; margin-right: 16px; color: var(--soft); }
      .panel__highlights { display: flex; flex-wrap: wrap; gap: 8px; margin: 0 0 24px; }
      .panel__highlight-chip { display: inline-flex; align-items: center; min-height: 32px; padding: 6px 14px; background: var(--accent-bg); color: var(--accent); border: 1px solid var(--accent-light); border-radius: 999px; font-size: 0.75rem; font-weight: 600; }
      .panel__section-title { margin: 0 0 10px; font-size: 0.7rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--accent-light); }
      .panel__desc { font-size: 0.95rem; line-height: 1.75; color: var(--muted); margin: 0 0 28px; font-weight: 300; }
      .panel__cta-row { display: flex; justify-content: center; margin: 8px 0 20px; }
      .panel__sms-btn { display: inline-flex; align-items: center; justify-content: center; min-height: 48px; padding: 0 32px; background: var(--accent); color: white; font-size: 0.88rem; font-weight: 600; border-radius: 999px; border: 2px solid var(--accent); transition: all 0.22s var(--ease); }
      .panel__sms-btn:hover { background: var(--ink); border-color: var(--ink); transform: translateY(-2px); box-shadow: 0 6px 20px rgba(28,25,23,0.18); }
      .panel__nav-row { display: flex; justify-content: center; gap: 12px; }

      /* RESPONSIVE */
      @media (max-width: 1100px) {
        .shell { width: calc(100% - 60px); }
        .hero__grid, .bio-section { grid-template-columns: 1fr; gap: 48px; }
        .city-section { grid-template-columns: 1fr; gap: 40px; }
        .listing-grid { grid-template-columns: repeat(2, 1fr); }
        .social-grid { grid-template-columns: repeat(2, 1fr); }
        .section-head { grid-template-columns: 1fr; gap: 20px; }
        .stats-strip__inner { grid-template-columns: 1fr; }
        .stat-cell { border-right: 0; border-bottom: 1px solid var(--line); }
        .stat-cell:last-child { border-bottom: 0; }
      }

      @media (max-width: 700px) {
        .shell { width: calc(100% - 32px); }
        .group-grid, .listing-grid, .social-grid { grid-template-columns: 1fr; }
        .hero { padding: 48px 0 40px; }
        .footer__inner { flex-direction: column; text-align: center; }
        .footer__disclaimer { text-align: center; }
        .panel { left: 0; right: 0; width: 100%; max-height: 100svh; border-radius: 0; transform: translateY(-110%); }
        .panel.open { transform: translateY(0); }
        .panel__grab { display: flex; justify-content: center; align-items: center; padding: 10px 0 6px; background: var(--surface); }
        .panel__grab::before { content: ""; width: 40px; height: 4px; background: var(--line-warm); border-radius: 999px; }
        .panel__header-actions { display: none; }
        .panel__body { padding: 24px 20px 32px; }
      }
    </style>
  </head>

  <body>
    <main class="page">
      <header class="agent-header">
        <div class="shell agent-header__inner">
          <a class="agent-brand" href="/">
            <strong>{agent.name}</strong>
            <span>{agent.title} · {agent.city}</span>
          </a>
          <a class="agent-contact" href={`tel:${agent.phone}`}>Call {agent.phone}</a>
        </div>
      </header>

      <section class="hero">
        <div class="shell hero__grid">
          <div>
            <p class="eyebrow">{page.heroEyebrow}</p>
            <h1 class="hero-title">{heroHeadingMain}<br/><em>{heroHeadingAccent}</em></h1>
            <p class="hero-intro">{page.heroIntro}</p>
            <div class="btn-row">
              <a class="btn btn--primary" href={newListingsHref}>View new listings</a>
              <a class="btn btn--secondary" href={`mailto:${agent.email}`}>Ask {agent.name}</a>
            </div>
          </div>
          <div>
            {featuredListing ? (
              <div class="hero-card">
                <button type="button" class="featured-listing-btn listing-modal-trigger"
                  data-price={getListingPrice(featuredListing)}
                  data-address={getListingAddress(featuredListing)}
                  data-image={getListingImage(featuredListing)}
                  data-images={JSON.stringify(getListingImages(featuredListing))}
                  data-beds={String(getListingBeds(featuredListing))}
                  data-baths={String(getListingBaths(featuredListing))}
                  data-sqft={String(getListingSqft(featuredListing))}
                  data-description={getListingDescription(featuredListing)}
                  data-year={String(getListingYearBuilt(featuredListing))}
                  data-lot-size={String(getListingLotSize(featuredListing))}
                  data-area={String(getListingArea(featuredListing))}
                  data-property-type={String(getListingPropertyType(featuredListing))}
                  data-dom={String(getListingDom(featuredListing))}
                  data-mls={getListingMls(featuredListing)}
                  data-href={featuredListing.listing_url || `/listings?mls=${getListingMls(featuredListing)}`}
                >
                  <div class="featured-listing__image" style={getListingImage(featuredListing) ? `background-image:url('${getListingImage(featuredListing)}');` : ""}>
                    <span class="featured-listing__badge">Featured listing</span>
                  </div>
                  <div class="featured-listing__body">
                    <div class="featured-listing__price">{getListingPrice(featuredListing)}</div>
                    <div class="featured-listing__address">{getListingAddress(featuredListing)}</div>
                  </div>
                </button>
              </div>
            ) : (
              <div class="hero-card">
                <div class="hero-card__placeholder">
                  <p class="hero-card__placeholder-eyebrow">Agent pick</p>
                  <strong>{page.agentPickTitle}</strong>
                  <p>{page.agentPickText}</p>
                </div>
              </div>
            )}
          </div>
        </div>
      </section>

      <section class="stats-strip">
        <div class="shell">
          <div class="stats-strip__inner">
            <div class="stat-cell">
              <span class="stat-cell__label">Active Listings</span>
              <span class="stat-cell__value">{marketStats.total || "—"}</span>
              <span class="stat-cell__meta">in {agent.city}</span>
            </div>
            <div class="stat-cell">
              <span class="stat-cell__label">New This Week</span>
              <span class="stat-cell__value">{marketStats.newThisWeek}</span>
              <span class="stat-cell__meta">fresh to market</span>
            </div>
            <div class="stat-cell">
              <span class="stat-cell__label">Avg. Days on Market</span>
              <span class="stat-cell__value">{marketStats.avgDom || "—"}</span>
              <span class="stat-cell__meta">current pace</span>
            </div>
          </div>
        </div>
      </section>

      <section class="section">
        <div class="shell">
          <div class="section-head">
            <div>
              <p class="section-label">Browse by category</p>
              <h2 class="section-title">Homes worth watching.</h2>
            </div>
            <p class="section-intro">Quick groups that help buyers find the right part of the market without sorting through everything.</p>
          </div>
          <div class="group-grid">
            {groups.map((group) => (
              <a class="group-card" href={group.href}>
                <div>
                  <span class="group-card__kicker">{group.kicker}</span>
                  <h3 class="group-card__title">{group.title}</h3>
                  <p class="group-card__text">{group.text}</p>
                </div>
                <span class="group-card__link">View homes</span>
              </a>
            ))}
          </div>
        </div>
      </section>

      <section class="section section--alt">
        <div class="shell city-section">
          <div>
            <p class="section-label">About the area</p>
            <h2 class="city-section__title">Buying in<br/><em>{agent.city}.</em></h2>
          </div>
          <div class="city-section__right">
            <p>{page.cityIntro}</p>
            <p>{page.cityNotes}</p>
          </div>
        </div>
      </section>

      <section class="section">
        <div class="shell">
          <div class="section-head">
            <div>
              <p class="section-label">Latest listings</p>
              <h2 class="section-title">{page.newListingsTitle}</h2>
            </div>
            <p class="section-intro">{page.newListingsIntro}</p>
          </div>
          <div class="listing-grid">
            {newListings.length > 0 ? (
              newListings.map((listing) => {
                const image = getListingImage(listing);
                const images = getListingImages(listing);
                const address = getListingAddress(listing);
                const price = getListingPrice(listing);
                const beds = getListingBeds(listing);
                const baths = getListingBaths(listing);
                const sqft = getListingSqft(listing);
                const description = getListingDescription(listing);
                const mls = getListingMls(listing);
                return (
                  <button type="button" class="listing-card listing-modal-trigger"
                    data-price={price} data-address={address} data-image={image}
                    data-images={JSON.stringify(images)} data-beds={String(beds)}
                    data-baths={String(baths)} data-sqft={String(sqft)}
                    data-description={description}
                    data-year={String(getListingYearBuilt(listing))}
                    data-lot-size={String(getListingLotSize(listing))}
                    data-area={String(getListingArea(listing))}
                    data-property-type={String(getListingPropertyType(listing))}
                    data-dom={String(getListingDom(listing))} data-mls={mls}
                    data-href={listing.listing_url || `/listings?mls=${mls}`}
                  >
                    <div class="listing-card__image" style={image ? `background-image:url('${image}');` : ""}></div>
                    <div class="listing-card__body">
                      <div class="listing-card__price">{price}</div>
                      <p class="listing-card__address">{address}</p>
                      <div class="listing-card__meta">
                        <span>{beds} bed</span>
                        <span>{baths} bath</span>
                        {sqft ? <span>{sqft} sq ft</span> : null}
                      </div>
                      <p class="listing-card__desc">{description}</p>
                    </div>
                  </button>
                );
              })
            ) : (
              [1,2,3,4,5,6].map(() => (
                <a class="listing-card" href={newListingsHref}>
                  <div class="listing-card__image"></div>
                  <div class="listing-card__body">
                    <div class="listing-card__price">Listing</div>
                    <p class="listing-card__address">{listingCity}</p>
                  </div>
                </a>
              ))
            )}
          </div>
          <div style="display:flex;justify-content:center;margin-top:40px;">
            <a class="btn btn--primary" href={newListingsHref}>View all listings</a>
          </div>
        </div>
      </section>

      {hasSocialSection && (
        <section class="section section--alt">
          <div class="shell">
            <div class="section-head">
              <div>
                <p class="section-label">Stay connected</p>
                <h2 class="section-title">{page.socialTitle || "Follow along."}</h2>
              </div>
              <p class="section-intro">{page.socialIntro}</p>
            </div>
            <div class="social-grid">
              {socialLinks.map((link) => (
                <a class="social-card" href={link.url} target="_blank" rel="noopener noreferrer">
                  <span class="social-card__platform">{link.label}</span>
                  <div>
                    <div class="social-card__name">{agent.name}</div>
                    <div class="social-card__cta">View updates →</div>
                  </div>
                </a>
              ))}
            </div>
          </div>
        </section>
      )}

      <section class="section">
        <div class="shell bio-section">
          <div class="bio-photo"></div>
          <div>
            <p class="section-label">Meet your agent</p>
            <h2 class="bio-name">{agent.name}</h2>
            <span class="bio-title-tag">{agent.title} · {agent.city}</span>
            <p class="bio-text">{agent.bio}</p>
            <div class="btn-row">
              <a class="btn btn--primary" href={`tel:${agent.phone}`}>Call {agent.name}</a>
              <a class="btn btn--secondary" href={`mailto:${agent.email}`}>Send an email</a>
            </div>
          </div>
        </div>
      </section>

      <footer>
        <div class="shell footer__inner">
          <div class="footer__brand">{agent.name} · {agent.city}</div>
          <p class="footer__disclaimer">Listings and market data are subject to change. This page is a curated buyer resource.</p>
        </div>
      </footer>
    </main>

    <div class="modal-overlay" id="listing-modal-overlay"></div>

    <aside class="panel" id="listing-modal" aria-hidden="true"
      data-agent-name={agent.name} data-agent-phone={agent.phone} data-agent-email={agent.email}>
      <div class="panel__grab" aria-hidden="true"></div>
      <div class="panel__progress-track"><div class="panel__progress-bar"></div></div>
      <div class="panel__header">
        <div class="panel__position" id="listing-modal-position">Listing preview</div>
        <div class="panel__header-actions">
          <button class="panel__top-btn" id="listing-modal-prev" type="button">← Previous</button>
          <button class="panel__top-btn" id="listing-modal-next" type="button">Next →</button>
        </div>
        <button class="panel__close" id="listing-modal-close" type="button" aria-label="Close">✕</button>
      </div>
      <div class="panel__view" id="listing-modal-scroll">
        <div class="panel__image-stage">
          <img id="listing-modal-image" class="panel__image" src="https://placehold.co/800x600?text=Listing" alt="" loading="lazy" decoding="async" />
          <button type="button" class="photo-nav photo-nav--prev" id="listing-photo-prev">‹</button>
          <button type="button" class="photo-nav photo-nav--next" id="listing-photo-next">›</button>
          <div class="panel__photo-count" id="listing-photo-count">1 / 1 photos</div>
        </div>
        <div class="panel__body">
          <h2 class="panel__price" id="listing-modal-price">—</h2>
          <p class="panel__address" id="listing-modal-address">Address</p>
          <div class="panel__meta" id="listing-modal-meta">—</div>
          <div class="panel__intelligence" id="listing-modal-intelligence">Fresh listing worth a closer look</div>
          <div class="panel__detail-row" id="listing-modal-detail-row"></div>
          <div class="panel__highlights" id="listing-modal-highlights"></div>
          <div>
            <h3 class="panel__section-title">Description</h3>
            <p class="panel__desc" id="listing-modal-description">A quiet preview of this property.</p>
          </div>
          <div class="panel__cta-row">
            <a class="panel__sms-btn" id="listing-modal-sms" href="#">Request info / showing →</a>
          </div>
          <div class="panel__nav-row">
            <button class="panel__next-btn" id="listing-modal-bottom-prev" type="button">← Previous</button>
            <button class="panel__next-btn" id="listing-modal-bottom-next" type="button">Next →</button>
          </div>
        </div>
      </div>
    </aside>

    <script is:inline>
      function initModal() {
        const modal = document.getElementById("listing-modal");
        const overlay = document.getElementById("listing-modal-overlay");
        const closeBtn = document.getElementById("listing-modal-close");
        const imageEl = document.getElementById("listing-modal-image");
        const priceEl = document.getElementById("listing-modal-price");
        const addressEl = document.getElementById("listing-modal-address");
        const metaEl = document.getElementById("listing-modal-meta");
        const descEl = document.getElementById("listing-modal-description");
        const smsEl = document.getElementById("listing-modal-sms");
        const positionEl = document.getElementById("listing-modal-position");
        const intelligenceEl = document.getElementById("listing-modal-intelligence");
        const detailRowEl = document.getElementById("listing-modal-detail-row");
        const highlightsEl = document.getElementById("listing-modal-highlights");
        const photoCountEl = document.getElementById("listing-photo-count");
        const photoPrevBtn = document.getElementById("listing-photo-prev");
        const photoNextBtn = document.getElementById("listing-photo-next");
        const prevListingBtn = document.getElementById("listing-modal-prev");
        const nextListingBtn = document.getElementById("listing-modal-next");
        const bottomPrevBtn = document.getElementById("listing-modal-bottom-prev");
        const bottomNextBtn = document.getElementById("listing-modal-bottom-next");
        const scrollArea = document.getElementById("listing-modal-scroll");

        if (!modal || !overlay) return;
        if (modal.dataset.initialized === "true") return;
        modal.dataset.initialized = "true";

        let activePhotos = [], activePhotoIndex = 0, allCards = [], activeIndex = -1;

        function parseImages(value, fallback) {
          try { const parsed = JSON.parse(value || "[]"); const images = Array.isArray(parsed) ? parsed.filter(Boolean) : []; return Array.from(new Set([fallback, ...images].filter(Boolean))); }
          catch { return fallback ? [fallback] : []; }
        }

        function preloadImage(src) { if (src) { const img = new Image(); img.src = src; } }

        function renderPhoto() {
          if (!imageEl) return;
          imageEl.src = activePhotos[activePhotoIndex] || "https://placehold.co/800x600?text=Listing";
          preloadImage(activePhotos[activePhotoIndex + 1]);
          preloadImage(activePhotos[activePhotoIndex - 1]);
          if (photoCountEl) photoCountEl.textContent = `${activePhotoIndex + 1} / ${Math.max(activePhotos.length, 1)} photos`;
          if (photoPrevBtn) photoPrevBtn.disabled = activePhotoIndex === 0;
          if (photoNextBtn) photoNextBtn.disabled = activePhotoIndex >= activePhotos.length - 1;
        }

        function updateNavBtns() {
          [prevListingBtn, bottomPrevBtn].forEach(b => { if (b) b.disabled = activeIndex <= 0; });
          [nextListingBtn, bottomNextBtn].forEach(b => { if (b) b.disabled = activeIndex >= allCards.length - 1; });
        }

        function buildNote(card) {
          const desc = String(card.dataset.description || "").toLowerCase();
          const pt = String(card.dataset.propertyType || "").toLowerCase();
          const isCondo = pt.includes("condo") || pt.includes("apartment");
          const isHouse = pt.includes("house") || pt.includes("detached") || pt.includes("single family");
          const isTownhouse = pt.includes("townhouse") || pt.includes("townhome");
          const hasView = /ocean view|water view|harbour|lake view|mountain view|panoramic/.test(desc);
          const hasSuite = /suite|income|mortgage helper/.test(desc);
          const isUpdated = /renovated|updated|modernized|new kitchen/.test(desc);
          if (isCondo) { if (isUpdated) return "Move-in ready condo"; if (hasView) return "Open outlook"; return "Low-maintenance living"; }
          if (isTownhouse) { if (hasSuite) return "Income potential"; return "Balanced space and value"; }
          if (isHouse) { if (hasView && hasSuite) return "Views and income potential"; if (hasSuite) return "Flexible layout with suite"; if (hasView) return "Nice outlook from main living"; return "Solid detached option"; }
          return "Worth a closer look";
        }

        function openModal(card, resetIdx = true) {
          if (resetIdx) { allCards = Array.from(document.querySelectorAll(".listing-modal-trigger")); activeIndex = allCards.indexOf(card); }
          const image = card.dataset.image || "";
          activePhotos = parseImages(card.dataset.images || "[]", image);
          activePhotoIndex = 0;
          if (priceEl) priceEl.textContent = card.dataset.price || "Price on request";
          if (addressEl) addressEl.textContent = card.dataset.address || "Address available";
          if (imageEl) imageEl.alt = card.dataset.address || "Listing";
          if (descEl) descEl.textContent = card.dataset.description || "A quiet preview of this property.";
          if (positionEl) positionEl.textContent = card.dataset.mls ? `MLS ${card.dataset.mls}` : "Listing preview";
          if (intelligenceEl) intelligenceEl.textContent = buildNote(card);
          if (detailRowEl) { const details = [card.dataset.propertyType, card.dataset.area, card.dataset.year ? `Built ${card.dataset.year}` : "", card.dataset.lotSize ? `${card.dataset.lotSize} lot` : ""].filter(Boolean); detailRowEl.innerHTML = details.map(i => `<span>${i}</span>`).join(""); }
          if (highlightsEl) { let h = []; try { h = JSON.parse(card.dataset.highlights || "[]"); } catch {} highlightsEl.innerHTML = h.map(i => `<span class="panel__highlight-chip">${i}</span>`).join(""); }
          if (metaEl) metaEl.textContent = [card.dataset.beds ? `${card.dataset.beds} Bed` : "", card.dataset.baths ? `${card.dataset.baths} Bath` : "", card.dataset.sqft ? `${card.dataset.sqft} Sq Ft` : ""].filter(Boolean).join(" · ");
          if (smsEl) {
            const phone = String(modal.dataset.agentPhone || "").replace(/[^0-9]/g, "");
            const email = modal.dataset.agentEmail || "";
            const name = modal.dataset.agentName || "there";
            const msg = `Hi ${name}, I'd like more info on ${card.dataset.address || "this listing"}${card.dataset.mls ? ` MLS ${card.dataset.mls}` : ""}.`;
            const isMobile = /iPhone|iPad|iPod|Android/i.test(navigator.userAgent);
            smsEl.textContent = isMobile ? "Text for info / showing →" : "Email for info / showing →";
            smsEl.href = isMobile && phone ? `sms:${phone}?&body=${encodeURIComponent(msg)}` : `mailto:${email}?subject=Listing Inquiry&body=${encodeURIComponent(msg)}`;
          }
          renderPhoto(); updateNavBtns();
          modal.classList.add("open"); overlay.classList.add("open");
          modal.setAttribute("aria-hidden", "false");
          document.body.classList.add("modal-open");
          requestAnimationFrame(() => { if (scrollArea) scrollArea.scrollTop = 0; });
        }

        function closeModal() {
          modal.classList.remove("open"); overlay.classList.remove("open");
          modal.setAttribute("aria-hidden", "true");
          document.body.classList.remove("modal-open");
        }

        document.addEventListener("click", (e) => { const trigger = e.target.closest(".listing-modal-trigger"); if (!trigger) return; e.preventDefault(); e.stopPropagation(); openModal(trigger); });
        closeBtn?.addEventListener("click", closeModal);
        overlay?.addEventListener("click", closeModal);
        photoPrevBtn?.addEventListener("click", () => { if (activePhotoIndex > 0) { activePhotoIndex--; renderPhoto(); } });
        photoNextBtn?.addEventListener("click", () => { if (activePhotoIndex < activePhotos.length - 1) { activePhotoIndex++; renderPhoto(); } });
        [nextListingBtn, bottomNextBtn].forEach(b => b?.addEventListener("click", () => { if (activeIndex < allCards.length - 1) { activeIndex++; openModal(allCards[activeIndex], false); } }));
        [prevListingBtn, bottomPrevBtn].forEach(b => b?.addEventListener("click", () => { if (activeIndex > 0) { activeIndex--; openModal(allCards[activeIndex], false); } }));
        document.addEventListener("keydown", (e) => {
          if (!modal.classList.contains("open")) return;
          if (e.key === "Escape") closeModal();
          if (e.key === "ArrowLeft") { if (activePhotoIndex > 0) { activePhotoIndex--; renderPhoto(); } }
          if (e.key === "ArrowRight") { if (activePhotoIndex < activePhotos.length - 1) { activePhotoIndex++; renderPhoto(); } }
        });
      }

      if (document.readyState === "loading") { document.addEventListener("DOMContentLoaded", initModal, { once: true }); } else { initModal(); }
      document.addEventListener("astro:page-load", initModal);
    </script>
  </body>
</html>