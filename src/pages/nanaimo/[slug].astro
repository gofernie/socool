        min-height: 460px;
        border: 1px solid var(--line);
        border-radius: 18px;
        overflow: hidden;
        margin-bottom: 22px;
        background: #e8e4de;
      }

      .grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 18px;
}

    .grid.map-hidden {
  display: none;
}

body.is-map-mode .bottom-refine-cta {
  display: none;
}

  .card {
         background: #fff;
        border-radius: var(--radius-lg);
        overflow: hidden;
        border: 1px solid var(--line-warm);
        color: inherit;
        display: block;
        cursor: pointer;
        transition: all 0.28s var(--ease);
        box-shadow: 0 2px 16px rgba(28, 25, 23, 0.04);
      }

      .card:hover {
        transform: translateY(-4px);
        box-shadow: 0 16px 48px rgba(28, 25, 23, 0.1);
        border-color: var(--accent-light);
      }

      .grid > article[hidden],
.grid > aside[hidden],
.grid > section[hidden],
.grid > div[hidden] {
  display: none !important;
}

   .card img {
  width: 100%;
  aspect-ratio: 16 / 9;
        object-fit: cover;
        display: block;
      }

      .card-body {
        padding: 16px;
      }

     .card-decision-badge {
  display: inline-flex;
  width: fit-content;
  margin-top: 14px;
  padding: 7px 11px;
  border-radius: 999px;
  font-size: 0.72rem;
  font-weight: 900;
  letter-spacing: 0.05em;
  text-transform: uppercase;
}

.card-decision-badge[hidden] {
