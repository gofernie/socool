            listing?.images?.[0]?.highRes ||
            listing?.images?.[0]?.mediumRes ||
            listing?.images?.[0]?.lowRes ||
            listing?.images?.[0];

          const image =
            normalizeImageUrl(firstImage) ||
            "https://placehold.co/800x600?text=Listing";

          return (
            <>
              <article
                class="card original-card"
                data-item-id={String(listing?.id || listing?.mls_number || index)}
                data-card-id={String(listing?.id || listing?.mls_number || index)}
                data-listing-id={String(listing?.id || listing?.mls_number || "")}
                data-mls={String(listing?.mls_number || listing?.id || "")}
                data-image={image}
                data-images={JSON.stringify(listing?.images || [])}
                data-price={formatPrice(listing.price)}
                data-sort-index={index}
data-raw-price={String(listing?.price || 0)}
data-listed-at={String(listing?.listed_at || listing?.created_at || "")}
                data-address={listing.address}
                data-meta={`${listing.beds || "-"} bed · ${listing.baths || "-"} bath`}
                data-beds={String(listing?.beds || "-")}
                data-baths={String(listing?.baths || "-")}
                data-sqft={String(listing?.sqft || "")}
data-type={String(listing?.normalized_type || listing?.property_type || page.property_type || "Home")}                data-year={String(listing?.year_built || "")}
                data-dom={String(listing?.days_on_market || listing?.dom || "")}
                data-description={String(listing?.description || "").replace(/"/g, "&quot;")}
                data-liked-tags="[]"
                data-is-favourite="false"
                data-decision=""
                data-lat={listing?.lat || ""}
                data-lng={listing?.lng || ""}
                data-city={String(listing?.normalized_city || listing?.city || "nanaimo")}
                data-area={String(listing?.normalized_area || listing?.area || "").toLowerCase()}
              >
                <img src={image} alt={listing.address || "Listing"} />

                <div class="card-body">
                  <div class="price">{formatPrice(listing.price)}</div>
                  <div class="address">{listing.address}</div>
                <div class="meta">
  {listing.beds || "-"} bed · {listing.baths || "-"} bath
</div>

<div class="card-decision-badge" hidden></div>
                </div>
