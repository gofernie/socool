}

.card-decision-badge.is-love {
  background: rgba(255, 77, 0, 0.14);
  color: #ff4d00;
}

.card-decision-badge.is-maybe {
  background: rgba(24, 22, 20, 0.08);
  color: rgba(24, 22, 20, 0.72);
}

.card-decision-badge.is-pass {
  background: rgba(24, 22, 20, 0.08);
  color: rgba(24, 22, 20, 0.56);
}

.card.is-passed {
  opacity: 0.32;
  filter: grayscale(0.55);
}

.card.is-passed:hover {
  opacity: 0.65;
}

      .price {
        font-size: 1.36rem;
        font-weight: 850;
        margin-bottom: 6px;
      }

      .address {
        margin-bottom: 10px;
        color: var(--ink);
        line-height: 1.35;
      }

      .meta {
        font-size: 0.9rem;
        color: var(--muted);
      }

     .interrupt-card {
  grid-column: 1 / -1;
  margin: 12px 0 18px;
  background: #fff;
  border: 1px solid var(--line-warm);
  border-radius: 20px;
  padding: 26px;
  box-shadow: 0 8px 24px rgba(28, 25, 23, 0.06);
}

.interrupt-card::before {
