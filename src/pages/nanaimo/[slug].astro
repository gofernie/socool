   const interruptCard = document.getElementById("intent-interrupt-card");
const refinedAnchor = document.getElementById("refined-results-anchor");
const refinedResults = document.getElementById("refined-results");
const visibleCards = cards.filter((card) => !card.hidden);

if (interruptCard) {
  const insertAfterCard = visibleCards[11] || null;

  if (insertAfterCard) {
    insertAfterCard.after(interruptCard);

    if (refinedAnchor) {
      interruptCard.after(refinedAnchor);
      refinedAnchor.hidden = false;
    }

    if (refinedAnchor && refinedResults) {
      refinedAnchor.after(refinedResults);
      refinedResults.hidden = false;
    }

    interruptCard.hidden = false;
    interruptCard.style.display = "";
  } else {
    interruptCard.hidden = true;
    interruptCard.style.display = "";

    if (refinedAnchor) refinedAnchor.hidden = true;
    if (refinedResults && !refinedResults.innerHTML.trim()) {
      refinedResults.hidden = true;
