      const areaButtons = document.querySelectorAll(".area-filter");
const priceButtons = document.querySelectorAll(".price-filter");
let activePriceFilter = "all";

      function applyAreaFilter(area) {
        const cards = Array.from(document.querySelectorAll(".original-card"));
        const resultsBar = document.querySelector(".results-bar");

        let visibleCount = 0;

        cards.forEach((card) => {
          if (card.classList.contains("is-hidden-by-refine")) return;

          const cardArea = String(card.dataset.area || "").toLowerCase();
const rawPrice = String(card.dataset.price || "")
  .replace(/\$/g, "")
  .replace(/,/g, "");

const price = Number(rawPrice || 0);

const matchesArea = area === "all" || cardArea === area;

const matchesPrice =
  activePriceFilter === "all" ||
  (activePriceFilter === "under-450" && price < 450000) ||
  (activePriceFilter === "450-650" && price >= 450000 && price < 650000) ||
  (activePriceFilter === "650-850" && price >= 650000 && price < 850000) ||
(activePriceFilter === "850-1100" && price >= 850000 && price < 1100000) ||
(activePriceFilter === "1100-plus" && price >= 1100000);

const shouldShow = matchesArea && matchesPrice;
          card.style.display = shouldShow ? "" : "none";

          if (shouldShow) visibleCount += 1;
        });

        const interruptCard = document.getElementById("intent-interrupt-card");
        const refinedAnchor = document.getElementById("refined-results-anchor");
        const refinedResults = document.getElementById("refined-results");
        const visibleCards = cards.filter((card) => card.style.display !== "none");

        if (interruptCard) {
          interruptCard.style.display = visibleCards.length > 0 ? "" : "none";

          const insertAfterCard = visibleCards[11] || visibleCards[visibleCards.length - 1];

          if (insertAfterCard) {
            insertAfterCard.after(interruptCard);

            if (refinedAnchor) {
              interruptCard.after(refinedAnchor);
            }

            if (refinedAnchor && refinedResults) {
              refinedAnchor.after(refinedResults);
            }
          }
        }

        areaButtons.forEach((button) => {
          button.classList.toggle("active", button.dataset.areaFilter === area);
        });

        if (resultsBar) {
          resultsBar.textContent =
            area === "all"
              ? `${visibleCount} listings found`
              : `${visibleCount} listings found in ${area}`;
        }

        if (googleMap && intentMapEl && !intentMapEl.hidden) {
          initIntentGoogleMap();
        }
      }

      areaButtons.forEach((button) => {
        button.addEventListener("click", () => {
          applyAreaFilter(button.dataset.areaFilter || "all");
        });
      });
      priceButtons.forEach((button) => {
  button.addEventListener("click", () => {
    activePriceFilter = button.dataset.priceFilter || "all";

    priceButtons.forEach((btn) => {
      btn.classList.toggle("active", btn === button);
    });

    const activeAreaButton = document.querySelector(".area-filter.active");
    const activeArea = activeAreaButton?.dataset.areaFilter || "all";

    applyAreaFilter(activeArea);
  });
});
document.addEventListener("click", (event) => {
  const button = event.target.closest("[data-sort]");

  if (!button) return;

  const sort = button.dataset.sort || "recommended";
  const grid = document.querySelector(".grid");

  if (!grid) return;

  document.querySelectorAll("[data-sort]").forEach((btn) => {
    btn.classList.toggle("active", btn === button);
  });

  const cards = Array.from(grid.querySelectorAll(".original-card"));

  cards.sort((a, b) => {
    if (sort === "price-asc") {
      return Number(a.dataset.rawPrice || 0) - Number(b.dataset.rawPrice || 0);
    }

    if (sort === "price-desc") {
      return Number(b.dataset.rawPrice || 0) - Number(a.dataset.rawPrice || 0);
    }

    if (sort === "newest") {
      return (
        new Date(b.dataset.listedAt || 0).getTime() -
        new Date(a.dataset.listedAt || 0).getTime()
      );
    }

    return Number(a.dataset.sortIndex || 0) - Number(b.dataset.sortIndex || 0);
  });

  cards.forEach((card) => {
    grid.appendChild(card);
  });

  const activeAreaButton = document.querySelector(".area-filter.active");
  const activeArea = activeAreaButton?.dataset.areaFilter || "all";

  applyAreaFilter(activeArea);

  if (googleMap && intentMapEl && !intentMapEl.hidden) {
    initIntentGoogleMap();
  }
});
