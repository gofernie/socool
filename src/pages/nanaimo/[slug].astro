---
import { createClient } from "@supabase/supabase-js";
import ShortlistReviewModal from "../../components/ShortlistReviewModal.astro";
import IntentModalController from "../../components/IntentModalController.astro";
export const prerender = false;

const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.SUPABASE_SERVICE_ROLE_KEY
);

const googleMapsApiKey = import.meta.env.PUBLIC_GOOGLE_MAPS_API_KEY || "";

const slug = Astro.params.slug || "";

const { data: page, error: pageError } = await supabase
  .from("intent_pages")
  .select("*")
  .eq("slug", slug)
  .eq("city", "nanaimo")
  .single();

if (!page || pageError) {
  return Astro.redirect("/404");
}

const { data: featureRows } = await supabase
  .from("intent_page_features")
  .select("*")
  .eq("intent_page_id", page.id);

const features = (featureRows || []).map((f) => f.feature_key);

let query = supabase
  .from("listing_rows")
  .select("*")
  .eq("status", "A")
  .eq("normalized_city", "nanaimo");

if (page.property_type) {
  query = query.eq("normalized_type", page.property_type);
}

if (page.price_min) {
  query = query.gte("price", page.price_min);
}

if (page.price_max) {
  query = query.lte("price", page.price_max);
}

const featureTerms: Record<string, string[]> = {
  yard: ["yard", "fenced", "outdoor"],
  garage: ["garage", "shop"],
  suite: ["suite", "income", "mortgage helper"],
  updated: ["updated", "renovated", "modern"],
  views: ["ocean view", "water view", "view"],
};

for (const feature of features) {
  const terms = featureTerms[feature];
  if (!terms?.length) continue;

  const orQuery = terms
    .map((term) => `description.ilike.%${term}%`)
    .join(",");

  query = query.or(orQuery);
}

const { data: listings } = await query
  .order("price", { ascending: false })
  .limit(200);

function formatPrice(price: number) {
  return `$${Number(price || 0).toLocaleString()}`;
}

function normalizeImageUrl(url: any) {
  const value = String(url || "").trim();

  if (!value) return "";
  if (value.startsWith("http://") || value.startsWith("https://")) return value;
  if (value.startsWith("/vreb/")) return `https://cdn.repliers.io${value}`;
  if (value.startsWith("/")) return `https://cdn.repliers.io${value}`;
  if (value.startsWith("vreb/")) return `https://cdn.repliers.io/${value}`;

  return value;
}

const listingCount = listings?.length || 0;
const priceLabel = page.price_max
  ? `Under ${formatPrice(page.price_max)}`
  : page.price_min
    ? `${formatPrice(page.price_min)}+`
    : "Live market";

const priceDirectionLabels = page.price_max
  ? [
      "Show lower-priced options",
      `Show up to ${formatPrice(Number(page.price_max) + 50000)}`,
      `Show up to ${formatPrice(Number(page.price_max) + 100000)}`,
      "Stay close to this budget",
    ]
  : [
      "Show lower-priced options",
      "Show mid-range options",
      "Show premium options",
      "Show best value",
    ];

const defaultFeatureDirectionsByType: Record<string, string[]> = {
  condo: ["Better layout", "More modern", "Walkability", "Views"],
  house: ["Better layout", "Larger yard", "Garage space", "Suite potential"],
  townhouse: ["Better layout", "Garage space", "Outdoor space", "Better value"],
  mobile: ["Better value", "Updated", "Parking", "Outdoor space"],
};

const savedFeatureLabels = features.map((feature) =>
  feature
    .replaceAll("_", " ")
    .replace(/\b\w/g, (char) => char.toUpperCase())
);

const fallbackFeatureLabels =
  defaultFeatureDirectionsByType[String(page.property_type || "house").toLowerCase()] ||
  ["Better layout", "More modern", "Better value", "Outdoor space"];

const featureDirectionLabels = Array.from(
  new Set([
    ...savedFeatureLabels,
    ...fallbackFeatureLabels,
    "Better value",
    "More modern",
  ])
);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{page.seo_title}</title>
    <meta name="description" content={page.intro_copy} />
<meta name="viewport" content="width=device-width, initial-scale=1" />

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Nunito+Sans:opsz,wght@6..12,300;6..12,400;6..12,500;6..12,600;6..12,700&display=swap" rel="stylesheet" />
    <style>
   :root {
        --bg: #f5f2ed;
        --surface: #fdfcfa;
        --surface-soft: #f9f6f1;
        --ink: #1c1917;
        --ink-soft: #3d3935;
        --muted: #6b6560;
        --soft: #9c9590;
        --line: #e8e3dc;
        --line-warm: #ddd8d0;
        --accent: #8b6f47;
        --accent-light: #c4a882;
        --accent-soft: #f7f0e6;
        --hero-bg: #fdfcfa;
        --hero-ink: #1c1917;
        --hero-muted: #6b6560;
        --radius-lg: 20px;
        --radius-md: 12px;
        --serif: "Lora", Georgia, serif;
        --sans: "Nunito Sans", system-ui, sans-serif;
        --ease: cubic-bezier(0.25, 0.46, 0.45, 0.94);
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        background: var(--bg);
        color: var(--ink);
        font-family: var(--sans);
      }

      a {
        color: inherit;
      }

    .page {
  width: 100%;
  margin: 0;
  padding: 0 0 100px;
}

.intent-content-shell {
  width: min(1400px, calc(100% - 80px));
  margin: 0 auto;
  padding-top: 28px;
}

.intent-hero {
  position: relative;
  overflow: hidden;
  min-height: 360px;
  padding: 56px 0 46px;
  margin-bottom: 0;
  background:
