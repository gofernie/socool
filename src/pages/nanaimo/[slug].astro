        inset: 0;
        background:
          radial-gradient(circle at top right, rgba(139,111,71,0.12), transparent 36%),
          linear-gradient(135deg, rgba(196,168,130,0.1), transparent 40%);
        pointer-events: none;
      }

  .hero-inner {
  position: relative;
  z-index: 1;
  display: block;
  width: min(1400px, calc(100% - 80px));
  margin: 0 auto;
  max-width: none;
}

      .eyebrow {
        display: inline-flex;
        margin-bottom: 18px;
        padding: 7px 12px;
        border-radius: 999px;
        background: rgba(255,255,255,.08);
        border: 1px solid rgba(255,255,255,.18);
        font-size: 0.75rem;
        font-weight: 800;
        letter-spacing: .08em;
        text-transform: uppercase;
