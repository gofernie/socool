        font-size: 0.85rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--accent);
        margin-bottom: 10px;
      }

      .hero-side-card p {
        margin: 0;
        color: var(--hero-muted);
        line-height: 1.55;
      }

      .hero-side-card,
.hero-stats,
.pill-row {
  display: none;
}

  .hero-stats {
        position: relative;
        z-index: 1;
        display: grid;
        grid-template-columns: repeat(3, minmax(0,1fr));
        gap: 14px;
        margin-top: 40px;
      }

      .stat-card {
        background: rgba(253, 252, 250, 0.78);
        border: 1px solid var(--line-warm);
        border-radius: 20px;
