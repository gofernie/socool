      }

      .refine-chip:hover,
      .refine-chip.active {
        background: var(--hero-ink);
        color: var(--hero-bg);
        border-color: var(--hero-ink);
      }

      .refine-chip.is-loading {
        opacity: 0.6;
        pointer-events: none;
      }

    .generated-refine-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: auto;
  min-height: 38px;
  padding: 10px 15px;
  border-radius: 999px;
  background: var(--surface);
  border: 1px solid var(--line-warm);
  color: var(--ink);
  font: inherit;
  font-size: 0.88rem;
  font-weight: 750;
  cursor: pointer;
  transition: all 0.15s ease;
}

.generated-refine-chip:hover,
.generated-refine-chip.active {
  background: var(--hero-ink);
  color: var(--hero-bg);
  border-color: var(--hero-ink);
}

      .interrupt-card.is-refining {
        opacity: 0.92;
      }

      .refined-section-title {
        grid-column: 1 / -1;
        margin: 0 0 4px;
        font-family: var(--serif);
        font-size: clamp(1.7rem, 3vw, 2.6rem);
        letter-spacing: -0.04em;
      }

      .refined-section-copy {
        grid-column: 1 / -1;
        margin: 0 0 18px;
        color: var(--muted);
      }

      .refined-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        margin-bottom: 10px;
        padding: 7px 12px;
        border-radius: 999px;
        background: var(--accent-soft);
        color: var(--accent);
        font-size: 0.8rem;
        font-weight: 800;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }

      .modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.55);
        display: grid;
        place-items: center;
        z-index: 9999;
        padding: 18px;
      }

      .modal-overlay[hidden] {
        display: none;
      }

      .modal {
        width: min(760px, 100%);
        background: var(--surface);
        border-radius: 20px;
        padding: 18px;
      }

      .modal-close {
        appearance: none;
        border: 1px solid var(--line);
        background: var(--surface);
        border-radius: 999px;
        padding: 8px 14px;
        cursor: pointer;
        font: inherit;
        margin-bottom: 12px;
      }

      .modal img {
        width: 100%;
        aspect-ratio: 16 / 10;
        object-fit: cover;
        border-radius: 16px;
      }

      .modal h2 {
        margin-bottom: 6px;
      }

@media (max-width: 800px) {
        .page {
          width: 100vw;
          max-width: none;
          margin: 0;
          padding: 0 0 80px;
        }

        .intent-hero {
          width: 100vw;
          margin: 0 0 22px;
          border-left: 0;
          border-right: 0;
        }

