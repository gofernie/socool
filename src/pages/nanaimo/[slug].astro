  padding: 0 18px;
  border-radius: 999px;
  border: 1px solid var(--line-warm);
  background: #fff;
  color: var(--ink);
  font: inherit;
  font-size: 0.88rem;
  font-weight: 850;
  box-shadow: 0 8px 24px rgba(28, 25, 23, 0.07);
  cursor: pointer;
}

     .context-card {
  display: contents;
}

     .context-card h3 {
  display: none;
}

      .context-links {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
      }

   .area-filter,
.price-filter {
