        display: inline-flex;
        margin-top: 16px;
        padding: 14px 22px;
        border-radius: 999px;
        background: var(--accent);
        color: white;
        border: 0;
        font: inherit;
        font-weight: 850;
        cursor: pointer;
      }

      .refine-options {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 24px;
        margin-bottom: 12px;
      }

 .refine-chip {
        appearance: none;
        border: 1px solid var(--line-warm);
        background: var(--surface);
        color: var(--ink);
        padding: 10px 16px;
        border-radius: 999px;
        cursor: pointer;
        font: inherit;
        font-size: 0.9rem;
