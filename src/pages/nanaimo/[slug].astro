  font-family: var(--serif);
  font-size: clamp(3.8rem, 7vw, 6rem);
  line-height: 0.95;
  letter-spacing: -0.06em;
  font-weight: 500;
}

.accent-dot {
  color: var(--accent);
}

.hero-copy {
  max-width: 760px;
  margin: 22px 0 0;
  color: var(--hero-muted);
  font-size: clamp(1rem, 1.8vw, 1.22rem);
  line-height: 1.55;
}

 .hero-side-card {
