        border-radius: 999px;
        background: var(--accent-soft);
        border: 1px solid var(--line-warm);
        color: var(--accent);
        font-size: 0.78rem;
        font-weight: 700;
        text-transform: capitalize;
      }

     .market-context {
  display: flex;
  align-items: center;
  gap: 14px;
  flex-wrap: wrap;
  margin-bottom: 26px;
}

.intent-controls {
  display: flex;
  align-items: center;
  gap: 14px;
  flex-wrap: wrap;
  margin: 0 0 26px;
}

.intent-controls .view-toggle {
