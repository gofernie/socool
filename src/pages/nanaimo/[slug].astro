    <script is:inline>
     

window.addEventListener("DOMContentLoaded", () => {
  const params = new URLSearchParams(window.location.search);

  const targetListingId = String(params.get("listing_id") || "")
    .trim()
    .toLowerCase();

  const targetAddress = String(params.get("listing") || "")
    .trim()
    .toLowerCase();

  if (!targetListingId && !targetAddress) return;

  window.setTimeout(() => {
    const cards = Array.from(document.querySelectorAll(".card"));

    const matchingCard = cards.find((card) => {
      const listingId = String(card.dataset.listingId || "")
        .trim()
        .toLowerCase();

      const mls = String(card.dataset.mls || "")
        .trim()
        .toLowerCase();

      const itemId = String(card.dataset.itemId || "")
        .trim()
        .toLowerCase();

      const address = String(card.dataset.address || "")
        .trim()
        .toLowerCase();

      return (
        (targetListingId &&
          (listingId === targetListingId ||
            mls === targetListingId ||
            itemId === targetListingId)) ||
        (targetAddress && address === targetAddress)
      );
    });

    if (!matchingCard) {
      console.warn("Could not find listing card for modal deep link", {
        targetListingId,
        targetAddress,
      });
      return;
    }

    matchingCard.scrollIntoView({ behavior: "smooth", block: "center" });

    matchingCard.click();
}, 150);
});
