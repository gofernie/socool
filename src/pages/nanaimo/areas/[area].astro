---
import { supabase } from "../../../lib/supabase";
import ListingCard from "../../../components/ListingCard.astro";
import ShortlistReviewModal from "../../../components/ShortlistReviewModal.astro";
import IntentModalController from "../../../components/IntentModalController.astro";

const areaSlug = Astro.params.area || "";
const area = areaSlug.replace(/-/g, " "); 

const labelize = (value) =>
  String(value || "")
    .replace(/-/g, " ")
    .replace(/\b\w/g, (c) => c.toUpperCase());

const { data: listings = [] } = await supabase
  .from("listing_rows")
  .select("*")
  .eq("normalized_city", "nanaimo")
  .eq("normalized_area", area)
  .order("listed_at", { ascending: false });

const normalizeListingImageUrl = (value) => {
  if (!value) return "";
  const raw =
    typeof value === "string"
      ? value
      : value.highRes || value.mediumRes || value.lowRes || value.url || "";

  if (!raw) return "";
  if (raw.startsWith("http")) return raw;

  const cleaned = raw.startsWith("/") ? raw : `/${raw}`;
  return cleaned.startsWith("/vreb/") ? `https://cdn.repliers.io${cleaned}` : cleaned;
};

const getListingImage = (listing) =>
  normalizeListingImageUrl(
    listing.image_url ||
      listing.images?.[0] ||
      listing.raw?.images?.[0] ||
      listing.raw?.images?.[0]?.url
  );

const prices = listings
  .map((listing) => Number(listing.price || 0))
  .filter((price) => price > 0)
  .sort((a, b) => a - b);

const avgPrice =
  prices.length > 0
    ? Math.round(prices.reduce((sum, price) => sum + price, 0) / prices.length)
    : 0;

const medianPrice =
  prices.length > 0 ? prices[Math.floor(prices.length / 2)] : 0;

const houseCount = listings.filter((l) => l.normalized_type === "house").length;
const condoCount = listings.filter((l) => l.normalized_type === "condo").length;
const townhomeCount = listings.filter((l) => l.normalized_type === "townhouse").length;

const priceBuckets = [
  { label: "Under $500k", min: 0, max: 500000 },
  { label: "$500k-$750k", min: 500000, max: 750000 },
  { label: "$750k-$1M", min: 750000, max: 1000000 },
  { label: "$1M-$1.5M", min: 1000000, max: 1500000 },
  { label: "$1.5M+", min: 1500000, max: Infinity },
];

const chartData = {
  priceLabels: priceBuckets.map((bucket) => bucket.label),
  priceCounts: priceBuckets.map((bucket) =>
    listings.filter((listing) => {
      const price = Number(listing.price || 0);
      return price >= bucket.min && price < bucket.max;
    }).length
  ),
};
---

<html lang="en">
  <head>
    <title>{labelize(area)} Real Estate | Nanaimo</title>
    <meta name="description" content={`Browse active listings in ${labelize(area)}, Nanaimo.`} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Nunito+Sans:opsz,wght@6..12,300;6..12,400;6..12,500;6..12,600&display=swap"
  rel="stylesheet"
/>
<script defer src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>

  <body>
    <main class="shell">
      <a class="back" href="/nanaimo-real-estate-market">Back to Nanaimo Market</a>

    <h1>{labelize(area)} Real Estate</h1>

<p class="area-intro">
  {labelize(area)} offers a mix of Nanaimo real estate options for buyers comparing
  price, location, layout, and long-term value. Browse active listings below, then
  use the filters to narrow the search.
</p>

<section class="area-stats">
  <div class="stat-card">
    <strong>{listings.length}</strong>
    <span>Active Listings</span>
  </div>

  <div class="stat-card">
    <strong>${avgPrice.toLocaleString()}</strong>
    <span>Average Price</span>
  </div>

  <div class="stat-card">
    <strong>${medianPrice.toLocaleString()}</strong>
    <span>Median Price</span>
  </div>

  <div class="stat-card">
    <strong>{houseCount}</strong>
    <span>Houses</span>
  </div>

  <div class="stat-card">
    <strong>{condoCount}</strong>
    <span>Condos</span>
  </div>

  <div class="stat-card">
    <strong>{townhomeCount}</strong>
    <span>Townhomes</span>
  </div>
</section>

<section class="filter-bar">
  <select id="type-filter">
    <option value="all">All property types</option>
    <option value="house">Houses</option>
    <option value="condo">Condos</option>
    <option value="townhouse">Townhomes</option>
  </select>

  <select id="price-filter">
    <option value="all">Any price</option>
    <option value="under-500">Under $500k</option>
    <option value="500-750">$500k - $750k</option>
    <option value="750-1000">$750k - $1M</option>
    <option value="1000-plus">$1M+</option>
  </select>

  <select id="beds-filter">
    <option value="all">Any beds</option>
    <option value="2">2+ beds</option>
    <option value="3">3+ beds</option>
    <option value="4">4+ beds</option>
  </select>

  <div class="filter-count">
    <span id="visible-count">{listings.length}</span> homes showing
  </div>
</section>

<section class="chart-card">
  <div>
    <span class="eyebrow">PRICE DISTRIBUTION</span>
    <h2>Where {labelize(area)} Inventory Sits by Price</h2>
  </div>

  <div class="chart-wrap">
    <canvas id="priceChart"></canvas>
  </div>
</section>

<div class="listing-grid">
       {listings.map((listing) => (
  <div
    class="listing-card-wrap"
    data-type={listing.normalized_type || ""}
    data-price={listing.price || 0}
    data-beds={listing.beds || 0}
  >
    <ListingCard listing={listing} image={getListingImage(listing)} />
  </div>
))}
      </div>
    </main>

    <ShortlistReviewModal />
    <IntentModalController />

<script is:inline define:vars={{ chartData }}>
  window.addEventListener("load", () => {
    const typeFilter = document.getElementById("type-filter");
    const priceFilter = document.getElementById("price-filter");
    const bedsFilter = document.getElementById("beds-filter");
    const visibleCount = document.getElementById("visible-count");

    function applyFilters() {
      const type = typeFilter?.value || "all";
      const priceRange = priceFilter?.value || "all";
      const bedsMin = bedsFilter?.value || "all";

      let count = 0;

      document.querySelectorAll(".listing-card-wrap").forEach((card) => {
        const cardType = card.dataset.type || "";
        const price = Number(card.dataset.price || 0);
        const beds = Number(card.dataset.beds || 0);

        const matchesType = type === "all" || cardType === type;

        const matchesPrice =
          priceRange === "all" ||
          (priceRange === "under-500" && price < 500000) ||
          (priceRange === "500-750" && price >= 500000 && price < 750000) ||
          (priceRange === "750-1000" && price >= 750000 && price < 1000000) ||
          (priceRange === "1000-plus" && price >= 1000000);

        const matchesBeds = bedsMin === "all" || beds >= Number(bedsMin);

        const show = matchesType && matchesPrice && matchesBeds;

        card.hidden = !show;
        if (show) count += 1;
      });

      if (visibleCount) visibleCount.textContent = String(count);
    }

    typeFilter?.addEventListener("change", applyFilters);
    priceFilter?.addEventListener("change", applyFilters);
    bedsFilter?.addEventListener("change", applyFilters);

    if (window.Chart) {
      new Chart(document.getElementById("priceChart"), {
        type: "bar",
        data: {
          labels: chartData.priceLabels,
          datasets: [{ label: "Listings", data: chartData.priceCounts }],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: { legend: { display: false } },
          scales: {
            x: { grid: { display: false } },
            y: { beginAtZero: true, ticks: { precision: 0 } },
          },
        },
      });
    }
  });
</script>
</body>
</html>

<style is:global>
  :root {
    --bg: #f5f2ed;
    --surface: #fdfcfa;
    --ink: #1c1917;
    --ink-soft: #3d3935;
    --muted: #6b6560;
    --line: #e8e3dc;
    --line-warm: #ddd8d0;
    --accent: #8b6f47;
    --accent-light: #c4a882;
    --f-display: "Lora", Georgia, serif;
    --f-body: "Nunito Sans", system-ui, sans-serif;
    --ease: cubic-bezier(0.25, 0.46, 0.45, 0.94);
    --radius-lg: 20px;
  }

 * {
  box-sizing: border-box;
}

html {
  width: 100%;
  overflow-y: scroll;
  scrollbar-gutter: stable;
}

body {
    margin: 0;
    background: var(--bg);
    color: var(--ink);
    font-family: var(--f-body);
    -webkit-font-smoothing: antialiased;
  }

  .shell {
    width: min(1400px, calc(100% - 80px));
    margin: 0 auto;
    padding: 48px 0 90px;
  }

  .back {
    display: inline-flex;
    margin-bottom: 34px;
    padding: 8px 18px;
    border-radius: 999px;
    background: #fff;
    border: 1px solid var(--line-warm);
    color: var(--ink);
    text-decoration: none;
    font-size: 0.86rem;
    font-weight: 850;
  }

  h1 {
    max-width: 780px;
    margin: 0 0 14px;
    font-family: var(--f-display);
    font-size: clamp(3.4rem, 6vw, 6rem);
    line-height: 0.95;
    letter-spacing: -0.06em;
    font-weight: 500;
  }

  p {
    margin: 0 0 34px;
    color: var(--muted);
    font-size: 1rem;
    font-weight: 650;
  }

  .listing-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 18px;
  }
.area-intro {
  max-width: 760px;
  margin: 0 0 28px;
  color: var(--muted);
  line-height: 1.65;
}

.area-stats {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 12px;
  margin: 0 0 26px;
}

.stat-card {
  padding: 16px;
  border-radius: 16px;
  background: #fff;
  border: 1px solid var(--line-warm);
}

.stat-card strong {
  display: block;
  font-family: var(--f-display);
  font-size: 1.55rem;
  line-height: 1;
}

.stat-card span {
  display: block;
  margin-top: 8px;
  color: var(--muted);
  font-size: 0.78rem;
  font-weight: 800;
}

.filter-bar {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 12px;
  margin: 0 0 28px;
}

.filter-bar select,
.filter-count {
  min-height: 42px;
  padding: 0 16px;
  border-radius: 999px;
  border: 1px solid var(--line-warm);
  background: #fff;
  color: var(--ink);
  font: inherit;
  font-weight: 800;
}

.filter-count {
  display: inline-flex;
  align-items: center;
  color: var(--muted);
}

.chart-card {
  margin: 0 0 34px;
  padding: 24px;
  border-radius: 22px;
  background: #fff;
  border: 1px solid var(--line-warm);
}

.chart-card .eyebrow {
  margin-bottom: 10px;
}

.chart-card h2 {
  margin: 0 0 18px;
  font-family: var(--f-display);
  font-size: clamp(1.8rem, 3vw, 2.8rem);
  line-height: 0.98;
  letter-spacing: -0.055em;
  font-weight: 500;
}

.chart-wrap {
  position: relative;
  height: 260px;
}

.listing-card-wrap[hidden] {
  display: none !important;
}
 @media (max-width: 1100px) {
  .shell {
    width: calc(100% - 60px);
  }

  .area-stats {
    grid-template-columns: repeat(3, 1fr);
  }

  .listing-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

  @media (max-width: 640px) {
  .shell {
    width: calc(100% - 32px);
  }

  .area-stats {
    grid-template-columns: 1fr;
  }

  .filter-bar {
    align-items: stretch;
    flex-direction: column;
  }

  .filter-bar select,
  .filter-count {
    width: 100%;
  }

  .listing-grid {
    grid-template-columns: 1fr;
  }
}
</style>