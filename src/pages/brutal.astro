---
import { loadAgentPage, getListingImage, getListingImages, getListingPrice, getListingAddress, getListingBeds, getListingBaths, getListingSqft, getListingYearBuilt, getListingLotSize, getListingArea, getListingPropertyType, getListingDom, getListingDescription, getListingMls, buildListingHighlights } from "../lib/agent-listings";

export const prerender = false;

const slug = "chris-crump";

const {
  page,
  agent,
  groups,
  newListings,
  featuredListing,
  marketStats,
  socialLinks,
  hasSocialSection,
  newListingsHref,
  heroHeadingMain,
  heroHeadingAccent,
  listingCity,
} = await loadAgentPage(slug, Astro, import.meta.env);

if (page.template === "calm") {
  return Astro.redirect("/calm");
}
---

<html lang="en">
  <head>
    <title>{agent.city} Homes Curated by {agent.name}</title>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content={`A simple curated ${agent.city} listing page with condos, single-family homes, popular price points, and new listings.`}
    />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&display=swap"
      rel="stylesheet"
    />

    <style>
  :root {
    --bg: #fafaf9;
    --surface: #ffffff;
    --ink: #0a0a0a;
    --ink-soft: #262626;
    --muted: #737373;
    --soft: #a3a3a3;
    --line: #e5e5e5;
    --line-heavy: #d4d4d4;
    --accent: #ff4d00;
    --accent-dark: #cc3d00;
    --accent-bg: #fff4f0;

    --f-display: "DM Serif Display", Georgia, serif;
    --f-body: "DM Sans", -apple-system, BlinkMacSystemFont, sans-serif;

    --ease: cubic-bezier(0.22, 1, 0.36, 1);
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html,
  body {
    width: 100%;
    overflow-x: hidden;
  }

  body {
    font-family: var(--f-body);
    background: var(--bg);
    color: var(--ink);
    font-size: 15px;
    line-height: 1.5;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body.modal-open {
    overflow: hidden;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  button {
    font: inherit;
  }

  .page {
    min-height: 100vh;
  }

  .shell {
    width: min(1600px, calc(100% - 80px));
    margin: 0 auto;
  }

  /* ========== HEADER ========== */
  
  .agent-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(250, 250, 249, 0.9);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    border-bottom: 1px solid var(--line);
    padding: 16px 0;
  }

  .agent-header__inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
  }

  .agent-brand {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .agent-brand strong {
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--ink);
  }

  .agent-brand span {
    font-size: 0.75rem;
    color: var(--muted);
    font-weight: 500;
    letter-spacing: 0.01em;
  }

  .agent-contact {
    border: 1.5px solid var(--ink);
    padding: 8px 18px;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--ink);
    transition: all 0.2s var(--ease);
    position: relative;
  }

  .agent-contact::before {
    content: "";
    position: absolute;
    inset: -2px;
    background: var(--ink);
    z-index: -1;
    opacity: 0;
    transition: opacity 0.2s var(--ease);
  }

  .agent-contact:hover::before {
    opacity: 1;
  }

  .agent-contact:hover {
    color: var(--bg);
    transform: translate(-2px, -2px);
  }

  /* ========== HERO ========== */
  
  .hero {
    position: relative;
    background: var(--ink);
    color: var(--bg);
    padding: 140px 0 120px;
    overflow: hidden;
  }

  .hero::before {
    content: "";
    position: absolute;
    top: 0;
    right: 0;
    width: 50%;
    height: 100%;
    background: linear-gradient(135deg, transparent, rgba(255, 77, 0, 0.08));
    pointer-events: none;
  }

  .hero__grid {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 1.3fr 0.7fr;
    gap: 100px;
    align-items: center;
  }

  .eyebrow {
    display: inline-block;
    margin: 0 0 20px;
    padding: 4px 12px;
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: var(--bg);
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .hero-title {
    margin: 0 0 40px;
    font-family: var(--f-display);
    font-size: clamp(4rem, 9vw, 9rem);
    font-weight: 400;
    line-height: 0.85;
    letter-spacing: -0.04em;
  }

  .hero-title span {
    display: block;
  }

  .hero-title em {
    display: block;
    font-style: italic;
    color: var(--accent);
  }

  .hero p {
    max-width: 520px;
    margin: 0;
    color: rgba(250, 250, 249, 0.6);
    font-size: 1rem;
    line-height: 1.6;
    font-weight: 400;
  }

  .hero-card {
    position: relative;
    min-height: 480px;
    padding: 0;
    border: 1px solid rgba(255, 255, 255, 0.15);
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(40px);
    -webkit-backdrop-filter: blur(40px);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    overflow: hidden;
    transition: transform 0.4s var(--ease);
  }

  .hero-card:hover {
    transform: scale(1.02);
  }

  .hero-card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--accent);
  }

  .hero-card strong {
    display: block;
    font-family: var(--f-display);
    font-size: 2rem;
    font-weight: 400;
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--bg);
    margin-bottom: 8px;
  }

  .hero-card p {
    color: rgba(250, 250, 249, 0.5);
    font-size: 0.85rem;
    line-height: 1.5;
  }

  .featured-listing {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .featured-listing__image {
  flex: 1;
  min-height: 280px;
  background: linear-gradient(135deg, rgba(255, 77, 0, 0.2), rgba(10, 10, 10, 0.4));
  background-size: cover;
  background-position: center;
  position: relative;
  overflow: hidden;
}

  .featured-listing__image::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(10, 10, 10, 0.8), transparent 60%);
  }

  .featured-listing > div:last-child {
    padding: 28px;
  }

  .featured-listing span {
    display: block;
    margin-top: 6px;
    color: rgba(250, 250, 249, 0.5);
    font-size: 0.85rem;
  }

  .btn-row {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    margin-top: 44px;
  }

  .btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 52px;
    padding: 0 32px;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    transition: all 0.25s var(--ease);
    overflow: hidden;
  }

  .btn::before {
    content: "";
    position: absolute;
    inset: -2px;
    background: transparent;
    z-index: -1;
    transition: all 0.25s var(--ease);
  }

  .btn--dark {
    background: var(--accent);
    color: white;
    border: 2px solid var(--accent);
  }

  .btn--dark::before {
    background: var(--accent-dark);
  }

  .btn--dark:hover {
    transform: translate(-3px, -3px);
    border-color: var(--accent-dark);
  }

  .btn--dark:hover::before {
    inset: 0;
  }

  .btn--light {
    background: transparent;
    color: var(--bg);
    border: 1.5px solid rgba(250, 250, 249, 0.3);
  }

  .btn--light::before {
    background: rgba(250, 250, 249, 0.1);
  }

  .btn--light:hover {
    transform: translate(-3px, -3px);
    border-color: var(--bg);
  }

  .btn--light:hover::before {
    inset: 0;
  }

  /* ========== DATA STRIP ========== */

  .data-strip {
    position: relative;
    z-index: 10;
    margin-top: -60px;
    padding: 0 0 100px;
  }

  .data-strip .shell {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    background: var(--line);
    border: 2px solid var(--ink);
  }

  .data-card {
    background: var(--surface);
    padding: 36px 32px;
    transition: all 0.3s var(--ease);
    position: relative;
  }

  .data-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--accent-bg);
    opacity: 0;
    transition: opacity 0.3s var(--ease);
  }

  .data-card:hover::before {
    opacity: 1;
  }

  .data-card:hover {
    transform: scale(1.02);
  }

  .data-card__label {
    position: relative;
    z-index: 2;
    display: block;
    margin-bottom: 12px;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .data-card__value {
    position: relative;
    z-index: 2;
    display: block;
    font-family: var(--f-display);
    font-size: 3.5rem;
    font-weight: 400;
    line-height: 0.9;
    letter-spacing: -0.03em;
    color: var(--ink);
    margin-bottom: 8px;
  }

  .data-card__meta {
    position: relative;
    z-index: 2;
    font-size: 0.8rem;
    color: var(--soft);
    font-weight: 500;
  }

  /* ========== SECTIONS ========== */

  .section {
    padding: 100px 0;
  }

  .section-head {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: end;
    margin-bottom: 60px;
  }

  .section-head h2 {
    margin: 0;
    font-family: var(--f-display);
    font-size: clamp(3rem, 6vw, 6rem);
    font-weight: 400;
    line-height: 0.88;
    letter-spacing: -0.04em;
    color: var(--ink);
  }

 .section-head p {
    max-width: 480px;
    margin: 0;
    color: var(--muted);
    font-size: 1.05rem;
    line-height: 1.65;
  }

/* ========== GROUPS SECTION ========== */

  .section--groups {
    background: var(--surface);
    border-top: 2px solid var(--ink);
    border-bottom: 2px solid var(--ink);
  }

  /* ========== BENTO GRID ========== */
  .group-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: repeat(2, 280px);
    gap: 2px;
    background: var(--line-heavy);
    border: 2px solid var(--ink);
  }

  .group-card {
    background: var(--surface);
    padding: 32px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    transition: all 0.35s var(--ease);
    position: relative;
    overflow: hidden;
  }

  .group-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--accent-bg);
    opacity: 0;
    transition: opacity 0.35s var(--ease);
    z-index: 0;
  }

  .group-card:hover::before {
    opacity: 1;
  }

  .group-card:nth-child(1) {
    grid-column: 1 / 3;
    grid-row: 1 / 2;
  }

  .group-card:nth-child(2) {
    grid-column: 3 / 5;
    grid-row: 1 / 2;
  }

  .group-card:nth-child(3) {
    grid-column: 1 / 2;
    grid-row: 2 / 3;
  }

  .group-card:nth-child(4) {
    grid-column: 2 / 5;
    grid-row: 2 / 3;
  }

  .group-card > * {
    position: relative;
    z-index: 1;
  }

  .group-card:hover {
    transform: scale(1.02);
  }

 .group-card small {
    display: block;
    color: var(--accent);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.7rem;
    margin-bottom: 16px;
  }

  .group-card h3 {
    margin: 0 0 14px;
    font-family: var(--f-display);
    font-size: 2rem;
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--ink);
  }

  .group-card p {
    margin: 0;
    color: var(--muted);
    font-size: 1rem;
    line-height: 1.6;
  }

  .card-link-text {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 24px;
    font-size: 0.9rem;
    font-weight: 800;
    color: var(--ink);
    letter-spacing: -0.01em;
  }

  .card-link-text::after {
    content: "→";
    font-size: 1.2em;
  }

  /* ========== CITY BAND ========== */

  .city-band {
    background: var(--ink);
    color: var(--bg);
    padding: 80px;
    display: grid;
    grid-template-columns: 0.7fr 1.3fr;
    gap: 80px;
    border: 2px solid var(--ink);
    position: relative;
    overflow: hidden;
  }

  .city-band::before {
    content: "";
    position: absolute;
    top: -30%;
    right: -10%;
    width: 600px;
    height: 600px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 50%;
    pointer-events: none;
  }

  .city-band h2 {
    margin: 0 0 24px;
    font-family: var(--f-display);
    font-size: clamp(3.5rem, 6vw, 6.5rem);
    font-weight: 400;
    line-height: 0.88;
    letter-spacing: -0.04em;
  }

  .city-band p {
    color: rgba(250, 250, 249, 0.65);
    line-height: 1.7;
    margin: 0 0 24px;
    font-size: 0.95rem;
  }

  /* ========== LISTINGS BENTO ========== */

  .listing-strip {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    grid-auto-rows: 320px;
    gap: 2px;
    background: var(--line-heavy);
    border: 2px solid var(--ink);
  }

  .listing-placeholder {
    appearance: none;
    width: 100%;
    height: 100%;
    overflow: hidden;
    text-align: left;
    cursor: pointer;
    color: inherit;
    padding: 0;
    background: var(--surface);
    border: 0;
    transition: all 0.4s var(--ease);
    position: relative;
  }

  .listing-placeholder:nth-child(1) {
    grid-column: 1 / 4;
    grid-row: 1 / 3;
  }

  .listing-placeholder:nth-child(2) {
    grid-column: 4 / 7;
    grid-row: 1 / 2;
  }

  .listing-placeholder:nth-child(3) {
    grid-column: 4 / 7;
    grid-row: 2 / 3;
  }

  .listing-placeholder:nth-child(4) {
    grid-column: 1 / 3;
    grid-row: 3 / 4;
  }

  .listing-placeholder:nth-child(5) {
    grid-column: 3 / 5;
    grid-row: 3 / 4;
  }

  .listing-placeholder:nth-child(6) {
    grid-column: 5 / 7;
    grid-row: 3 / 4;
  }

  .listing-placeholder::before {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--accent-bg);
    opacity: 0;
    transition: opacity 0.4s var(--ease);
    z-index: 0;
  }

  .listing-placeholder:hover::before {
    opacity: 1;
  }

  .listing-placeholder:hover {
    transform: scale(1.03);
    z-index: 10;
  }

  .listing-placeholder__image {
    height: 100%;
    background: linear-gradient(135deg, rgba(255, 77, 0, 0.1), rgba(10, 10, 10, 0.05));
    background-size: cover;
    background-position: center;
    position: relative;
    overflow: hidden;
    filter: grayscale(20%);
    mix-blend-mode: multiply;
  }

  .listing-placeholder:hover .listing-placeholder__image {
    filter: grayscale(0%);
  }

  .listing-placeholder__image::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(10, 10, 10, 0.95), rgba(10, 10, 10, 0.3) 60%, transparent);
    opacity: 1;
    transition: opacity 0.3s var(--ease);
  }

  .listing-placeholder:hover .listing-placeholder__image::after {
    background: linear-gradient(to top, rgba(10, 10, 10, 0.95), rgba(10, 10, 10, 0.6));
  }

  .listing-placeholder__body {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 24px;
    z-index: 3;
  }

  .listing-placeholder__body strong {
    display: block;
    font-family: var(--f-display);
    font-size: 2rem;
    font-weight: 400;
    letter-spacing: -0.03em;
    line-height: 1;
    margin-bottom: 8px;
    color: var(--bg);
  }

  .listing-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 4px 10px;
    font-size: 0.8rem;
    color: rgba(250, 250, 249, 0.7);
    font-weight: 500;
  }

  .listing-meta span + span::before {
    content: "·";
    margin-right: 10px;
  }

  .listing-card-desc {
    margin: 12px 0 0;
    color: rgba(250, 250, 249, 0.6);
    font-size: 0.8rem;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ========== SOCIAL CARDS ========== */

  .social-card-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2px;
    background: var(--line-heavy);
    border: 2px solid var(--ink);
  }

  .social-profile-card {
    background: var(--surface);
    padding: 36px 32px;
    min-height: 240px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    transition: all 0.35s var(--ease);
    position: relative;
  }

  .social-profile-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--accent-bg);
    opacity: 0;
    transition: opacity 0.35s var(--ease);
  }

  .social-profile-card:hover::before {
    opacity: 1;
  }

  .social-profile-card:hover {
    transform: scale(1.05);
    z-index: 10;
  }

  .social-profile-card > * {
    position: relative;
    z-index: 1;
  }

  .social-profile-card small {
    display: block;
    color: var(--accent);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.65rem;
    margin-bottom: 12px;
  }

  .social-profile-card strong {
    font-family: var(--f-display);
    font-size: 1.85rem;
    font-weight: 400;
    color: var(--ink);
  }

  .social-profile-card span {
    color: var(--muted);
    font-weight: 700;
    font-size: 0.85rem;
  }

  /* ========== BIO ========== */

  .bio {
    background: var(--surface);
    border: 2px solid var(--ink);
    padding: 60px;
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: 60px;
    align-items: center;
  }

  .bio__photo {
    aspect-ratio: 1;
    background: linear-gradient(135deg, rgba(255, 77, 0, 0.15), rgba(10, 10, 10, 0.08));
    border: 2px solid var(--ink);
  }

  .bio h2 {
    margin: 0 0 20px;
    font-family: var(--f-display);
    font-size: 4rem;
    font-weight: 400;
    letter-spacing: -0.03em;
    line-height: 0.9;
    color: var(--ink);
  }

  .bio p {
    color: var(--muted);
    line-height: 1.7;
    margin: 0 0 36px;
    font-size: 0.95rem;
  }

  .bio .btn--light {
    color: var(--ink);
    background: transparent;
    border-color: var(--ink);
  }

  .bio .btn--light::before {
    background: var(--ink);
  }

  .bio .btn--light:hover {
    color: var(--bg);
  }

  /* ========== FOOTER ========== */

  footer {
    padding: 60px 0;
    color: var(--muted);
    font-size: 0.8rem;
    background: var(--surface);
    border-top: 2px solid var(--ink);
  }

  /* ========== MODAL ========== */

  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(10, 10, 10, 0.8);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s var(--ease);
    z-index: 800;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .modal-overlay.open {
    opacity: 1;
    pointer-events: auto;
  }

  .panel {
    position: fixed;
    left: 50%;
    top: 0;
    width: min(960px, calc(100vw - 40px));
    max-height: 100vh;
    background: var(--surface);
    z-index: 900;
    overflow: hidden;
    transform: translate(-50%, -110%);
    transition: transform 0.5s var(--ease);
    display: flex;
    flex-direction: column;
    border: 2px solid var(--ink);
    border-top: 0;
  }

  .panel.open {
    transform: translate(-50%, 0);
  }

  .panel__grab {
    display: none;
  }

  .panel__progress-wrap {
    position: sticky;
    top: 0;
    z-index: 8;
    background: var(--surface);
    border-bottom: 1px solid var(--line);
  }

  .panel__progress-track {
    height: 3px;
    width: 100%;
    background: var(--line);
    overflow: hidden;
  }

  .panel__progress-bar {
    height: 100%;
    width: 100%;
    background: var(--accent);
  }

  .panel__header {
    padding: 20px 28px;
    display: grid;
    grid-template-columns: 1fr auto auto;
    align-items: center;
    gap: 16px;
    background: var(--surface);
  }

  .panel__position {
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .panel__header-actions {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .panel__top-btn,
  .panel__close {
    appearance: none;
    height: 42px;
    padding: 0 20px;
    border: 1.5px solid var(--ink);
    background: var(--surface);
    color: var(--ink);
    cursor: pointer;
    font: inherit;
    font-size: 0.8rem;
    font-weight: 700;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s var(--ease);
    text-decoration: none;
    position: relative;
  }

  .panel__top-btn::before,
  .panel__close::before {
    content: "";
    position: absolute;
    inset: -2px;
    background: var(--ink);
    z-index: -1;
    opacity: 0;
    transition: opacity 0.2s var(--ease);
  }

  .panel__top-btn:hover::before,
  .panel__close:hover::before {
    opacity: 1;
  }

  .panel__top-btn:hover,
  .panel__close:hover {
    color: var(--bg);
    transform: translate(-2px, -2px);
  }

  .panel__close {
    width: 42px;
    padding: 0;
  }

  .panel__view {
    overflow-y: auto;
    flex: 1;
  }

  .panel__content {
    display: block;
  }

  .panel__image-stage {
    position: relative;
    background: var(--line);
  }

  .panel__image {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    display: block;
    filter: grayscale(15%);
  }

  .panel__photo-count {
    position: absolute;
    right: 20px;
    bottom: 20px;
    z-index: 2;
    background: rgba(10, 10, 10, 0.9);
    color: var(--bg);
    padding: 10px 16px;
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.05em;
  }

  .panel__detail-row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px 20px;
    margin: 0 0 24px;
    color: var(--muted);
    font-size: 0.85rem;
    font-weight: 600;
  }

  .panel__detail-row span + span::before {
    content: "·";
    margin-right: 20px;
  }

  .panel__highlights {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin: 0 0 28px;
  }

  .panel__highlight-chip {
    display: inline-flex;
    align-items: center;
    min-height: 36px;
    padding: 10px 16px;
    background: var(--accent-bg);
    color: var(--accent-dark);
    border: 1.5px solid var(--accent);
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.02em;
  }

  .photo-nav {
    position: absolute;
    top: 50%;
    z-index: 3;
    transform: translateY(-50%);
    width: 48px;
    height: 48px;
    border: 1.5px solid var(--bg);
    background: rgba(10, 10, 10, 0.6);
    color: var(--bg);
    font-size: 1.8rem;
    line-height: 1;
    cursor: pointer;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    transition: all 0.2s var(--ease);
  }

  .photo-nav:hover {
    background: rgba(10, 10, 10, 0.9);
  }

  .photo-nav--prev {
    left: 20px;
  }

  .photo-nav--next {
    right: 20px;
  }

  .photo-nav:disabled {
    opacity: 0.3;
    cursor: default;
  }

  .panel__body {
    padding: 40px 44px 44px;
  }

  .panel__headline {
    display: block;
    margin-bottom: 24px;
  }

  .panel__headline > div {
    min-width: 0;
  }

  .panel__price {
    font-family: var(--f-display);
    font-size: clamp(2.8rem, 5vw, 4rem);
    font-weight: 400;
    letter-spacing: -0.03em;
    line-height: 0.9;
    color: var(--ink);
    margin: 0 0 12px;
  }

  .panel__address {
    font-size: 1.4rem;
    color: var(--muted);
    line-height: 1.3;
    margin: 0 0 16px;
    font-weight: 500;
  }

  .panel__meta-item {
    display: inline-flex;
    align-items: baseline;
    gap: 6px;
    padding: 10px 14px;
    border: 1.5px solid var(--line);
    background: var(--surface);
    text-align: center;
  }

  .panel__meta-label {
    display: inline;
    color: var(--soft);
    font-size: 0.7rem;
    line-height: 1;
    font-weight: 700;
    letter-spacing: 0.05em;
  }

  .panel__meta-item strong {
    display: inline;
    color: var(--ink);
    font-size: 0.9rem;
    line-height: 1;
    font-weight: 800;
  }

  .panel__intelligence {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    min-height: 40px;
    padding: 12px 18px;
    background: var(--accent-bg);
    border: 1.5px solid var(--accent);
    color: var(--accent-dark);
    font-size: 0.8rem;
    font-weight: 800;
    margin-bottom: 20px;
    letter-spacing: 0.01em;
  }

  .panel__intelligence::before {
    content: "✦";
    font-size: 1.1rem;
  }

  .panel__desc-wrap {
    margin-top: 0;
    margin-bottom: 28px;
  }

  .panel__desc {
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--muted);
    margin: 0;
  }

  .panel__section-title {
    margin: 0 0 12px;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .panel__footer {
    display: flex;
    justify-content: center;
    padding-top: 10px;
  }

  .panel__cta-row {
    display: flex;
    justify-content: center;
    margin: 8px 0 20px;
  }

  .panel__sms-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 52px;
    padding: 0 28px;
    background: var(--accent);
    color: white;
    font-size: 0.85rem;
    font-weight: 800;
    border: 2px solid var(--accent);
    transition: all 0.25s var(--ease);
    position: relative;
  }

  .panel__sms-btn::before {
    content: "";
    position: absolute;
    inset: -2px;
    background: var(--accent-dark);
    z-index: -1;
    opacity: 0;
    transition: opacity 0.25s var(--ease);
  }

  .panel__sms-btn:hover::before {
    opacity: 1;
  }

  .panel__sms-btn:hover {
    transform: translate(-3px, -3px);
  }

  .panel__nav-row {
    display: flex;
    justify-content: center;
    gap: 14px;
  }

  .panel__next-btn {
    appearance: none;
    background: transparent;
    border: 1.5px solid var(--ink);
    color: var(--ink);
    padding: 14px 24px;
    cursor: pointer;
    font: inherit;
    font-size: 0.8rem;
    font-weight: 700;
    transition: all 0.2s var(--ease);
    text-decoration: none;
    position: relative;
  }

  .panel__next-btn::before {
    content: "";
    position: absolute;
    inset: -2px;
    background: var(--ink);
    z-index: -1;
    opacity: 0;
    transition: opacity 0.2s var(--ease);
  }

  .panel__next-btn:hover::before {
    opacity: 1;
  }

  .panel__next-btn:hover {
    color: var(--bg);
    transform: translate(-2px, -2px);
  }

  /* ========== RESPONSIVE ========== */

  @media (max-width: 1200px) {
    .shell {
      width: calc(100% - 60px);
    }

    .hero {
      padding: 100px 0 80px;
    }

    .hero__grid {
      grid-template-columns: 1fr;
      gap: 60px;
    }

    .section-head {
      grid-template-columns: 1fr;
      gap: 28px;
    }

    .group-grid {
      grid-template-columns: repeat(2, 1fr);
      grid-template-rows: auto;
    }

    .group-card:nth-child(1),
    .group-card:nth-child(2),
    .group-card:nth-child(3),
    .group-card:nth-child(4) {
      grid-column: auto;
      grid-row: auto;
    }

    .listing-strip {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 300px;
    }

    .listing-placeholder:nth-child(1),
    .listing-placeholder:nth-child(2),
    .listing-placeholder:nth-child(3),
    .listing-placeholder:nth-child(4),
    .listing-placeholder:nth-child(5),
    .listing-placeholder:nth-child(6) {
      grid-column: auto;
      grid-row: auto;
    }

    .city-band {
      grid-template-columns: 1fr;
      gap: 44px;
    }

    .bio {
      grid-template-columns: 1fr;
      gap: 40px;
      text-align: center;
    }

    .bio__photo {
      width: 240px;
      margin: 0 auto;
    }

    .bio .btn-row {
      justify-content: center;
    }

    .social-card-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .shell {
      width: calc(100% - 32px);
    }

    .agent-header {
      padding: 12px 0;
    }

    .agent-header__inner {
      flex-direction: column;
      align-items: stretch;
    }

    .agent-contact {
      width: 100%;
      text-align: center;
    }

    .hero {
      padding: 70px 0 60px;
    }

    .section {
      padding: 70px 0;
    }

    .hero-card {
      min-height: auto;
    }

    .data-strip {
      margin-top: -40px;
      padding-bottom: 60px;
    }

    .data-strip .shell {
      grid-template-columns: 1fr;
    }

    .group-grid,
    .listing-strip,
    .social-card-grid {
      grid-template-columns: 1fr;
    }

    .city-band {
      padding: 40px 32px;
    }

    .bio {
      padding: 40px 32px;
    }

    .panel {
      left: 0;
      right: 0;
      top: 0;
      width: 100%;
      max-height: 100svh;
      transform: translateY(-110%);
    }

    .panel.open {
      transform: translateY(0);
    }

    .panel__grab {
      display: flex;
      justify-content: center;
      align-items: center;
      padding: 10px 0 6px;
      background: var(--surface);
      position: sticky;
      top: 0;
      z-index: 9;
    }

    .panel__grab::before {
      content: "";
      width: 44px;
      height: 4px;
      background: var(--line-heavy);
    }

    .panel__header {
      padding: 16px 20px;
    }

    .panel__top-btn,
    .panel__close {
      height: 38px;
      font-size: 0.75rem;
    }

    .panel__body {
      padding: 28px 28px 32px;
    }

    .panel__meta {
      display: flex;
      gap: 10px;
      margin: 6px 0 22px;
    }
  }
</style>
  </head>

  <body>
    <main class="page">
      <header class="agent-header">
        <div class="shell agent-header__inner">
          <a class="agent-brand" href="/">
            <strong>{agent.name}</strong>
            <span>{agent.title} · {agent.city}</span>
          </a>

          <a class="agent-contact" href={`tel:${agent.phone}`}>Call {agent.phone}</a>
        </div>
      </header>

      <section class="hero">
        <div class="shell hero__grid">
          <div>
            <p class="eyebrow">{page.heroEyebrow}</p>

            <h1 class="hero-title">
              <span>{heroHeadingMain}</span>
              <em>{heroHeadingAccent}</em>
            </h1>

            <p>{page.heroIntro}</p>

            <div class="btn-row">
              <a class="btn btn--dark" href={newListingsHref}>View new listings</a>
              <a class="btn btn--light" href={`mailto:${agent.email}`}>Ask {agent.name}</a>
            </div>
          </div>

          <aside class="hero-card">
            {featuredListing ? (
              <button
                type="button"
                class="featured-listing listing-modal-trigger"
                data-price={getListingPrice(featuredListing)}
                data-address={getListingAddress(featuredListing)}
                data-image={getListingImage(featuredListing)}
                data-images={JSON.stringify(getListingImages(featuredListing))}
                data-beds={String(getListingBeds(featuredListing))}
                data-baths={String(getListingBaths(featuredListing))}
                data-sqft={String(getListingSqft(featuredListing))}
                data-description={getListingDescription(featuredListing)}
                data-year={String(getListingYearBuilt(featuredListing))}
                data-lot-size={String(getListingLotSize(featuredListing))}
                data-area={String(getListingArea(featuredListing))}
                data-property-type={String(getListingPropertyType(featuredListing))}
                data-dom={String(getListingDom(featuredListing))}
                data-highlights={JSON.stringify(buildListingHighlights(featuredListing))}
                data-mls={getListingMls(featuredListing)}
                data-href={featuredListing.listing_url || `/listings?mls=${getListingMls(featuredListing)}`}
                style="appearance:none;border:0;background:transparent;color:inherit;text-align:left;padding:0;cursor:pointer;"
              >
                <div
                  class="featured-listing__image"
                  style={getListingImage(featuredListing) ? `background-image:url('${getListingImage(featuredListing)}');` : ""}
                ></div>

                <div>
                  <p class="eyebrow">Featured listing</p>
                  <strong>{getListingPrice(featuredListing)}</strong>
                  <span>{getListingAddress(featuredListing)}</span>
                </div>
              </button>
            ) : (
              <div>
                <p class="eyebrow">Agent pick</p>
                <strong>{page.agentPickTitle}</strong>
                <p>{page.agentPickText}</p>
              </div>
            )}
          </aside>
        </div>
      </section>

      <section class="data-strip">
        <div class="shell">
          <div class="data-card">
            <span class="data-card__label">Active Listings</span>
            <span class="data-card__value">{marketStats.total || '—'}</span>
            <span class="data-card__meta">in {agent.city}</span>
          </div>
          <div class="data-card">
            <span class="data-card__label">New This Week</span>
            <span class="data-card__value">{marketStats.newThisWeek}</span>
            <span class="data-card__meta">fresh options</span>
          </div>
          <div class="data-card">
            <span class="data-card__label">Avg. Days on Market</span>
            <span class="data-card__value">{marketStats.avgDom || '—'}</span>
            <span class="data-card__meta">current pace</span>
          </div>
        </div>
      </section>

      <section class="section section--groups">
        <div class="shell">
          <div class="section-head">
            <div>
              <h2>Homes worth watching.</h2>
            </div>
            <div>
              <p>
                Quick groups that help buyers jump into the right part of the market
                without sorting through everything.
              </p>
            </div>
          </div>

          <div class="group-grid">
            {groups.map((group) => (
              <a class="group-card" href={group.href}>
                <div>
                  <small>{group.kicker}</small>
                  <h3>{group.title}</h3>
                  <p>{group.text}</p>
                </div>
                <strong class="card-link-text">View homes</strong>
              </a>
            ))}
          </div>
        </div>
      </section>

      <section class="section">
        <div class="shell city-band">
          <div>
            <p class="eyebrow">About the city</p>
            <h2>Buying in {agent.city}.</h2>
          </div>

          <div>
            <p>{page.cityIntro}</p>
            <p>{page.cityNotes}</p>
          </div>
        </div>
      </section>

      <section class="section">
        <div class="shell">
          <div class="section-head">
            <h2>{page.newListingsTitle}</h2>
            <p>{page.newListingsIntro}</p>
          </div>

          <div class="listing-strip">
            {newListings.length > 0 ? (
              newListings.map((listing) => {
                const image = getListingImage(listing);
                const images = getListingImages(listing);
                const address = getListingAddress(listing);
                const price = getListingPrice(listing);
                const beds = getListingBeds(listing);
                const baths = getListingBaths(listing);
                const sqft = getListingSqft(listing);
                const description = getListingDescription(listing);
                const mls = getListingMls(listing);
                const href = listing.listing_url || `/listings?mls=${mls}`;

                return (
                  <button
                    type="button"
                    class="listing-placeholder listing-modal-trigger"
                    data-price={price}
                    data-address={address}
                    data-image={image}
                    data-images={JSON.stringify(images)}
                    data-beds={String(beds)}
                    data-baths={String(baths)}
                    data-sqft={String(sqft)}
                    data-description={description}
                    data-year={String(getListingYearBuilt(listing))}
                    data-lot-size={String(getListingLotSize(listing))}
                    data-area={String(getListingArea(listing))}
                    data-property-type={String(getListingPropertyType(listing))}
                    data-dom={String(getListingDom(listing))}
                    data-highlights={JSON.stringify(buildListingHighlights(listing))}
                    data-mls={mls}
                    data-href={href}
                  >
                    <div
                      class="listing-placeholder__image"
                      style={image ? `background-image:url('${image}');` : ""}
                    ></div>

                    <div class="listing-placeholder__body">
                      <strong>{price}</strong>
                      <span class="listing-meta">
                        <span>{address}</span>
                        <span>{beds} bed</span>
                        <span>{baths} bath</span>
                        {getListingDom(listing) ? <span>{getListingDom(listing)} DOM</span> : null}
                      </span>
                      <p class="listing-card-desc">{description}</p>
                    </div>
                  </button>
                );
              })
            ) : (
              [1, 2, 3, 4, 5, 6].map(() => (
                <a class="listing-placeholder" href={newListingsHref}>
                  <div class="listing-placeholder__image"></div>
                  <div class="listing-placeholder__body">
                    <strong>New listing placeholder</strong>
                    <span>$000,000 • 3 bed • 2 bath • {listingCity}</span>
                  </div>
                </a>
              ))
            )}
          </div>

          <div class="btn-row">
            <a class="btn btn--dark" href={newListingsHref}>
              View all matching listings
            </a>
          </div>
        </div>
      </section>

      {hasSocialSection && (
        <section class="section">
          <div class="shell">
            <div class="section-head">
              <h2>{page.socialTitle || "Follow along."}</h2>
              <p>{page.socialIntro}</p>
            </div>

            <div class="social-card-grid">
              {socialLinks.map((link) => (
                <a
                  class={`social-profile-card social-profile-card--${link.label.toLowerCase().replace(/[^a-z]/g, "")}`}
                  href={link.url}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <small>{link.label}</small>
                  <strong>{agent.name}</strong>
                  <span>View latest updates →</span>
                </a>
              ))}
            </div>
          </div>
        </section>
      )}

      <section class="section">
        <div class="shell bio">
          <div class="bio__photo"></div>
          <div>
            <p class="eyebrow">Meet your agent</p>
            <h2>{agent.name}</h2>
            <p>{agent.bio}</p>

            <div class="btn-row">
              <a class="btn btn--dark" href={`tel:${agent.phone}`}>Call {agent.name}</a>
              <a class="btn btn--light" href={`mailto:${agent.email}`}>Email agent</a>
            </div>
          </div>
        </div>
      </section>

      <footer>
        <div class="shell">
          Listings, market data, and availability are subject to change. This page is
          intended as a simple curated buyer resource.
        </div>
      </footer>
    </main>

    <div class="modal-overlay" id="listing-modal-overlay"></div>

    <aside
      class="panel"
      id="listing-modal"
      aria-hidden="true"
      data-agent-name={agent.name}
      data-agent-phone={agent.phone}
      data-agent-email={agent.email}
    >
      <div class="panel__grab" aria-hidden="true"></div>

      <div class="panel__progress-wrap">
        <div class="panel__progress-track">
          <div class="panel__progress-bar"></div>
        </div>

        <div class="panel__header">
          <div class="panel__position" id="listing-modal-position">Listing preview</div>

          <div class="panel__header-actions">
            <button class="panel__top-btn" id="listing-modal-prev" type="button">← Previous</button>
            <button class="panel__top-btn" id="listing-modal-next" type="button">Next →</button>
          </div>

          <button class="panel__close" id="listing-modal-close" type="button" aria-label="Close">✕</button>
        </div>
      </div>

      <div class="panel__view" id="listing-modal-scroll">
        <section class="panel__content">
          <div class="panel__image-stage">
            <img
              id="listing-modal-image"
              class="panel__image"
              src="https://placehold.co/800x600?text=Listing"
              alt=""
              loading="lazy"
              decoding="async"
            />
            <button type="button" class="photo-nav photo-nav--prev" id="listing-photo-prev">‹</button>
            <button type="button" class="photo-nav photo-nav--next" id="listing-photo-next">›</button>
            <div class="panel__photo-count" id="listing-photo-count">1 / 1 photos</div>
          </div>

          <div class="panel__body">
            <div class="panel__headline">
              <div>
                <h2 class="panel__price" id="listing-modal-price">—</h2>
                <p class="panel__address" id="listing-modal-address">Address</p>
                <div class="panel__meta" id="listing-modal-meta">—</div>
              </div>
            </div>

            <div class="panel__intelligence" id="listing-modal-intelligence">
              Fresh listing worth a closer look
            </div>

            <div class="panel__detail-row" id="listing-modal-detail-row"></div>

            <div class="panel__highlights" id="listing-modal-highlights"></div>

            <div class="panel__desc-wrap">
              <h3 class="panel__section-title">Description</h3>
              <p class="panel__desc" id="listing-modal-description">
                A quick preview of this property.
              </p>
            </div>

            <div class="panel__cta-row">
              <a class="panel__sms-btn" id="listing-modal-sms" href="#">
                Request info / showing →
              </a>
            </div>

            <div class="panel__footer">
              <div class="panel__nav-row">
                <button class="panel__next-btn" id="listing-modal-bottom-prev" type="button">← Previous</button>
                <button class="panel__next-btn" id="listing-modal-bottom-next" type="button">Next →</button>
              </div>
            </div>
          </div>
        </section>
      </div>
    </aside>

    <script is:inline>
  function initAgentListingModal() {
    const modal = document.getElementById("listing-modal");
    const overlay = document.getElementById("listing-modal-overlay");
    const closeBtn = document.getElementById("listing-modal-close");
    const imageEl = document.getElementById("listing-modal-image");
    const priceEl = document.getElementById("listing-modal-price");
    const addressEl = document.getElementById("listing-modal-address");
    const metaEl = document.getElementById("listing-modal-meta");
    const descEl = document.getElementById("listing-modal-description");
    const linkEl = document.getElementById("listing-modal-link");
    const smsEl = document.getElementById("listing-modal-sms");
    const positionEl = document.getElementById("listing-modal-position");
    const intelligenceEl = document.getElementById("listing-modal-intelligence");
    const detailRowEl = document.getElementById("listing-modal-detail-row");
    const highlightsEl = document.getElementById("listing-modal-highlights");
    const photoCountEl = document.getElementById("listing-photo-count");
    const photoPrevBtn = document.getElementById("listing-photo-prev");
    const photoNextBtn = document.getElementById("listing-photo-next");
    const prevListingBtn = document.getElementById("listing-modal-prev");
    const nextListingBtn = document.getElementById("listing-modal-next");
    const bottomNextListingBtn = document.getElementById("listing-modal-bottom-next");
    const bottomPrevListingBtn = document.getElementById("listing-modal-bottom-prev");
    const scrollArea = document.getElementById("listing-modal-scroll");

    if (!modal || !overlay) return;

    let activePhotos = [];
    let activePhotoIndex = 0;
    let allCards = [];
    let activeIndex = -1;

    function parseImages(value, fallback) {
      try {
        const parsed = JSON.parse(value || "[]");
        const images = Array.isArray(parsed) ? parsed.filter(Boolean) : [];
        return Array.from(new Set([fallback, ...images].filter(Boolean)));
      } catch {
        return fallback ? [fallback] : [];
      }
    }

    function preloadImage(src) {
      if (!src) return;
      const img = new Image();
      img.src = src;
    }

    function renderPhoto() {
      if (!imageEl) return;
      const src = activePhotos[activePhotoIndex] || "https://placehold.co/800x600?text=Listing";
      imageEl.src = src;
      preloadImage(activePhotos[activePhotoIndex + 1]);
      preloadImage(activePhotos[activePhotoIndex - 1]);
      window.requestIdleCallback?.(() => {
        activePhotos.slice(8).forEach(preloadImage);
      }) || setTimeout(() => {
        activePhotos.slice(8).forEach(preloadImage);
      }, 800);
      if (photoCountEl) photoCountEl.textContent = `${activePhotoIndex + 1} / ${Math.max(activePhotos.length, 1)} photos`;
      if (photoPrevBtn) photoPrevBtn.disabled = activePhotoIndex === 0;
      if (photoNextBtn) photoNextBtn.disabled = activePhotoIndex >= activePhotos.length - 1;
    }

    function showPrevPhoto() {
      if (activePhotoIndex <= 0) return;
      activePhotoIndex -= 1;
      renderPhoto();
    }

    function showNextPhoto() {
      if (activePhotoIndex >= activePhotos.length - 1) return;
      activePhotoIndex += 1;
      renderPhoto();
    }

    function showNextListing() {
      if (!allCards.length || activeIndex >= allCards.length - 1) return;
      activeIndex += 1;
      const nextCard = allCards[activeIndex];
      if (nextCard) openModal(nextCard);
    }

    function showPrevListing() {
      if (!allCards.length || activeIndex <= 0) return;
      activeIndex -= 1;
      const prevCard = allCards[activeIndex];
      if (prevCard) openModal(prevCard);
    }

    function pickNote(seed, options) {
      const text = String(seed || "");
      const total = text.split("").reduce((sum, char) => sum + char.charCodeAt(0), 0);
      return options[total % options.length];
    }

    function openModal(card) {
      allCards = Array.from(document.querySelectorAll(".listing-modal-trigger"));
      activeIndex = allCards.indexOf(card);

      const image = card.dataset.image || "";
      activePhotos = parseImages(card.dataset.images || "[]", image);
      activePhotoIndex = 0;

      if (priceEl) priceEl.textContent = card.dataset.price || "Price on request";
      if (addressEl) addressEl.textContent = card.dataset.address || "Address available";
      if (imageEl) imageEl.alt = card.dataset.address || "Listing";
      if (descEl) {
        descEl.textContent = card.dataset.description || "A quick preview of this property.";
        descEl.classList.remove("is-collapsed");
      }

      if (linkEl) linkEl.href = card.dataset.href || "/listings";

      if (smsEl) {
        const phone = String(modal.dataset.agentPhone || "").replace(/[^0-9]/g, "");
        const email = modal.dataset.agentEmail || "";
        const agentName = modal.dataset.agentName || "there";
        const message = `Hi ${agentName}, I'd like more info or a showing for ${card.dataset.address || "this listing"}${card.dataset.mls ? ` MLS ${card.dataset.mls}` : ""}.`;
        const isMobile = /iPhone|iPad|iPod|Android/i.test(navigator.userAgent);
        smsEl.textContent = isMobile ? "Text for info / showing →" : "Email for info / showing →";
        smsEl.href = isMobile && phone ? `sms:${phone}?&body=${encodeURIComponent(message)}` : `mailto:${email}?subject=Listing Inquiry&body=${encodeURIComponent(message)}`;
      }

      if (positionEl) positionEl.textContent = card.dataset.mls ? `MLS ${card.dataset.mls}` : "Listing preview";

      if (intelligenceEl) {
        const desc = String(card.dataset.description || "").toLowerCase();
        const propertyType = String(card.dataset.propertyType || "").toLowerCase();
        const beds = Number(card.dataset.beds || 0);
        const baths = Number(card.dataset.baths || 0);
        const sqft = Number(String(card.dataset.sqft || "").replace(/[^0-9.]/g, ""));
        const year = Number(card.dataset.year || 0);
        const dom = Number(card.dataset.dom || 0);

        const isCondo = propertyType.includes("condo") || propertyType.includes("apartment");
        const isTownhouse = propertyType.includes("townhouse") || propertyType.includes("townhome") || propertyType.includes("row");
        const isHouse = propertyType.includes("house") || propertyType.includes("detached") || propertyType.includes("single family");
        const isNew = dom && dom <= 7;
        const hasView = /ocean view|water view|harbour view|harbor view|sea view|lake view|mountain view|city view|panoramic view/.test(desc);
        const hasSuite = isHouse && /suite|income|mortgage helper|secondary suite|legal suite/.test(desc);
        const isUpdated = /renovated|updated|modernized|new kitchen|new roof|contemporary/.test(desc);
        const hasParking = /garage|rv parking|double garage|underground parking|secure parking/.test(desc);
        const amenities = /pool|gym|fitness|clubhouse|elevator|storage locker|amenities/.test(desc);
        const outdoor = /patio|balcony|deck|yard|garden|outdoor space/.test(desc);

        let note = "";
        if (isCondo) {
          if (sqft >= 900 && outdoor) note = "Feels bigger than most condos";
          else if (isUpdated) note = pickNote(card.dataset.mls || card.dataset.address, ["Move-in ready condo option", "Clean, easy condo choice", "A simpler option to step into", "Low-effort condo living"]);
          else if (sqft >= 900) note = "More room than the typical condo";
          else if (amenities) note = "Easy living with building perks";
          else if (hasParking) note = "Convenient everyday setup";
          else if (isNew) note = "Fresh option worth a look";
          else note = "Simple, low-maintenance living";
        } else if (isTownhouse) {
          if (beds >= 3 && outdoor) note = "Great layout for everyday living";
          else if (hasParking) note = "Practical townhome setup";
          else if (isUpdated) note = "Updated townhome option";
          else if (isNew) note = "New townhome worth a look";
          else note = "Balanced space with low upkeep";
        } else if (isHouse) {
          const isFamilySized = beds >= 4 && baths >= 3;
          const isLarge = sqft >= 2500;
          const isNewer = year >= 2015;
          if (hasView && hasSuite) note = "Strong upside with income potential";
          else if (isNewer && isFamilySized && isLarge) note = "Checks the boxes for a growing family";
          else if (isUpdated && isLarge) note = "Updated home with real space";
          else if (hasSuite) note = "Flexible layout with income potential";
          else if (hasView) note = "Nice outlook from main living areas";
          else if (isNew) note = "New listing worth acting on";
          else note = "Solid detached option to consider";
        } else {
          if (hasView) note = "Open outlook worth noting";
          else if (isUpdated) note = "Updated features stand out";
          else note = "Worth a closer look";
        }
        intelligenceEl.textContent = note;
      }

      if (detailRowEl) {
        const details = [
          card.dataset.propertyType,
          card.dataset.area ? `${card.dataset.area}` : "",
          card.dataset.year ? `Built ${card.dataset.year}` : "",
          card.dataset.lotSize ? `${card.dataset.lotSize} lot` : "",
          card.dataset.dom ? `${card.dataset.dom} Days on Market` : ""
        ].filter(Boolean);
        detailRowEl.innerHTML = details.map((item) => `<span>${item}</span>`).join("");
      }

      if (highlightsEl) {
        let highlights = [];
        try { highlights = JSON.parse(card.dataset.highlights || "[]"); } catch {}
        highlightsEl.innerHTML = highlights.map((item) => `<span class="panel__highlight-chip">${item}</span>`).join("");
      }

      if (metaEl) {
        const facts = [
          card.dataset.beds ? `${card.dataset.beds} Bed` : "",
          card.dataset.baths ? `${card.dataset.baths} Bath` : "",
          card.dataset.sqft ? `${card.dataset.sqft} Sq Ft` : ""
        ].filter(Boolean);
        metaEl.innerHTML = facts.join(" • ");
      }

      renderPhoto();
      modal.classList.add("open");
      overlay.classList.add("open");
      modal.setAttribute("aria-hidden", "false");
      document.body.classList.add("modal-open");
      requestAnimationFrame(() => { if (scrollArea) scrollArea.scrollTop = 0; });
    }

    function closeModal() {
      modal.classList.remove("open");
      overlay.classList.remove("open");
      modal.setAttribute("aria-hidden", "true");
      document.body.classList.remove("modal-open");
    }

    document.addEventListener("click", (event) => {
      const trigger = event.target.closest(".listing-modal-trigger");
      if (!trigger) return;
      event.preventDefault();
      event.stopPropagation();
      openModal(trigger);
    });

    closeBtn?.addEventListener("click", closeModal);
    overlay?.addEventListener("click", closeModal);
    photoPrevBtn?.addEventListener("click", showPrevPhoto);
    photoNextBtn?.addEventListener("click", showNextPhoto);
    prevListingBtn?.addEventListener("click", showPrevListing);
    nextListingBtn?.addEventListener("click", showNextListing);
    bottomNextListingBtn?.addEventListener("click", showNextListing);
    bottomPrevListingBtn?.addEventListener("click", showPrevListing);

    document.addEventListener("keydown", (event) => {
      if (!modal.classList.contains("open")) return;
      if (event.key === "Escape") closeModal();
      if (event.key === "ArrowLeft") showPrevPhoto();
      if (event.key === "ArrowRight") showNextPhoto();
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initAgentListingModal, { once: true });
  } else {
    initAgentListingModal();
  }

  document.addEventListener("astro:page-load", initAgentListingModal);

  window.addEventListener("load", () => {
    document.querySelectorAll('a[href^="/explore"]').forEach((link) => {
      const prefetch = document.createElement("link");
      prefetch.rel = "prefetch";
      prefetch.href = link.href;
      prefetch.as = "document";
      document.head.appendChild(prefetch);
    });
  });
</script>
  </body>
</html>