      function initShortlistPage() {
        function coordsLookWrong(lat, lng, card) {
  if (!Number.isFinite(lat) || !Number.isFinite(lng)) return true;
  if (lat === 0 || lng === 0) return true;

  const city = String(card?.dataset?.city || "").toLowerCase();

  const cityBounds = {
    nanaimo: { minLat: 49.0, maxLat: 49.35, minLng: -124.15, maxLng: -123.75 },
    lantzville: { minLat: 49.2, maxLat: 49.35, minLng: -124.15, maxLng: -123.9 },
    parksville: { minLat: 49.25, maxLat: 49.4, minLng: -124.45, maxLng: -124.2 }
  };

  const bounds = cityBounds[city];

  if (!bounds) {
    return lat < 48.2 || lat > 50.7 || lng < -128.5 || lng > -122.9;
  }

  return (
    lat < bounds.minLat ||
    lat > bounds.maxLat ||
    lng < bounds.minLng ||
    lng > bounds.maxLng
  );
}

function getGeocodeAddress(card) {
  const address = card.dataset.address || "";
  const city = card.dataset.city || "";

  return city
    ? `${address}, ${city}, BC, Canada`
    : `${address}, British Columbia, Canada`;
}
        const body = document.body;
        const isAgentView = body?.dataset.agentView === "true";
const pageSlug = body?.dataset.shortlistSlug || "";
const isExpandedReview = new URLSearchParams(window.location.search).has("expanded");
if (!isAgentView && pageSlug) {
  fetch("/api/shortlists/track-view", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ slug: pageSlug })
  }).catch(() => {});
}
const viewedKey = `shortlist_viewed_${pageSlug}`;

function getViewedListings() {
  try {
    return new Set(JSON.parse(localStorage.getItem(viewedKey) || "[]"));
  } catch {
    return new Set();
  }
}

function markListingViewed(card) {
  if (!card) return;

  const id = card.dataset.itemId || card.dataset.cardId || "";
  if (!id) return;

  const viewed = getViewedListings();
  viewed.add(id);
  localStorage.setItem(viewedKey, JSON.stringify([...viewed]));

  card.dataset.viewed = "true";
  card.dataset.isNew = "false";
  card.querySelector(".card__new-badge")?.remove();
}

function clearNewBadgesAfterModalClose() {
  const viewed = getViewedListings();

  document.querySelectorAll(".card").forEach((card) => {
    const id = card.dataset.itemId || card.dataset.cardId || "";

    if (id && viewed.has(id)) {
      card.dataset.viewed = "true";
      card.dataset.isNew = "false";
      card.querySelector(".card__new-badge")?.remove();
    }
  });
}

