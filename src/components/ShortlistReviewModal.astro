  function buildReviewMessage(reason = "completed") {
  const cards = getCards();

  const favs = cards.filter((card) => card.dataset.isFavourite === "true").length;
  const maybes = cards.filter((card) => card.dataset.decision === "maybe").length;
  const no = cards.filter((card) => card.dataset.decision === "pass").length;
  const reviewed = favs + maybes + no;

  const parts = [];

  if (favs > 0) parts.push(`${favs} favourite${favs > 1 ? "s" : ""}`);
  if (maybes > 0) parts.push(`${maybes} maybe${maybes > 1 ? "s" : ""}`);
  if (no > 0) parts.push(`${no} not for me`);

  const summary = parts.length ? parts.join(", ") : "no choices saved yet";

  if (reason === "skipped") {
  return `Buyer left after reviewing ${reviewed} of ${cards.length} homes: ${summary}.`;
}

if (reason === "comment") {
  return `Buyer added a note after reviewing ${cards.length} homes: ${summary}.`;
}

return `Buyer reviewed all ${cards.length} homes: ${summary}.`;
}

async function sendReviewComplete(reason = "completed", comment = "") {
  try {
    const res = await fetch("/api/shortlists/review-complete", {
      method: "POST",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify({
        slug: pageSlug,
        message: buildReviewMessage(reason),
        comment,
        reason
      })
    });

    const data = await res.json().catch(() => null);

    if (!res.ok || !data?.ok) {
      throw new Error(data?.error || "Failed");
    }

    return true;
  } catch (err) {
    console.warn("Could not send review summary", err);
    return false;
  }
}

async function autoSendReviewComplete(reason = "completed") {
  if (isAgentView) return;
  if (hasAutoSentReviewSummary) return;

  hasAutoSentReviewSummary = true;
  await sendReviewComplete(reason, "");
}
