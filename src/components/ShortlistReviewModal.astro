  100% { opacity: 1; }
}

@keyframes loveButtonGlow {
  0% {
    box-shadow: 0 0 0 0 rgba(176, 125, 42, 0);
  }

  45% {
    box-shadow: 0 0 0 6px rgba(176, 125, 42, 0.14);
