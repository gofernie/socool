let activePhotoUrls = [];
let activePhotoIndex = 0;
let photoTouchStartX = 0;
let photoTouchEndX = 0;

const shortlistSendId = document.body?.dataset.shortlistSendId || "";

let metricListingId = "";
let metricMls = "";
let metricStartTime = 0;
let metricViewedImages = new Set();
let metricImageViews = 0;
let metricMaxImageIndex = 0;

function trackActivePhotoMetric(index = activePhotoIndex) {
  if (!metricListingId) return;

  metricViewedImages.add(index);
  metricImageViews += 1;
  metricMaxImageIndex = Math.max(metricMaxImageIndex, index);
}

async function flushListingMetrics(extra = {}) {
  if (!shortlistSendId || !metricListingId || !metricStartTime) return;

  const timeSpentSeconds = Math.max(
    1,
    Math.round((Date.now() - metricStartTime) / 1000)
  );

  const payload = {
    shortlistSendId,
    listingId: metricListingId,
    mls: metricMls,
    timeSpentSeconds,
    uniqueImagesViewed: metricViewedImages.size,
    imageViews: metricImageViews,
    maxImageIndex: metricMaxImageIndex,
    ...extra
  };

  metricListingId = "";
  metricMls = "";
  metricStartTime = 0;
  metricViewedImages = new Set();
  metricImageViews = 0;
  metricMaxImageIndex = 0;

  try {
    await fetch("/api/shortlists/track-listing-metrics", {
      method: "POST",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify(payload)
    });
  } catch (err) {
    console.warn("Could not track listing metrics", err);
  }
}

function startListingMetrics(card) {
  flushListingMetrics();

  metricListingId =
    card?.dataset?.listingId ||
    card?.dataset?.cardId ||
    card?.dataset?.itemId ||
    "";

  metricMls = card?.dataset?.mls || metricListingId;
  metricStartTime = Date.now();
  metricViewedImages = new Set();
