function sortCardsByReview() {
  if (!shortlistGrid) return;

  reviewCards = null;

  const cards = Array.from(document.querySelectorAll(".card"));

  const scoreCard = (card) => {
  // HARD RULE: "Not for me" always last
  if (card.dataset.decision === "pass") return 99;

  // Then order the rest
  if (card.dataset.isFavourite === "true") return 0;
  if (card.dataset.decision === "maybe") return 1;

  // undecided
  return 2;
};

  cards
    .sort((a, b) => {
      const scoreDiff = scoreCard(a) - scoreCard(b);
      if (scoreDiff !== 0) return scoreDiff;

      return Number(a.dataset.originalOrder || 999999) - Number(b.dataset.originalOrder || 999999);
    })
    .forEach((card, index) => {
      shortlistGrid.appendChild(card);

      const indexEl = card.querySelector(".card__index");
      if (indexEl) {
        indexEl.textContent = `No. ${String(index + 1).padStart(2, "0")}`;
      }

      card.dataset.featured = index === 0 ? "true" : "false";
    });

  reviewCards = null;
}
        function refreshCardUI(card, tags, isFav, decision) {
  if (!card) return;

  card.dataset.likedTags = JSON.stringify(tags);
  card.dataset.isFavourite = isFav ? "true" : "false";
  card.dataset.decision = decision || "";
// once viewed, never show NEW again
card.dataset.isNew = card.dataset.viewed === "true"
  ? "false"
  : (!isFav && !decision ? "true" : "false");

  const wrap = card.querySelector(".card__image-wrap");
  if (!wrap) return;

  wrap.querySelector(".card__love-badge")?.remove();
  wrap.querySelector(".card__maybe-badge")?.remove();
wrap.querySelector(".card__new-badge")?.remove();
  if (isFav) {
    const badge = document.createElement("div");
    badge.className = "card__love-badge";
    badge.innerHTML = `
      <span class="card__love-badge-heart">♥</span>
      <span>Loved</span>
    `;
    wrap.appendChild(badge);
    return;
  }

  if (decision === "maybe") {
    const badge = document.createElement("div");
    badge.className = "card__maybe-badge";
    badge.innerHTML = `
      <span>🤔</span>
      <span>Not sure</span>
    `;
    wrap.appendChild(badge);
  }
}
