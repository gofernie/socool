    return [
      ["layout", "Layout"],
      ["views", "Views"],
      ["building", "Building"],
      ["amenities", "Amenities"],
      ["walkability", "Walkability"],
      ["modern", "Modern"],
      ["value", "Value"],
      ["area", "Location"],
    ];
  }

  if (type.includes("town")) {
    return [
      ["layout", "Layout"],
      ["garage", "Garage"],
      ["yard", "Yard"],
      ["storage", "Storage"],
      ["modern", "Modern"],
      ["value", "Value"],
      ["area", "Area"],
    ];
  }

  if (type.includes("mobile") || type.includes("manufactured")) {
    return [
      ["value", "Affordable"],
      ["modern", "Updated"],
      ["community", "Community"],
      ["views", "Views"],
      ["layout", "Layout"],
      ["parking", "Parking"],
      ["yard", "Yard"],
    ];
  }

  return [
    ["layout", "Layout"],
    ["yard", "Yard"],
    ["garage", "Garage"],
    ["suite", "Suite potential"],
    ["views", "Views"],
    ["privacy", "Privacy"],
    ["modern", "Modern"],
    ["area", "Area"],
  ];
}

