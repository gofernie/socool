function getCardPhotoUrls(card) {
  if (!card) return [];

  const normalizePhotoUrl = (url) => {
    const value = String(url || "").trim();

    if (!value) return "";
    if (value.startsWith("http://") || value.startsWith("https://")) return value;
    if (value.startsWith("/")) return `https://cdn.repliers.io${value}`;

    return `https://cdn.repliers.io/${value}`;
  };

  let rawImages = [];

  try {
    rawImages = JSON.parse(card.dataset.images || "[]");
  } catch {
    rawImages = [];
  }

  const urls = rawImages
    .map((img) => {
      if (typeof img === "string") return normalizePhotoUrl(img);

      return normalizePhotoUrl(
        img.highRes ||
        img.mediumRes ||
        img.lowRes ||
        img.url ||
        ""
      );
    })
    .filter(Boolean);

  return urls.length
    ? urls
    : [card.dataset.image || "https://placehold.co/800x600?text=Listing"];
}

