function getHighlightChips(description = "") {
  const lower = description.toLowerCase();
  return HIGHLIGHT_RULES
    .filter(rule => rule.keywords.some(kw => lower.includes(kw)))
    .map(rule => rule.label)
    .slice(0, 5);
}

