function getContextualLikeTags(card) {
  const text = [
    card?.dataset?.type,
    card?.dataset?.propertyType,
    card?.dataset?.description,
    card?.dataset?.address,
    card?.dataset?.area,
  ].join(" ").toLowerCase();

  if (
    text.includes("waterfront") ||
    text.includes("oceanfront") ||
    text.includes("beachfront") ||
    text.includes("water view") ||
    text.includes("ocean view")
  ) {
    return [
      ["waterfront", "🌊 Waterfront"],
      ["location", "📍 Location"],
      ["views", "🌅 Views"],
    ];
  }

  if (
    text.includes("condo") ||
    text.includes("apartment") ||
    text.includes("strata")
  ) {
    return [
      ["walkability", "🚶 Walkability"],
      ["location", "📍 Location"],
      ["updated", "✨ Updated interior"],
    ];
  }

  if (
    text.includes("family") ||
    text.includes("yard") ||
    text.includes("garage") ||
    text.includes("bedroom")
  ) {
    return [
      ["layout", "🏡 Layout"],
      ["yard", "🌳 Yard"],
      ["location", "📍 Location"],
    ];
  }

  return [
    ["location", "📍 Location"],
    ["views", "🌊 Views"],
    ["layout", "🏡 Layout"],
  ];
}

function renderLikeTags(card) {
  if (!likeTagsEl) return;

  const decision = card?.dataset.decision || "";
  const shouldShow = decision === "love" || decision === "maybe";

  likeTagsEl.classList.toggle("open", shouldShow);

  if (!shouldShow) {
    likeTagsEl.hidden = true;
    likeTagsEl.innerHTML = "";
    return;
  }



  let savedTags = [];

  try {
    savedTags = JSON.parse(card.dataset.likedTags || "[]");
  } catch {
    savedTags = [];
  }

  const tagOptions =
  decision === "love"
    ? getContextualLikeTags(card)
    : [
        ["location", "📍 Location"],
        ["value", "💰 Value"],
        ["layout", "🏡 Layout"],
      ];

  likeTagsEl.innerHTML = `
    <div class="intent-like-tags-kicker">What stood out?</div>
    <div class="intent-like-tags-row">
      ${tagOptions
        .map(([key, label]) => {
          const activeClass = savedTags.includes(key) ? " active" : "";

          return `
            <button
              type="button"
              class="intent-like-tag${activeClass}"
              data-like-tag="${key}"
            >
              ${label}
            </button>
          `;
        })
        .join("")}
    </div>
  `;

  likeTagsEl.hidden = false;
likeTagsEl.classList.remove("is-visible");

setTimeout(() => {
  likeTagsEl.classList.add("is-visible");
}, 120);
}

function getSharedIntentSessionId() {
  if (typeof window.getSharedIntentSessionId === "function") {
    return window.getSharedIntentSessionId();
  }

  const key = "intent_session_id";
  let value = window.localStorage.getItem(key);

  if (!value) {
    value =
      window.crypto?.randomUUID?.() ||
      `intent_${Date.now()}_${Math.random().toString(16).slice(2)}`;

    window.localStorage.setItem(key, value);
  }

  return value;
}
