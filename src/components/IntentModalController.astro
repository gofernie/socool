       sheetMapBtn?.addEventListener("click", async () => {
  if (!activeCard || !sheetMiniMap) return;

  const mapIsOpen = !sheetMiniMap.hidden;

  if (mapIsOpen) {
    sheetMiniMap.hidden = true;
    sheetMiniMap.style.display = "none";

    if (sheetImageStage) {
      sheetImageStage.classList.remove("is-hidden");
    }

    if (sheetMapBtn) {
      sheetMapBtn.textContent = "Map";
    }

    return;
  }

  const point = getCardLatLng(activeCard);

  if (!point) {
    sheetMiniMap.hidden = false;
    sheetMiniMap.style.display = "block";

    if (sheetMapBtn) {
      sheetMapBtn.textContent = "Pictures";
    }

    sheetMiniMap.innerHTML =
      "<p style='padding:16px;color:#6b6560;'>No map location available for this listing.</p>";

    return;
  }

  if (sheetImageStage) {
    sheetImageStage.classList.add("is-hidden");
  }

  sheetMiniMap.hidden = false;
  sheetMiniMap.style.display = "block";

  if (sheetMapBtn) {
    sheetMapBtn.textContent = "Pictures";
  }

  try {
    await loadGoogleMaps();
  } catch (error) {
    console.error("Google Maps failed to load:", error);

    sheetMiniMap.innerHTML =
      "<p style='padding:16px;color:#6b6560;'>Map could not load.</p>";

    return;
  }

  sheetMiniMapInstance = new google.maps.Map(sheetMiniMap, {
    center: point,
    zoom: 15,
    mapTypeControl: false,
    streetViewControl: false,
    fullscreenControl: false,
  });

  if (sheetMiniMapMarker) {
    sheetMiniMapMarker.setMap(null);
  }

  sheetMiniMapMarker = new google.maps.Marker({
    position: point,
    map: sheetMiniMapInstance,
    title: activeCard.dataset.address || "Listing",
  });

  window.setTimeout(() => {
    google.maps.event.trigger(sheetMiniMapInstance, "resize");
    sheetMiniMapInstance.setCenter(point);
  }, 120);
});
