---
type NavItem = {
  label: string;
  href: string;
};

const {
  city = "nanaimo",
  areas = [],
  types = [],
  intentPages = [],
  showAreaNav = false,
} = Astro.props;

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";

const cityLabel = String(city)
  .replace(/-/g, " ")
  .replace(/\b\w/g, (char) => char.toUpperCase());

const slugify = (value: string) =>
  String(value || "")
    .toLowerCase()
    .trim()
    .replace(/\s+/g, "-");

const isActive = (href: string) => {
  const cleanHref = href.replace(/\/$/, "") || "/";

  if (
    cleanHref === `/${slugify(city)}-real-estate-market` &&
    currentPath.startsWith(`/${slugify(city)}/areas/`)
  ) {
    return true;
  }

  return currentPath === cleanHref;
};

const TYPE_PAGE_MAP: Record<string, string> = {
  house: "homes",
  home: "homes",
  condo: "condos",
  townhouse: "townhomes",
  townhome: "townhomes",
  land: "land",
};

const cleanAreaLabel = (value: string) =>
  String(value || "")
    .replace(/^pq\s+/i, "")
    .replace(/\s+/g, " ")
    .trim()
    .replace(/\b\w/g, (char) => char.toUpperCase());

const areaLinks: NavItem[] = areas.slice(0, 8).map((area: string) => ({
  label: cleanAreaLabel(area),
  href: `/${slugify(city)}/areas/${slugify(area)}`,
}));

const TYPE_ORDER = ["house", "condo", "townhouse", "mobile", "land"];
const sortedTypes = [...types].sort(
  (a, b) =>
    (TYPE_ORDER.indexOf(a.toLowerCase()) + 1 || 99) -
    (TYPE_ORDER.indexOf(b.toLowerCase()) + 1 || 99)
);

const typeLinks: NavItem[] = sortedTypes.slice(0, 5).map((type: string) => {
  const key = String(type).toLowerCase();
  const typePageSlug = TYPE_PAGE_MAP[key] || `${slugify(type)}s`;

  return {
    label: String(type)
      .replace(/-/g, " ")
      .replace(/\b\w/g, (char) => char.toUpperCase()),
    href: `/${slugify(city)}-${typePageSlug}`,
  };
});

const intentLinks: NavItem[] = intentPages.slice(0, 6).map((page: any) => ({
  label:
    page.nav_label ||
    page.card_title ||
    page.hero_heading ||
    page.seo_heading ||
    page.lifestyle_angle ||
    page.slug
      .replace(/-/g, " ")
      .replace(/\b\w/g, (char: string) => char.toUpperCase()),
  href: `/${slugify(city)}/${page.slug}`,
}));

const finalNavLinks: NavItem[] = intentLinks.length > 0 ? intentLinks : typeLinks;
---

<nav class="site-nav">
  <div class="shell site-nav__inner">
    <a class="site-nav__brand" href="/">
      {cityLabel} Homes
    </a>

    <button
      class="site-nav__toggle"
      type="button"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="site-nav-links"
    >
      <span aria-hidden="true">&equiv;</span>
    </button>

    <div class="site-nav__links" id="site-nav-links">
      <a
        class:list={{ active: isActive(`/${slugify(city)}-real-estate-market`) }}
        href={`/${slugify(city)}-real-estate-market`}
      >
        Areas
      </a>

   {finalNavLinks.map((item) => (
  <a class:list={{ active: isActive(item.href) }} href={item.href}>
    {item.label}
  </a>
))}
    </div>
  </div>
</nav>

{showAreaNav && areaLinks.length > 0 && (
  <div class="site-subnav">
    <div class="shell site-subnav__inner">
      {areaLinks.map((item) => (
        <a class:list={{ active: isActive(item.href) }} href={item.href}>
          {item.label}
        </a>
      ))}
    </div>
  </div>
)}

<script is:inline>
  const navToggle = document.querySelector(".site-nav__toggle");
  const navLinks = document.querySelector(".site-nav__links");

  navToggle?.addEventListener("click", () => {
    const isOpen = navLinks?.classList.toggle("open");
    navToggle.setAttribute("aria-expanded", isOpen ? "true" : "false");
  });
</script>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--surface) 94%, transparent);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--line);
  }

  .site-nav__inner {
    min-height: 58px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .site-nav__brand {
    font-family: var(--f-display, Georgia, serif);
    font-size: 1.35rem;
    font-weight: 600;
    letter-spacing: -0.04em;
    white-space: nowrap;
    color: var(--ink);
    text-decoration: none;
  }

  .site-nav__toggle {
    display: none;
  }

  .site-nav__toggle span {
    transform: translateY(-1px);
  }

.site-nav__links,
.site-subnav__inner {
  display: flex;
  align-items: center;
  gap: 8px;
}

.site-nav__links {
  flex-wrap: nowrap;
  overflow-x: auto;
  scrollbar-width: none;
}

.site-nav__links::-webkit-scrollbar {
  display: none;
}

.site-subnav__inner {
  flex-wrap: wrap;
}

.site-nav__links a {
  white-space: nowrap;
}

  .site-nav__links a,
  .site-subnav__inner a {
    padding: 9px 14px;
    border-radius: 999px;
    color: var(--muted);
    font-family: system-ui, sans-serif;
    font-size: 0.86rem;
    font-weight: 700;
    text-decoration: none;
    transition:
      background 0.18s ease,
      color 0.18s ease,
      box-shadow 0.18s ease;
  }

  .site-nav__links a:hover,
  .site-subnav__inner a:hover {
    background: var(--accent-soft);
    color: var(--accent);
  }

  .site-nav__links a.active,
  .site-subnav__inner a.active {
    background: var(--accent) !important;
    color: #fff !important;
    border-color: var(--accent) !important;
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--accent) 32%, transparent) !important;
  }

  .site-subnav {
    background: var(--surface);
    border-bottom: 1px solid var(--line);
  }

  .site-subnav__inner {
    min-height: 50px;
    padding: 6px 0;
  }

  .site-nav .shell {
    width: min(1400px, calc(100% - 80px)) !important;
    margin: 0 auto !important;
    padding-top: 0 !important;
    padding-bottom: 0 !important;
  }

  @media (max-width: 760px) {
    .site-nav .shell {
      width: calc(100% - 28px) !important;
    }

    .site-nav__inner {
      position: relative;
      min-height: 58px;
      flex-direction: row;
      align-items: center;
      gap: 14px;
    }

    .site-nav__toggle {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      margin-left: auto;
      width: 42px;
      height: 38px;
      border-radius: 999px;
      border: 1px solid var(--line-warm);
      background: var(--surface);
      color: var(--ink);
      font-size: 1.2rem;
      line-height: 1;
      cursor: pointer;
    }

    .site-nav__links {
      display: none;
    }

    .site-nav__links.open {
      position: absolute;
      top: 58px;
      left: 0;
      right: 0;
      display: grid;
      gap: 8px;
      padding: 12px;
      border: 1px solid var(--line-warm);
      border-radius: 18px;
      background: var(--surface);
      box-shadow: 0 18px 50px rgba(0, 0, 0, 0.12);
    }

    .site-nav__links.open a {
      padding: 12px 14px;
      background: var(--surface);
      border: 1px solid var(--line-warm);
      white-space: nowrap;
    }

    .site-subnav__inner {
      width: 100%;
      overflow-x: auto;
      flex-wrap: nowrap;
      padding-bottom: 4px;
    }

    .site-subnav__inner a {
      white-space: nowrap;
      background: var(--surface);
      border: 1px solid var(--line-warm);
    }
  }
</style>