---
interface Props {
  title?: string;
  accentColor?: string;
  city?: string;
}
const { title, accentColor = "#2f6f73", city = "nanaimo" } = Astro.props;
---
<!doctype html>
<html lang="en" style={`--accent: ${accentColor};`}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
   <title>{title ?? "Astro Basics"}</title>

  </head>

<body data-google-maps-api-key={import.meta.env.PUBLIC_GOOGLE_MAPS_API_KEY || ""}>
    <slot />

    <nav class="mobile-bottom-nav">
<a class="mobile-bottom-nav__item" href={`/${city}-real-estate-market#browse-by-area`}>
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        <span>Areas</span>
      </a>
<a class="mobile-bottom-nav__item" href={`/${city}/${city}-homes`}>
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <span>Search</span>
      </a>
      <button class="mobile-bottom-nav__item" id="mobile-saved-btn" type="button">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
        <span>Saved</span>
      </button>
    </nav>

    <script is:inline>
      document.getElementById("mobile-saved-btn")?.addEventListener("click", () => {
        document.getElementById("shortlist-modal")?.removeAttribute("hidden");
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
   /* Derived colours */
    --accent-light: color-mix(in srgb, var(--accent) 35%, white);
 --accent-soft: color-mix(in srgb, var(--accent) 12%, white);

/* Theme-aware surfaces */
--surface: color-mix(in srgb, var(--accent) 1.5%, white);
--bg: color-mix(in srgb, var(--accent) 2%, #faf9f7);
    /* Cards & sections */
    --card-bg: #ffffff;
    --card-soft: color-mix(in srgb, var(--accent) 4%, white);
--section-bg: color-mix(in srgb, var(--accent) 1%, #fdfcfb);
    /* Typography */
    --ink: #1c1917;
    --muted: #6b6560;

    /* Borders */
    --line: color-mix(in srgb, var(--accent) 10%, #dcdcdc);
    --line-warm: color-mix(in srgb, var(--accent) 16%, #d0d0d0);
  }

  html,
  body {
    margin: 0;
    width: 100%;
    min-height: 100%;
    background: var(--bg);
    color: var(--ink);
    font-family:
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      sans-serif;
  }

  a {
    color: inherit;
  }

  button,
  select,
  input,
  textarea {
    font: inherit;
  }

  .accent-bg {
    background: var(--accent);
    color: white;
  }

  .accent-text {
    color: var(--accent);
  }

.accent-soft {
    background: var(--accent-soft);
  }

  .mobile-bottom-nav {
    display: none;
  }

  @media (max-width: 760px) {
    .mobile-bottom-nav {
      display: flex;
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      z-index: 100;
      background: color-mix(in srgb, var(--surface) 96%, transparent);
      backdrop-filter: blur(14px);
      border-top: 1px solid var(--line);
      padding-bottom: env(safe-area-inset-bottom);
    }

    .mobile-bottom-nav__item {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 4px;
      padding: 10px 0;
      color: var(--muted);
      font-size: 0.7rem;
      font-weight: 700;
      text-decoration: none;
      background: none;
      border: none;
      cursor: pointer;
      transition: color 0.15s ease;
    }

    .mobile-bottom-nav__item:hover,
    .mobile-bottom-nav__item.active {
      color: var(--accent);
    }

    body {
      padding-bottom: calc(64px + env(safe-area-inset-bottom));
    }
  }
</style>